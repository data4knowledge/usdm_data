<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C127262> a skos:Concept ;
    rdfs:label "Environmental Setting" ;
    gsk:extensible "true" ;
    ns1:identifier "C127262" ;
    skos:altLabel "Environmental Setting" ;
