<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188698-C112038> a skos:Concept ;
    ns1:identifier "C112038" ;
    skos:altLabel "Trial Disease/Condition Indication",
        "Trial Disease/Condition Indication Description" ;
    skos:definition "The textual representation of the condition, disease or disorder that the clinical trial is intended to investigate or address." ;
    skos:notation "Trial Disease/Condition Indication Description" ;
    skos:prefLabel "Trial Indication" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188698-C142427> a skos:Concept ;
    ns1:identifier "C142427" ;
    skos:definition "Contact between subject/patient and healthcare practitioner/researcher, during which an assessment or activity is performed. Contact may be physical or virtual." ;
    skos:notation "Clinical Encounter" ;
    skos:prefLabel "Clinical Encounter" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188698-C142450> a skos:Concept ;
    ns1:identifier "C142450" ;
    skos:definition "The reason for performing a study in terms of the scientific questions to be answered by the analysis of data collected during the study." ;
    skos:notation "Study Objective" ;
    skos:prefLabel "Clinical Trial Objective" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188698-C142728> a skos:Concept ;
    ns1:identifier "C142728" ;
    skos:altLabel "Target Population" ;
    skos:definition "The population within the general population for which the study results can be generalized." ;
    skos:notation "Target Study Population" ;
    skos:prefLabel "Target Study Population" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188698-C142735> a skos:Concept ;
    ns1:identifier "C142735" ;
    skos:definition "A basic building block for time within a clinical study comprising the following characteristics: a description of what happens to the subject during the element; a definition of the start of the element; a rule for ending the element." ;
    skos:notation "Study Design Element" ;
    skos:prefLabel "Trial Design Element" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188698-C15206> a skos:Concept ;
    ns1:identifier "C15206" ;
    skos:definition "A clinical study involves research using human volunteers (also called participants) that is intended to add to medical knowledge. There are two main types of clinical studies: clinical trials (also called interventional studies) and observational studies. [ClinicalTrials.gov] See also clinical trial. (CDISC Glossary)" ;
    skos:notation "Clinical Study" ;
    skos:prefLabel "Clinical Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188698-C15320> a skos:Concept ;
    ns1:identifier "C15320" ;
    skos:definition "A plan detailing how a study will be performed in order to represent the phenomenon under examination, to answer the research questions that have been asked, and informing the statistical approach." ;
    skos:notation "Study Design" ;
    skos:prefLabel "Study Design" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188698-C174447> a skos:Concept ;
    ns1:identifier "C174447" ;
    skos:altLabel "Arm" ;
    skos:definition "A planned pathway assigned to the subject as they progress through the study, usually referred to by a name that reflects one or more treatments, exposures, and/or controls included in the path." ;
    skos:notation "Study Arm" ;
    skos:prefLabel "Study Arm" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188698-C188810> a skos:Concept ;
    ns1:identifier "C188810" ;
    skos:definition "A partitioning of a study arm into individual pieces, which are associated with an epoch and any number of sequential elements within that epoch." ;
    skos:notation "Study Design Cell" ;
    skos:prefLabel "Study Design Cell" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188698-C188811> a skos:Concept ;
    ns1:identifier "C188811" ;
    skos:definition "Data collected in the course of a clinical study." ;
    skos:notation "Clinical Study Data" ;
    skos:prefLabel "Clinical Study Data" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188698-C188812> a skos:Concept ;
    ns1:identifier "C188812" ;
    skos:definition "The textual representation of the workflow item." ;
    skos:notation "Workflow Item Description" ;
    skos:prefLabel "Workflow Item Description" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188698-C188813> a skos:Concept ;
    ns1:identifier "C188813" ;
    skos:definition "A precise description of the treatment effect reflecting the clinical question posed by a given clinical trial objective. It summarises at a population level what the outcomes would be in the same patients under different treatment conditions being compared. (ICH E9 R1 Addendum)" ;
    skos:notation "Estimand" ;
    skos:prefLabel "Estimand" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188698-C188814> a skos:Concept ;
    ns1:identifier "C188814" ;
    skos:definition "A target study population on which an analysis is performed. These may be represented by the entire study population, a subgroup defined by a particular characteristic measured at baseline, or a principal stratum defined by the occurrence (or non-occurrence, depending on context) of a specific intercurrent event. (ICH E9 R1 Addendum)" ;
    skos:notation "Target Study Population for Analysis" ;
    skos:prefLabel "Target Study Population for Analysis" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188698-C188815> a skos:Concept ;
    ns1:identifier "C188815" ;
    skos:definition "An event(s) occurring after treatment initiation that affects either the interpretation or the existence of the measurements associated with the clinical question of interest. (ICH E9 Addendum on Estimands)" ;
    skos:notation "Intercurrent Event" ;
    skos:prefLabel "Intercurrent Event" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188698-C19711> a skos:Concept ;
    ns1:identifier "C19711" ;
    skos:definition "A formalized group of persons or other organizations collected together for a common purpose (such as administrative, legal, political) and the infrastructure to carry out that purpose. (BRIDG)" ;
    skos:notation "Organization" ;
    skos:prefLabel "Professional Organization or Group" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188698-C25162> a skos:Concept ;
    ns1:identifier "C25162" ;
    skos:definition "A symbol or combination of symbols which is assigned to the members of a collection." ;
    skos:notation "Code" ;
    skos:prefLabel "Code" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188698-C25212> a skos:Concept ;
    ns1:identifier "C25212" ;
    skos:definition "A defined variable intended to reflect an outcome of interest that is statistically analyzed to address a particular research question. NOTE: A precise definition of an endpoint typically specifies the type of assessments made, the timing of those assessments, the assessment tools used, and possibly other details, as applicable, such as how multiple assessments within an individual are to be combined. [After BEST Resource] (CDISC Glossary)" ;
    skos:notation "Study Endpoint" ;
    skos:prefLabel "End Point" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188698-C25218> a skos:Concept ;
    ns1:identifier "C25218" ;
    skos:definition "The drug, device, therapy, or process under investigation in a clinical study that is believed to have an effect on outcomes of interest in a study (e.g., health-related quality of life, efficacy, safety, pharmacoeconomics). [After https://grants.nih.gov/grants/policy/faq_clinical_trial_definition.htm#5224]" ;
    skos:notation "Intervention" ;
    skos:prefLabel "Intervention or Procedure" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188698-C42753> a skos:Concept ;
    ns1:identifier "C42753" ;
    skos:definition "The operational aspect of a work procedure: how tasks are structured, who performs them, what their relative order is, how they are synchronized, how information flows to support the tasks and how tasks are being tracked." ;
    skos:notation "Workflow" ;
    skos:prefLabel "Workflow" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188698-C71473> a skos:Concept ;
    ns1:identifier "C71473" ;
    skos:definition "An action, undertaking, or event, which is anticipated to be performed or observed, or was performed or observed, according to the study protocol during the execution of the study." ;
    skos:notation "Study Activity" ;
    skos:prefLabel "Study Activity" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188698-C71738> a skos:Concept ;
    ns1:identifier "C71738" ;
    skos:definition "A named time period defined in the protocol, wherein a study activity is specified and unchanging throughout the interval, to support a study-specific purpose." ;
    skos:notation "Study Epoch" ;
    skos:prefLabel "Clinical Trial Epoch" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188698-C82567> a skos:Concept ;
    ns1:identifier "C82567" ;
    skos:definition "A guide that governs the allocation of subjects to operational options at a discrete decision point or branch (e.g., assignment to a particular arm, discontinuation) within a clinical trial plan." ;
    skos:notation "Transition Rule" ;
    skos:prefLabel "Transition Rule" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188698-C83082> a skos:Concept ;
    ns1:identifier "C83082" ;
    skos:definition "A sequence of characters used to identify, name, or characterize the study." ;
    skos:notation "Study Identifier" ;
    skos:prefLabel "Study Identifier" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188698-C93490> a skos:Concept ;
    ns1:identifier "C93490" ;
    skos:definition "A plan at a particular point in time for a formal investigation to assess the utility, impact, pharmacological, physiological, and/or psychological effects of a particular treatment, procedure, drug, device, biologic, food product, cosmetic, care plan, or subject characteristic. (BRIDG)" ;
    skos:notation "Study Protocol Version" ;
    skos:prefLabel "Study Protocol Version" .

