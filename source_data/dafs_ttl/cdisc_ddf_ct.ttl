<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C127262-C102647> a skos:Concept ;
    ns1:identifier "C102647" ;
    skos:definition "The area in which an individual lives." ;
    skos:notation "HOUSEHOLD ENVIRONMENT" ;
    skos:prefLabel "Household Environment" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C127262-C102650> a skos:Concept ;
    ns1:identifier "C102650" ;
    skos:definition "A setting outside the clinic or a comparable health care facility, e.g. a doctor\'s office, the subject\'s home or workplace, a school, a public park, or a restaurant." ;
    skos:notation "FIELD" ;
    skos:prefLabel "In the Field" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C127262-C102679> a skos:Concept ;
    ns1:identifier "C102679" ;
    skos:definition "An area outside of that in which an individual lives." ;
    skos:notation "NON-HOUSEHOLD ENVIRONMENT" ;
    skos:prefLabel "Non-household Environment" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C127262-C102712> a skos:Concept ;
    ns1:identifier "C102712" ;
    skos:definition "The surroundings or environment in which social activities occur." ;
    skos:notation "SOCIAL SETTING" ;
    skos:prefLabel "Social Setting" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C127262-C127785> a skos:Concept ;
    ns1:identifier "C127785" ;
    skos:definition "An establishment that provides care for infants and children." ;
    skos:notation "CHILD CARE CENTER" ;
    skos:prefLabel "Childcare Center" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C127262-C16281> a skos:Concept ;
    ns1:identifier "C16281" ;
    skos:definition "A medical care center that provides healthcare services on an outpatient basis." ;
    skos:notation "OUTPATIENT CLINIC" ;
    skos:prefLabel "Ambulatory Care Facility" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C127262-C16696> a skos:Concept ;
    ns1:identifier "C16696" ;
    skos:definition "An institution that provides medical, surgical, or psychiatric care and treatment for the sick or the injured." ;
    skos:notation "HOSPITAL" ;
    skos:prefLabel "Hospital" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C127262-C17118> a skos:Concept ;
    ns1:identifier "C17118" ;
    skos:definition "An educational institution." ;
    skos:notation "SCHOOL" ;
    skos:prefLabel "School" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C127262-C17556> a skos:Concept ;
    ns1:identifier "C17556" ;
    skos:definition "Place or physical location of work or employment." ;
    skos:notation "WORKSITE" ;
    skos:prefLabel "Worksite" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C127262-C18002> a skos:Concept ;
    ns1:identifier "C18002" ;
    skos:definition "A person\'s place of residence." ;
    skos:notation "HOME" ;
    skos:prefLabel "Home" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C127262-C181529> a skos:Concept ;
    ns1:identifier "C181529" ;
    skos:definition "A motorized conveyance for people and goods." ;
    skos:notation "MOTOR VEHICLE" ;
    skos:prefLabel "Motor Vehicle" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C127262-C181530> a skos:Concept ;
    ns1:identifier "C181530" ;
    skos:definition "Any environmental setting outside of a clinic." ;
    skos:notation "NOT IN CLINIC" ;
    skos:prefLabel "Not In Clinic" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C127262-C21541> a skos:Concept ;
    ns1:identifier "C21541" ;
    skos:definition "The buildings and organizations where healthcare services are provided." ;
    skos:notation "HEALTH FACILITY" ;
    skos:prefLabel "Healthcare Facility" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C127262-C41206> a skos:Concept ;
    ns1:identifier "C41206" ;
    skos:definition "An established society, corporation, foundation or other organization founded and united for a specific purpose, e.g. for health-related research; also used to refer to a building or buildings occupied or used by such organization." ;
    skos:notation "INSTITUTION" ;
    skos:prefLabel "Institution" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C127262-C48953> a skos:Concept ;
    ns1:identifier "C48953" ;
    skos:definition "A tract of land cultivated for the purpose of agricultural production or devoted to the raising and breeding of domestic animals." ;
    skos:notation "FARM" ;
    skos:prefLabel "Farm" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C127262-C51282> a skos:Concept ;
    ns1:identifier "C51282" ;
    skos:definition "A health care facility where subjects or patients may receive assessments, procedures, or treatments that are provided by physicians and other healthcare providers." ;
    skos:notation "CLINIC" ;
    skos:prefLabel "Clinic" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C127262-C85862> a skos:Concept ;
    ns1:identifier "C85862" ;
    skos:definition "An institution where persons are confined for punishment and to protect the public." ;
    skos:notation "PRISON" ;
    skos:prefLabel "Correctional Institution" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C127262-C85863> a skos:Concept ;
    ns1:identifier "C85863" ;
    skos:definition "Temporary housing for displaced or at-risk persons." ;
    skos:notation "SHELTER" ;
    skos:prefLabel "Shelter" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C171445> a skos:Concept ;
    rdfs:label "Mode of Subject Contact" ;
    gsk:extensible "true" ;
    ns1:identifier "C171445" ;
    skos:altLabel "Mode of Subject Contact" ;
    skos:definition "Terminology relevant to the means by which interaction occurs between the subject and person or entity." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C171445-C171524>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C171445-C171525>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C171445-C171533>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C171445-C171537>,
