        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C171445-C177933> ;
    skos:notation "CNTMODE" ;
    skos:prefLabel "CDISC SDTM Mode of Subject Contact Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C171445-C171524> a skos:Concept ;
    ns1:identifier "C171524" ;
    skos:definition "A form of remote communication by audio technology." ;
    skos:notation "REMOTE AUDIO" ;
    skos:prefLabel "Audioconferencing" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C171445-C171525> a skos:Concept ;
    ns1:identifier "C171525" ;
    skos:definition "A form of remote communication by audio video technology." ;
    skos:notation "REMOTE AUDIO VIDEO" ;
    skos:prefLabel "Audio-Videoconferencing" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C171445-C171533> a skos:Concept ;
    ns1:identifier "C171533" ;
    skos:definition "Receipt of shipped material was confirmed by signature." ;
    skos:notation "SHIPMENT CONFIRMED BY SIGNATURE" ;
    skos:prefLabel "Shipment Confirmed by Signature" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C171445-C171537> a skos:Concept ;
    ns1:identifier "C171537" ;
    skos:definition "Communication by way of telephone." ;
    skos:notation "TELEPHONE CALL" ;
    skos:prefLabel "Telephone Call" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C171445-C175574> a skos:Concept ;
    ns1:identifier "C175574" ;
    skos:altLabel "In-Person" ;
    skos:definition "An interaction that takes place in the physical presence of someone else." ;
    skos:notation "IN PERSON" ;
    skos:prefLabel "In Person" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C171445-C177933> a skos:Concept ;
    ns1:identifier "C177933" ;
    skos:altLabel "Interactive Voice Response System" ;
    skos:definition "A type of automated system in which individuals can access information menus containing pre-recorded or dynamically generated information with voice prompts, without the need for an agent or operator." ;
    skos:notation "IVRS" ;
    skos:prefLabel "Interactive Voice Response System" .

