    skos:notation "Approved" ;
    skos:prefLabel "Approval" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188723-C25508> a skos:Concept ;
    ns1:identifier "C25508" ;
    skos:definition "Conclusive in a process or progression." ;
    skos:notation "Final" ;
    skos:prefLabel "Final" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188723-C63553> a skos:Concept ;
    ns1:identifier "C63553" ;
    skos:definition "No longer in use or valid; old." ;
    skos:notation "Obsolete" ;
    skos:prefLabel "Obsolete" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188723-C85255> a skos:Concept ;
    ns1:identifier "C85255" ;
    skos:definition "A preliminary version of a written work, design, or picture." ;
    skos:notation "Draft" ;
    skos:prefLabel "Draft" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188724> a skos:Concept ;
    rdfs:label "Organization Type Value Set Terminology" ;
    ns1:identifier "C188724" ;
    skos:altLabel "Organization Type Value Set Terminology" ;
    skos:definition "The terminology relevant to the organization type." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188724-C188863>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188724-C70793>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188724-C93453> ;
    skos:notation "Organization Type Value Set Terminology" ;
    skos:prefLabel "CDISC DDF Organization Type Value Set Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188724-C188863> a skos:Concept ;
    ns1:identifier "C188863" ;
    skos:altLabel "Regulator",
        "Regulatory Body" ;
    skos:definition "An organization (typically a government agency) that is responsible for implementing and enforcing laws, licensing and regulating products and services, promoting the use of standards, and ensuring safety and consumer protections." ;
    skos:notation "Regulatory Agency" ;
    skos:prefLabel "Regulatory Agency" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188724-C70793> a skos:Concept ;
    ns1:identifier "C70793" ;
    skos:altLabel "Clinical Study Sponsor",
        "Sponsor",
        "Study Sponsor" ;
    skos:definition "An individual, company, institution, or organization that takes responsibility for the initiation, management, and/or financing of a clinical study. [After ICH E6, WHO, 21 CFR 50.3 (e), and after IDMP]" ;
    skos:notation "Clinical Study Sponsor" ;
    skos:prefLabel "Clinical Study Sponsor" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188724-C93453> a skos:Concept ;
    ns1:identifier "C93453" ;
    skos:definition "An organization (typically a government agency) that administers the registration of studies. (BRIDG)" ;
    skos:notation "Clinical Study Registry" ;
    skos:prefLabel "Study Registry" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188725> a skos:Concept ;
    rdfs:label "Objective Level Value Set Terminology" ;
    ns1:identifier "C188725" ;
    skos:altLabel "Objective Level Value Set Terminology" ;
    skos:definition "The terminology relevant to the objective level." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188725-C85826>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188725-C85827> ;
    skos:notation "Objective Level Value Set Terminology" ;
    skos:prefLabel "CDISC DDF Objective Level Value Set Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188725-C85826> a skos:Concept ;
    ns1:identifier "C85826" ;
    skos:altLabel "Study Primary Objective",
        "Trial Primary Objective" ;
    skos:definition "A principle objective of the study." ;
    skos:notation "Study Primary Objective" ;
    skos:prefLabel "Trial Primary Objective" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188725-C85827> a skos:Concept ;
    ns1:identifier "C85827" ;
    skos:altLabel "Study Secondary Objective",
        "Trial Secondary Objective" ;
    skos:definition "An auxiliary objective of the study." ;
    skos:notation "Study Secondary Objective" ;
    skos:prefLabel "Trial Secondary Objective" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188726> a skos:Concept ;
    rdfs:label "Endpoint Level Value Set Terminology" ;
    ns1:identifier "C188726" ;
    skos:altLabel "Endpoint Level Value Set Terminology" ;
    skos:definition "The terminology relevant to the endpoint level." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188726-C139173>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188726-C170559>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188726-C94496> ;
    skos:notation "Endpoint Level Value Set Terminology" ;
    skos:prefLabel "CDISC DDF Endpoint Level Value Set Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188726-C139173> a skos:Concept ;
    ns1:identifier "C139173" ;
    skos:definition "Endpoint(s) that may provide supportive information about the effect of the study intervention(s) on the primary endpoint or demonstrate additional effects on the disease or condition. (After FDA-NIH Protocol Template)" ;
    skos:notation "Secondary Endpoint" ;
    skos:prefLabel "Secondary Endpoint" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188726-C170559> a skos:Concept ;
    ns1:identifier "C170559" ;
    skos:definition "Endpoint(s) that may include clinically important events that are expected to occur too infrequently to show a treatment effect or endpoints that for other reasons are thought to be less likely to show an effect but are included to explore new hypotheses. (After FDA-NIH Protocol Template)" ;
    skos:notation "Exploratory Endpoint" ;
    skos:prefLabel "Exploratory Endpoint" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188726-C94496> a skos:Concept ;
    ns1:identifier "C94496" ;
    skos:definition "Endpoint(s) of greatest importance that is the basis for concluding whether the study met its objective(s) and provides a clinically relevant, valid, and reliable measure of the primary objective(s). (After FDA-NIH Protocol Template)" ;
    skos:notation "Primary Endpoint" ;
    skos:prefLabel "Primary Endpoint" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188727> a skos:Concept ;
    rdfs:label "Study Arm Data Origin Type Value Set Terminology" ;
    ns1:identifier "C188727" ;
    skos:altLabel "Study Arm Data Origin Type Value Set Terminology" ;
    skos:definition "The terminology relevant to the study arm data origin type." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188727-C165830>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188727-C176263>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188727-C188864>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188727-C188865>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188727-C188866> ;
    skos:notation "Study Arm Data Origin Type Value Set Terminology" ;
    skos:prefLabel "CDISC DDF Study Arm Data Origin Type Value Set Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188727-C165830> a skos:Concept ;
    ns1:identifier "C165830" ;
    skos:definition "Data relating to patient health status and/or the delivery of health care routinely collected from sources other than traditional clinical trials. NOTE: Examples of sources include data derived from electronic health records (EHRs); medical claims and billing data; data from product and disease registries; patient-generated data, including from in-home-use settings; and data gathered from other sources that can inform on health status, such as mobile devices. [After 21 U.S.C. 355g(b)).5 and Framework for FDA\'s Real-World Evidence Program December 2018] See also Real-World Evidence (RWE)" ;
    skos:notation "Real World Data" ;
    skos:prefLabel "Real-world Data" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188727-C176263> a skos:Concept ;
    ns1:identifier "C176263" ;
    skos:definition "Data that are artificially created rather than being generated by actual events. NOTE: Data are often created with the help of algorithms and used for a wide range of activities, including as test data for new products and tools, for model validation, and in AI optimization. [After The Ultimate Guide to Synthetic Data in 2020, August 29, 2020]. See also artificial intelligence." ;
    skos:notation "Synthetic Data" ;
    skos:prefLabel "Synthetic Data" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188727-C188864> a skos:Concept ;
    ns1:identifier "C188864" ;
    skos:definition "Data from studies that have occurred in the past." ;
    skos:notation "Historical Data" ;
    skos:prefLabel "Historical Data" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188727-C188865> a skos:Concept ;
    ns1:identifier "C188865" ;
    skos:definition "Data that are generated from virtual encounters between investigators and subjects." ;
    skos:notation "Virtual Data" ;
    skos:prefLabel "Virtual Data" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188727-C188866> a skos:Concept ;
    ns1:identifier "C188866" ;
    skos:definition "Data that are generated from the current study." ;
    skos:notation "Data Generated Within Study" ;
    skos:prefLabel "Data Generated Within Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188728> a skos:Concept ;
    rdfs:label "Encounter Type Value Set Terminology" ;
    ns1:identifier "C188728" ;
    skos:altLabel "Encounter Type Value Set Terminology" ;
    skos:definition "The terminology relevant to the encounter type." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188728-C25716> ;
    skos:notation "Encounter Type Value Set Terminology" ;
    skos:prefLabel "CDISC DDF Encounter Type Value Set Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C188728-C25716> a skos:Concept ;
    ns1:identifier "C25716" ;
    skos:definition "The act of going to see some person or place or thing; it can cover a short or long period but refers to a non-permanent arrangement." ;
    skos:notation "Visit" ;
    skos:prefLabel "Visit" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66736> a skos:Concept ;
    rdfs:label "Trial Intent Type Response" ;
    gsk:extensible "true" ;
    ns1:identifier "C66736" ;
    skos:altLabel "Trial Intent Type Response" ;
    skos:definition "A terminology codelist relevant to the responses for the planned purpose of the therapy, device, or agent under study in the clinical trial." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66736-C139174>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66736-C15245>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66736-C15714>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66736-C170629>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66736-C49653>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66736-C49654>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66736-C49655>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66736-C49656>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66736-C49657>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66736-C71485>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66736-C71486> ;
    skos:notation "TINDTP" ;
    skos:prefLabel "CDISC SDTM Trial Indication Type Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66736-C139174> a skos:Concept ;
    ns1:identifier "C139174" ;
    skos:definition "An intervention of a device product is being evaluated to determine the feasibility of the product or to test a prototype device and not health outcomes. Such studies are conducted to confirm the design and operating specifications of a device before beginning a full clinical trial. (ClinicalTrials.gov)" ;
    skos:notation "DEVICE FEASIBILITY" ;
    skos:prefLabel "Device Feasibility Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66736-C15245> a skos:Concept ;
    ns1:identifier "C15245" ;
    skos:definition "A type of study designed to evaluate the delivery, processes, management, organization or financing of health care. (ClinicalTrials.gov)" ;
    skos:notation "HEALTH SERVICES RESEARCH" ;
    skos:prefLabel "Health Services Research" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66736-C15714> a skos:Concept ;
    ns1:identifier "C15714" ;
    skos:altLabel "Basic Research" ;
    skos:definition "A type of study designed to examine the basic mechanism of action (e.g., physiology, biomechanics) of an intervention. (ClinicalTrials.gov)" ;
    skos:notation "BASIC SCIENCE" ;
    skos:prefLabel "Basic Research" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66736-C170629> a skos:Concept ;
    ns1:identifier "C170629" ;
    skos:definition "A type of study designed to evaluate the effects of treatment(s) intended to cause a change in disease, syndrome, or condition beyond the point of treatment administration." ;
    skos:notation "DISEASE MODIFYING" ;
    skos:prefLabel "Disease Modifying Treatment Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66736-C49653> a skos:Concept ;
    ns1:identifier "C49653" ;
    skos:definition "A type of study designed to evaluate intervention(s) aimed at identifying a disease or condition." ;
    skos:notation "DIAGNOSIS" ;
    skos:prefLabel "Diagnosis Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66736-C49654> a skos:Concept ;
    ns1:identifier "C49654" ;
    skos:definition "A type of study designed to evaluate intervention(s) aimed to cure a disease or condition." ;
    skos:notation "CURE" ;
    skos:prefLabel "Cure Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66736-C49655> a skos:Concept ;
    ns1:identifier "C49655" ;
    skos:definition "A type of study designed to identify actions necessary to eliminate or reduce the risk to human life or well-being as a result of a particular medication or treatment regimen. (NCI)" ;
    skos:notation "MITIGATION" ;
    skos:prefLabel "Adverse Effect Mitigation Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66736-C49656> a skos:Concept ;
    ns1:identifier "C49656" ;
    skos:altLabel "Therapy Trial" ;
    skos:definition "A type of study designed to evaluate intervention(s) for treatment of disease, syndrome or condition." ;
    skos:notation "TREATMENT" ;
    skos:prefLabel "Treatment Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66736-C49657> a skos:Concept ;
    ns1:identifier "C49657" ;
    skos:altLabel "Prophylaxis Study" ;
    skos:definition "A type of study designed to identify actions necessary to permanently eliminate or reduce the long-term risk to human life as a result of a particular medication or treatment regimen." ;
    skos:notation "PREVENTION" ;
    skos:prefLabel "Prevention Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66736-C71485> a skos:Concept ;
    ns1:identifier "C71485" ;
    skos:definition "A type of study designed to assess or examine methods of identifying a condition (or risk factors for a condition) in people who are not yet known to have the condition (or risk factor). (Clinicaltrials.gov)" ;
    skos:notation "SCREENING" ;
    skos:prefLabel "Screening Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66736-C71486> a skos:Concept ;
    ns1:identifier "C71486" ;
    skos:definition "A type of study designed to evaluate one or more interventions where the primary intent is to maximize comfort, minimize side effects or mitigate against a decline in the subject\'s health or function. In general, supportive care interventions are not intended to cure a disease. (ClinicalTrials.gov)" ;
    skos:notation "SUPPORTIVE CARE" ;
    skos:prefLabel "Supportive Care Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66737> a skos:Concept ;
    rdfs:label "Trial Phase Response" ;
    gsk:extensible "true" ;
    ns1:identifier "C66737" ;
    skos:altLabel "Trial Phase Response" ;
    skos:definition "A terminology codelist relevant to the phase, or stage, of the clinical trial." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66737-C15600>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66737-C15601>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66737-C15602>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66737-C15603>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66737-C15693>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66737-C15694>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66737-C47865>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66737-C48660>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66737-C49686>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66737-C49687>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66737-C49688>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66737-C49689>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66737-C54721> ;
    skos:notation "TPHASE" ;
    skos:prefLabel "CDISC SDTM Trial Phase Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66737-C15600> a skos:Concept ;
    ns1:identifier "C15600" ;
    skos:altLabel "1",
        "Trial Phase 1" ;
    skos:definition "The initial introduction of an investigational new drug into humans. Phase 1 studies are typically closely monitored and may be conducted in patients or normal volunteer subjects. NOTE: These studies are designed to determine the metabolism and pharmacologic actions of the drug in humans, the side effects associated with increasing doses, and, if possible, to gain early evidence on effectiveness. During Phase 1, sufficient information about the drug\'s pharmacokinetics and pharmacological effects should be obtained to permit the design of well-controlled, scientifically valid, Phase 2 studies. The total number of subjects and patients included in Phase I studies varies with the drug, but is generally in the range of 20 to 80. Phase 1 studies also include studies of drug metabolism, structure-activity relationships, and mechanism of action in humans, as well as studies in which investigational drugs are used as research tools to explore biological phenomena or disease processes. [After FDA CDER Handbook, ICH E8] (CDISC glossary)" ;
    skos:notation "PHASE I TRIAL" ;
    skos:prefLabel "Phase I Trial" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66737-C15601> a skos:Concept ;
    ns1:identifier "C15601" ;
    skos:altLabel "2",
        "Trial Phase 2" ;
    skos:definition "Phase 2. Controlled clinical studies conducted to evaluate the effectiveness of the drug for a particular indication or indications in patients with the disease or condition under study and to determine the common short-term side effects and risks associated with the drug. NOTE: Phase 2 studies are typically well controlled, closely monitored, and conducted in a relatively small number of patients, usually involving no more than several hundred subjects. [After FDA CDER Handbook, ICH E8] (CDISC glossary)" ;
    skos:notation "PHASE II TRIAL" ;
    skos:prefLabel "Phase II Trial" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66737-C15602> a skos:Concept ;
    ns1:identifier "C15602" ;
    skos:altLabel "3",
        "Trial Phase 3" ;
    skos:definition "Phase 3. Studies are expanded controlled and uncontrolled trials. They are performed after preliminary evidence suggesting effectiveness of the drug has been obtained, and are intended to gather the additional information about effectiveness and safety that is needed to confirm efficacy and evaluate the overall benefit-risk relationship of the drug and to provide an adequate basis for physician labeling. NOTE: Phase 3 studies usually include from several hundred to several thousand subjects. [After FDA CDER Handbook, ICH E8] (CDISC glossary)" ;
    skos:notation "PHASE III TRIAL" ;
    skos:prefLabel "Phase III Trial" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66737-C15603> a skos:Concept ;
    ns1:identifier "C15603" ;
    skos:altLabel "4",
        "Trial Phase 4" ;
    skos:definition "Phase 4. Postmarketing (Phase 4) studies to delineate additional information about the drug\'s risks, benefits, and optimal use that may be requested by regulatory authorities in conjunction with marketing approval. NOTE: These studies could include, but would not be limited to, studying different doses or schedules of administration than were used in Phase 2 studies, use of the drug in other patient populations or other stages of the disease, or use of the drug over a longer period of time. [After FDA CDER Handbook, ICH E8] (CDISC glossary)" ;
    skos:notation "PHASE IV TRIAL" ;
    skos:prefLabel "Phase IV Trial" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66737-C15693> a skos:Concept ;
    ns1:identifier "C15693" ;
    skos:altLabel "1-2",
        "Trial Phase 1-2" ;
    skos:definition "A class of clinical study that combines elements characteristic of traditional Phase I and Phase II trials. See also Phase I, Phase II." ;
    skos:notation "PHASE I/II TRIAL" ;
    skos:prefLabel "Phase I/II Trial" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66737-C15694> a skos:Concept ;
    ns1:identifier "C15694" ;
    skos:altLabel "2-3",
        "Trial Phase 2-3" ;
    skos:definition "A class of clinical study that combines elements characteristic of traditional Phase II and Phase III trials." ;
    skos:notation "PHASE II/III TRIAL" ;
    skos:prefLabel "Phase II/III Trial" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66737-C47865> a skos:Concept ;
    ns1:identifier "C47865" ;
    skos:altLabel "5",
        "Trial Phase 5" ;
    skos:definition "Postmarketing surveillance is sometimes referred to as Phase V." ;
    skos:notation "PHASE V TRIAL" ;
    skos:prefLabel "Phase V Trial" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66737-C48660> a skos:Concept ;
    ns1:identifier "C48660" ;
    skos:altLabel "NA",
        "Not Applicable" ;
    skos:definition "Determination of a value is not relevant in the current context. (NCI)" ;
    skos:notation "NOT APPLICABLE" ;
    skos:prefLabel "Not Applicable" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66737-C49686> a skos:Concept ;
    ns1:identifier "C49686" ;
    skos:altLabel "2A",
        "Trial Phase 2A" ;
    skos:definition "A clinical research protocol generally referred to as a pilot or feasibility trial that aims to prove the concept of the new intervention in question. (NCI)" ;
    skos:notation "PHASE IIA TRIAL" ;
    skos:prefLabel "Phase IIa Trial" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66737-C49687> a skos:Concept ;
    ns1:identifier "C49687" ;
    skos:altLabel "3A",
        "Trial Phase 3A" ;
    skos:definition "A classification typically assigned retrospectively to a Phase III trial upon determination by regulatory authorities of a need for a Phase III B trial. (NCI)" ;
    skos:notation "PHASE IIIA TRIAL" ;
    skos:prefLabel "Phase IIIa Trial" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66737-C49688> a skos:Concept ;
    ns1:identifier "C49688" ;
    skos:altLabel "2B",
        "Trial Phase 2B" ;
    skos:definition "A clinical research protocol generally referred to as a well-controlled and pivotal trial that aims to prove the mechanism of action of the new intervention in question. A pivotal study will generally be well-controlled, randomized, of adequate size, and whenever possible, double-blind. (NCI)" ;
    skos:notation "PHASE IIB TRIAL" ;
    skos:prefLabel "Phase IIb Trial" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66737-C49689> a skos:Concept ;
    ns1:identifier "C49689" ;
    skos:altLabel "3B",
        "Trial Phase 3B" ;
    skos:definition "A subcategory of Phase III trials done near the time of approval to elicit additional findings. NOTE: Dossier review may continue while associated Phase IIIB trials are conducted. These trials may be required as a condition of regulatory authority approval." ;
    skos:notation "PHASE IIIB TRIAL" ;
    skos:prefLabel "Phase IIIb Trial" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66737-C54721> a skos:Concept ;
    ns1:identifier "C54721" ;
    skos:altLabel "0",
        "Pre-clinical Trial",
        "Trial Phase 0" ;
    skos:definition "First-in-human trials, in a small number of subjects, that are conducted before Phase 1 trials and are intended to assess new candidate therapeutic and imaging agents. The study agent is administered at a low dose for a limited time, and there is no therapeutic or diagnostic intent. NOTE: FDA Guidance for Industry, Investigators, and Reviewers: Exploratory IND Studies, January 2006 classifies such studies as Phase 1. NOTE: A Phase 0 study might not include any drug delivery but may be an exploration of human material from a study (e.g., tissue samples or biomarker determinations). [Improving the Quality of Cancer Clinical Trials: Workshop summary-Proceedings of the National Cancer Policy Forum Workshop, improving the Quality of Cancer Clinical Trials (Washington, DC, Oct 2007)] (CDISC glossary)" ;
    skos:notation "PHASE 0 TRIAL" ;
    skos:prefLabel "Phase 0 Trial" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739> a skos:Concept ;
    rdfs:label "Trial Type Response" ;
    gsk:extensible "true" ;
    ns1:identifier "C66739" ;
    skos:altLabel "Trial Type Response" ;
    skos:definition "A terminology codelist relevant to the type of primary outcome or endpoint that the protocol is designed to evaluate." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C120842>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C127803>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C129001>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C158283>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C158284>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C158285>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C158286>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C158287>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C158288>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C158289>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C158290>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C161477>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C161478>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C161479>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C161480>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C174366>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C178057>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C39493>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C49653>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C49656>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C49657>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C49661>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C49662>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C49663>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C49664>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C49665>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C49666>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C49667>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C98729>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C98791> ;
    skos:notation "TTYPE" ;
    skos:prefLabel "CDISC SDTM Trial Type Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C120842> a skos:Concept ;
    ns1:identifier "C120842" ;
    skos:definition "A study that assesses an agent\'s ability to provoke an immune response." ;
    skos:notation "IMMUNOGENICITY" ;
    skos:prefLabel "Immunogenicity Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C127803> a skos:Concept ;
    ns1:identifier "C127803" ;
    skos:definition "A study of the effect of dose changes on the efficacy of a drug in order to determine the dose-response relationship and optimal dose of a therapy." ;
    skos:notation "DOSE RESPONSE" ;
    skos:prefLabel "Dose Response Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C129001> a skos:Concept ;
    ns1:identifier "C129001" ;
    skos:definition "A study that assesses variation in DNA sequence, usually within a single gene, and its effect on drug response." ;
    skos:notation "PHARMACOGENETIC" ;
    skos:prefLabel "Pharmacogenetic Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C158283> a skos:Concept ;
    ns1:identifier "C158283" ;
    skos:definition "A type of study designed to evaluate the strength of the bond between an adhesive and the application surface." ;
    skos:notation "ADHESION PERFORMANCE" ;
    skos:prefLabel "Adhesion Performance Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C158284> a skos:Concept ;
    ns1:identifier "C158284" ;
    skos:definition "A type of study designed to evaluate the effects of alcohol on investigational product safety and/or efficacy." ;
    skos:notation "ALCOHOL EFFECT" ;
    skos:prefLabel "Alcohol Effect Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C158285> a skos:Concept ;
    ns1:identifier "C158285" ;
    skos:definition "A type of study designed to evaluate the interaction between a device and a drug, where the use of one may affect the disposition, function, efficacy, or safety of the other." ;
    skos:notation "DEVICE-DRUG INTERACTION" ;
    skos:prefLabel "Device-Drug Interaction Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C158286> a skos:Concept ;
    ns1:identifier "C158286" ;
    skos:definition "A type of study designed to evaluate the interaction between drugs, where the use of one may affect the disposition, efficacy, or safety of the other." ;
    skos:notation "DRUG-DRUG INTERACTION" ;
    skos:prefLabel "Drug-Drug Interaction Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C158287> a skos:Concept ;
    ns1:identifier "C158287" ;
    skos:altLabel "TQT Study" ;
    skos:definition "A type of study designed to evaluate the ability of an investigational product and/or approved drug to delay cardiac ventricular repolarization as detected by QT prolongation and other ECG parameters." ;
    skos:notation "THOROUGH QT" ;
    skos:prefLabel "Thorough QT Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C158288> a skos:Concept ;
    ns1:identifier "C158288" ;
    skos:definition "A type of study designed to evaluate whether a biologic test article is highly similar in function and effect to an existing biologic that has already been clinically tested and approved for use." ;
    skos:notation "BIOSIMILARITY" ;
    skos:prefLabel "Biosimilarity Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C158289> a skos:Concept ;
    ns1:identifier "C158289" ;
    skos:definition "An early phase clinical study with the objective of determining the optimal dose of an investigational product." ;
    skos:notation "DOSE FINDING" ;
    skos:prefLabel "Dose Finding Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C158290> a skos:Concept ;
    ns1:identifier "C158290" ;
    skos:definition "A type of study designed to evaluate the relationship between dose and resulting exposure." ;
    skos:notation "DOSE PROPORTIONALITY" ;
    skos:prefLabel "Dose Proportionality Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C161477> a skos:Concept ;
    ns1:identifier "C161477" ;
    skos:definition "A type of study designed to evaluate the effect of body position during and/or after administration of the investigational product." ;
    skos:notation "POSITION EFFECT" ;
    skos:prefLabel "Position Effect Trial" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C161478> a skos:Concept ;
    ns1:identifier "C161478" ;
    skos:definition "A type of study designed to evaluate the effect of the investigational product on the physiologic act of swallowing." ;
    skos:notation "SWALLOWING FUNCTION" ;
    skos:prefLabel "Swallowing Function Trial" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C161479> a skos:Concept ;
    ns1:identifier "C161479" ;
    skos:definition "A type of study designed to evaluate the user experience with a product." ;
    skos:notation "USABILITY TESTING" ;
    skos:prefLabel "Usability Testing Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C161480> a skos:Concept ;
    ns1:identifier "C161480" ;
    skos:definition "A type of study designed to evaluate the effects of water on investigational product safety and/or efficacy." ;
    skos:notation "WATER EFFECT" ;
    skos:prefLabel "Water Effect Trial" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C174366> a skos:Concept ;
    ns1:identifier "C174366" ;
    skos:definition "A type of study designed to evaluate the expected, acute types of immunological responses, sometimes considered excessive, following agent administration." ;
    skos:notation "REACTOGENICITY" ;
    skos:prefLabel "Reactogenicity Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C178057> a skos:Concept ;
    ns1:identifier "C178057" ;
    skos:altLabel "Electrocardiographic Study" ;
    skos:definition "A study that evaluates the effect of a treatment on cardiac electrical activity, as assessed by electrocardiography." ;
    skos:notation "ECG" ;
    skos:prefLabel "Electrocardiographic Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C39493> a skos:Concept ;
    ns1:identifier "C39493" ;
    skos:definition "A study that assesses the value associated with a given drug in therapeutic and economic terms. This type of study is multidisciplinary in nature and takes into consideration the social and economic costs (resource utilization costs including direct, indirect, and intangible costs) of drug therapy in addition to its direct therapeutic benefits. Analyses relate the difference in therapeutic benefits to the difference in costs between treatment alternatives. (NCI)" ;
    skos:notation "PHARMACOECONOMIC" ;
    skos:prefLabel "Pharmacoeconomic Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C49653> a skos:Concept ;
    ns1:identifier "C49653" ;
    skos:definition "A type of study designed to evaluate intervention(s) aimed at identifying a disease or condition." ;
    skos:notation "DIAGNOSIS" ;
    skos:prefLabel "Diagnosis Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C49656> a skos:Concept ;
    ns1:identifier "C49656" ;
    skos:altLabel "Therapy Trial" ;
    skos:definition "A type of study designed to evaluate intervention(s) for treatment of disease, syndrome or condition." ;
    skos:notation "TREATMENT" ;
    skos:prefLabel "Treatment Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C49657> a skos:Concept ;
    ns1:identifier "C49657" ;
    skos:altLabel "Prophylaxis Study" ;
    skos:definition "A type of study designed to identify actions necessary to permanently eliminate or reduce the long-term risk to human life as a result of a particular medication or treatment regimen." ;
    skos:notation "PREVENTION" ;
    skos:prefLabel "Prevention Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C49661> a skos:Concept ;
    ns1:identifier "C49661" ;
    skos:definition "A study that identifies or assesses variations within the entire genome, including DNA, RNA, or transcriptional elements, and its effects on drug response." ;
    skos:notation "PHARMACOGENOMIC" ;
    skos:prefLabel "Pharmacogenomic Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C49662> a skos:Concept ;
    ns1:identifier "C49662" ;
    skos:definition "A study of the biochemical and physiological effect of a drug and the mechanism of drug action and the relationship between drug concentration and effect. (NCI)" ;
    skos:notation "PHARMACODYNAMIC" ;
    skos:prefLabel "Pharmacodynamic Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C49663> a skos:Concept ;
    ns1:identifier "C49663" ;
    skos:definition "A study of the process by which a drug is absorbed, distributed, metabolized, and eliminated by the body. (NCI)" ;
    skos:notation "PHARMACOKINETIC" ;
    skos:prefLabel "Pharmacokinetic Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C49664> a skos:Concept ;
    ns1:identifier "C49664" ;
    skos:definition "A study of the degree to which or rate at which a drug or other substance is absorbed or becomes available at the site of physiological activity after administration. (NCI)" ;
    skos:notation "BIO-AVAILABILITY" ;
    skos:prefLabel "Bioavailability Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C49665> a skos:Concept ;
    ns1:identifier "C49665" ;
    skos:definition "A study most often used to compare the efficacy of different formulations to treat a given disease. It is the testing of an old versus a new formulation in healthy volunteers or subjects with the disease under study and usually in one dose. (NCI)" ;
    skos:notation "BIO-EQUIVALENCE" ;
    skos:prefLabel "Therapeutic Equivalency Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C49666> a skos:Concept ;
    ns1:identifier "C49666" ;
    skos:definition "A study of the relative therapeutic efficacy of treatment of a disease. Usually this is a Phase II or III study. (NCI)" ;
    skos:notation "EFFICACY" ;
    skos:prefLabel "Efficacy Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C49667> a skos:Concept ;
    ns1:identifier "C49667" ;
    skos:definition "A study that assesses the medical risks to a subject. Safety is usually assessed by examining a wide range of clinical parameters, including adverse events, vital signs, physical exam, laboratory tests." ;
    skos:notation "SAFETY" ;
    skos:prefLabel "Safety Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C98729> a skos:Concept ;
    ns1:identifier "C98729" ;
    skos:definition "Studies that are conducted to assess the effect of food on the rate and extent of absorption of a drug, either compared to a fasted state or to a reference drug." ;
    skos:notation "FOOD EFFECT" ;
    skos:prefLabel "Food Effect Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C66739-C98791> a skos:Concept ;
    ns1:identifier "C98791" ;
    skos:definition "A type of safety study that assesses the degree to which overt adverse effects can be tolerated by the subject." ;
    skos:notation "TOLERABILITY" ;
    skos:prefLabel "Tolerability Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C99076> a skos:Concept ;
    rdfs:label "Intervention Model Response" ;
    gsk:extensible "true" ;
    ns1:identifier "C99076" ;
    skos:altLabel "Intervention Model Response" ;
    skos:definition "A terminology codelist relevant to the trial design developed to compare treatment groups." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C99076-C142568>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C99076-C82637>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C99076-C82638>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C99076-C82639>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C99076-C82640> ;
    skos:notation "INTMODEL" ;
    skos:prefLabel "CDISC SDTM Intervention Model Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C99076-C142568> a skos:Concept ;
    ns1:identifier "C142568" ;
    skos:definition "Groups of participants are assigned to receive interventions based on prior milestones being reached in the study. (clinicaltrials.gov)" ;
    skos:notation "SEQUENTIAL" ;
    skos:prefLabel "Group Sequential Design" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C99076-C82637> a skos:Concept ;
    ns1:identifier "C82637" ;
    skos:definition "Participants receive one of two or more alternative intervention(s) during the initial epoch of the study and receive other intervention(s) during the subsequent epoch(s) of the study." ;
    skos:notation "CROSS-OVER" ;
    skos:prefLabel "Crossover Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C99076-C82638> a skos:Concept ;
    ns1:identifier "C82638" ;
    skos:definition "Two or more interventions, each alone or in combination, are evaluated in parallel against a control group. This study design allows for the comparison of active drug to placebo, presence of drug-drug interactions, and comparison of active drugs against each other." ;
    skos:notation "FACTORIAL" ;
    skos:prefLabel "Factorial Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C99076-C82639> a skos:Concept ;
    ns1:identifier "C82639" ;
    skos:definition "Participants are assigned to one of two or more treatment groups in parallel for the duration of the study." ;
    skos:notation "PARALLEL" ;
    skos:prefLabel "Parallel Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C99076-C82640> a skos:Concept ;
    ns1:identifier "C82640" ;
    skos:definition "All trial participants are assigned to a single treatment group for the duration of the study." ;
    skos:notation "SINGLE GROUP" ;
    skos:prefLabel "Single Group Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C99077> a skos:Concept ;
    rdfs:label "Study Type Response" ;
    gsk:extensible "false" ;
    ns1:identifier "C99077" ;
    skos:altLabel "Study Type Response" ;
    skos:definition "A terminology codelist relevant to the role the study plays in determining the interventions a subject receives." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C99077-C129000>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C99077-C16084>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C99077-C98388>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C99077-C98722> ;
    skos:notation "STYPE" ;
    skos:prefLabel "CDISC SDTM Study Type Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C99077-C129000> a skos:Concept ;
    ns1:identifier "C129000" ;
    skos:definition "Observational studies which include an organized system that uses observational methods to collect uniform data (clinical and other) prospectively for a population defined by a particular disorder/disease, condition (including susceptibility to a disorder), or exposure (including products, health care services, and/or procedures) and that serves a predetermined scientific, clinical, or policy purpose. Patient registries may be single purpose or on-going data collection programs that address one or more questions. (AHRQ)" ;
    skos:notation "PATIENT REGISTRY" ;
    skos:prefLabel "Patient Registry Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C99077-C16084> a skos:Concept ;
    ns1:identifier "C16084" ;
    skos:definition "Studies in which biomedical and/or health outcomes are assessed in pre-defined groups of individuals. Subjects in the study may receive diagnostic, therapeutic, or other interventions, but the investigator does not assign specific interventions to the subjects of the study." ;
    skos:notation "OBSERVATIONAL" ;
    skos:prefLabel "Observational Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C99077-C98388> a skos:Concept ;
    ns1:identifier "C98388" ;
    skos:definition "Studies in which individuals are assigned by an investigator based on a protocol to receive specific interventions. Subjects may receive diagnostic, therapeutic or other types of interventions. The assignment of the intervention may or may not be random. The individuals are then followed and biomedical and/or health outcomes are assessed." ;
    skos:notation "INTERVENTIONAL" ;
    skos:prefLabel "Interventional Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C99077-C98722> a skos:Concept ;
    ns1:identifier "C98722" ;
    skos:altLabel "Compassionate Use" ;
    skos:definition "Studies that provide a means for obtaining an experimental drug or device for patients who are not adequately treated by existing therapy, who do not meet the eligibility criteria for enrollment, or who are otherwise unable to participate in another clinical study." ;
    skos:notation "EXPANDED ACCESS" ;
    skos:prefLabel "Expanded Access Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C99079> a skos:Concept ;
    rdfs:label "Epoch" ;
    gsk:extensible "true" ;
    ns1:identifier "C99079" ;
    skos:altLabel "Epoch" ;
    skos:definition "The name of the EPOCH." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C99079-C101526>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C99079-C102255>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C99079-C102256>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C99079-C123452>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C99079-C123453>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C99079-C125938>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C99079-C16032>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C99079-C165873>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C99079-C42872>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C99079-C48262>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C99079-C98779>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C99079-C99158> ;
    skos:notation "EPOCH" ;
    skos:prefLabel "CDISC SDTM Epoch Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C99079-C101526> a skos:Concept ;
    ns1:identifier "C101526" ;
    skos:definition "A period in a study during which subjects are receiving investigational therapy or treatment." ;
    skos:notation "TREATMENT" ;
    skos:prefLabel "Treatment Epoch" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C99079-C102255> a skos:Concept ;
    ns1:identifier "C102255" ;
    skos:definition "A period in a clinical study during which subjects receive blinded therapeutic treatment." ;
    skos:notation "BLINDED TREATMENT" ;
    skos:prefLabel "Blinded Treatment Epoch" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C99079-C102256> a skos:Concept ;
    ns1:identifier "C102256" ;
    skos:definition "A period in a clinical study during which subjects receive open label therapeutic treatment." ;
    skos:notation "OPEN LABEL TREATMENT" ;
    skos:prefLabel "Open Label Treatment Epoch" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C99079-C123452> a skos:Concept ;
    ns1:identifier "C123452" ;
    skos:altLabel "Continuation Phase" ;
    skos:definition "A period in a clinical study during which subjects receive continuation treatment." ;
    skos:notation "CONTINUATION TREATMENT" ;
    skos:prefLabel "Continuation Therapy Epoch" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C99079-C123453> a skos:Concept ;
    ns1:identifier "C123453" ;
    skos:altLabel "Induction Phase",
        "Intensive Phase" ;
    skos:definition "A period in a clinical study during which subjects receive induction treatment." ;
    skos:notation "INDUCTION TREATMENT" ;
    skos:prefLabel "Induction Therapy Epoch" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C99079-C125938> a skos:Concept ;
    ns1:identifier "C125938" ;
    skos:definition "A period in a clinical study after eligibility has been met and before the start of treatment, at which baseline measurements are collected." ;
    skos:notation "BASELINE" ;
    skos:prefLabel "Baseline Epoch" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C99079-C16032> a skos:Concept ;
    ns1:identifier "C16032" ;
    skos:definition "A period in a clinical study during which information about the health status of an individual is obtained long after study interventions have concluded." ;
    skos:notation "LONG-TERM FOLLOW-UP" ;
    skos:prefLabel "Long-term Follow-up" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C99079-C165873> a skos:Concept ;
    ns1:identifier "C165873" ;
    skos:definition "A period in a clinical study during which subjects are observed, without any planned intervention." ;
    skos:notation "OBSERVATION" ;
    skos:prefLabel "Observation Study Epoch" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C99079-C42872> a skos:Concept ;
    ns1:identifier "C42872" ;
    skos:definition "A period of time during a study when a subject is taken off of the investigational therapy or treatment in order to reduce the amount of investigational product within the body." ;
    skos:notation "WASHOUT" ;
    skos:prefLabel "Washout Period" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C99079-C48262> a skos:Concept ;
    ns1:identifier "C48262" ;
    skos:definition "A period in a clinical study during which subjects are evaluated for participation in the study." ;
    skos:notation "SCREENING" ;
    skos:prefLabel "Trial Screening" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C99079-C98779> a skos:Concept ;
    ns1:identifier "C98779" ;
    skos:definition "A period in a clinical study that occurs before the commencement of the primary clinical study investigation, during which subjects may be assessed for suitability in the clinical study, withdrawn from existing therapy, trained in study methodology or evaluated for any other protocol-specified reason." ;
    skos:notation "RUN-IN" ;
    skos:prefLabel "Run-in Period" .

<http://id.gsk.com/dataset/cdisc/ct/v48/ddf/C99079-C99158> a skos:Concept ;
    ns1:identifier "C99158" ;
    skos:definition "A period in a clinical study during which information about the health status of an individual is obtained after study interventions have concluded." ;
    skos:notation "FOLLOW-UP" ;
    skos:prefLabel "Clinical Study Follow-up" .

