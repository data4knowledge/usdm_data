@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<model> a clr:Scheme ;
    rdfs:label "CLINICAL RECORDING MODEL" ;
    skos:hasTopConcept </adverse_event>,
        </observation>,
        </therapeutic_intervention> .

</adverse_event> a clr:Concept ;
    rdfs:label "ADVERSE EVENT" ;
    rdfs:comment "" ;
    skos:narrower </adverse_event/category>,
        </adverse_event/causality>,
        </adverse_event/response>,
        </adverse_event/serious>,
        </adverse_event/severity>,
        </adverse_event/term>,
        </adverse_event/toxicity>,
        <common/location>,
        <common/period> .

</adverse_event/causality> a clr:Concept ;
    rdfs:label "CAUSALITY" ;
    rdfs:comment "" ;
