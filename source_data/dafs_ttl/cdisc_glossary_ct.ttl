<http://id.gsk.com/dataset/cdisc/ct/v48/glossary> a skos:ConceptScheme ;
    rdfs:label "Glossary Controlled Terminology Package 52 Effective 2022-12-16" ;
    ns1:description "CDISC Controlled Terminology for Glossary is the set of CDISC-developed or CDISC-adopted standard expressions (values) used with data items within CDISC-defined GLOSSARY datasets." ;
    ns1:source "Glossary Controlled Terminology developed by the CDISC Terminology Team in collaboration with the National Cancer Institute\'s Enterprise Vocabulary Services (EVS)" ;
    ns2:valid "2022-12-16" ;
    skos:hasTopConcept <http://id.gsk.com/dataset/cdisc/ct/v48/glossary/C67497> .

