    sdtmig:simpleDatatype "Char" ;
    dc:description "Method of the test or examination. Examples: SPECTROPHOTOMETRY, ELECTROPHORESIS." ;
    dc:identifier "BSMETHOD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/BS/BSNAM> a sdtmig:Variable ;
    rdfs:label "Vendor Name" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "20" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Name or identifier of the vendor (e.g., laboratory) that provided the test results." ;
    dc:identifier "BSNAM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/BS/BSORRES> a sdtmig:Variable ;
    rdfs:label "Result or Finding in Original Units" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "13" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Result of the measurement or finding as originally received or collected." ;
    dc:identifier "BSORRES" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/BS/BSORRESU> a sdtmig:Variable ;
    rdfs:label "Original Units" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C71620> ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "14" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Unit for BSORRES. Examples: mg, mL." ;
    dc:identifier "BSORRESU" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/BS/BSREASND> a sdtmig:Variable ;
    rdfs:label "Reason Test Not Done" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "19" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Reason not done. Used in conjunction with BSSTAT when value is NOT DONE." ;
    dc:identifier "BSREASND" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/BS/BSREFID> a sdtmig:Variable ;
    rdfs:label "Reference ID" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "7" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Internal or external identifier such as lab specimen ID." ;
    dc:identifier "BSREFID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/BS/BSRFTDTC> a sdtmig:Variable ;
    rdfs:label "Date/Time of Reference Time Point" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "35" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Date/time for a fixed reference time point defined by BSTPTREF." ;
    dc:identifier "BSRFTDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/BS/BSSCAT> a sdtmig:Variable ;
    rdfs:label "Subcategory for Biospecimen Test" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "12" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to define a further categorization of BSCAT values." ;
    dc:identifier "BSSCAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/BS/BSSEQ> a sdtmig:Variable ;
    rdfs:label "Sequence Number" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "5" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Sequence number given to ensure uniqueness within a dataset for a subject. May be any valid number (including decimals) and does not have to start at 1." ;
    dc:identifier "BSSEQ" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/BS/BSSPCCND> a sdtmig:Variable ;
    rdfs:label "Specimen Condition" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C78733> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "23" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Defines the condition of the specimen. Examples: HEMOLYZED, ICTERIC, LIPEMIC." ;
    dc:identifier "BSSPCCND" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/BS/BSSPEC> a sdtmig:Variable ;
    rdfs:label "Specimen Type" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C78734> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "21" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Defines the type of specimen used for a measurement. Examples: SERUM, PLASMA, URINE, SOFT TISSUE." ;
    dc:identifier "BSSPEC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/BS/BSSPID> a sdtmig:Variable ;
    rdfs:label "Sponsor-Defined Identifier" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "8" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Sponsor-defined identifier." ;
    dc:identifier "BSSPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/BS/BSSTAT> a sdtmig:Variable ;
    rdfs:label "Completion Status" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66789> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "18" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to indicate that a test was not done, or was attempted but did not generate a result. Should be null or have a value of NOT DONE." ;
    dc:identifier "BSSTAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/BS/BSSTRESC> a sdtmig:Variable ;
    rdfs:label "Character Result/Finding in Std Format" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "15" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Contains the result value for all findings, copied or derived from BSORRES in a standard format or standard units. BSSTRESC should store all results or findings in character format; if results are numeric, they should also be stored in numeric format in BSSTRESN." ;
    dc:identifier "BSSTRESC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/BS/BSSTRESN> a sdtmig:Variable ;
    rdfs:label "Numeric Result/Finding in Standard Units" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "16" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Used for continuous or numeric results or findings in standard format; copied in numeric format from BSSTRESC. BSSTRESN should store all numeric test results or findings." ;
    dc:identifier "BSSTRESN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/BS/BSSTRESU> a sdtmig:Variable ;
    rdfs:label "Standard Units" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C71620> ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "17" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Standardized unit used for BSSTRESC and BSSTRESN." ;
    dc:identifier "BSSTRESU" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/BS/BSTEST> a sdtmig:Variable ;
    rdfs:label "Biospecimen Test Name" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C124299> ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "10" ;
    sdtmig:role "Synonym Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Long name for BSTESTCD. Examples: Volume, RNA Integrity Number." ;
    dc:identifier "BSTEST" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/BS/BSTESTCD> a sdtmig:Variable ;
    rdfs:label "Biospecimen Test Short Name" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C124300> ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "9" ;
    sdtmig:role "Topic" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Short character value for BSTEST used as a column name when converting a dataset from a vertical format to a horizontal format. The short value can be up to 8 characters. Examples: VOLUME, RIN." ;
    dc:identifier "BSTESTCD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/BS/BSTPT> a sdtmig:Variable ;
    rdfs:label "Planned Time Point Name" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "31" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Text description of time when a measurement or observation should be taken as defined in the protocol. This may be represented as an elapsed time relative to a fixed reference point, such as time of last dose. See BSTPTNUM and BSTPTREF." ;
    dc:identifier "BSTPT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/BS/BSTPTNUM> a sdtmig:Variable ;
    rdfs:label "Planned Time Point Number" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "32" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Numerical version of BSTPT used in sorting." ;
    dc:identifier "BSTPTNUM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/BS/BSTPTREF> a sdtmig:Variable ;
    rdfs:label "Time Point Reference" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "34" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Name of the fixed reference point referred to by BSELTM, BSTPTNUM, and BSTPT. Examples: PREVIOUS DOSE, PREVIOUS MEAL." ;
    dc:identifier "BSTPTREF" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/BS/DOMAIN> a sdtmig:Variable ;
    rdfs:label "Domain Abbreviation" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "2" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Two-character abbreviation for the domain." ;
    dc:identifier "DOMAIN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/BS/SPDEVID> a sdtmig:Variable ;
    rdfs:label "Sponsor Device Identifier" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "4" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Sponsor-defined identifier for a device." ;
    dc:identifier "SPDEVID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/BS/STUDYID> a sdtmig:Variable ;
    rdfs:label "Study Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "1" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Unique identifier for a study." ;
    dc:identifier "STUDYID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/BS/USUBJID> a sdtmig:Variable ;
    rdfs:label "Unique Subject Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "3" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifier used to uniquely identify a subject across all studies for all applications or submissions involving the product." ;
    dc:identifier "USUBJID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/BS/VISIT> a sdtmig:Variable ;
    rdfs:label "Visit Name" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "27" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Protocol-defined description of clinical encounter." ;
    dc:identifier "VISIT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/BS/VISITDY> a sdtmig:Variable ;
    rdfs:label "Planned Study Day of Visit" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "28" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Planned study day of VISIT. Should be an integer." ;
    dc:identifier "VISITDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/BS/VISITNUM> a sdtmig:Variable ;
    rdfs:label "Visit Number" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "26" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Clinical encounter number. Numeric version of VISIT, used for sorting." ;
    dc:identifier "VISITNUM" .

