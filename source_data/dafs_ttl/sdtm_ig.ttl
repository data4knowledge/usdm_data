<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RE/DOMAIN> a sdtmig:Variable ;
    rdfs:label "Domain Abbreviation" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "2" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Two-character abbreviation for the domain." ;
    dc:identifier "DOMAIN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RE/EPOCH> a sdtmig:Variable ;
    rdfs:label "Epoch" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C99079> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "40" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Epoch associated with the date/time at which the assessment was made." ;
    dc:identifier "EPOCH" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RE/REBLFL> a sdtmig:Variable ;
    rdfs:label "Baseline Flag" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "31" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Indicator used to identify a baseline value. Should be Y or null. Note that REBLFL is retained for backward compatibility. The authoritative baseline flag for statistical analysis is in an ADaM dataset." ;
    dc:identifier "REBLFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RE/RECAT> a sdtmig:Variable ;
    rdfs:label "Category for Respiratory Test" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "13" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to categorize observations across subjects." ;
    dc:identifier "RECAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RE/REDIR> a sdtmig:Variable ;
    rdfs:label "Directionality" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C99074> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "28" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Qualifier for anatomical location or specimen further detailing directionality. Examples: \"ANTERIOR\", \"LOWER\", \"PROXIMAL\"." ;
    dc:identifier "REDIR" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RE/REDRVFL> a sdtmig:Variable ;
    rdfs:label "Derived Flag" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "32" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to indicate a derived record. Should be \"Y\" or null. Records that represent the average of other records, or that do not come from the CRF, or are not as originally collected or received are examples of records that would be derived for the submission datasets. If REDRVFL = \"Y\", then REORRES could be null, with RESTRESC and (if numeric) RESTRESN having the derived value." ;
    dc:identifier "REDRVFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RE/REDTC> a sdtmig:Variable ;
    rdfs:label "Date/Time of Collection" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "41" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Date/time of procedure or test." ;
    dc:identifier "REDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RE/REDY> a sdtmig:Variable ;
    rdfs:label "Study Day of Visit/Collection/Exam" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "42" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Actual study day of visit/collection/exam expressed in integer days relative to the sponsor-defined RFSTDTC in Demographics." ;
    dc:identifier "REDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RE/REELTM> a sdtmig:Variable ;
    rdfs:label "Planned Elapsed Time from Time Point Ref" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "45" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 duration" ;
    dc:description "Planned elapsed time relative to a planned fixed reference (RETPTREF). Not a clock time or a date/time variable, but an interval, represented as ISO duration. Examples: \"-PT15M\" to represent 15 minutes prior to the reference time point indicated by RETPTREF, \"PT8H\" to represent 8 hours after the reference time point represented by RETPTREF." ;
    dc:identifier "REELTM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RE/REEVAL> a sdtmig:Variable ;
    rdfs:label "Evaluator" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C78735> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "33" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Role of the person who provided the evaluation. Used only for results that are subjective (e.g., assigned by a person or a group). Examples: \"ADJUDICATION COMMITTEE\", \"INDEPENDENT ASSESSOR\", \"RADIOLOGIST\"." ;
    dc:identifier "REEVAL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RE/REEVALID> a sdtmig:Variable ;
    rdfs:label "Evaluator Identifier" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C96777> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "34" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to distinguish multiple evaluators with the same role recorded in REEVAL. Examples: \"RADIOLOGIST1\", \"RADIOLOGIST2\"." ;
    dc:identifier "REEVALID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RE/REGRPID> a sdtmig:Variable ;
    rdfs:label "Group ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "6" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Optional group identifier, used to link together a block of related records within a subject in a domain." ;
    dc:identifier "REGRPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RE/RELAT> a sdtmig:Variable ;
    rdfs:label "Laterality" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C99073> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "27" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Side of the body used to collect measurement. Examples: \"RIGHT\", \"LEFT\"." ;
    dc:identifier "RELAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RE/RELNKGRP> a sdtmig:Variable ;
    rdfs:label "Link Group" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "10" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifier used to link related records across domains. This will usually be a many-to-one relationship." ;
    dc:identifier "RELNKGRP" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RE/RELNKID> a sdtmig:Variable ;
    rdfs:label "Link ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "9" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifier used to link related records across domains. This may be a one-to-one or a one-to-many relationship." ;
    dc:identifier "RELNKID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RE/RELOBXFL> a sdtmig:Variable ;
    rdfs:label "Last Observation Before Exposure Flag" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "30" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Operationally-derived indicator used to identify the last non-missing value prior to RFXSTDTC. The value should be \"Y\" or null." ;
    dc:identifier "RELOBXFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RE/RELOC> a sdtmig:Variable ;
    rdfs:label "Location Used for the Measurement" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C74456> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "26" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Anatomical location of the subject relevant to the collection of the measurement. Examples: \"LUNG\", \"BRONCHUS\"." ;
    dc:identifier "RELOC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RE/REMETHOD> a sdtmig:Variable ;
    rdfs:label "Method of Test or Examination" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C85492> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "29" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Method used to create the result." ;
    dc:identifier "REMETHOD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RE/REORREF> a sdtmig:Variable ;
    rdfs:label "Reference Result in Original Units" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "18" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Reference result for continuous measurements in original units. Should be collected only for continuous results." ;
    dc:identifier "REORREF" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RE/REORRES> a sdtmig:Variable ;
    rdfs:label "Result or Finding in Original Units" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "16" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Result of the procedure measurement or finding as originally received or collected." ;
    dc:identifier "REORRES" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RE/REORRESU> a sdtmig:Variable ;
    rdfs:label "Original Units" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C71620> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "17" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Original units in which the data were collected. The unit for REORRES and REORREF." ;
    dc:identifier "REORRESU" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RE/REPOS> a sdtmig:Variable ;
    rdfs:label "Position of Subject During Observation" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C71148> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "15" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Position of the subject during a measurement or examination. Examples: \"SUPINE\", \"STANDING\", \"SITTING\"." ;
    dc:identifier "REPOS" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RE/REREASND> a sdtmig:Variable ;
    rdfs:label "Reason Not Done" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "25" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Describes why a measurement or test was not performed. Examples: \"BROKEN EQUIPMENT\", \"SUBJECT REFUSED\". Used in conjunction with RESTAT when value is \"NOT DONE\"." ;
    dc:identifier "REREASND" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RE/REREFID> a sdtmig:Variable ;
    rdfs:label "Reference ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "7" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Optional internal or external procedure identifier." ;
    dc:identifier "REREFID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RE/REREPNUM> a sdtmig:Variable ;
    rdfs:label "Repetition Number" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "35" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "The instance number of a test that is repeated within a given time frame for the same test. The level of granularity can vary (e.g., within a time point, within a visit). Example: multiple measurements of pulmonary function." ;
    dc:identifier "REREPNUM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RE/RERFTDTC> a sdtmig:Variable ;
    rdfs:label "Date/Time of Reference Time Point" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "47" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Date/time for a fixed reference time point defined by RETPTREF." ;
    dc:identifier "RERFTDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RE/RESCAT> a sdtmig:Variable ;
    rdfs:label "Subcategory for Respiratory Test" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "14" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "A further categorization." ;
    dc:identifier "RESCAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RE/RESEQ> a sdtmig:Variable ;
    rdfs:label "Sequence Number" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "5" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Sequence number to ensure uniqueness of records within a dataset for a subject. May be any valid number (including decimals) and does not have to start at 1." ;
    dc:identifier "RESEQ" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RE/RESPID> a sdtmig:Variable ;
    rdfs:label "Sponsor-Defined Identifier" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "8" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Sponsor-defined identifier. May be preprinted on the CRF as an explicit line identifier or defined in the sponsor\'s operational database." ;
    dc:identifier "RESPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RE/RESTAT> a sdtmig:Variable ;
    rdfs:label "Completion Status" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66789> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "24" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to indicate that a test was not done or a measurement was not taken. Should be null if a result exists in REORRES." ;
    dc:identifier "RESTAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RE/RESTREFC> a sdtmig:Variable ;
    rdfs:label "Character Reference Result" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "22" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Reference value for the result or finding copied or derived from --ORREF in a standard format." ;
    dc:identifier "RESTREFC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RE/RESTREFN> a sdtmig:Variable ;
    rdfs:label "Numeric Reference Result in Std Units" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "23" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Reference result for continuous measurements in standard units. Should be populated only for continuous results." ;
    dc:identifier "RESTREFN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RE/RESTRESC> a sdtmig:Variable ;
    rdfs:label "Character Result/Finding in Std Format" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "19" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Contains the result value for all findings, copied or derived from REORRES in a standard format or in standard units. RESTRESC should store all results or findings in character format; if results are numeric, they should also be stored in numeric format in RESTRESN." ;
    dc:identifier "RESTRESC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RE/RESTRESN> a sdtmig:Variable ;
    rdfs:label "Numeric Result/Finding in Standard Units" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "20" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Used for continuous or numeric results or findings in standard format; copied in numeric format from RESTRESC. RESTRESN should store all numeric test results or findings." ;
    dc:identifier "RESTRESN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RE/RESTRESU> a sdtmig:Variable ;
    rdfs:label "Standard Units" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C71620> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "21" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Standardized unit used for RESTRESC, RESTRESN and RESTREFN." ;
    dc:identifier "RESTRESU" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RE/RETEST> a sdtmig:Variable ;
    rdfs:label "Name of Respiratory Test" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C111107> ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "12" ;
    sdtmig:role "Synonym Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Verbatim name of the test or examination used to obtain the measurement or finding. The value in RETEST cannot be longer than 40 characters. Examples: \"Forced Expiratory Volume in 1 Second\", \"Forced Vital Capacity\"." ;
    dc:identifier "RETEST" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RE/RETESTCD> a sdtmig:Variable ;
    rdfs:label "Short Name of Respiratory Test" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C111106> ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "11" ;
    sdtmig:role "Topic" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Short name of the measurement, test, or examination. It can be used as a column name when converting a dataset from a vertical format to a horizontal format. The value in RETESTCD cannot be longer than 8 characters, nor can it start with a number (e.g., \"1TEST\" is not valid). RETESTCD cannot contain characters other than letters, numbers, or underscores. Examples: \"FEV1\", \"FVC\"." ;
    dc:identifier "RETESTCD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RE/RETPT> a sdtmig:Variable ;
    rdfs:label "Planned Time Point Name" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "43" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Text description of time when a measurement or observation should be taken as defined in the protocol. This may be represented as an elapsed time relative to a fixed reference point (e.g., \"TIME OF LAST DOSE\"). See RETPTNUM and RETPTREF. Examples: \"START\", \"5 MINUTES POST\"." ;
    dc:identifier "RETPT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RE/RETPTNUM> a sdtmig:Variable ;
    rdfs:label "Planned Time Point Number" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "44" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Numeric version of RETPT to aid in sorting." ;
    dc:identifier "RETPTNUM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RE/RETPTREF> a sdtmig:Variable ;
    rdfs:label "Time Point Reference" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "46" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Description of the fixed reference point referred to by REELTM, RETPTNUM, and RETPT. Examples: \"PREVIOUS DOSE\", \"PREVIOUS MEAL\"." ;
    dc:identifier "RETPTREF" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RE/SPDEVID> a sdtmig:Variable ;
    rdfs:label "Sponsor Device Identifier" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "4" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Sponsor-defined identifier for a device." ;
    dc:identifier "SPDEVID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RE/STUDYID> a sdtmig:Variable ;
    rdfs:label "Study Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "1" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Unique identifier for a study." ;
    dc:identifier "STUDYID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RE/TAETORD> a sdtmig:Variable ;
    rdfs:label "Planned Order of Element within Arm" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "39" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Number that gives the planned order of the element within the arm for the element in which the assessment was made." ;
    dc:identifier "TAETORD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RE/USUBJID> a sdtmig:Variable ;
    rdfs:label "Unique Subject Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "3" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifier used to uniquely identify a subject across all studies for all applications or submissions involving the product." ;
    dc:identifier "USUBJID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RE/VISIT> a sdtmig:Variable ;
    rdfs:label "Visit Name" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "37" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Protocol-defined description of a clinical encounter. May be used in addition to VISITNUM and/or VISITDY." ;
    dc:identifier "VISIT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RE/VISITDY> a sdtmig:Variable ;
    rdfs:label "Planned Study Day of Visit" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "38" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Planned study day of the visit based upon RFSTDTC in Demographics." ;
    dc:identifier "VISITDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RE/VISITNUM> a sdtmig:Variable ;
    rdfs:label "Visit Number" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "36" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Clinical encounter number. Numeric version of VISIT, used for sorting." ;
    dc:identifier "VISITNUM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RELREC> a sdtmig:Domain ;
    rdfs:label "Related Records" ;
    sdtmig:hasVariable <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RELREC/IDVAR>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RELREC/IDVARVAL>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RELREC/RDOMAIN>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RELREC/RELID>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RELREC/RELTYPE>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RELREC/STUDYID>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RELREC/USUBJID> ;
    sdtmig:ordinal "40" ;
    sdtmig:structure "One record per related record, group of records or dataset" ;
    dc:description "Related Records" ;
    dc:identifier "RELREC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RELREC/IDVAR> a sdtmig:Variable ;
    rdfs:label "Identifying Variable" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "4" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Name of the identifying variable in the general-observation-class dataset that identifies the related record(s). Examples: --SEQ, --GRPID." ;
    dc:identifier "IDVAR" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RELREC/IDVARVAL> a sdtmig:Variable ;
    rdfs:label "Identifying Variable Value" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "5" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Value of identifying variable described in IDVAR. If --SEQ is the variable being used to describe this record, then the value of --SEQ would be entered here." ;
    dc:identifier "IDVARVAL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RELREC/RDOMAIN> a sdtmig:Variable ;
    rdfs:label "Related Domain Abbreviation" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66734> ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "2" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Abbreviation for the domain of the parent record(s)." ;
    dc:identifier "RDOMAIN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RELREC/RELID> a sdtmig:Variable ;
    rdfs:label "Relationship Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "7" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Unique value within USUBJID that identifies the relationship. All records for the same USUBJID that have the same RELID are considered related/associated. RELID can be any value the sponsor chooses, and is only meaningful within the RELREC dataset to identify the related/associated domain records." ;
    dc:identifier "RELID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RELREC/RELTYPE> a sdtmig:Variable ;
    rdfs:label "Relationship Type" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C78737> ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "6" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifies the hierarchical level of the records in the relationship. Values should be either \"ONE\" or \"MANY\". Used only when identifying a relationship between datasets (as described in Section 8.3, Relating Datasets)." ;
    dc:identifier "RELTYPE" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RELREC/STUDYID> a sdtmig:Variable ;
    rdfs:label "Study Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "1" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Unique identifier for a study." ;
    dc:identifier "STUDYID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RELREC/USUBJID> a sdtmig:Variable ;
    rdfs:label "Unique Subject Identifier" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "3" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifier used to uniquely identify a subject across all studies for all applications or submissions involving the product." ;
    dc:identifier "USUBJID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RELSPEC> a sdtmig:Domain ;
    rdfs:label "Related Specimens" ;
    sdtmig:hasVariable <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RELSPEC/LEVEL>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RELSPEC/PARENT>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RELSPEC/REFID>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RELSPEC/SPEC>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RELSPEC/STUDYID>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RELSPEC/USUBJID> ;
    sdtmig:ordinal "41" ;
    sdtmig:structure "One record per specimen identifier per subject" ;
    dc:description "Related Specimens" ;
    dc:identifier "RELSPEC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RELSPEC/LEVEL> a sdtmig:Variable ;
    rdfs:label "Specimen Level" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "6" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Identifies the generation number of the sample where the collected sample is considered the first generation." ;
    dc:identifier "LEVEL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RELSPEC/PARENT> a sdtmig:Variable ;
    rdfs:label "Specimen Parent" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "5" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifies the REFID of the parent of a specimen to support tracking its genealogy." ;
    dc:identifier "PARENT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RELSPEC/REFID> a sdtmig:Variable ;
    rdfs:label "Specimen ID" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "3" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Specimen identifier, unique within USUBJID." ;
    dc:identifier "REFID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RELSPEC/SPEC> a sdtmig:Variable ;
    rdfs:label "Specimen Type" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C78734> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "4" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Defines the type of specimen used for a measurement. Examples: \"SERUM\", \"PLASMA\", \"URINE\", \"SOFT TISSUE\"." ;
    dc:identifier "SPEC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RELSPEC/STUDYID> a sdtmig:Variable ;
    rdfs:label "Study Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "1" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Unique identifier for a study." ;
    dc:identifier "STUDYID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RELSPEC/USUBJID> a sdtmig:Variable ;
    rdfs:label "Unique Subject Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "2" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifier used to uniquely identify a subject across all studies for all applications or submissions involving the product." ;
    dc:identifier "USUBJID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RELSUB> a sdtmig:Domain ;
    rdfs:label "Related Subjects" ;
    sdtmig:hasVariable <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RELSUB/POOLID>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RELSUB/RSUBJID>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RELSUB/SREL>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RELSUB/STUDYID>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RELSUB/USUBJID> ;
    sdtmig:ordinal "42" ;
    sdtmig:structure "One record per relationship per related subject per subject" ;
    dc:description "Related Subjects" ;
    dc:identifier "RELSUB" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RELSUB/POOLID> a sdtmig:Variable ;
    rdfs:label "Pool Identifier" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "3" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifier used to identify a pool of subjects. If POOLID is entered, POOLDEF records must exist for each subject in the pool and USUBJID must be null. Either USUBJID or POOLID must be populated." ;
    dc:identifier "POOLID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RELSUB/RSUBJID> a sdtmig:Variable ;
    rdfs:label "Related Subject or Pool Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "4" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifier used to identify a related subject or pool of subjects. RSUBJID will be populated with either the USUBJID of the related subject or the POOLID of the related pool." ;
    dc:identifier "RSUBJID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RELSUB/SREL> a sdtmig:Variable ;
    rdfs:label "Subject Relationship" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C100130> ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "5" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Describes the relationship of the subject identified in USUBJID or the pool identified in POOLID to the subject or pool identified in RSUBJID." ;
    dc:identifier "SREL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RELSUB/STUDYID> a sdtmig:Variable ;
    rdfs:label "Study Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "1" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Unique identifier for a study." ;
    dc:identifier "STUDYID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RELSUB/USUBJID> a sdtmig:Variable ;
    rdfs:label "Unique Subject Identifier" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "2" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifier used to uniquely identify a subject across all studies for all applications or submissions involving the product. Either USUBJID or POOLID must be populated." ;
    dc:identifier "USUBJID" .

