    sdtmig:core "Req" ;
    sdtmig:ordinal "9" ;
    sdtmig:role "Topic" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Verbatim medication name that is either preprinted or collected on a CRF." ;
    dc:identifier "AGTRT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AG/DOMAIN> a sdtmig:Variable ;
    rdfs:label "Domain Abbreviation" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "2" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Two-character abbreviation for the domain." ;
    dc:identifier "DOMAIN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AG/EPOCH> a sdtmig:Variable ;
