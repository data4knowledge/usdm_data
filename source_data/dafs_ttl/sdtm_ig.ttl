    sdtmig:simpleDatatype "Num" ;
    dc:description "Actual study day of visit/collection/exam expressed in integer days relative to the sponsor-defined RFSTDTC in Demographics." ;
    dc:identifier "MSDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MS/MSELTM> a sdtmig:Variable ;
    rdfs:label "Planned Elapsed Time from Time Point Ref" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "57" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 duration" ;
    dc:description "Planned elapsed time relative to a planned fixed reference (MSTPTREF; e.g., previous dose, previous meal). This variable is useful where there are repetitive measures. Not a clock time or a date/time variable, but an interval, represented as ISO duration." ;
    dc:identifier "MSELTM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MS/MSEVAL> a sdtmig:Variable ;
    rdfs:label "Evaluator" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C78735> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "41" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Role of the person who provided the evaluation. Used only for results that are subjective (e.g., assigned by a person or a group). Examples: \"ADJUDICATION COMMITTEE\", \"INDEPENDENT ASSESSOR\", \"MICROSCOPIST\"." ;
    dc:identifier "MSEVAL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MS/MSEVALID> a sdtmig:Variable ;
    rdfs:label "Evaluator Identifier" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C96777> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "42" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to distinguish multiple evaluators with the same role recorded in MSEVAL. Examples: \"RADIOLOGIST1\" or \"RADIOLOGIST2\"." ;
    dc:identifier "MSEVALID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MS/MSEVINTX> a sdtmig:Variable ;
    rdfs:label "Evaluation Interval Text" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "61" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Evaluation interval associated with an observation, where the interval is not able to be represented in ISO 8601 format. Examples: \"LIFETIME\", \"LAST NIGHT\", \"RECENTLY\", \"OVER THE LAST FEW WEEKS\"." ;
    dc:identifier "MSEVINTX" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MS/MSEVLINT> a sdtmig:Variable ;
    rdfs:label "Evaluation Interval" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "60" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 duration or interval" ;
    dc:description "Duration of interval associated with an observation such as a finding MSTESTCD. Example: \"-P2M\" to represent a period of the past 2 months before the assessment." ;
    dc:identifier "MSEVLINT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MS/MSFAST> a sdtmig:Variable ;
    rdfs:label "Fasting Status" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "39" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Indicator used to identify fasting status. Valid values include \"Y\", \"N\", \"U\", or null if not relevant." ;
    dc:identifier "MSFAST" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MS/MSGRPID> a sdtmig:Variable ;
    rdfs:label "Group ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "6" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Optional group identifier, used to link together a block of related records within a subject in a domain. In SDTMIG v3.2 this was an Expected variable. In this version, the core designation has been changed to Permissible." ;
    dc:identifier "MSGRPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MS/MSLAT> a sdtmig:Variable ;
    rdfs:label "Laterality" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C99073> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "33" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Qualifier for anatomical location or specimen further detailing laterality. Examples: \"RIGHT\", \"LEFT\", \"BILATERAL\"." ;
    dc:identifier "MSLAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MS/MSLLOQ> a sdtmig:Variable ;
    rdfs:label "Lower Limit of Quantitation" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "44" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Indicates the lower limit of quantitation for an assay. Units will be those used for MSSTRESU." ;
    dc:identifier "MSLLOQ" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MS/MSLNKID> a sdtmig:Variable ;
    rdfs:label "Link ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "9" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifier used to link related records across domains. This may be a one-to-one or a one-to-many relationship. For example, it may be used to link genetic findings (in the PF domain) about a microbe to the original culture of that microbe (in MB), or to susceptibility records (in MS) if needed." ;
    dc:identifier "MSLNKID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MS/MSLOBXFL> a sdtmig:Variable ;
    rdfs:label "Last Observation Before Exposure Flag" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "37" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Operationally derived indicator used to identify the last non-missing value prior to RFXSTDTC. The value should be \"Y\" or null." ;
    dc:identifier "MSLOBXFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MS/MSLOC> a sdtmig:Variable ;
    rdfs:label "Location Used for the Measurement" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C74456> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "32" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Anatomical location of the subject relevant to the collection of the measurement." ;
    dc:identifier "MSLOC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MS/MSLOINC> a sdtmig:Variable ;
    rdfs:label "LOINC Code" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "29" ;
    sdtmig:role "Synonym Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Logical Observation Identifiers Names and Codes (LOINC) code for the topic variable such as a lab test." ;
    dc:identifier "MSLOINC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MS/MSMETHOD> a sdtmig:Variable ;
    rdfs:label "Method of Test or Examination" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C85492> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "35" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Method of the test or examination. Examples: \"EPSILOMETER\", \"MACRO BROTH DILUTION\"." ;
    dc:identifier "MSMETHOD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MS/MSNAM> a sdtmig:Variable ;
    rdfs:label "Laboratory/Vendor Name" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "28" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Name or identifier of the vendor (e.g., laboratory) that provided the test results." ;
    dc:identifier "MSNAM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MS/MSNRIND> a sdtmig:Variable ;
    rdfs:label "Normal/Reference Range Indicator" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C78736> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "23" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to indicate the value is outside the normal range or reference range. May be defined by MSORNRLO and MSORNRHI or other objective criteria. Examples: \"Y\", \"N\", \"HIGH\", \"LOW\", \"NORMAL\". \"ABNORMAL\"." ;
    dc:identifier "MSNRIND" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MS/MSORRES> a sdtmig:Variable ;
    rdfs:label "Result or Finding in Original Units" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "18" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Result of the measurement or finding as originally received or collected." ;
    dc:identifier "MSORRES" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MS/MSORRESU> a sdtmig:Variable ;
    rdfs:label "Original Units" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C71620> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "19" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Unit for MSORRES. Examples: \"ug/mL\"." ;
    dc:identifier "MSORRESU" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MS/MSREASND> a sdtmig:Variable ;
    rdfs:label "Reason Not Done" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "26" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Reason not done. Used in conjunction with MSSTAT when value is \"NOT DONE\"." ;
    dc:identifier "MSREASND" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MS/MSREFID> a sdtmig:Variable ;
    rdfs:label "Reference ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "7" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Optional internal or external identifier (e.g., an identifier for the culture/isolate being tested for susceptibility)." ;
    dc:identifier "MSREFID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MS/MSREPNUM> a sdtmig:Variable ;
    rdfs:label "Repetition Number" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "46" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "The incidence number of a test that is repeated within a given timeframe for the same test. The level of granularity can vary (e.g., within a time point, within a visit). Examples: multiple measurements of blood pressure, multiple analyses of a sample." ;
    dc:identifier "MSREPNUM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MS/MSRESCAT> a sdtmig:Variable ;
    rdfs:label "Result Category" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C85495> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "24" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to categorize the result of a finding. In SDTMIG v3.2, MSRESCAT was used to categorize a numeric susceptibility result represented in MSORRES as either \"SUSCEPTIBLE\", \"INTERMEDIATE\", or \"RESISTANT\". However, results from some susceptibility tests may report only a categorical result and not a numeric result. Thus, in order for susceptibility results to be represented consistently, MSRESCAT should no longer be used for this purpose. In this version, the core designation has been changed from Expected to Permissible." ;
    dc:identifier "MSRESCAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MS/MSRFTDTC> a sdtmig:Variable ;
    rdfs:label "Date/Time of Reference Time Point" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "59" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Date/time for a fixed reference time point defined by MSTPTREF." ;
    dc:identifier "MSRFTDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MS/MSSCAT> a sdtmig:Variable ;
    rdfs:label "Subcategory" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "17" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to define a further categorization of MSCAT values." ;
    dc:identifier "MSSCAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MS/MSSEQ> a sdtmig:Variable ;
    rdfs:label "Sequence Number" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "5" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Sequence number to ensure uniqueness of records within a dataset for a subject (or within a parameter, in the case of the Trial Summary domain). May be any valid number (including decimals) and does not have to start at 1." ;
    dc:identifier "MSSEQ" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MS/MSSPCCND> a sdtmig:Variable ;
    rdfs:label "Specimen Condition" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C78733> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "31" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Defines the condition of the specimen. Example: \"CLOUDY\"." ;
    dc:identifier "MSSPCCND" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MS/MSSPEC> a sdtmig:Variable ;
    rdfs:label "Specimen Material Type" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C78734> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "30" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Defines the type of specimen used for a measurement. Example: \"SPUTUM\"." ;
    dc:identifier "MSSPEC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MS/MSSPID> a sdtmig:Variable ;
    rdfs:label "Sponsor-Defined Identifier" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "8" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Sponsor-defined reference number. May be preprinted on the CRF as an explicit line identifier or defined in the sponsor\'s operational database." ;
    dc:identifier "MSSPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MS/MSSTAT> a sdtmig:Variable ;
    rdfs:label "Completion Status" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66789> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "25" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to indicate that a question was not asked or a test was not done, or a test was attempted but did not generate a result. Should be null or have a value of \"NOT DONE\"." ;
    dc:identifier "MSSTAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MS/MSSTRESC> a sdtmig:Variable ;
    rdfs:label "Result or Finding in Standard Format" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "20" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Contains the result value for all findings, copied or derived from MSORRES in a standard format or in standard units. MSSTRESC should store all results or findings in character format; if results are numeric, they should also be stored in numeric format in MSSTRESN. For example, if various tests have results \"NONE\", \"NEG\", and \"NEGATIVE\" in MSORRES and these results effectively have the same meaning, they could be represented in standard format in MSSTRESC as \"NEGATIVE\"." ;
    dc:identifier "MSSTRESC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MS/MSSTRESN> a sdtmig:Variable ;
    rdfs:label "Numeric Result/Finding in Standard Units" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "21" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Used for continuous or numeric results or findings in standard format; copied in numeric format from MSSTRESC. MSSTRESN should store all numeric test results or findings." ;
    dc:identifier "MSSTRESN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MS/MSSTRESU> a sdtmig:Variable ;
    rdfs:label "Standard Units" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C71620> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "22" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Standardized units used for MSSTRESC and MSSTRESN. Example: \"mol/L\"." ;
    dc:identifier "MSSTRESU" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MS/MSTEST> a sdtmig:Variable ;
    rdfs:label "Name of Assessment" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C128687> ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "11" ;
    sdtmig:role "Synonym Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Verbatim name of the test or examination used to obtain the measurement or finding. The value in MSTEST cannot be longer than 40 characters. Examples: \"Minimum Inhibitory Concentration\", \"Microbial Susceptibility\"." ;
    dc:identifier "MSTEST" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MS/MSTESTCD> a sdtmig:Variable ;
    rdfs:label "Short Name of Assessment" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C128688> ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "10" ;
    sdtmig:role "Topic" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Short character value for MSTEST used as a column name when converting a dataset from a vertical format to a horizontal format. It can be used as a column name when converting a dataset from a vertical to a horizontal format. The value in MSTESTCD cannot be longer than 8 characters, nor can it start with a number (e.g., \"1TEST\" is not valid). MSTESTCD cannot contain characters other than letters, numbers, or underscores. Examples: \"MIC\" for Minimum Inhibitory Concentration; \"MICROSUS\" for Microbial Susceptibility." ;
    dc:identifier "MSTESTCD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MS/MSTPT> a sdtmig:Variable ;
    rdfs:label "Planned Time Point Name" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "55" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Text description of time when a measurement or observation should be taken as defined in the protocol. This may be represented as an elapsed time relative to a fixed reference point (e.g., time of last dose). See MSTPTNUM and MSTPTREF." ;
    dc:identifier "MSTPT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MS/MSTPTNUM> a sdtmig:Variable ;
    rdfs:label "Planned Time Point Number" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "56" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Numeric version of planned time point used in sorting." ;
    dc:identifier "MSTPTNUM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MS/MSTPTREF> a sdtmig:Variable ;
    rdfs:label "Time Point Reference" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "58" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Description of the fixed reference point referred to by MSELTM, MSTPTNUM, and MSTPT. Example: \"PREVIOUS DOSE\"." ;
    dc:identifier "MSTPTREF" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MS/MSTSTDTL> a sdtmig:Variable ;
    rdfs:label "Measurement, Test or Examination Detail" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "15" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Further description of MSTESTCD and MSTEST." ;
    dc:identifier "MSTSTDTL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MS/MSULOQ> a sdtmig:Variable ;
    rdfs:label "Upper Limit of Quantitation" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "45" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Indicates the upper limit of quantitation for an assay. Units will be those used for MSSTRESU." ;
    dc:identifier "MSULOQ" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MS/MSXFN> a sdtmig:Variable ;
    rdfs:label "External File Path" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "27" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Filename for an external file." ;
    dc:identifier "MSXFN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MS/NHOID> a sdtmig:Variable ;
    rdfs:label "Non-host Organism ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "4" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Sponsor-defined identifier for a non-host organism which should only be used when the organism is the subject of the TEST. This variable should be populated with an intuitive name based on the identity of the non-host organism as reported by a lab (e.g., \"A/California/7/2009 (H1N1)\"). It is not to be used as a qualifier of the result in the record on which it appears." ;
    dc:identifier "NHOID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MS/STUDYID> a sdtmig:Variable ;
    rdfs:label "Study Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "1" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Unique identifier for a study." ;
    dc:identifier "STUDYID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MS/TAETORD> a sdtmig:Variable ;
    rdfs:label "Planned Order of Element within Arm" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "50" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Number that gives the planned order of the element within the arm for the element in which the specimen was collected." ;
    dc:identifier "TAETORD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MS/USUBJID> a sdtmig:Variable ;
    rdfs:label "Unique Subject Identifier" ;
    sdtmig:core "Req" ;
