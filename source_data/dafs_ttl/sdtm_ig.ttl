<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PP/DOMAIN> a sdtmig:Variable ;
    rdfs:label "Domain Abbreviation" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "2" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Two-character abbreviation for the domain." ;
    dc:identifier "DOMAIN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PP/EPOCH> a sdtmig:Variable ;
    rdfs:label "Epoch" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C99079> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "20" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Epoch associated with the start date/time of the observation, or the date/time of collection if start date/time is not collected." ;
    dc:identifier "EPOCH" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PP/PPANMETH> a sdtmig:Variable ;
    rdfs:label "Analysis Method" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C172330> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "18" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Analysis method applied to obtain a summarized result. Analysis method describes the method of secondary processing applied to a complex observation result. Example: A named formula used to calculate AUC, such as \"LIN-LOG TRAPEZOIDAL METHOD\". \\n Sponsor-defined formulas can also be represented by this variable. Example: Calculating ratio AUCs where the PPANMETH may be \"DRUG METABOLITE 1 TO DRUG PARENT\" or \"DRUG METABOLITE 2 TO METABOLITE 1\"." ;
    dc:identifier "PPANMETH" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PP/PPCAT> a sdtmig:Variable ;
    rdfs:label "Parameter Category" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "8" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to define a category of related records. For PP, this should be the name of the analyte in PCTEST whose profile the parameter is associated with." ;
    dc:identifier "PPCAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PP/PPDTC> a sdtmig:Variable ;
    rdfs:label "Date/Time of Parameter Calculations" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "21" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Nominal date/time of parameter calculations." ;
    dc:identifier "PPDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PP/PPDY> a sdtmig:Variable ;
    rdfs:label "Study Day of Parameter Calculations" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "22" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Study day of the collection, in integer days. The algorithm for calculations must be relative to the sponsor-defined RFSTDTC variable in the Demographics (DM) domain." ;
    dc:identifier "PPDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PP/PPENINT> a sdtmig:Variable ;
    rdfs:label "Planned End of Assessment Interval" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "26" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 duration" ;
    dc:description "The end of a planned evaluation or assessment interval relative to the time point reference." ;
    dc:identifier "PPENINT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PP/PPGRPID> a sdtmig:Variable ;
    rdfs:label "Group ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "5" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to tie together a block of related records in a single domain to support relationships within the domain and between domains." ;
    dc:identifier "PPGRPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PP/PPORRES> a sdtmig:Variable ;
    rdfs:label "Result or Finding in Original Units" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "10" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Result of the measurement or finding as originally received or collected." ;
    dc:identifier "PPORRES" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PP/PPORRESU> a sdtmig:Variable ;
    rdfs:label "Original Units" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C85494> ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "11" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Original units in which the data were collected. The unit for PPORRES. Example: \"ng/L\". See PP Assumption 3." ;
    dc:identifier "PPORRESU" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PP/PPREASND> a sdtmig:Variable ;
    rdfs:label "Reason Parameter Not Calculated" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "16" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Describes why a parameter was not calculated, such as \"INSUFFICIENT DATA\". Used in conjunction with PPSTAT when value is \"NOT DONE\"." ;
    dc:identifier "PPREASND" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PP/PPRFTDTC> a sdtmig:Variable ;
    rdfs:label "Date/Time of Reference Point" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "24" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Date/time of the reference time point from the PC records used to calculate a parameter record. The values in PPRFTDTC should be the same as that in PCRFTDTC for related records." ;
    dc:identifier "PPRFTDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PP/PPSCAT> a sdtmig:Variable ;
    rdfs:label "Parameter Subcategory" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "9" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Categorization of the model type used to calculate the PK parameters. Examples: \"COMPARTMENTAL\", \"NON-COMPARTMENTAL\"." ;
    dc:identifier "PPSCAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PP/PPSEQ> a sdtmig:Variable ;
    rdfs:label "Sequence Number" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "4" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Sequence number given to ensure uniqueness of subject records within a domain. May be any valid number." ;
    dc:identifier "PPSEQ" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PP/PPSPEC> a sdtmig:Variable ;
    rdfs:label "Specimen Material Type" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C78734> ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "17" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Defines the type of specimen used for a measurement. If multiple specimen types are used for a calculation (e.g., serum and urine for renal clearance), then this field should be left blank. Examples: \"SERUM\", \"PLASMA\", \"URINE\"." ;
    dc:identifier "PPSPEC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PP/PPSTAT> a sdtmig:Variable ;
    rdfs:label "Completion Status" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66789> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "15" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to indicate that a parameter was not calculated. Should be null if a result exists in PPORRES." ;
    dc:identifier "PPSTAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PP/PPSTINT> a sdtmig:Variable ;
    rdfs:label "Planned Start of Assessment Interval" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "25" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 duration" ;
    dc:description "The start of a planned evaluation or assessment interval relative to the time point reference." ;
    dc:identifier "PPSTINT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PP/PPSTRESC> a sdtmig:Variable ;
    rdfs:label "Character Result/Finding in Std Format" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "12" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Contains the result value for all findings, copied or derived from PPORRES in a standard format or standard units. PPSTRESC should store all results or findings in character format; if results are numeric, they should also be stored in numeric format in PPSTRESN." ;
    dc:identifier "PPSTRESC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PP/PPSTRESN> a sdtmig:Variable ;
    rdfs:label "Numeric Result/Finding in Standard Units" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "13" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Used for continuous or numeric results or findings in standard format; copied in numeric format from PPSTRESC. PPSTRESN should store all numeric test results or findings." ;
    dc:identifier "PPSTRESN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PP/PPSTRESU> a sdtmig:Variable ;
    rdfs:label "Standard Units" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C85494> ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "14" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Standardized unit used for PPSTRESC and PPSTRESN. See PP Assumption 3." ;
    dc:identifier "PPSTRESU" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PP/PPTEST> a sdtmig:Variable ;
    rdfs:label "Parameter Name" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C85493> ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "7" ;
    sdtmig:role "Synonym Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Name of the pharmacokinetic parameter. The value in PPTEST cannot be longer than 40 characters. Examples: \"AUC All\", \"Time of CMAX\", \"Max Conc\"." ;
    dc:identifier "PPTEST" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PP/PPTESTCD> a sdtmig:Variable ;
    rdfs:label "Parameter Short Name" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C85839> ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "6" ;
    sdtmig:role "Topic" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Short name of the pharmacokinetic parameter. It can be used as a column name when converting a dataset from a vertical to a horizontal format. The value in PPTESTCD cannot be longer than 8 characters, nor can it start with a number (e.g., \"1TEST\" is not valid). PPTESTCD cannot contain characters other than letters, numbers, or underscores. Examples: \"AUCALL\", \"TMAX\", \"CMAX\"." ;
    dc:identifier "PPTESTCD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PP/PPTPTREF> a sdtmig:Variable ;
    rdfs:label "Time Point Reference" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "23" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "The description of a time point that acts as a fixed reference for a series of planned time points." ;
    dc:identifier "PPTPTREF" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PP/STUDYID> a sdtmig:Variable ;
    rdfs:label "Study Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "1" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
