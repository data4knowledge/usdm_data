    sdtmig:core "Perm" ;
    sdtmig:ordinal "39" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Name or identifier of the vendor that provided the test result. When more than 1 vendor is involved in the generation of the result, additional vendors should be represented as supplemental qualifiers." ;
    dc:identifier "GFNAM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/GF/GFORREF> a sdtmig:Variable ;
    rdfs:label "Reference Result in Original Units" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "19" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Reference value for the result or finding as originally received or collected. GFORREF uses the same units as GFORRES, if applicable." ;
    dc:identifier "GFORREF" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/GF/GFORRES> a sdtmig:Variable ;
    rdfs:label "Result or Finding in Original Units" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "17" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Result of the measurement or finding as originally received or collected." ;
    dc:identifier "GFORRES" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/GF/GFORRESU> a sdtmig:Variable ;
    rdfs:label "Original Units" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C71620> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "18" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Unit for GFORRES." ;
    dc:identifier "GFORRESU" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/GF/GFPVRID> a sdtmig:Variable ;
    rdfs:label "Published Variant Identifier" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "34" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "A unique identifier for the variation that has been publicly characterized in an external database. Examples: \"rs2231142\", \"COSM41596\"." ;
    dc:identifier "GFPVRID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/GF/GFREASND> a sdtmig:Variable ;
    rdfs:label "Reason Test Not Done" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "37" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Reason not done. Used in conjunction with GFSTAT when value is \"NOT DONE\"." ;
    dc:identifier "GFREASND" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/GF/GFREFID> a sdtmig:Variable ;
    rdfs:label "Reference ID" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "8" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "A unique identifier for the assayed genetic specimen." ;
    dc:identifier "GFREFID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/GF/GFREPNUM> a sdtmig:Variable ;
    rdfs:label "Repetition Number" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "47" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "The instance number of a test that is repeated within a given timeframe for the same test performed by the wet lab." ;
    dc:identifier "GFREPNUM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/GF/GFRESCAT> a sdtmig:Variable ;
    rdfs:label "Result Category" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "25" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to categorize the result of a finding." ;
    dc:identifier "GFRESCAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/GF/GFRFTDTC> a sdtmig:Variable ;
    rdfs:label "Date/Time of Reference Time Point" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "57" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Date/time for a fixed reference time point defined by GFTPTREF." ;
    dc:identifier "GFRFTDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/GF/GFRUNID> a sdtmig:Variable ;
