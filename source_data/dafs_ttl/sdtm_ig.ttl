    sdtmig:core "Perm" ;
    sdtmig:ordinal "8" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Sponsor-defined reference associated with the comment. May be the CRF page number (e.g., 650), or a module name (e.g., DEMOG), or a combination of information that identifies the reference (e.g. 650-VITALS-VISIT 2)." ;
    dc:identifier "COREF" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CO/COSEQ> a sdtmig:Variable ;
    rdfs:label "Sequence Number" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "5" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Sequence Number given to ensure uniqueness of subject records within a domain. May be any valid number." ;
    dc:identifier "COSEQ" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CO/COVAL> a sdtmig:Variable ;
    rdfs:label "Comment" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "9" ;
    sdtmig:role "Topic" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "The text of the comment. Text over 200 characters can be added to additional columns COVAL1-COVALn. See Assumption 3." ;
    dc:identifier "COVAL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CO/DOMAIN> a sdtmig:Variable ;
    rdfs:label "Domain Abbreviation" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "2" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Two-character abbreviation for the domain." ;
    dc:identifier "DOMAIN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CO/IDVAR> a sdtmig:Variable ;
    rdfs:label "Identifying Variable" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "6" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifying variable in the parent dataset that identifies the record(s) to which the comment applies. Examples AESEQ or CMGRPID. Used only when individual comments are related to domain records. Null for comments collected on separate CRFs." ;
    dc:identifier "IDVAR" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CO/IDVARVAL> a sdtmig:Variable ;
    rdfs:label "Identifying Variable Value" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "7" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Value of identifying variable of the parent record(s). Used only when individual comments are related to domain records. Null for comments collected on separate CRFs." ;
    dc:identifier "IDVARVAL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CO/RDOMAIN> a sdtmig:Variable ;
