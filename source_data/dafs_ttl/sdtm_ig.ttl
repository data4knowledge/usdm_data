    sdtmig:ordinal "12" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Original units in which the data were collected. The unit for QSORRES, such as minutes or seconds or the units associated with a visual analog scale." ;
    dc:identifier "QSORRESU" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/QS/QSREASND> a sdtmig:Variable ;
    rdfs:label "Reason Not Performed" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "17" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Describes why a question was not answered. Used in conjunction with QSSTAT when value is \"NOT DONE\". Example: \"SUBJECT REFUSED\"." ;
    dc:identifier "QSREASND" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/QS/QSRFTDTC> a sdtmig:Variable ;
    rdfs:label "Date/Time of Reference Time Point" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "33" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Date/time of the reference time point, QSTPTREF." ;
    dc:identifier "QSRFTDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/QS/QSSCAT> a sdtmig:Variable ;
    rdfs:label "Subcategory for Question" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "10" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "A further categorization of the questions within the category. Examples: \"MENTAL HEALTH\" , \"DEPRESSION\", \"WORD RECALL\"." ;
    dc:identifier "QSSCAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/QS/QSSEQ> a sdtmig:Variable ;
    rdfs:label "Sequence Number" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "4" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Sequence number given to ensure uniqueness of subject records within a domain. May be any valid number." ;
    dc:identifier "QSSEQ" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/QS/QSSPID> a sdtmig:Variable ;
    rdfs:label "Sponsor-Defined Identifier" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "6" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Sponsor-defined reference number. May be preprinted on the CRF as an explicit line identifier or defined in the sponsor\'s operational database. Example: Question number on a questionnaire." ;
    dc:identifier "QSSPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/QS/QSSTAT> a sdtmig:Variable ;
    rdfs:label "Completion Status" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66789> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "16" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to indicate that a question was not done or was not answered. Should be null if a result exists in QSORRES." ;
    dc:identifier "QSSTAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/QS/QSSTRESC> a sdtmig:Variable ;
    rdfs:label "Character Result/Finding in Std Format" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "13" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Contains the finding for all questions or subscores copied or derived from QSORRES, in a standard format or standard units. QSSTRESC should store all findings in character format; if findings are numeric, they should also be stored in numeric format in QSSTRESN. If question scores are derived from the original finding, then the standard format is the score. Examples: \"0\", \"1\". \\n When sponsors apply codelist to indicate the code values are statistically meaningful standardized scores (which are defined by sponsors or by valid methodologies, e.g., SF36 questionnaires), QSORRES will contain the decode format; QSSTRESC and QSSTRESN may contain the standardized code values or scores." ;
    dc:identifier "QSSTRESC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/QS/QSSTRESN> a sdtmig:Variable ;
    rdfs:label "Numeric Finding in Standard Units" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "14" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Used for continuous or numeric findings in standard format; copied in numeric format from QSSTRESC. QSSTRESN should store all numeric results or findings." ;
    dc:identifier "QSSTRESN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/QS/QSSTRESU> a sdtmig:Variable ;
    rdfs:label "Standard Units" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C71620> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "15" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Standardized unit used for QSSTRESC or QSSTRESN." ;
    dc:identifier "QSSTRESU" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/QS/QSTEST> a sdtmig:Variable ;
    rdfs:label "Question Name" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "8" ;
    sdtmig:role "Synonym Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Verbatim name of the question or group of questions used to obtain the measurement or finding. The value in QSTEST cannot be longer than 40 characters. \\n Controlled terminology for QSTEST is published in separate codelists for each questionnaire. See https://www.cdisc.org/standards/semantics/terminology for values for QSTEST. Example: \"BPR01 - Emotional Withdrawal\"." ;
    dc:identifier "QSTEST" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/QS/QSTESTCD> a sdtmig:Variable ;
    rdfs:label "Question Short Name" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "7" ;
    sdtmig:role "Topic" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Topic variable for QS. Short name for the value in QSTEST, which can be used as a column name when converting the dataset from a vertical format to a horizontal format. The value in QSTESTCD cannot be longer than 8 characters, nor can it start with a number (e.g., \"1TEST\" is not valid). QSTESTCD cannot contain characters other than letters, numbers, or underscores. \\n Controlled terminology for QSTESTCD is published in separate codelists for each questionnaire. See https://www.cdisc.org/standards/semantics/terminology for values for QSTESTCD. Examples: \"ADCCMD01\", \"BPR0103\"." ;
    dc:identifier "QSTESTCD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/QS/QSTPT> a sdtmig:Variable ;
    rdfs:label "Planned Time Point Name" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "29" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Text description of time when questionnaire should be administered. This may be represented as an elapsed time relative to a fixed reference point (e.g., \"TIME OF LAST DOSE\"). See QSTPTNUM and QSTPTREF." ;
    dc:identifier "QSTPT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/QS/QSTPTNUM> a sdtmig:Variable ;
    rdfs:label "Planned Time Point Number" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "30" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Numerical version of QSTPT to aid in sorting." ;
    dc:identifier "QSTPTNUM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/QS/QSTPTREF> a sdtmig:Variable ;
    rdfs:label "Time Point Reference" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "32" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Name of the fixed reference point referred to by QSELTM, QSTPTNUM, and QSTPT. Examples: \"PREVIOUS DOSE\", \"PREVIOUS MEAL\"." ;
    dc:identifier "QSTPTREF" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/QS/STUDYID> a sdtmig:Variable ;
    rdfs:label "Study Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "1" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Unique identifier for a study." ;
    dc:identifier "STUDYID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/QS/TAETORD> a sdtmig:Variable ;
    rdfs:label "Planned Order of Element within Arm" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "25" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Number that gives the planned order of the element within the arm for the element in which the assessment was made." ;
    dc:identifier "TAETORD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/QS/USUBJID> a sdtmig:Variable ;
    rdfs:label "Unique Subject Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "3" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifier used to uniquely identify a subject across all studies for all applications or submissions involving the product." ;
    dc:identifier "USUBJID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/QS/VISIT> a sdtmig:Variable ;
    rdfs:label "Visit Name" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "23" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Protocol-defined description of clinical encounter. May be used in addition to VISITNUM and/or VISITDY." ;
    dc:identifier "VISIT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/QS/VISITDY> a sdtmig:Variable ;
    rdfs:label "Planned Study Day of Visit" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "24" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Planned study day of the visit based upon RFSTDTC in Demographics." ;
    dc:identifier "VISITDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/QS/VISITNUM> a sdtmig:Variable ;
    rdfs:label "Visit Number" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "22" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Clinical encounter number. Numeric version of VISIT, used for sorting." ;
    dc:identifier "VISITNUM" .

