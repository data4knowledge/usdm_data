    sdtmig:core "Perm" ;
    sdtmig:ordinal "25" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to categorize the result of a finding or medical status per interpretation of test results. Examples: \"POSITIVE\", \"NEGATIVE\". The variable OERESCAT is not meant to replace the use of OENRIND for cases where normal ranges are provided." ;
    dc:identifier "OERESCAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/OE/OERFTDTC> a sdtmig:Variable ;
    rdfs:label "Date/Time of Reference Time Point" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "52" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Date/time of the reference time point, OETPTREF." ;
    dc:identifier "OERFTDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/OE/OESCAT> a sdtmig:Variable ;
    rdfs:label "Subcategory for Ophthalmic Test or Exam" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "13" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to define a further categorization of OECAT values. Example: \"HIGH CONTRAST\" or \"LOW CONTRAST\" when OECAT is \"VISUAL ACUITY\"." ;
    dc:identifier "OESCAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/OE/OESEQ> a sdtmig:Variable ;
    rdfs:label "Sequence Number" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "5" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Sequence number given to ensure uniqueness of subject records within a domain. May be any valid number." ;
    dc:identifier "OESEQ" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/OE/OESTAT> a sdtmig:Variable ;
    rdfs:label "Completion Status" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66789> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "26" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to indicate that a question was not asked or a test was not done, or a test was attempted but did not generate a result. Should be null or have a value of \"NOT DONE\"." ;
    dc:identifier "OESTAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/OE/OESTNRC> a sdtmig:Variable ;
