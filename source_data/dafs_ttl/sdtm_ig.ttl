    dc:identifier "DOMAIN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/EPOCH> a sdtmig:Variable ;
    rdfs:label "Epoch" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C99079> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "51" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Epoch associated with the start date/time of the observation, or the date/time of collection if start date/time is not collected." ;
    dc:identifier "EPOCH" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/LBANMETH> a sdtmig:Variable ;
    rdfs:label "Analysis Method" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C160922> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "38" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Analysis method applied to obtain a summarized result. Analysis method describes the method of secondary processing applied to a complex observation result (e.g., a calculation used to measure eGFR)." ;
    dc:identifier "LBANMETH" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/LBBDAGNT> a sdtmig:Variable ;
    rdfs:label "Binding Agent" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "11" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "The textual description of the agent that is binding to the entity in the LBTEST variable. The LBBDAGNT variable is used to indicate that there is a binding relationship between the entities in the LBTEST and LBBDAGNT variables, regardless of direction. \\n LBBDAGNT is not a method qualifier. It should only be used when the actual interest of the measurement is the binding interaction between the 2 entities in LBTEST and LBBDAGNT. In other words, the combination of LBTEST and LBBDAGNT should describe the thing, the entity, or the analyte being measured, without the need for additional variables. \\n The binding agent may be (but is not limited to) a test article, a portion of the test article, a related compound, or an endogenous molecule." ;
    dc:identifier "LBBDAGNT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/LBBLFL> a sdtmig:Variable ;
    rdfs:label "Baseline Flag" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "41" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Indicator used to identify a baseline value. Should be \"Y\" or null. Note that LBBLFL is retained for backward compatibility. The authoritative baseline for statistical analysis is in an ADaM dataset." ;
    dc:identifier "LBBLFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/LBCAT> a sdtmig:Variable ;
    rdfs:label "Category for Lab Test" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "13" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to define a category of related records across subjects. Examples: \"HEMATOLOGY\", \"URINALYSIS\", \"CHEMISTRY\"." ;
    dc:identifier "LBCAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/LBCLSIG> a sdtmig:Variable ;
    rdfs:label "Clinically Significant, Collected" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "46" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to indicate whether a collected observation is clinically significant based on judgment." ;
    dc:identifier "LBCLSIG" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/LBCOLSRT> a sdtmig:Variable ;
    rdfs:label "Collected Summary Result Type" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C177908> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "19" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to indicate the type of collected summary result. This includes source summary results collected on a CRF or provided by an external vendor (e.g., central lab). If the summary result is derived by the sponsor using individual source data records from SDTM, the derived summary result is represented in ADaM. If the summary result is produced and reported by the lab, the collected summary result is represented in SDTM." ;
    dc:identifier "LBCOLSRT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/LBDRVFL> a sdtmig:Variable ;
    rdfs:label "Derived Flag" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "43" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to indicate a derived record. The value should be \"Y\" or null. Records that represent the average of other records, or do not come from the CRF, or are not as originally received or collected are examples of records that might be derived for the submission datasets. If LBDRVFL=\"Y\", then LBORRES may be null, with LBSTRESC and (if numeric) LBSTRESN having the derived value." ;
    dc:identifier "LBDRVFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/LBDTC> a sdtmig:Variable ;
    rdfs:label "Date/Time of Specimen Collection" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "52" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Date/time of specimen collection represented in ISO 8601 character format." ;
    dc:identifier "LBDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/LBDY> a sdtmig:Variable ;
    rdfs:label "Study Day of Specimen Collection" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "54" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Study day of specimen collection, measured as integer days. Algorithm for calculations must be relative to the sponsor-defined RFSTDTC variable in Demographics. This formula should be consistent across the submission." ;
    dc:identifier "LBDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/LBELTM> a sdtmig:Variable ;
    rdfs:label "Planned Elapsed Time from Time Point Ref" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "58" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 duration" ;
    dc:description "Planned elapsed time (in ISO 8601) relative to a planned fixed reference (LBTPTREF). This variable is useful where there are repetitive measures. Not a clock time or a date/time variable. Represented as ISO 8601 duration. Examples: \"-PT15M\" to represent the period of 15 minutes prior to the reference point indicated by LBTPTREF, \"PT8H\" to represent the period of 8 hours after the reference point indicated by LBTPTREF." ;
    dc:identifier "LBELTM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/LBENDTC> a sdtmig:Variable ;
    rdfs:label "End Date/Time of Specimen Collection" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "53" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "End date/time of specimen collection represented in ISO 8601 character format." ;
    dc:identifier "LBENDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/LBENDY> a sdtmig:Variable ;
    rdfs:label "Study Day of End of Observation" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "55" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Actual study day of end of observation expressed in integer days relative to the sponsor-defined RFSTDTC in Demographics." ;
    dc:identifier "LBENDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/LBFAST> a sdtmig:Variable ;
    rdfs:label "Fasting Status" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "42" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Indicator used to identify fasting status. Examples: \"Y\", \"N\"." ;
    dc:identifier "LBFAST" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/LBGRPID> a sdtmig:Variable ;
    rdfs:label "Group ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "5" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to tie together a block of related records in a single domain for a subject." ;
    dc:identifier "LBGRPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/LBLLOD> a sdtmig:Variable ;
    rdfs:label "Lower Limit of Detection" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "22" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "The lowest threshold (as originally received or collected) for reliably detecting the presence or absence of substance measured by a specific test. The value for the field will be as described in documentation from the instrument or lab vendor." ;
    dc:identifier "LBLLOD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/LBLOBXFL> a sdtmig:Variable ;
    rdfs:label "Last Observation Before Exposure Flag" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "40" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Operationally derived indicator used to identify the last non-missing value prior to RFXSTDTC. The value should be \"Y\" or null." ;
    dc:identifier "LBLOBXFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/LBLOINC> a sdtmig:Variable ;
    rdfs:label "LOINC Code" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "33" ;
    sdtmig:role "Synonym Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "LOINC" ;
    dc:description "Code for the lab test from the LOINC code system. The sponsor is expected to provide the dictionary name and version used to map the terms utilizing the Define-XML external codelist attributes." ;
    dc:identifier "LBLOINC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/LBMETHOD> a sdtmig:Variable ;
    rdfs:label "Method of Test or Examination" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C85492> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "37" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Method of the test or examination. Examples: \"EIA\" (enzyme immunoassay), \"ELECTROPHORESIS\", \"DIPSTICK\"." ;
    dc:identifier "LBMETHOD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/LBNAM> a sdtmig:Variable ;
    rdfs:label "Vendor Name" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "32" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "The name or identifier of the laboratory that performed the test." ;
    dc:identifier "LBNAM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/LBNRIND> a sdtmig:Variable ;
    rdfs:label "Reference Range Indicator" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C78736> ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "29" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Indicates where the value falls with respect to reference range defined by LBORNRLO and LBORNRHI, LBSTNRLO and LBSTNRHI, or by LBSTNRC. Examples: \"NORMAL\", \"ABNORMAL\", \"HIGH\", \"LOW\". Sponsors should specify in the study metadata (Comments column in the Define-XML document) whether LBNRIND refers to the original or standard reference ranges and results. LBNRIND is not used to indicate clinical significance." ;
    dc:identifier "LBNRIND" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/LBORNRHI> a sdtmig:Variable ;
    rdfs:label "Reference Range Upper Limit in Orig Unit" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "21" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Upper end of reference range for continuous measurement in original units. Should be populated only for continuous results." ;
    dc:identifier "LBORNRHI" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/LBORNRLO> a sdtmig:Variable ;
    rdfs:label "Reference Range Lower Limit in Orig Unit" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "20" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Lower end of reference range for continuous measurement in original units. Should be populated only for continuous results." ;
    dc:identifier "LBORNRLO" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/LBORRES> a sdtmig:Variable ;
    rdfs:label "Result or Finding in Original Units" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "15" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Result of the measurement or finding as originally received or collected." ;
    dc:identifier "LBORRES" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/LBORRESU> a sdtmig:Variable ;
    rdfs:label "Original Units" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C71620> ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "16" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Original units in which the data were collected. The unit for LBORRES. Example: \"g/L\"." ;
    dc:identifier "LBORRESU" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/LBPDUR> a sdtmig:Variable ;
    rdfs:label "Planned Duration" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "62" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 duration" ;
    dc:description "Planned duration of specimen collection. If LBPTFL is \"Y\" then LBPDUR is null." ;
    dc:identifier "LBPDUR" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/LBPTFL> a sdtmig:Variable ;
    rdfs:label "Point in Time Flag" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "61" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "An indication that the specimen was collected at a single point in time. The value is \"Y\" or null. The intent of this variable in the LB domain is to aid mapping to LOINC codes in the dataset, when LOINC part \"Time Aspect\" = \"Pt\"." ;
    dc:identifier "LBPTFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/LBREASND> a sdtmig:Variable ;
    rdfs:label "Reason Test Not Done" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "31" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Describes why a measurement or test was not performed. Examples: \"BROKEN EQUIPMENT\", \"SUBJECT REFUSED\", or \"SPECIMEN LOST\". Used in conjunction with LBSTAT when value is \"NOT DONE\"." ;
    dc:identifier "LBREASND" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/LBREFID> a sdtmig:Variable ;
    rdfs:label "Specimen ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "6" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Internal or external specimen identifier. Example: specimen ID." ;
    dc:identifier "LBREFID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/LBRESSCL> a sdtmig:Variable ;
    rdfs:label "Result Scale" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C177910> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "17" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Classifies the scale of the original result value; for example, whether the result is ordinal, nominal, quantitative, or narrative." ;
    dc:identifier "LBRESSCL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/LBRESTYP> a sdtmig:Variable ;
    rdfs:label "Result Type" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C179588> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "18" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Classifies the kind of result (i.e., property type) originally reported for the test. Examples include substance concentration, proportion, mass rate, and arbitrary concentration." ;
    dc:identifier "LBRESTYP" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/LBRFTDTC> a sdtmig:Variable ;
    rdfs:label "Date/Time of Reference Time Point" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "60" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Date/time of the reference time point, LBTPTREF." ;
    dc:identifier "LBRFTDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/LBSCAT> a sdtmig:Variable ;
    rdfs:label "Subcategory for Lab Test" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "14" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "A further categorization of a test category. Examples: \"DIFFERENTIAL\", \"COAGULATION\", \"LIVER FUNCTION\", \"ELECTROLYTES\"." ;
    dc:identifier "LBSCAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/LBSEQ> a sdtmig:Variable ;
    rdfs:label "Sequence Number" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "4" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Sequence number given to ensure uniqueness of subject records within a domain. May be any valid number." ;
    dc:identifier "LBSEQ" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/LBSPCCND> a sdtmig:Variable ;
    rdfs:label "Specimen Condition" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C78733> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "35" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "The physical state or quality of a sample for an assessment. Examples: \"HEMOLYZED\", \"ICTERIC\", \"LIPEMIC\"." ;
    dc:identifier "LBSPCCND" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/LBSPCUFL> a sdtmig:Variable ;
    rdfs:label "Specimen Usability for the Test" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "36" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Describes the usability of the specimen for the test. The value will be \"N\" if the specimen is not usable, and null if the specimen is usable." ;
    dc:identifier "LBSPCUFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/LBSPEC> a sdtmig:Variable ;
    rdfs:label "Specimen Type" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C78734> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "34" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Defines the type of specimen used for a measurement. Examples: \"SERUM\", \"PLASMA\", \"URINE\"." ;
    dc:identifier "LBSPEC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/LBSPID> a sdtmig:Variable ;
    rdfs:label "Sponsor-Defined Identifier" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "7" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Sponsor-defined reference number. May be preprinted on the CRF as an explicit line identifier or defined in the sponsor\'s operational database. Example: Line number on the Lab page." ;
    dc:identifier "LBSPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/LBSTAT> a sdtmig:Variable ;
    rdfs:label "Completion Status" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66789> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "30" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to indicate exam not done. Should be null if a result exists in LBORRES." ;
    dc:identifier "LBSTAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/LBSTNRC> a sdtmig:Variable ;
    rdfs:label "Reference Range for Char Rslt-Std Units" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "28" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "For normal range values that are character in ordinal scale or if categorical ranges were supplied. Examples: \"-1 to +1\", \"NEGATIVE TO TRACE\"." ;
    dc:identifier "LBSTNRC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/LBSTNRHI> a sdtmig:Variable ;
    rdfs:label "Reference Range Upper Limit-Std Units" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "27" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Upper end of reference range for continuous measurements in standardized units. Should be populated only for continuous results." ;
    dc:identifier "LBSTNRHI" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/LBSTNRLO> a sdtmig:Variable ;
    rdfs:label "Reference Range Lower Limit-Std Units" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "26" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Lower end of reference range for continuous measurements for LBSTRESC/LBSTRESN in standardized units. Should be populated only for continuous results." ;
    dc:identifier "LBSTNRLO" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/LBSTRESC> a sdtmig:Variable ;
    rdfs:label "Character Result/Finding in Std Format" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C102580> ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "23" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Contains the result value for all findings, copied or derived from LBORRES in a standard format or standard units. LBSTRESC should store all results or findings in character format; if results are numeric, they should also be stored in numeric format in LBSTRESN. For example, if a test has results \"NONE\", \"NEG\", and \"NEGATIVE\" in LBORRES and these results effectively have the same meaning, they could be represented in standard format in LBSTRESC as \"NEGATIVE\". For other examples, see Original and Standardized Results." ;
    dc:identifier "LBSTRESC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/LBSTRESN> a sdtmig:Variable ;
    rdfs:label "Numeric Result/Finding in Standard Units" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "24" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Used for continuous or numeric results or findings in standard format; copied in numeric format from LBSTRESC. LBSTRESN should store all numeric test results or findings." ;
    dc:identifier "LBSTRESN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/LBSTRESU> a sdtmig:Variable ;
    rdfs:label "Standard Units" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C71620> ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "25" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Standardized unit used for LBSTRESC or LBSTRESN." ;
    dc:identifier "LBSTRESU" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/LBTEST> a sdtmig:Variable ;
    rdfs:label "Lab Test or Examination Name" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C67154> ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "9" ;
    sdtmig:role "Synonym Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Verbatim name of the test or examination used to obtain the measurement or finding. Note: Any test normally performed by a clinical laboratory is considered a lab test. The value in LBTEST cannot be longer than 40 characters. Examples: \"Alanine Aminotransferase\", \"Lactate Dehydrogenase\"." ;
    dc:identifier "LBTEST" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/LBTESTCD> a sdtmig:Variable ;
    rdfs:label "Lab Test or Examination Short Name" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C65047> ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "8" ;
    sdtmig:role "Topic" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Short name of the measurement, test, or examination described in LBTEST. It can be used as a column name when converting a dataset from a vertical to a horizontal format. The value in LBTESTCD cannot be longer than 8 characters, nor can it start with a number (e.g., \"1TEST\" is not valid). LBTESTCD cannot contain characters other than letters, numbers, or underscores. Examples: \"ALT\", \"LDH\"." ;
    dc:identifier "LBTESTCD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/LBTMTHSN> a sdtmig:Variable ;
    rdfs:label "Test Method Sensitivity" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C179589> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "39" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "The sensitivity of the test methodology with respect to observation, detection, or quantification." ;
    dc:identifier "LBTMTHSN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/LBTOX> a sdtmig:Variable ;
    rdfs:label "Toxicity" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "44" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Description of toxicity quantified by LBTOXGR. The sponsor is expected to provide the name of the scale and version used to map the terms, utilizing the external codelist element in the Define-XML document." ;
    dc:identifier "LBTOX" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/LBTOXGR> a sdtmig:Variable ;
    rdfs:label "Standard Toxicity Grade" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "45" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Records toxicity grade value using a standard toxicity scale (e.g., the NCI CTCAE). If value is from a numeric scale, represent only the number (e.g., \"2\" not \"Grade 2\"). The sponsor is expected to provide the name of the scale and version used to map the terms, utilizing the external codelist element in the Define-XML document." ;
    dc:identifier "LBTOXGR" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/LBTPT> a sdtmig:Variable ;
    rdfs:label "Planned Time Point Name" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "56" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Text description of time when specimen should be taken. This may be represented as an elapsed time relative to a fixed reference point, such as time of last dose. See LBTPTNUM and LBTPTREF. Examples: \"Start\", \"5 min post\"." ;
    dc:identifier "LBTPT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/LBTPTNUM> a sdtmig:Variable ;
    rdfs:label "Planned Time Point Number" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "57" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Numerical version of LBTPT to aid in sorting." ;
    dc:identifier "LBTPTNUM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/LBTPTREF> a sdtmig:Variable ;
    rdfs:label "Time Point Reference" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "59" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Name of the fixed reference point referred to by LBELTM, LBTPTNUM, and LBTPT. Examples: \"PREVIOUS DOSE\", \"PREVIOUS MEAL\"." ;
    dc:identifier "LBTPTREF" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/LBTSTCND> a sdtmig:Variable ;
    rdfs:label "Test Condition" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C181175> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "10" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifies any planned condition imposed by the assay system on the specimen at the time the test is performed." ;
    dc:identifier "LBTSTCND" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/LBTSTOPO> a sdtmig:Variable ;
    rdfs:label "Test Operational Objective" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C181170> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "12" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Text description of the high-level purpose of the test at the operational level." ;
    dc:identifier "LBTSTOPO" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/STUDYID> a sdtmig:Variable ;
    rdfs:label "Study Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "1" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Unique identifier for a study." ;
    dc:identifier "STUDYID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/TAETORD> a sdtmig:Variable ;
    rdfs:label "Planned Order of Element within Arm" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "50" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Number that gives the planned order of the element within the arm." ;
    dc:identifier "TAETORD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/USUBJID> a sdtmig:Variable ;
    rdfs:label "Unique Subject Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "3" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifier used to uniquely identify a subject across all studies for all applications or submissions involving the product." ;
    dc:identifier "USUBJID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/VISIT> a sdtmig:Variable ;
    rdfs:label "Visit Name" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "48" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Protocol-defined description of clinical encounter. May be used in addition to VISITNUM and/or VISITDY." ;
    dc:identifier "VISIT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/VISITDY> a sdtmig:Variable ;
    rdfs:label "Planned Study Day of Visit" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "49" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Planned study day of the visit based upon RFSTDTC in Demographics." ;
    dc:identifier "VISITDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/LB/VISITNUM> a sdtmig:Variable ;
    rdfs:label "Visit Number" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "47" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Clinical encounter number. Numeric version of VISIT, used for sorting." ;
    dc:identifier "VISITNUM" .

