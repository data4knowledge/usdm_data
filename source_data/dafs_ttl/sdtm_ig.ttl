    sdtmig:ordinal "21" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Defines the types of specimen used for a measurement. Example: \"SKIN\"." ;
    dc:identifier "SRSPEC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SR/SRSPID> a sdtmig:Variable ;
    rdfs:label "Sponsor-Defined Identifier" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "7" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Sponsor-defined identifier." ;
    dc:identifier "SRSPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SR/SRSTAT> a sdtmig:Variable ;
    rdfs:label "Completion Status" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66789> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "18" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to indicate exam not done. Should be null if a result exists in SRORRES." ;
    dc:identifier "SRSTAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SR/SRSTRESC> a sdtmig:Variable ;
    rdfs:label "Character Result/Finding in Std Format" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "15" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Contains the result value for all findings copied or derived from SRORRES, in a standard format or in standard units. SRSTRESC should store all results or findings in character format; if results are numeric, they should also be stored in numeric format in SRSTRESN." ;
    dc:identifier "SRSTRESC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SR/SRSTRESN> a sdtmig:Variable ;
    rdfs:label "Numeric Results/Findings in Std. Units" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "16" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Used for continuous or numeric results or findings in standard format; copied in numeric format from SRSTRESC. SRSTRESN should store all numeric test results or findings." ;
    dc:identifier "SRSTRESN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SR/SRSTRESU> a sdtmig:Variable ;
    rdfs:label "Standard Units" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C71620> ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "17" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Standardized units used for SRSTRESC and SRSTRESN. Example: \"mm\"." ;
    dc:identifier "SRSTRESU" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SR/SRTEST> a sdtmig:Variable ;
    rdfs:label "Skin Response Test or Examination Name" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C112023> ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "9" ;
    sdtmig:role "Synonym Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Verbatim name of the test or examination used to obtain the measurement or finding. The value in SRTEST cannot be longer than 40 characters. Example: \"Wheal Diameter\"." ;
    dc:identifier "SRTEST" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SR/SRTESTCD> a sdtmig:Variable ;
    rdfs:label "Skin Response Test or Exam Short Name" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C112024> ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "8" ;
    sdtmig:role "Topic" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Short name of the measurement, test, or examination described in SRTEST. It can be used as a column name when converting a dataset from a vertical to a horizontal format. The value in SRTESTCD cannot be longer than 8 characters, nor can it start with a number (e.g., \"1TEST\" is not valid). SRTESTCD cannot contain characters other than letters, numbers, or underscores." ;
    dc:identifier "SRTESTCD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SR/SRTPT> a sdtmig:Variable ;
    rdfs:label "Planned Time Point Name" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "35" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Text description of time when measurement should be taken. This may be represented as an elapsed time relative to a fixed reference point, such as time of last dose. See SRTPTNUM and SRTPTREF. Examples: \"START\", \"5 MIN POST\"." ;
    dc:identifier "SRTPT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SR/SRTPTNUM> a sdtmig:Variable ;
    rdfs:label "Planned Time Point Number" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "36" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Numerical version of SRTPT to aid in sorting." ;
    dc:identifier "SRTPTNUM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SR/SRTPTREF> a sdtmig:Variable ;
    rdfs:label "Time Point Reference" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "38" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Name of the fixed reference point referred to by SRELTM, SRTPTNUM, and SRTPT. Example: \"INTRADERMAL INJECTION\"." ;
    dc:identifier "SRTPTREF" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SR/STUDYID> a sdtmig:Variable ;
    rdfs:label "Study Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "1" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Unique identifier for a study." ;
    dc:identifier "STUDYID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SR/TAETORD> a sdtmig:Variable ;
    rdfs:label "Planned Order of Element within Arm" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "31" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Number that gives the planned order of the element within the arm." ;
    dc:identifier "TAETORD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SR/USUBJID> a sdtmig:Variable ;
    rdfs:label "Unique Subject Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "3" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
