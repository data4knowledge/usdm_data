<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SU/DOMAIN> a sdtmig:Variable ;
    rdfs:label "Domain Abbreviation" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "2" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Two-character abbreviation for the domain." ;
    dc:identifier "DOMAIN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SU/EPOCH> a sdtmig:Variable ;
    rdfs:label "Epoch" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C99079> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "26" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Epoch associated with the start date/time of the substance use. Null for substances that started before study participation." ;
    dc:identifier "EPOCH" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SU/STUDYID> a sdtmig:Variable ;
    rdfs:label "Study Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "1" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Unique identifier for a study." ;
    dc:identifier "STUDYID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SU/SUCAT> a sdtmig:Variable ;
    rdfs:label "Category for Substance Use" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "10" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to define a category of related records. Examples: \"TOBACCO\", \"ALCOHOL\", or \"CAFFEINE\"." ;
    dc:identifier "SUCAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SU/SUCLAS> a sdtmig:Variable ;
    rdfs:label "Substance Use Class" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "16" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Substance use class. May be obtained from coding. When coding to a single class, populate with class value. If using a dictionary and coding to multiple classes, then follow Section 4.2.8.3, Multiple Values for a Non-result Qualifier Variable, or omit SUCLAS." ;
    dc:identifier "SUCLAS" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SU/SUCLASCD> a sdtmig:Variable ;
    rdfs:label "Substance Use Class Code" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "17" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Code corresponding to SUCLAS. May be obtained from coding." ;
    dc:identifier "SUCLASCD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SU/SUDECOD> a sdtmig:Variable ;
    rdfs:label "Standardized Substance Name" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "9" ;
    sdtmig:role "Synonym Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Standardized or dictionary-derived text description of SUTRT or SUMODIFY if the sponsor chooses to code the substance use. The sponsor is expected to provide the dictionary name and version used to map the terms utilizing the external codelist element in the Define-XML document." ;
    dc:identifier "SUDECOD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SU/SUDOSE> a sdtmig:Variable ;
    rdfs:label "Substance Use Consumption" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "18" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Amount of SUTRT consumed. Not populated if SUDOSTXT is populated." ;
    dc:identifier "SUDOSE" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SU/SUDOSFRM> a sdtmig:Variable ;
    rdfs:label "Dose Form" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66726> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "21" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Dose form for SUTRT. Examples: \"INJECTABLE\", \"LIQUID\", \"POWDER\"." ;
    dc:identifier "SUDOSFRM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SU/SUDOSFRQ> a sdtmig:Variable ;
    rdfs:label "Use Frequency Per Interval" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C71113> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "22" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Usually expressed as the number of repeated administrations of SUDOSE within a specific time period. Example: \"Q24H\" (every day)." ;
    dc:identifier "SUDOSFRQ" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SU/SUDOSTOT> a sdtmig:Variable ;
    rdfs:label "Total Daily Consumption" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "23" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Total daily use of SUTRT using the units in SUDOSU. Used when dosing is collected as total daily dose. If a sponsor needs to aggregate the data over a period other than daily, then the aggregated total could be recorded in a supplemental qualifier variable." ;
    dc:identifier "SUDOSTOT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SU/SUDOSTXT> a sdtmig:Variable ;
    rdfs:label "Substance Use Consumption Text" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "19" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Substance use consumption amounts or a range of consumption information collected in text form. Not populated if SUDOSE is populated." ;
    dc:identifier "SUDOSTXT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SU/SUDOSU> a sdtmig:Variable ;
    rdfs:label "Consumption Units" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C71620> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "20" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Units for SUDOSE, SUDOSTOT, or SUDOSTXT. Examples: \"oz\", \"CIGARETTE\", \"PACK\", \"g\"." ;
    dc:identifier "SUDOSU" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SU/SUDUR> a sdtmig:Variable ;
    rdfs:label "Duration of Substance Use" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "31" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 duration" ;
    dc:description "Collected duration of substance use in ISO 8601 format. Used only if collected on the CRF and not derived from start and end date/times." ;
    dc:identifier "SUDUR" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SU/SUENDTC> a sdtmig:Variable ;
    rdfs:label "End Date/Time of Substance Use" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "28" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "End date/time of the substance use represented in ISO 8601 character format." ;
    dc:identifier "SUENDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SU/SUENDY> a sdtmig:Variable ;
    rdfs:label "Study Day of End of Substance Use" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "30" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Study day of end of substance use relative to the sponsor-defined RFSTDTC." ;
    dc:identifier "SUENDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SU/SUENRF> a sdtmig:Variable ;
    rdfs:label "End Relative to Reference Period" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66728> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "33" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Describes the end of the substance use with relative to the sponsor-defined reference period. The sponsor-defined reference period is a continuous period of time defined by a discrete starting point and a discrete ending point (represented by RFSTDTC and RFENDTC in Demographics). If information such as \"PRIOR\", \"ONGOING\", or \"CONTINUING\" was collected, this information may be translated into SUENRF. \\n Not all values of the codelist are allowable for this variable. See Section 4.4.7, Use of Relative Timing Variables." ;
    dc:identifier "SUENRF" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SU/SUENRTPT> a sdtmig:Variable ;
    rdfs:label "End Relative to Reference Time Point" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66728> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "36" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifies the end of the substance as being before or after the reference time point defined by variable SUENTPT. \\n Not all values of the codelist are allowable for this variable. See Section 4.4.7 , Use of Relative Timing Variables." ;
    dc:identifier "SUENRTPT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SU/SUENTPT> a sdtmig:Variable ;
    rdfs:label "End Reference Time Point" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "37" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Description or date/time in ISO 8601 character format of the reference point referred to by SUENRTPT. Examples: \"2003-12-25\", \"VISIT 2\"." ;
    dc:identifier "SUENTPT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SU/SUGRPID> a sdtmig:Variable ;
    rdfs:label "Group ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "5" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to tie together a block of related records in a single domain for a subject." ;
    dc:identifier "SUGRPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SU/SUMODIFY> a sdtmig:Variable ;
    rdfs:label "Modified Substance Name" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "8" ;
    sdtmig:role "Synonym Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "If SUTRT is modified, then the modified text is placed here." ;
    dc:identifier "SUMODIFY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SU/SUOCCUR> a sdtmig:Variable ;
    rdfs:label "SU Occurrence" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "13" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "When the use of specific substances is solicited, SUOCCUR is used to indicate whether (\"Y\"/\"N\") a particular prespecified substance was used. Values are null for substances not specifically solicited." ;
    dc:identifier "SUOCCUR" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SU/SUPRESP> a sdtmig:Variable ;
    rdfs:label "SU Pre-Specified" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "12" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to indicate whether (\"Y\"/null) information about the use of a specific substance was solicited on the CRF." ;
    dc:identifier "SUPRESP" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SU/SUREASND> a sdtmig:Variable ;
    rdfs:label "Reason Substance Use Not Collected" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "15" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Describes the reason substance use was not collected. Used in conjunction with SUSTAT when value of SUSTAT is \"NOT DONE\"." ;
    dc:identifier "SUREASND" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SU/SUROUTE> a sdtmig:Variable ;
    rdfs:label "Route of Administration" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66729> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "24" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Route of administration for SUTRT. Examples: \"ORAL\", \"INTRAVENOUS\"." ;
    dc:identifier "SUROUTE" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SU/SUSCAT> a sdtmig:Variable ;
    rdfs:label "Subcategory for Substance Use" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "11" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "A further categorization of substance use. Examples: \"CIGARS\", \"CIGARETTES\", \"BEER\", \"WINE\"." ;
    dc:identifier "SUSCAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SU/SUSEQ> a sdtmig:Variable ;
    rdfs:label "Sequence Number" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "4" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Sequence number given to ensure uniqueness of subject records within a domain. May be any valid number." ;
    dc:identifier "SUSEQ" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SU/SUSPID> a sdtmig:Variable ;
    rdfs:label "Sponsor-Defined Identifier" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "6" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Sponsor-defined reference number. May be preprinted on the CRF as an explicit line identifier or defined in the sponsor\'s operational database. Example: Line number on a Tobacco & Alcohol Use CRF page." ;
    dc:identifier "SUSPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SU/SUSTAT> a sdtmig:Variable ;
    rdfs:label "Completion Status" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66789> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "14" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "When the use of prespecified substances is solicited, the completion status indicates that there was no response to the question about the prespecified substance. When there is no prespecified list on the CRF, then the completion status indicates that substance use was not assessed for the subject." ;
    dc:identifier "SUSTAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SU/SUSTDTC> a sdtmig:Variable ;
    rdfs:label "Start Date/Time of Substance Use" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "27" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Start date/time of the substance use represented in ISO 8601 character format." ;
    dc:identifier "SUSTDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SU/SUSTDY> a sdtmig:Variable ;
    rdfs:label "Study Day of Start of Substance Use" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "29" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Study day of start of substance use relative to the sponsor-defined RFSTDTC." ;
    dc:identifier "SUSTDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SU/SUSTRF> a sdtmig:Variable ;
    rdfs:label "Start Relative to Reference Period" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66728> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "32" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Describes the start of the substance use relative to the sponsor-defined reference period. The sponsor-defined reference period is a continuous period of time defined by a discrete starting point and a discrete ending point (represented by RFSTDTC and RFENDTC in Demographics). If information such as \"PRIOR\" was collected, this information may be translated into SUSTRF. \\n Not all values of the codelist are allowable for this variable. See Section 4.4.7, Use of Relative Timing Variables." ;
    dc:identifier "SUSTRF" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SU/SUSTRTPT> a sdtmig:Variable ;
    rdfs:label "Start Relative to Reference Time Point" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66728> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "34" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifies the start of the substance as being before or after the reference time point defined by variable SUSTTPT. \\n Not all values of the codelist are allowable for this variable. See Section 4.4.7 , Use of Relative Timing Variables." ;
    dc:identifier "SUSTRTPT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SU/SUSTTPT> a sdtmig:Variable ;
    rdfs:label "Start Reference Time Point" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "35" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Description or date/time in ISO 8601 character format of the reference point referred to by SUSTRTPT. Examples: \"2003-12-15\", \"VISIT 1\"." ;
    dc:identifier "SUSTTPT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SU/SUTRT> a sdtmig:Variable ;
    rdfs:label "Reported Name of Substance" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "7" ;
    sdtmig:role "Topic" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Substance name. Examples: \"CIGARETTES\", \"COFFEE\"." ;
    dc:identifier "SUTRT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SU/TAETORD> a sdtmig:Variable ;
    rdfs:label "Planned Order of Element within Arm" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "25" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Number that gives the planned order of the element within the arm for the element in which the substance use started. Null for substances that started before study participation." ;
    dc:identifier "TAETORD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SU/USUBJID> a sdtmig:Variable ;
    rdfs:label "Unique Subject Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "3" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifier used to uniquely identify a subject across all studies for all applications or submissions involving the product." ;
    dc:identifier "USUBJID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SUPPQUAL> a sdtmig:Domain ;
