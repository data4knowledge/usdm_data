    sdtmig:core "Perm" ;
    sdtmig:ordinal "36" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 duration" ;
    dc:description "Collected duration of a procedure represented in ISO 8601 character format. Used only if collected on the CRF and not derived from start and end date/times." ;
    dc:identifier "PRDUR" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PR/PRELTM> a sdtmig:Variable ;
