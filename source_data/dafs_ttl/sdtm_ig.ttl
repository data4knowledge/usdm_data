<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AG/AGCAT> a sdtmig:Variable ;
    rdfs:label "Category for Agent" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "12" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to define a category of agent. Examples: \"CHALLENGE AGENT\", \"PET TRACER\"." ;
    dc:identifier "AGCAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AG/AGCLAS> a sdtmig:Variable ;
    rdfs:label "Agent Class" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "18" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Drug class. May be obtained from coding. When coding to a single class, populate with class value. If using a dictionary and coding to multiple classes, follow guidance in Section 4.2.8.3, Multiple Values for a Non-result Qualifier Variable, or omit AGCLAS." ;
    dc:identifier "AGCLAS" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AG/AGCLASCD> a sdtmig:Variable ;
    rdfs:label "Agent Class Code" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "19" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Class code corresponding to AGCLAS. Drug class. May be obtained from coding. When coding to a single class, populate with class code. If using a dictionary and coding to multiple classes, follow guidance in Section 4.2.8.3, Multiple Values for a Non-result Qualifier Variable, or omit AGCLASCD." ;
    dc:identifier "AGCLASCD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AG/AGDECOD> a sdtmig:Variable ;
    rdfs:label "Standardized Agent Name" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "11" ;
    sdtmig:role "Synonym Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Standardized or dictionary-derived text description of AGTRT or AGMODIFY. Equivalent to the generic medication name in WHO Drug. The sponsor is expected to provide the dictionary name and version used to map the terms utilizing the external codelist element in the Define-XML document. If an intervention term does not have a decode value in the dictionary, then AGDECOD will be left blank." ;
    dc:identifier "AGDECOD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AG/AGDOSE> a sdtmig:Variable ;
    rdfs:label "Dose per Administration" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "20" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Amount of AGTRT taken." ;
    dc:identifier "AGDOSE" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AG/AGDOSFRM> a sdtmig:Variable ;
    rdfs:label "Dose Form" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66726> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "23" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Dose form for AGTRT. Examples: \"TABLET\", \"AEROSOL\"." ;
    dc:identifier "AGDOSFRM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AG/AGDOSFRQ> a sdtmig:Variable ;
    rdfs:label "Dosing Frequency per Interval" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C71113> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "24" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Usually expressed as the number of repeated administrations of AGDOSE within a specific time period. Example: \"ONCE\"." ;
    dc:identifier "AGDOSFRQ" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AG/AGDOSTXT> a sdtmig:Variable ;
    rdfs:label "Dose Description" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "21" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Dosing amounts or a range of dosing information collected in text form. Units may be stored in AGDOSU. Examples: \"200-400\", \"15-20\"." ;
    dc:identifier "AGDOSTXT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AG/AGDOSU> a sdtmig:Variable ;
    rdfs:label "Dose Units" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C71620> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "22" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Units for AGDOSE and AGDOSTXT. Examples: \"ng\", \"mg\", \"mg/kg\"." ;
    dc:identifier "AGDOSU" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AG/AGDUR> a sdtmig:Variable ;
    rdfs:label "Duration of Agent" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "35" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 duration" ;
    dc:description "Collected duration for an agent episode. Used only if collected on the CRF and not derived from start and end date/times." ;
    dc:identifier "AGDUR" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AG/AGENDTC> a sdtmig:Variable ;
    rdfs:label "End Date/Time of Agent" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "32" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "The date/time when administration of the treatment indicated by AGTRT and the dosing variables ended." ;
    dc:identifier "AGENDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AG/AGENDY> a sdtmig:Variable ;
    rdfs:label "Study Day of End of Agent" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "34" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Study day of end of agent relative to the sponsor-defined RFSTDTC." ;
    dc:identifier "AGENDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AG/AGENRF> a sdtmig:Variable ;
    rdfs:label "End Relative to Reference Period" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66728> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "37" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Describes the end of the agent relative to the sponsor-defined reference period. The sponsor-defined reference period is a continuous period of time defined by a discrete starting point and a discrete ending point (represented by RFSTDTC and RFENDTC in Demographics). If information such as \"PRIOR\", \"ONGOING\", or \"CONTINUING\" was collected, this information may be translated into AGENRF. \\n Not all values of the codelist are allowable for this variable. See Section 4.4.7, Use of Relative Timing Variables." ;
    dc:identifier "AGENRF" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AG/AGENRTPT> a sdtmig:Variable ;
    rdfs:label "End Relative to Reference Time Point" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66728> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "40" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifies the end of the agent as being before or after the reference time point defined by variable AGENTPT. Identifies the end of the agent as being before or after the sponsor-defined reference time point defined by variable AGENTPT. \\n Not all values of the codelist are allowable for this variable. See Section 4.4.7, Use of Relative Timing Variables." ;
    dc:identifier "AGENRTPT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AG/AGENTPT> a sdtmig:Variable ;
    rdfs:label "End Reference Time Point" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "41" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Description or date/time in ISO 8601 character format of the reference point referred to by AGENRTPT. Examples: \"2003-12-25\", \"VISIT 2\"." ;
    dc:identifier "AGENTPT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AG/AGGRPID> a sdtmig:Variable ;
    rdfs:label "Group ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "5" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to tie together a block of related records in a single domain for a subject." ;
    dc:identifier "AGGRPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AG/AGLNKGRP> a sdtmig:Variable ;
    rdfs:label "Link Group ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "8" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifier used to link related records across domains.This will usually be a many-to-one relationship." ;
    dc:identifier "AGLNKGRP" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AG/AGLNKID> a sdtmig:Variable ;
    rdfs:label "Link ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "7" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifier used to link related records across domains.This may be a one-to-one or a one-to-many relationship." ;
    dc:identifier "AGLNKID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AG/AGMODIFY> a sdtmig:Variable ;
    rdfs:label "Modified Reported Name" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "10" ;
    sdtmig:role "Synonym Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "If AGTRT is modified to facilitate coding, then AGMODIFY will contain the modified text." ;
    dc:identifier "AGMODIFY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AG/AGOCCUR> a sdtmig:Variable ;
    rdfs:label "AG Occurrence" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "15" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "When the use of specific agent is solicited, AGOCCUR is used to indicate whether (\"Y\"/\"N\") use of the agent occurred. Values are null for agents not specifically solicited." ;
    dc:identifier "AGOCCUR" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AG/AGPRESP> a sdtmig:Variable ;
    rdfs:label "AG Pre-Specified" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "14" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to indicate whether (\"Y\"/null) information about the use of a specific agent was solicited on the CRF." ;
    dc:identifier "AGPRESP" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AG/AGREASND> a sdtmig:Variable ;
