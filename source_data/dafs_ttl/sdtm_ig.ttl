<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SS/SSCAT> a sdtmig:Variable ;
    rdfs:label "Category for Assessment" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "9" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to categorize observations across subjects." ;
    dc:identifier "SSCAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SS/SSDTC> a sdtmig:Variable ;
    rdfs:label "Date/Time of Assessment" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "21" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Date and time of the subject status assessment represented in ISO 8601 character format." ;
    dc:identifier "SSDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SS/SSDY> a sdtmig:Variable ;
    rdfs:label "Study Day of Assessment" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "22" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Study day of the subject status assessment, measured as integer days. Algorithm for calculations must be relative to the sponsor-defined RFSTDTC variable in Demographics." ;
    dc:identifier "SSDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SS/SSEVAL> a sdtmig:Variable ;
    rdfs:label "Evaluator" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C78735> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "15" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Role of the person who provided the evaluation. Used only for results that are subjective (e.g., assigned by a person or a group). Should be null for records that contain collected or derived data. Examples: \"CAREGIVER\", \"ADJUDICATION COMMITTEE\", \"FRIEND\"." ;
    dc:identifier "SSEVAL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SS/SSGRPID> a sdtmig:Variable ;
    rdfs:label "Group ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "5" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to tie together a block of related records in a single domain for a subject." ;
    dc:identifier "SSGRPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SS/SSORRES> a sdtmig:Variable ;
    rdfs:label "Result or Finding Original Result" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "11" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Result of the status assessment finding as originally received or collected." ;
    dc:identifier "SSORRES" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SS/SSREASND> a sdtmig:Variable ;
    rdfs:label "Reason Assessment Not Performed" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "14" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Describes why an assessment was not performed. Example: \"Subject refused\". Used in conjunction with SSSTAT when value is \"NOT DONE\"." ;
    dc:identifier "SSREASND" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SS/SSSCAT> a sdtmig:Variable ;
    rdfs:label "Subcategory for Assessment" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "10" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "A further categorization." ;
    dc:identifier "SSSCAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SS/SSSEQ> a sdtmig:Variable ;
    rdfs:label "Sequence Number" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "4" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Sequence number given to ensure uniqueness of subject records within a domain. May be any valid number." ;
    dc:identifier "SSSEQ" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SS/SSSPID> a sdtmig:Variable ;
    rdfs:label "Sponsor-Defined Identifier" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "6" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Sponsor-defined reference number. May be preprinted on the CRF as an explicit line identifier or defined in the sponsor\'s operational database. Example: Line number from the Procedure or Test page." ;
    dc:identifier "SSSPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SS/SSSTAT> a sdtmig:Variable ;
    rdfs:label "Completion Status" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66789> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "13" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to indicate a status assessment was not done. Should be null if a result exists in SSORRES." ;
    dc:identifier "SSSTAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SS/SSSTRESC> a sdtmig:Variable ;
    rdfs:label "Character Result/Finding in Std Format" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C124304> ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "12" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Contains the result value for all findings copied or derived from SSORRES, in a standard format." ;
    dc:identifier "SSSTRESC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SS/SSTEST> a sdtmig:Variable ;
    rdfs:label "Status Name" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C124306> ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "8" ;
    sdtmig:role "Synonym Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Verbatim name of the status assessment used to obtain the finding. The value in SSTEST cannot be longer than 40 characters. Example: \"Survival Status\"." ;
    dc:identifier "SSTEST" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SS/SSTESTCD> a sdtmig:Variable ;
    rdfs:label "Status Short Name" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C124305> ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "7" ;
    sdtmig:role "Topic" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Short name of the status assessment described in SSTEST. It can be used as a column name when converting a dataset from a vertical to a horizontal format. The value in SSTESTCD cannot be longer than 8 characters, nor can it start with a number (e.g., \"1TEST\" is not valid). SSTESTCD cannot contain characters other than letters, numbers, or underscores. Example: \"SURVSTAT\"." ;
    dc:identifier "SSTESTCD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SS/STUDYID> a sdtmig:Variable ;
    rdfs:label "Study Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "1" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Unique identifier for a study." ;
    dc:identifier "STUDYID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SS/TAETORD> a sdtmig:Variable ;
    rdfs:label "Planned Order of Element within Arm" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "19" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Number that gives the planned order of the element within the arm." ;
    dc:identifier "TAETORD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SS/USUBJID> a sdtmig:Variable ;
    rdfs:label "Unique Subject Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "3" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifier used to uniquely identify a subject across all studies for all applications or submissions involving the product." ;
    dc:identifier "USUBJID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SS/VISIT> a sdtmig:Variable ;
    rdfs:label "Visit Name" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "17" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Protocol-defined description of clinical encounter. May be used in addition to VISITNUM and/or VISITDY." ;
    dc:identifier "VISIT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SS/VISITDY> a sdtmig:Variable ;
    rdfs:label "Planned Study Day of Visit" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "18" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Planned study day of the visit based upon RFSTDTC in Demographics." ;
    dc:identifier "VISITDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SS/VISITNUM> a sdtmig:Variable ;
    rdfs:label "Visit Number" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "16" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Clinical encounter number. Numeric version of VISIT, used for sorting." ;
    dc:identifier "VISITNUM" .

