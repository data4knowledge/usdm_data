    dc:identifier "TSGRPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TS/TSPARM> a sdtmig:Variable ;
    rdfs:label "Trial Summary Parameter" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C67152> ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "6" ;
    sdtmig:role "Synonym Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Term for the trial summary parameter. The value in TSPARM cannot be longer than 40 characters. Examples: \"Planned Minimum Age of Subjects\", \"Planned Maximum Age of Subjects\"." ;
    dc:identifier "TSPARM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TS/TSPARMCD> a sdtmig:Variable ;
    rdfs:label "Trial Summary Parameter Short Name" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66738> ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "5" ;
    sdtmig:role "Topic" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "TSPARMCD (the companion to TSPARM) is limited to 8 characters and does not have special character restrictions. These values should be short for ease of use in programming, but it is not expected that TSPARMCD will need to serve as variable names. Examples: \"AGEMIN\", \"AGEMAX\"." ;
    dc:identifier "TSPARMCD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TS/TSSEQ> a sdtmig:Variable ;
    rdfs:label "Sequence Number" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "3" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Sequence number given to ensure uniqueness within a parameter. Allows inclusion of multiple records for the same TSPARMCD." ;
    dc:identifier "TSSEQ" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TS/TSVAL> a sdtmig:Variable ;
    rdfs:label "Parameter Value" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "7" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Value of TSPARM. Example: \"ASTHMA\" when TSPARM value is \"Trial Indication\". TSVAL can only be null when TSVALNF is populated. Text over 200 characters can be added to additional columns TSVAL1-TSVALn. See Assumption 8." ;
    dc:identifier "TSVAL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TS/TSVALCD> a sdtmig:Variable ;
    rdfs:label "Parameter Value Code" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "9" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "This is the code of the term in TSVAL. For example, \"6CW7F3G59X\" is the code for gabapentin; \"C49488\" is the code for Y. The length of this variable can be longer than 8 to accommodate the length of the external terminology." ;
    dc:identifier "TSVALCD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TS/TSVALNF> a sdtmig:Variable ;
    rdfs:label "Parameter Value Null Flavor" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "8" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 21090 NullFlavor" ;
    dc:description "Null flavor for the value of TSPARM, to be populated only if TSVAL is null." ;
    dc:identifier "TSVALNF" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TS/TSVCDREF> a sdtmig:Variable ;
    rdfs:label "Name of the Reference Terminology" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66788> ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "10" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "The name of the reference terminology from which TSVALCD is taken. For example; CDISC CT, SNOMED, ISO 8601." ;
    dc:identifier "TSVCDREF" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TS/TSVCDVER> a sdtmig:Variable ;
    rdfs:label "Version of the Reference Terminology" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "11" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "The version number of the reference terminology, if applicable." ;
    dc:identifier "TSVCDVER" .

