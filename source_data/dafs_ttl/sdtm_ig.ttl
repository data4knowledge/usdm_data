    dc:identifier "DOMAIN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PC/EPOCH> a sdtmig:Variable ;
    rdfs:label "Epoch" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C99079> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "31" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Epoch associated with the start date/time of the observation, or the date/time of collection if start date/time is not collected." ;
    dc:identifier "EPOCH" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PC/PCCAT> a sdtmig:Variable ;
    rdfs:label "Test Category" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "10" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to define a category of related records. Examples: \"ANALYTE\", \"SPECIMEN PROPERTY\"." ;
    dc:identifier "PCCAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PC/PCDRVFL> a sdtmig:Variable ;
    rdfs:label "Derived Flag" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "24" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to indicate a derived record. The value should be \"Y\" or null. Records that represent the average of other records, which do not come from the CRF, are examples of records that would be derived for the submission datasets. If PCDRVFL = \"Y\", then PCORRES may be null with PCSTRESC, and PCSTRESN (if the result is numeric) having the derived value." ;
    dc:identifier "PCDRVFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PC/PCDTC> a sdtmig:Variable ;
    rdfs:label "Date/Time of Specimen Collection" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "32" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Date/time of specimen collection represented in ISO 8601 character format. If there is no end time, then this will be the collection time." ;
    dc:identifier "PCDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PC/PCDY> a sdtmig:Variable ;
    rdfs:label "Actual Study Day of Specimen Collection" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "34" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Study day of specimen collection, measured as integer days. Algorithm for calculations must be relative to the sponsor-defined RFSTDTC variable in Demographics." ;
    dc:identifier "PCDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PC/PCELTM> a sdtmig:Variable ;
    rdfs:label "Planned Elapsed Time from Time Point Ref" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "38" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 duration" ;
    dc:description "Planned elapsed time (in ISO 8601) relative to a planned fixed reference (PCTPTREF; e.g., \"PREVIOUS DOSE\", \"PREVIOUS MEAL\"). This variable is useful where there are repetitive measures. Not a clock time or a date time variable." ;
    dc:identifier "PCELTM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PC/PCENDTC> a sdtmig:Variable ;
    rdfs:label "End Date/Time of Specimen Collection" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "33" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "End date/time of specimen collection represented in ISO 8601 character format. If there is no end time, the collection time should be stored in PCDTC, and PCENDTC should be null." ;
    dc:identifier "PCENDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PC/PCENDY> a sdtmig:Variable ;
    rdfs:label "Study Day of End of Observation" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "35" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Actual study day of end of observation expressed in integer days relative to the sponsor-defined RFSTDTC in Demographics." ;
    dc:identifier "PCENDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PC/PCEVLINT> a sdtmig:Variable ;
    rdfs:label "Evaluation Interval" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "41" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 duration or interval" ;
    dc:description "Evaluation Interval associated with a PCTEST record represented in ISO 8601 character format. Example: \"-PT2H\" to represent an evaluation interval of 2 hours prior to a PCTPT." ;
    dc:identifier "PCEVLINT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PC/PCFAST> a sdtmig:Variable ;
    rdfs:label "Fasting Status" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "23" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Indicator used to identify fasting status." ;
    dc:identifier "PCFAST" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PC/PCGRPID> a sdtmig:Variable ;
    rdfs:label "Group ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "5" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to tie together a block of related records in a single domain to support relationships within the domain and between domains." ;
    dc:identifier "PCGRPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PC/PCLLOQ> a sdtmig:Variable ;
    rdfs:label "Lower Limit of Quantitation" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "25" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Indicates the lower limit of quantitation for an assay. Units should be those used in PCSTRESU." ;
    dc:identifier "PCLLOQ" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PC/PCMETHOD> a sdtmig:Variable ;
    rdfs:label "Method of Test or Examination" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C85492> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "22" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Method of the test or examination. Examples: \"HPLC/MS\", \"ELISA\". This should contain sufficient information and granularity to allow differentiation of various methods that might have been used within a study." ;
    dc:identifier "PCMETHOD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PC/PCNAM> a sdtmig:Variable ;
    rdfs:label "Vendor Name" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "19" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Name or identifier of the laboratory or vendor who provides the test results." ;
    dc:identifier "PCNAM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PC/PCORRES> a sdtmig:Variable ;
    rdfs:label "Result or Finding in Original Units" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "12" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Result of the measurement or finding as originally received or collected." ;
    dc:identifier "PCORRES" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PC/PCORRESU> a sdtmig:Variable ;
    rdfs:label "Original Units" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C85494> ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "13" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Original units in which the data were collected. The unit for PCORRES. Example: \"mg/L\"." ;
    dc:identifier "PCORRESU" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PC/PCREASND> a sdtmig:Variable ;
    rdfs:label "Reason Test Not Done" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "18" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Describes why a result was not obtained, such as \"SPECIMEN LOST\". Used in conjunction with PCSTAT when value is \"NOT DONE\"." ;
    dc:identifier "PCREASND" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PC/PCREFID> a sdtmig:Variable ;
    rdfs:label "Reference ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "6" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Internal or external specimen identifier." ;
    dc:identifier "PCREFID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PC/PCRFTDTC> a sdtmig:Variable ;
    rdfs:label "Date/Time of Reference Point" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "40" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Date/time of the reference time point described by PCTPTREF." ;
    dc:identifier "PCRFTDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PC/PCSCAT> a sdtmig:Variable ;
    rdfs:label "Test Subcategory" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "11" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "A further categorization of a test category." ;
    dc:identifier "PCSCAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PC/PCSEQ> a sdtmig:Variable ;
    rdfs:label "Sequence Number" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "4" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Sequence number given to ensure uniqueness of subject records within a domain. May be any valid number." ;
    dc:identifier "PCSEQ" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PC/PCSPCCND> a sdtmig:Variable ;
    rdfs:label "Specimen Condition" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C78733> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "21" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Free or standardized text describing the condition of the specimen. Examples: \"HEMOLYZED\", \"ICTERIC\", \"LIPEMIC\"." ;
    dc:identifier "PCSPCCND" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PC/PCSPEC> a sdtmig:Variable ;
    rdfs:label "Specimen Material Type" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C78734> ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "20" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Defines the type of specimen used for a measurement. Examples: \"SERUM\", \"PLASMA\", \"URINE\"." ;
    dc:identifier "PCSPEC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PC/PCSPID> a sdtmig:Variable ;
    rdfs:label "Sponsor-Defined Identifier" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "7" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Sponsor-defined reference number." ;
    dc:identifier "PCSPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PC/PCSTAT> a sdtmig:Variable ;
    rdfs:label "Completion Status" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66789> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "17" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to indicate a result was not obtained. Should be null if a result exists in PCORRES." ;
    dc:identifier "PCSTAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PC/PCSTRESC> a sdtmig:Variable ;
    rdfs:label "Character Result/Finding in Std Format" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "14" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Contains the result value for all findings, copied or derived from PCORRES in a standard format or standard units. PCSTRESC should store all results or findings in character format; if results are numeric, they should also be stored in numeric format in PCSTRESN. For example, if a test has results \"NONE\", \"NEG\", and \"NEGATIVE\" in PCORRES, and these results effectively have the same meaning, they could be represented in standard format in PCSTRESC as \"NEGATIVE\". For other examples, see general assumptions." ;
    dc:identifier "PCSTRESC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PC/PCSTRESN> a sdtmig:Variable ;
    rdfs:label "Numeric Result/Finding in Standard Units" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "15" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Used for continuous or numeric results or findings in standard format; copied in numeric format from PCSTRESC. PCSTRESN should store all numeric test results or findings." ;
    dc:identifier "PCSTRESN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PC/PCSTRESU> a sdtmig:Variable ;
    rdfs:label "Standard Units" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C85494> ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "16" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Standardized unit used for PCSTRESC and PCSTRESN." ;
    dc:identifier "PCSTRESU" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PC/PCTEST> a sdtmig:Variable ;
    rdfs:label "Pharmacokinetic Test Name" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "9" ;
    sdtmig:role "Synonym Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Name of the analyte or specimen characteristic. Note any test normally performed by a clinical laboratory is considered a lab test. The value in PCTEST cannot be longer than 40 characters. Examples: \"Acetylsalicylic Acid\", \"Volume\", \"Specific Gravity\"." ;
    dc:identifier "PCTEST" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PC/PCTESTCD> a sdtmig:Variable ;
    rdfs:label "Pharmacokinetic Test Short Name" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "8" ;
    sdtmig:role "Topic" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Short name of the analyte or specimen characteristic. It can be used as a column name when converting a dataset from a vertical to a horizontal format. The value in PCTESTCD cannot be longer than 8 characters, nor can it start with a number (e.g., \"1TEST\" is not valid). PCTESTCD cannot contain characters other than letters, numbers, or underscores. Examples: \"ASA\", \"VOL\", \"SPG\"." ;
    dc:identifier "PCTESTCD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PC/PCTPT> a sdtmig:Variable ;
    rdfs:label "Planned Time Point Name" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "36" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Text description of time when specimen should be taken. This may be represented as an elapsed time relative to a fixed reference point, such as time of last dose. See PCTPTNUM and PCTPTREF. Examples: \"Start\", \"5 min post\"." ;
    dc:identifier "PCTPT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PC/PCTPTNUM> a sdtmig:Variable ;
    rdfs:label "Planned Time Point Number" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "37" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Numerical version of PCTPT to aid in sorting." ;
    dc:identifier "PCTPTNUM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PC/PCTPTREF> a sdtmig:Variable ;
    rdfs:label "Time Point Reference" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "39" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Name of the fixed reference point used as a basis for PCTPT, PCTPTNUM, and PCELTM. Example: \"MOST RECENT DOSE\"." ;
    dc:identifier "PCTPTREF" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PC/PCULOQ> a sdtmig:Variable ;
    rdfs:label "Upper Limit of Quantitation" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "26" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Indicates the upper limit of quantitation for an assay. Units should be those used in PCSTRESU." ;
    dc:identifier "PCULOQ" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PC/STUDYID> a sdtmig:Variable ;
    rdfs:label "Study Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "1" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Unique identifier for a study." ;
    dc:identifier "STUDYID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PC/TAETORD> a sdtmig:Variable ;
    rdfs:label "Planned Order of Element within Arm" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "30" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Number that gives the planned order of the element within the arm." ;
    dc:identifier "TAETORD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PC/USUBJID> a sdtmig:Variable ;
    rdfs:label "Unique Subject Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "3" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifier used to uniquely identify a subject across all studies for all applications or submissions involving the product." ;
    dc:identifier "USUBJID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PC/VISIT> a sdtmig:Variable ;
    rdfs:label "Visit Name" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "28" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Protocol-defined description of clinical encounter. May be used in addition to VISITNUM and/or VISITDY." ;
    dc:identifier "VISIT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PC/VISITDY> a sdtmig:Variable ;
    rdfs:label "Planned Study Day of Visit" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "29" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Planned study day of the visit based upon RFSTDTC in Demographics." ;
    dc:identifier "VISITDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PC/VISITNUM> a sdtmig:Variable ;
    rdfs:label "Visit Number" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "27" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Clinical encounter number. Numeric version of VISIT, used for sorting." ;
    dc:identifier "VISITNUM" .

