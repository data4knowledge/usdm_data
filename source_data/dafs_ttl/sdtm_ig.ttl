        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RP/VISITDY>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RP/VISITNUM> ;
    sdtmig:ordinal "43" ;
    sdtmig:structure "One record per finding or result per time point per visit per subject" ;
