        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TU/TUREFID>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TU/TUSEQ>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TU/TUSPID>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TU/TUSTRESC>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TU/TUTEST>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TU/TUTESTCD>,
