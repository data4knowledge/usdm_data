    sdtmig:core "Perm" ;
    sdtmig:ordinal "6" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Internal or external specimen identifier. Example: \"Specimen ID\"." ;
    dc:identifier "SRREFID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SR/SRRFTDTC> a sdtmig:Variable ;
