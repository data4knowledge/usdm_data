<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MB/DOMAIN> a sdtmig:Variable ;
    rdfs:label "Domain Abbreviation" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "2" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Two-character abbreviation for the domain." ;
    dc:identifier "DOMAIN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MB/EPOCH> a sdtmig:Variable ;
    rdfs:label "Epoch" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C99079> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "40" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Epoch associated with the date/time at which the specimen was collected." ;
    dc:identifier "EPOCH" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MB/FOCID> a sdtmig:Variable ;
    rdfs:label "Focus of Study-Specific Interest" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "4" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identification of a focus of study-specific interest on or within a subject or specimen as called out in the protocol for which a measurement, test, or examination was performed. The value in this variable should have inherent semantic meaning." ;
    dc:identifier "FOCID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MB/MBBLFL> a sdtmig:Variable ;
    rdfs:label "Baseline Flag" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "33" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Indicator used to identify a baseline value. Should be \"Y\" or null. Note that MBBLFL is retained for backward compatibility. The authoritative baseline for statistical analysis is in an ADaM dataset." ;
    dc:identifier "MBBLFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MB/MBCAT> a sdtmig:Variable ;
    rdfs:label "Category" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "14" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to define a category of related records." ;
    dc:identifier "MBCAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MB/MBDIR> a sdtmig:Variable ;
    rdfs:label "Directionality" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C99074> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "30" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Qualifier for specimen collection location further detailing directionality. Examples: \"ANTERIOR\", \"LOWER\", \"PROXIMAL\"." ;
    dc:identifier "MBDIR" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MB/MBDRVFL> a sdtmig:Variable ;
    rdfs:label "Derived Flag" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "35" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to indicate a derived record (e.g., a record that represents the average of other records such as a computed baseline). Should be \"Y\" or null." ;
    dc:identifier "MBDRVFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MB/MBDTC> a sdtmig:Variable ;
    rdfs:label "Date/Time of Collection" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "41" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Date/time of specimen collection." ;
    dc:identifier "MBDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MB/MBDY> a sdtmig:Variable ;
    rdfs:label "Study Day of Visit/Collection/Exam" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "42" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Study day of the specimen collection, measured as integer days. Algorithm for calculations must be relative to the sponsor-defined RFSTDTC variable in Demographics. This formula should be consistent across the submission." ;
    dc:identifier "MBDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MB/MBELTM> a sdtmig:Variable ;
    rdfs:label "Planned Elapsed Time from Time Point Ref" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "45" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 duration" ;
    dc:description "Planned elapsed time (in ISO 8601) relative to a planned fixed reference (MBTPTREF). This variable is useful where there are repetitive measures. Not a clock time or a date time variable. Represented as an ISO 8601 duration. Examples: \"-PT15M\" to represent the period of 15 minutes prior to the reference point indicated by MBTPTREF, or \"PT8H\" to represent the period of 8 hours after the reference point indicated by MBTPTREF." ;
    dc:identifier "MBELTM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MB/MBFAST> a sdtmig:Variable ;
    rdfs:label "Fasting Status" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "34" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Indicator used to identify fasting status. Valid values include \"Y\", \"N\", \"U\", or null if not relevant." ;
    dc:identifier "MBFAST" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MB/MBGRPID> a sdtmig:Variable ;
    rdfs:label "Group ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "6" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Optional group identifier, used to link together a block of related records within a subject in a domain." ;
    dc:identifier "MBGRPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MB/MBLAT> a sdtmig:Variable ;
    rdfs:label "Laterality" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C99073> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "29" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Qualifier for specimen collection location further detailing laterality. Examples: \"RIGHT\", \"LEFT\", \"BILATERAL\"." ;
    dc:identifier "MBLAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MB/MBLNKGRP> a sdtmig:Variable ;
    rdfs:label "Link Group ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "10" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifier used to link related records across domains. This will usually be a many-to-one relationship." ;
    dc:identifier "MBLNKGRP" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MB/MBLNKID> a sdtmig:Variable ;
    rdfs:label "Link ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "9" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifier used to link related records across domains. This may be a one-to-one or a one-to-many relationship. For example, it may be used to link genetic findings (in the PF domain) about a microbe to the original culture of that microbe (in MB), or to susceptibility records (in MS) if needed." ;
    dc:identifier "MBLNKID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MB/MBLOBXFL> a sdtmig:Variable ;
    rdfs:label "Last Observation Before Exposure Flag" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "32" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Operationally derived indicator used to identify the last non-missing value prior to RFXSTDTC. The value should be \"Y\" or null." ;
    dc:identifier "MBLOBXFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MB/MBLOC> a sdtmig:Variable ;
    rdfs:label "Specimen Collection Location" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C74456> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "28" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Anatomical location relevant to the collection of the measurement." ;
    dc:identifier "MBLOC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MB/MBLOINC> a sdtmig:Variable ;
    rdfs:label "LOINC Code" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "25" ;
    sdtmig:role "Synonym Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Logical Observation Identifiers Names and Codes (LOINC) code for the topic variable (e.g., lab test)." ;
    dc:identifier "MBLOINC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MB/MBMETHOD> a sdtmig:Variable ;
    rdfs:label "Method of Test or Examination" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C85492> ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "31" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Method of the test or examination. Examples: \"GRAM STAIN\", \"MICROBIAL CULTURE, LIQUID\", \"QUANTITATIVE REVERSE TRANSCRIPTASE POLYMERASE CHAIN REACTION\"." ;
    dc:identifier "MBMETHOD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MB/MBNAM> a sdtmig:Variable ;
    rdfs:label "Laboratory/Vendor Name" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "24" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Name or identifier of the vendor (e.g., laboratory) that provided the test results." ;
    dc:identifier "MBNAM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MB/MBORRES> a sdtmig:Variable ;
    rdfs:label "Result or Finding in Original Units" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "16" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Result of the microbiology measurement or finding as originally received or collected. Examples for \"GRAM STAIN\" findings: \"+3 MODERATE\", \"+2 FEW\", \"<10\". Examples for \"CULTURE PLATE\" findings: \"KLEBSIELLA PNEUMONIAE\", \"STREPTOCOCCUS PNEUMONIAE\"." ;
    dc:identifier "MBORRES" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MB/MBORRESU> a sdtmig:Variable ;
    rdfs:label "Original Units" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C71620> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "17" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Original unit for MBORRES. Example: \"mcg/mL\"." ;
    dc:identifier "MBORRESU" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MB/MBREASND> a sdtmig:Variable ;
    rdfs:label "Reason Not Done" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "23" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Reason not done. Used in conjunction with MBSTAT when value is NOT DONE. Examples: \"BROKEN EQUIPMENT\", \"SUBJECT REFUSED\"." ;
    dc:identifier "MBREASND" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MB/MBREFID> a sdtmig:Variable ;
    rdfs:label "Reference ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "7" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Internal or external specimen identifier (e.g., sample ID for a subject sample from which a microbial culture was generated)." ;
    dc:identifier "MBREFID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MB/MBRESCAT> a sdtmig:Variable ;
    rdfs:label "Result Category" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "21" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to categorize the result of a finding in a standard format." ;
    dc:identifier "MBRESCAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MB/MBRFTDTC> a sdtmig:Variable ;
    rdfs:label "Date/Time of Reference Time Point" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "47" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Date/time for a fixed reference time point, MBTPTREF." ;
    dc:identifier "MBRFTDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MB/MBSCAT> a sdtmig:Variable ;
    rdfs:label "Subcategory" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "15" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to define a further categorization of MBCAT values." ;
    dc:identifier "MBSCAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MB/MBSEQ> a sdtmig:Variable ;
    rdfs:label "Sequence Number" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "5" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Sequence number to ensure uniqueness of records within a dataset for a subject. May be any valid number." ;
    dc:identifier "MBSEQ" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MB/MBSPCCND> a sdtmig:Variable ;
    rdfs:label "Specimen Condition" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C78733> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "27" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Free or standardized text describing the condition of the specimen. Example: \"CONTAMINATED\"." ;
    dc:identifier "MBSPCCND" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MB/MBSPEC> a sdtmig:Variable ;
    rdfs:label "Specimen Material Type" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C78734> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "26" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Defines the type of specimen used for a measurement. Examples: \"SPUTUM\", \"BLOOD\", \"PUS\"." ;
    dc:identifier "MBSPEC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MB/MBSPID> a sdtmig:Variable ;
    rdfs:label "Sponsor-Defined Identifier" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "8" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Sponsor-defined reference number. May be preprinted on the CRF as an explicit line identifier or defined in the sponsor\'s operational database." ;
    dc:identifier "MBSPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MB/MBSTAT> a sdtmig:Variable ;
    rdfs:label "Completion Status" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66789> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "22" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to indicate that a question was not asked or a test was not done, or that a test was attempted but did not generate a result. Should be null or have a value of \"NOT DONE\"." ;
    dc:identifier "MBSTAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MB/MBSTRESC> a sdtmig:Variable ;
    rdfs:label "Result or Finding in Standard Format" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "18" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Contains the result value for all findings copied or derived from MBORRES, in a standard format or standard units. MBSTRESC should store all results or findings in character format; if results are numeric, they should also be stored in numeric format in MBSTRESN. For example, if a test has results \"+3 MODERATE\", \"MOD\", and \"MODERATE\" in MBORRES and these results effectively have the same meaning, they could be represented in standard format in MBSTRESC as \"MODERATE\"." ;
    dc:identifier "MBSTRESC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MB/MBSTRESN> a sdtmig:Variable ;
    rdfs:label "Numeric Result/Finding in Standard Units" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "19" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Used for continuous or numeric results or findings in standard format; copied in numeric format from MBSTRESC. MBSTRESN should store all numeric test results or findings." ;
    dc:identifier "MBSTRESN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MB/MBSTRESU> a sdtmig:Variable ;
    rdfs:label "Standard Units" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C71620> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "20" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Standardized units used for MBSTRESC and MBSTRESN." ;
    dc:identifier "MBSTRESU" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MB/MBTEST> a sdtmig:Variable ;
    rdfs:label "Microbiology Test or Finding Name" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C120528> ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "12" ;
    sdtmig:role "Synonym Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Verbatim name of the test or examination used to obtain the measurement or finding. The value in MBTEST cannot be longer than 40 characters. Examples: \"Microbial Organism Identification\", \"Gram Negative Cocci\", \"HIV-1 RNA\"." ;
    dc:identifier "MBTEST" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MB/MBTESTCD> a sdtmig:Variable ;
    rdfs:label "Microbiology Test or Finding Short Name" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C120527> ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "11" ;
    sdtmig:role "Topic" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Short name of the measurement, test, or finding described in MBTEST. It can be used as a column name when converting a dataset from a vertical to a horizontal format. The value in MBTESTCD cannot be longer than 8 characters, nor can it start with a number (e.g., \"1TEST\" is not valid). MBTESTCD cannot contain characters other than letters, numbers, or underscores. Examples: \"MCORGIDN\" for Microbial Organism Identification \"GMNCOC\" for Gram Negative Cocci." ;
    dc:identifier "MBTESTCD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MB/MBTPT> a sdtmig:Variable ;
    rdfs:label "Planned Time Point Name" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "43" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Text description of time when specimen should be taken. This may be represented as an elapsed time relative to a fixed reference point, such as time of last dose. See MBTPTNUM and MBTPTREF. Examples: \"Start\", \"5 min post\"." ;
    dc:identifier "MBTPT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MB/MBTPTNUM> a sdtmig:Variable ;
    rdfs:label "Planned Time Point Number" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "44" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Numeric version of MBTPT used in sorting." ;
    dc:identifier "MBTPTNUM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MB/MBTPTREF> a sdtmig:Variable ;
    rdfs:label "Time Point Reference" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "46" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Name of the fixed reference point referred to by MBELTM, MBTPTNUM, and MBTPT. Example: \"PREVIOUS DOSE\"." ;
    dc:identifier "MBTPTREF" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MB/MBTSTDTL> a sdtmig:Variable ;
    rdfs:label "Measurement, Test or Examination Detail" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C174225> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "13" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Further description of MBTESTCD and MBTEST. Example: \"VIRAL LOAD\" when MBTESTCD represents viral genetic material, such as \"HCRNA\", \"QUANTIFICATION\" when MBTESTCD represents any organism being quantified." ;
    dc:identifier "MBTSTDTL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MB/STUDYID> a sdtmig:Variable ;
    rdfs:label "Study Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "1" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Unique identifier for a study." ;
    dc:identifier "STUDYID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MB/TAETORD> a sdtmig:Variable ;
    rdfs:label "Planned Order of Element within Arm" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "39" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Number that gives the planned order of the element within the arm for the element which the specimen collection occurred." ;
    dc:identifier "TAETORD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MB/USUBJID> a sdtmig:Variable ;
    rdfs:label "Unique Subject Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "3" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifier used to uniquely identify a subject across all studies for all applications or submissions involving the product." ;
    dc:identifier "USUBJID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MB/VISIT> a sdtmig:Variable ;
    rdfs:label "Visit Name" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "37" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Protocol-defined description of a clinical encounter." ;
    dc:identifier "VISIT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MB/VISITDY> a sdtmig:Variable ;
    rdfs:label "Planned Study Day of Visit" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "38" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Planned study day of VISIT. Should be an integer." ;
    dc:identifier "VISITDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MB/VISITNUM> a sdtmig:Variable ;
    rdfs:label "Visit Number" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "36" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Clinical encounter number. Numeric version of VISIT, used for sorting." ;
    dc:identifier "VISITNUM" .

