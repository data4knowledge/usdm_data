<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RP/DOMAIN> a sdtmig:Variable ;
    rdfs:label "Domain Abbreviation" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "2" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Two-character abbreviation for the domain." ;
    dc:identifier "DOMAIN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RP/EPOCH> a sdtmig:Variable ;
    rdfs:label "Epoch" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C99079> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "28" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Epoch associated with the date/time at which the assessment was made." ;
    dc:identifier "EPOCH" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RP/RPBLFL> a sdtmig:Variable ;
    rdfs:label "Baseline Flag" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "22" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Indicator used to identify a baseline value. Should be \"Y\" or null. Note that RPBLFL is retained for backward compatibility. The authoritative baseline for statistical analysis is in an ADaM dataset." ;
    dc:identifier "RPBLFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RP/RPCAT> a sdtmig:Variable ;
    rdfs:label "Category for Reproductive Test" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "12" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to define a category of topic-variable values. Example: \"No use case to date, but values would be relative to reproduction tests grouping\"." ;
    dc:identifier "RPCAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RP/RPDRVFL> a sdtmig:Variable ;
    rdfs:label "Derived Flag" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "23" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to indicate a derived record. The value should be \"Y\" or null. Records which represent the average of other records or which do not come from the CRF are examples of records that would be derived for the submission datasets. If RPDRVFL = \"Y\", then RPORRES may be null, with RPSTRESC and (if numeric) RPSTRESN having the derived value." ;
    dc:identifier "RPDRVFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RP/RPDTC> a sdtmig:Variable ;
    rdfs:label "Date/Time of Collection" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "29" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Collection date and time of an observation." ;
    dc:identifier "RPDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RP/RPDUR> a sdtmig:Variable ;
    rdfs:label "Duration" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "31" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 duration" ;
    dc:description "Collected duration of an event, intervention, or finding represented in ISO 8601 character format. Used only if collected on the CRF and not derived." ;
    dc:identifier "RPDUR" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RP/RPDY> a sdtmig:Variable ;
    rdfs:label "Study Day of Visit/Collection/Exam" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "30" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Actual study day of visit/collection/exam expressed in integer days relative to the sponsor-defined RFSTDTC in Demographics." ;
    dc:identifier "RPDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RP/RPELTM> a sdtmig:Variable ;
    rdfs:label "Planned Elapsed Time from Time Point Ref" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "34" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 duration" ;
    dc:description "Planned elapsed time in ISO 8601 character format relative to a planned fixed reference (RPTPTREF; e.g., \"PREVIOUS DOSE\", \"PREVIOUS MEAL\"). This variable is useful where there are repetitive measures. Not a clock time or a date/time variable, but an interval, represented as ISO duration." ;
    dc:identifier "RPELTM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RP/RPGRPID> a sdtmig:Variable ;
    rdfs:label "Group ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "5" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Optional group identifier, used to link together a block of related records within a subject in a domain. Also used to link together a block of related records in the Trial Summary dataset." ;
    dc:identifier "RPGRPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RP/RPLNKGRP> a sdtmig:Variable ;
    rdfs:label "Link Group ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "9" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifier used to link related records across domains. This will usually be a many-to-one relationship." ;
    dc:identifier "RPLNKGRP" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RP/RPLNKID> a sdtmig:Variable ;
    rdfs:label "Link ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "8" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifier used to link related records across domains. This may be a one-to-one or a one-to-many relationship." ;
    dc:identifier "RPLNKID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RP/RPLOBXFL> a sdtmig:Variable ;
    rdfs:label "Last Observation Before Exposure Flag" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "21" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Operationally derived indicator used to identify the last non-missing value prior to RFXSTDTC. The value should be \"Y\" or null." ;
    dc:identifier "RPLOBXFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RP/RPORRES> a sdtmig:Variable ;
    rdfs:label "Result or Finding in Original Units" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "14" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Result of the measurement or finding as originally received or collected. Examples: \"120\", \"<1\", \"POS\"." ;
    dc:identifier "RPORRES" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RP/RPORRESU> a sdtmig:Variable ;
    rdfs:label "Original Units" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C71620> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "15" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Unit for RPORRES. Examples: \"in\", \"LB\", \"kg/L\"." ;
    dc:identifier "RPORRESU" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RP/RPREASND> a sdtmig:Variable ;
    rdfs:label "Reason Not Done" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "20" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Reason not done. Used in conjunction with RPSTAT when value is \"NOT DONE\"." ;
    dc:identifier "RPREASND" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RP/RPREFID> a sdtmig:Variable ;
    rdfs:label "Reference ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "6" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Optional internal or external identifier (e.g., lab specimen ID, UUID for an ECG waveform or a medical image)." ;
    dc:identifier "RPREFID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RP/RPRFTDTC> a sdtmig:Variable ;
    rdfs:label "Date/Time of Reference Time Point" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "36" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Date/time for a fixed reference time point defined by RPTPTREF in ISO 8601 character format." ;
    dc:identifier "RPRFTDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RP/RPSCAT> a sdtmig:Variable ;
    rdfs:label "Subcategory for Reproductive Test" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "13" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to define a further categorization of RPCAT values. Example: \"No use case to date, but values would be relative to reproduction tests grouping\"." ;
    dc:identifier "RPSCAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RP/RPSEQ> a sdtmig:Variable ;
    rdfs:label "Sequence Number" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "4" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Sequence number to ensure uniqueness of records within a dataset for a subject (or within a parameter, in the case of the Trial Summary domain). May be any valid number (including decimals) and does not have to start at 1." ;
    dc:identifier "RPSEQ" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RP/RPSPID> a sdtmig:Variable ;
    rdfs:label "Sponsor-Defined Identifier" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "7" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Sponsor-defined identifier. Example: Preprinted line identifier on a CRF." ;
    dc:identifier "RPSPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RP/RPSTAT> a sdtmig:Variable ;
    rdfs:label "Completion Status" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66789> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "19" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to indicate that a question was not asked or a test was not done, or a test was attempted but did not generate a result. Should be null or have a value of \"NOT DONE\"." ;
    dc:identifier "RPSTAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RP/RPSTRESC> a sdtmig:Variable ;
    rdfs:label "Character Result/Finding in Std Format" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "16" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Contains the result value for all findings copied or derived from RPORRES, in a standard format or in standard units. RPSTRESC should store all results or findings in character format; if results are numeric, they should also be stored in numeric format in RPSTRESN. For example, if various tests have results \"NONE\", \"NEG\", and \"NEGATIVE\" in RPORRES, and these results effectively have the same meaning, they could be represented in standard format in RPSTRESC as \"NEGATIVE\"." ;
    dc:identifier "RPSTRESC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RP/RPSTRESN> a sdtmig:Variable ;
    rdfs:label "Numeric Result/Finding in Standard Units" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "17" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Used for continuous or numeric results or findings in standard format; copied in numeric format from RPSTRESC. RPSTRESN should store all numeric test results or findings." ;
    dc:identifier "RPSTRESN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RP/RPSTRESU> a sdtmig:Variable ;
    rdfs:label "Standard Units" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C71620> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "18" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Standardized units used for RPSTRESC and RPSTRESN. Example: \"mol/L\"." ;
    dc:identifier "RPSTRESU" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RP/RPTEST> a sdtmig:Variable ;
    rdfs:label "Name of Reproductive Test" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C106478> ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "11" ;
    sdtmig:role "Synonym Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Long name For RPTESTCD. Examples: \"Childbearing Potential\", \"Birth Control Method\", \"Menarche Age\"." ;
    dc:identifier "RPTEST" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RP/RPTESTCD> a sdtmig:Variable ;
    rdfs:label "Short Name of Reproductive Test" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C106479> ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "10" ;
    sdtmig:role "Topic" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Short character value for RPTEST used as a column name when converting a dataset from a vertical format to a horizontal format. The short value can be up to 8 characters. Examples: \"CHILDPOT\", \"BCMETHOD\", \"MENARAGE\"." ;
    dc:identifier "RPTESTCD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RP/RPTPT> a sdtmig:Variable ;
    rdfs:label "Planned Time Point Name" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "32" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Text description of time when a measurement or observation should be taken as defined in the protocol. This may be represented as an elapsed time relative to a fixed reference point, such as time of last dose." ;
    dc:identifier "RPTPT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RP/RPTPTNUM> a sdtmig:Variable ;
    rdfs:label "Planned Time Point Number" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "33" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Numeric version of planned time point used in sorting." ;
    dc:identifier "RPTPTNUM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RP/RPTPTREF> a sdtmig:Variable ;
