<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IS/DOMAIN> a sdtmig:Variable ;
    rdfs:label "Domain Abbreviation" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "2" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Two-character abbreviation for the domain." ;
    dc:identifier "DOMAIN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IS/EPOCH> a sdtmig:Variable ;
    rdfs:label "Epoch" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C99079> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "45" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Epoch associated with the start date/time of the observation, or the date/time of collection if start date/time is not collected." ;
    dc:identifier "EPOCH" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IS/ISBDAGNT> a sdtmig:Variable ;
    rdfs:label "Binding Agent" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C85491> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "13" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Text description of the agent that is binding to the entity in the ISTEST variable. ISBDAGNT is used to indicate that there is a binding relationship between the entities in the ISTEST and ISBDAGNT variables, regardless of direction. \\n ISBDAGNT is not a method qualifier. It should only be used when the actual interest of the measurement is the binding interaction between the 2 entities in ISTEST and ISBDAGNT. In other words, the combination of ISTEST and ISBDAGNT should describe the entity or the analyte being measured, without the need for additional variables. \\n The binding agent may be (but is not limited to) a test article, a portion of the test article, a related compound, an endogenous molecule, an allergen, or an infectious agent." ;
    dc:identifier "ISBDAGNT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IS/ISBLFL> a sdtmig:Variable ;
    rdfs:label "Baseline Flag" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "38" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Indicator used to identify a baseline value. Should be \"Y\" or null. Note that ISBLFL is retained for backward compatibility. The authoritative baseline for statistical analysis is in an ADaM dataset." ;
    dc:identifier "ISBLFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IS/ISCAT> a sdtmig:Variable ;
    rdfs:label "Category for Immunogenicity Test" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "17" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to define a category of topic-variable values across subjects. Example: \"SEROLOGY\"." ;
    dc:identifier "ISCAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IS/ISCNDAGT> a sdtmig:Variable ;
    rdfs:label "Test Condition Agent" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "12" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "The textual description of the agent used to impose a test condition. Examples are different stimulating agents used in immunoassays such as those in the Interferon Gamma Response assay (e.g., Mycobacterium tuberculosis ESAT-6, CFP-10, TB 7.7, Mitogen)." ;
    dc:identifier "ISCNDAGT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IS/ISDRVFL> a sdtmig:Variable ;
    rdfs:label "Derived Flag" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "39" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to indicate a derived record. The value should be \"Y\" or null. Examples of records that might be derived for the submission datasets include those that represent the average of other records, do not come from the CRF, or are not as originally received or collected. If ISDRVFL=\"Y\", then ISORRES may be null, with ISSTRESC and (if numeric) ISSTRESN having the derived value." ;
    dc:identifier "ISDRVFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IS/ISDTC> a sdtmig:Variable ;
    rdfs:label "Date/Time of Collection" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "46" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Collection date and time of an observation." ;
    dc:identifier "ISDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IS/ISDY> a sdtmig:Variable ;
    rdfs:label "Study Day of Visit/Collection/Exam" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "48" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Actual study day of visit/collection/exam expressed in integer days relative to sponsor-defined RFSTDTC in Demographics." ;
    dc:identifier "ISDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IS/ISELTM> a sdtmig:Variable ;
    rdfs:label "Planned Elapsed Time from Time Point Ref" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "52" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 duration" ;
    dc:description "Planned elapsed time (in ISO 8601) relative to a planned fixed reference (ISTPTREF). This variable is useful where there are repetitive measures. Not a clock time or a date/time variable. Represented as ISO 8601 duration. Examples: \"-PT15M\" to represent the period of 15 minutes prior to the reference point indicated by ISTPTREF, \"PT8H\" to represent the period of 8 hours after the reference point indicated by ISTPTREF." ;
    dc:identifier "ISELTM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IS/ISENDTC> a sdtmig:Variable ;
    rdfs:label "End Date/Time of Specimen Collection" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "47" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "End date/time of the observation." ;
    dc:identifier "ISENDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IS/ISENDY> a sdtmig:Variable ;
    rdfs:label "Study Day of End of Specimen Collection" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "49" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Actual study day of end of observation expressed in integer days relative to the sponsor-defined RFSTDTC in Demographics." ;
    dc:identifier "ISENDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IS/ISGRPID> a sdtmig:Variable ;
    rdfs:label "Group ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "6" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to tie together a block of related records in a single domain for a subject." ;
    dc:identifier "ISGRPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IS/ISLLOQ> a sdtmig:Variable ;
    rdfs:label "Lower Limit of Quantitation" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "40" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Indicates the lower limit of quantitation for an assay. Units will be those used for ISSTRESU." ;
    dc:identifier "ISLLOQ" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IS/ISLOBXFL> a sdtmig:Variable ;
    rdfs:label "Last Observation Before Exposure Flag" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "37" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Operationally derived indicator used to identify the last non-missing value prior to RFXSTDTC. The value should be \"Y\" or null." ;
    dc:identifier "ISLOBXFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IS/ISMETHOD> a sdtmig:Variable ;
    rdfs:label "Method of Test or Examination" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C85492> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "36" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Method of the test or examination. Examples: \"ELISA\", \"ELISPOT\"." ;
    dc:identifier "ISMETHOD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IS/ISMSCBCE> a sdtmig:Variable ;
    rdfs:label "Molecule Secreted by Cells" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "15" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Text description of the entity secreted by the cells represented in ISTEST. The combination of ISTEST and ISMSCBCE should describe the entity or the analyte being measured, without the need for additional variables." ;
    dc:identifier "ISMSCBCE" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IS/ISNAM> a sdtmig:Variable ;
    rdfs:label "Vendor Name" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "32" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Name or identifier of the laboratory or vendor who provided the test results." ;
    dc:identifier "ISNAM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IS/ISNRIND> a sdtmig:Variable ;
    rdfs:label "Reference Range Indicator" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C78736> ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "29" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Indicates where the value falls with respect to reference range defined by ISORNRLO and ISORNRHI, ISSTNRLO and ISSTNRHI, or by ISSTNRC. Examples: \"NORMAL\", \"ABNORMAL\", \"HIGH\", \"LOW\". \\n Sponsors should specify in the study metadata (Comments column in the Define-XML document) whether ISNRIND refers to the original or standard reference ranges and results. \\n Should not be used to indicate clinical significance." ;
    dc:identifier "ISNRIND" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IS/ISORNRHI> a sdtmig:Variable ;
    rdfs:label "Reference Range Upper Limit in Orig Unit" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "22" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Upper end of reference range for continuous measurement in original units. Should be populated only for continuous results." ;
    dc:identifier "ISORNRHI" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IS/ISORNRLO> a sdtmig:Variable ;
    rdfs:label "Reference Range Lower Limit in Orig Unit" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "21" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Lower end of reference range for continuous measurement in original units. Should be populated only for continuous results." ;
    dc:identifier "ISORNRLO" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IS/ISORRES> a sdtmig:Variable ;
    rdfs:label "Results or Findings in Original Units" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "19" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Result of the measurement or finding as originally received or collected." ;
    dc:identifier "ISORRES" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IS/ISORRESU> a sdtmig:Variable ;
    rdfs:label "Original Units" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C71620> ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "20" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Original units in which the data were collected. The unit for ISORRES. Examples: \"Index Value\", \"gpELISA\", \"unit/mL\"." ;
    dc:identifier "ISORRESU" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IS/ISREASND> a sdtmig:Variable ;
    rdfs:label "Reason Not Done" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "31" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Describes why a measurement or test was not performed. Used in conjunction with ISSTAT when value is \"NOT DONE\"." ;
    dc:identifier "ISREASND" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IS/ISREFID> a sdtmig:Variable ;
    rdfs:label "Reference ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "7" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Internal or external specimen identifier. Example: \"458975-01\"." ;
    dc:identifier "ISREFID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IS/ISRFTDTC> a sdtmig:Variable ;
    rdfs:label "Date/Time of Reference Time Point" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "54" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Date/time of the reference time point, ISTPTREF." ;
    dc:identifier "ISRFTDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IS/ISSCAT> a sdtmig:Variable ;
    rdfs:label "Subcategory for Immunogenicity Test" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "18" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "A further categorization of ISCAT." ;
    dc:identifier "ISSCAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IS/ISSEQ> a sdtmig:Variable ;
    rdfs:label "Sequence Number" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "5" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Sequence number to ensure uniqueness of records within a dataset for a subject. May be any valid number (including decimals) and does not have to start at 1." ;
    dc:identifier "ISSEQ" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IS/ISSPCCND> a sdtmig:Variable ;
    rdfs:label "Specimen Condition" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C78733> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "34" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Free or standardized text describing the condition of the specimen. Examples: \"HEMOLYZED\", \"ICTERIC\", \"LIPEMIC\"." ;
    dc:identifier "ISSPCCND" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IS/ISSPCUFL> a sdtmig:Variable ;
    rdfs:label "Specimen Usability for the Test" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "35" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Describes the usability of the specimen for the test. The value will be \"N\" if the specimen is not usable, and null if the specimen is usable." ;
    dc:identifier "ISSPCUFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IS/ISSPEC> a sdtmig:Variable ;
    rdfs:label "Specimen Type" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C78734> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "33" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Defines the types of specimen used for a measurement. Example: \"SERUM\"." ;
    dc:identifier "ISSPEC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IS/ISSPID> a sdtmig:Variable ;
    rdfs:label "Sponsor-Defined Identifier" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "8" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Sponsor-defined identifier." ;
    dc:identifier "ISSPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IS/ISSTAT> a sdtmig:Variable ;
    rdfs:label "Completion Status" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66789> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "30" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to indicate a test was not done. Should be null if a result exists in ISORRES." ;
    dc:identifier "ISSTAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IS/ISSTNRC> a sdtmig:Variable ;
    rdfs:label "Reference Range for Char Rslt-Std Units" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "28" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "For normal range values that are character in ordinal scale or if categorical ranges were supplied. Examples: \"-1 to +1\", \"NEGATIVE TO TRACE\"." ;
    dc:identifier "ISSTNRC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IS/ISSTNRHI> a sdtmig:Variable ;
    rdfs:label "Reference Range Upper Limit-Std Units" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "27" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Upper end of reference range for continuous measurements in standardized units. Should be populated only for continuous results." ;
    dc:identifier "ISSTNRHI" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IS/ISSTNRLO> a sdtmig:Variable ;
    rdfs:label "Reference Range Lower Limit-Std Units" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "26" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Lower end of reference range for continuous measurements for ISSTRESC/ISSTRESN in standardized units. Should be populated only for continuous results." ;
    dc:identifier "ISSTNRLO" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IS/ISSTRESC> a sdtmig:Variable ;
    rdfs:label "Character Result/Finding in Std Format" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "23" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Contains the result value for all findings copied or derived from ISORRES, in a standard format or in standard units. ISSTRESC should store all results or findings in character format; if results are numeric, they should also be stored in numeric format in ISSTRESN." ;
    dc:identifier "ISSTRESC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IS/ISSTRESN> a sdtmig:Variable ;
    rdfs:label "Numeric Results/Findings in Std. Units" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "24" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Used for continuous or numeric results or findings in standard format; copied in numeric format from ISSTRESC. ISSTRESN should store all numeric test results or findings." ;
    dc:identifier "ISSTRESN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IS/ISSTRESU> a sdtmig:Variable ;
    rdfs:label "Standard Units" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C71620> ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "25" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Standardized units used for ISSTRESC and ISSTRESN. Examples: \"Index Value\", \"gpELISA\", \"unit/mL\"." ;
    dc:identifier "ISSTRESU" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IS/ISTEST> a sdtmig:Variable ;
    rdfs:label "Immunogenicity Test or Examination Name" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C120526> ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "10" ;
    sdtmig:role "Synonym Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Verbatim name of the test or examination used to obtain the measurement or finding. The value in ISTEST cannot be longer than 40 characters. Example: \"Immunoglobulin E\"." ;
    dc:identifier "ISTEST" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IS/ISTESTCD> a sdtmig:Variable ;
    rdfs:label "Immunogenicity Test/Exam Short Name" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C120525> ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "9" ;
    sdtmig:role "Topic" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Short name of the measurement, test, or examination described in ISTEST. It can be used as a column name when converting a dataset from a vertical to a horizontal format. The value in ISTESTCD cannot be longer than 8 characters, nor can it start with a number (e.g., \"1TEST\" is not valid). ISTESTCD cannot contain characters other than letters, numbers, or underscores." ;
    dc:identifier "ISTESTCD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IS/ISTPT> a sdtmig:Variable ;
    rdfs:label "Planned Time Point Name" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "50" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Text description of time when specimen should be taken. This may be represented as an elapsed time relative to a fixed reference point, such as time of last dose. See ISTPTNUM and ISTPTREF. Examples: \"Start\", \"5 min post\"." ;
    dc:identifier "ISTPT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IS/ISTPTNUM> a sdtmig:Variable ;
    rdfs:label "Planned Time Point Number" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "51" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Numerical version of ISTPT to aid in sorting." ;
    dc:identifier "ISTPTNUM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IS/ISTPTREF> a sdtmig:Variable ;
    rdfs:label "Time Point Reference" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "53" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Name of the fixed reference point referred to by ISELTM, ISTPTNUM, and ISTPT. Examples: \"PREVIOUS DOSE\", \"PREVIOUS MEAL\"." ;
    dc:identifier "ISTPTREF" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IS/ISTSTCND> a sdtmig:Variable ;
    rdfs:label "Test Condition" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C181175> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "11" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifies any planned condition imposed by the assay system on the specimen at the time the test is performed." ;
    dc:identifier "ISTSTCND" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IS/ISTSTDTL> a sdtmig:Variable ;
    rdfs:label "Test Detail" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "16" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Further description of ISTESTCD and ISTEST." ;
    dc:identifier "ISTSTDTL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IS/ISTSTOPO> a sdtmig:Variable ;
    rdfs:label "Test Operational Objective" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C181170> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "14" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Text description of the high-level purpose of the test at the operational level. If populated, valid values are \"SCREEN\", \"CONFIRM\", and \"QUANTIFY\"." ;
    dc:identifier "ISTSTOPO" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IS/NHOID> a sdtmig:Variable ;
    rdfs:label "Non-host Organism ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "4" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Sponsor-defined identifier for a non-host organism which should only be used when the organism is the subject of the TEST. This variable should be populated with an intuitive name based on the identity of the non-host organism as reported by a lab (e.g., \"A/California/7/2009 (H1N1)\"). It is not to be used as a qualifier of the result in the record on which it appears." ;
    dc:identifier "NHOID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IS/STUDYID> a sdtmig:Variable ;
    rdfs:label "Study Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "1" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Unique identifier for a study." ;
    dc:identifier "STUDYID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IS/TAETORD> a sdtmig:Variable ;
    rdfs:label "Planned Order of Element within Arm" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "44" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
