    sdtmig:core "Perm" ;
    sdtmig:ordinal "35" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Description of the fixed reference point referred to by RPELTM, RPTPTNUM, and RPTPT. Examples: \"PREVIOUS DOSE\", \"PREVIOUS MEAL\"." ;
    dc:identifier "RPTPTREF" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RP/STUDYID> a sdtmig:Variable ;
