    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C99079> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "35" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Epoch associated with the date/time at which the assessment was made." ;
    dc:identifier "EPOCH" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/NV/FOCID> a sdtmig:Variable ;
    rdfs:label "Focus of Study-Specific Interest" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "4" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identification of a focus of study-specific interest on or within a subject or specimen as called out in the protocol for which a measurement, test, or examination was performed, such as a drug application site (e.g., \"Injection site 1\", \"Biopsy site 1\", \"Treated site 1\") or a more specific focus (e.g., \"OD\" (right eye), \"Upper left quadrant of the back\"). The value in this variable should have inherent semantic meaning." ;
    dc:identifier "FOCID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/NV/NVBLFL> a sdtmig:Variable ;
    rdfs:label "Baseline Flag" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "27" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Indicator used to identify a baseline value. Should be \"Y\" or null. Note that NVBLFL is retained for backward compatibility. The authoritative baseline flag for statistical analysis is in an ADaM dataset." ;
    dc:identifier "NVBLFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/NV/NVCAT> a sdtmig:Variable ;
    rdfs:label "Category for Nervous System Test" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "13" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to define a category of topic-variable values. Example: \"VISUAL EVOKED POTENTIAL\"." ;
    dc:identifier "NVCAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/NV/NVDIR> a sdtmig:Variable ;
    rdfs:label "Directionality" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C99074> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "24" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Qualifier for anatomical location or specimen further detailing directionality. Examples: \"ANTERIOR\", \"LOWER\", \"PROXIMAL\"." ;
    dc:identifier "NVDIR" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/NV/NVDRVFL> a sdtmig:Variable ;
    rdfs:label "Derived Flag" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "28" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to indicate a derived record (e.g., a record that represents the average of other records such as a computed baseline). Should be \"Y\" or null." ;
    dc:identifier "NVDRVFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/NV/NVDTC> a sdtmig:Variable ;
    rdfs:label "Date/Time of Collection" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "36" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Date of procedure or test." ;
    dc:identifier "NVDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/NV/NVDY> a sdtmig:Variable ;
    rdfs:label "Study Day of Visit/Collection/Exam" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "37" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Study day of the procedure or test, measured as integer days. Algorithm for calculations must be relative to the sponsor-defined RFSTDTC variable in Demographics." ;
    dc:identifier "NVDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/NV/NVELTM> a sdtmig:Variable ;
    rdfs:label "Planned Elapsed Time from Time Point Ref" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "40" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 duration" ;
    dc:description "Planned elapsed time (in ISO 8601) relative to a fixed time point reference (NVTPTREF). Not a clock time or a date time variable. Represented as an ISO 8601 duration. Examples: \"-PT15M\" to represent the period of 15 minutes prior to the reference point indicated by NVTPTREF, \"PT8H\" to represent the period of 8 hours after the reference point indicated by NVTPTREF." ;
    dc:identifier "NVELTM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/NV/NVEVAL> a sdtmig:Variable ;
    rdfs:label "Evaluator" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C78735> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "29" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Role of the person who provided the evaluation. Used only for results that are subjective (e.g., assigned by a person or a group). Examples: \"ADJUDICATION COMMITTEE\", \"INDEPENDENT ASSESSOR\", \"RADIOLOGIST\"." ;
    dc:identifier "NVEVAL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/NV/NVEVALID> a sdtmig:Variable ;
    rdfs:label "Evaluator Identifier" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C96777> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "30" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to distinguish multiple evaluators with the same role recorded in NVEVAL. Examples: \"RADIOLOGIST 1\", \"RADIOLOGIST 2\"." ;
    dc:identifier "NVEVALID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/NV/NVGRPID> a sdtmig:Variable ;
    rdfs:label "Group ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "6" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to tie together a block of related records in a single domain for a subject." ;
    dc:identifier "NVGRPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/NV/NVLAT> a sdtmig:Variable ;
