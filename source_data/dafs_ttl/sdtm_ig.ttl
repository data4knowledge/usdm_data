    sdtmig:ordinal "3" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Two-character abbreviation for the domain of the parent record(s). Null for comments collected on a general comments or additional information CRF page." ;
    dc:identifier "RDOMAIN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CO/STUDYID> a sdtmig:Variable ;
