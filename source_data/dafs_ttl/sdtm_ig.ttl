    dc:identifier "STUDYID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TA/TABRANCH> a sdtmig:Variable ;
    rdfs:label "Branch" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "8" ;
    sdtmig:role "Rule" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Condition subject met, at a \"branch\" in the trial design at the end of this element, to be included in this arm (e.g., \"Randomization to DRUG X\")." ;
    dc:identifier "TABRANCH" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TA/TAETORD> a sdtmig:Variable ;
    rdfs:label "Planned Order of Element within Arm" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "5" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Number that gives the order of the element within the arm." ;
