    dc:description "Used to define a further categorization of MICAT." ;
    dc:identifier "MISCAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MI/MISEQ> a sdtmig:Variable ;
    rdfs:label "Sequence Number" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "4" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Sequence number given to ensure uniqueness of subject records within a domain. May be any valid number." ;
    dc:identifier "MISEQ" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MI/MISPCCND> a sdtmig:Variable ;
    rdfs:label "Specimen Condition" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C78733> ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "23" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Free or standardized text describing the condition of the specimen. Example: \"AUTOLYZED\"." ;
    dc:identifier "MISPCCND" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MI/MISPEC> a sdtmig:Variable ;
    rdfs:label "Specimen Material Type" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C78734> ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "22" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Subject of the observation. Defines the type of specimen used for a measurement. Examples: \"TISSUE\", \"BLOOD\", \"BONE MARROW\"." ;
    dc:identifier "MISPEC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MI/MISPID> a sdtmig:Variable ;
    rdfs:label "Sponsor-Defined Identifier" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "7" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Sponsor-defined reference number. May be printed on the CRF as an explicit line identifier or defined in the sponsor\'s operational database. Example: line number from the MI Findings page." ;
    dc:identifier "MISPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MI/MISTAT> a sdtmig:Variable ;
    rdfs:label "Completion Status" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66789> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "19" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to indicate examination not done or result is missing. Should be null if a result exists in MIORRES or have a value of \"NOT DONE\" when MIORRES = \"NULL\"." ;
    dc:identifier "MISTAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MI/MISTRESC> a sdtmig:Variable ;
    rdfs:label "Character Result/Finding in Std Format" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "15" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Contains the result value for all findings, copied or derived from MIORRES in a standard format or standard units. MISTRESC should store all results or findings in character format; if results are numeric, they should also be stored in numeric format in MISTRESN." ;
    dc:identifier "MISTRESC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MI/MISTRESN> a sdtmig:Variable ;
    rdfs:label "Numeric Result/Finding in Standard Units" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "16" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Used for continuous or numeric results or findings in standard format; copied in numeric format from MISTRESC. MISTRESN should store all numeric test results or findings." ;
    dc:identifier "MISTRESN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MI/MISTRESU> a sdtmig:Variable ;
    rdfs:label "Standard Units" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C71620> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "17" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Standardized unit used for MISTRESC and MISTRESN." ;
    dc:identifier "MISTRESU" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MI/MITEST> a sdtmig:Variable ;
    rdfs:label "Microscopic Examination Name" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C132262> ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "9" ;
    sdtmig:role "Synonym Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Verbatim name of the test or examination used to obtain the measurement or finding. The value in MITEST cannot be longer than 40 characters. Examples: \"Human Epidermal Growth Factor Receptor 2\", \"Breast Cancer Susceptibility Gene 1\", \"Thyroid Transcription Factor 1\"." ;
    dc:identifier "MITEST" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MI/MITESTCD> a sdtmig:Variable ;
    rdfs:label "Microscopic Examination Short Name" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C132263> ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "8" ;
    sdtmig:role "Topic" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Short name of the measurement, test, or examination described in MITEST. It can be used as a column name when converting a dataset from a vertical to a horizontal format. The value in MITESTCD cannot be longer than 8 characters, nor can it start with a number (e.g., \"1TEST\" is not valid). MITESTCD cannot contain characters other than letters, numbers, or underscores. Examples: \"HER2\", \"BRCA1\", \"TTF1\"." ;
    dc:identifier "MITESTCD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MI/MITSTDTL> a sdtmig:Variable ;
    rdfs:label "Microscopic Examination Detail" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C125922> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "10" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Further description of the test performed in producing the MI result. This would be used to represent specific attributes, such as intensity score or percentage of cells displaying presence of the biomarker or compound." ;
    dc:identifier "MITSTDTL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MI/STUDYID> a sdtmig:Variable ;
    rdfs:label "Study Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "1" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Unique identifier for a study." ;
    dc:identifier "STUDYID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MI/TAETORD> a sdtmig:Variable ;
    rdfs:label "Planned Order of Element within Arm" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "34" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Number that gives the planned order of the element within the arm for the element in which the assessment was made." ;
    dc:identifier "TAETORD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MI/USUBJID> a sdtmig:Variable ;
    rdfs:label "Unique Subject Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "3" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifier used to uniquely identify a subject across all studies for all applications or submissions involving the product." ;
    dc:identifier "USUBJID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MI/VISIT> a sdtmig:Variable ;
    rdfs:label "Visit Name" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "32" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Protocol-defined description of clinical encounter. May be used in addition to VISITNUM and/or VISITDY." ;
    dc:identifier "VISIT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MI/VISITDY> a sdtmig:Variable ;
    rdfs:label "Planned Study Day of Visit" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "33" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Planned study day of the visit based upon RFSTDTC in Demographics." ;
    dc:identifier "VISITDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MI/VISITNUM> a sdtmig:Variable ;
    rdfs:label "Visit Number" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "31" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Clinical encounter number. Numeric version of VISIT, used for sorting." ;
    dc:identifier "VISITNUM" .

