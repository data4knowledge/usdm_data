    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C116107> ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "6" ;
    sdtmig:role "Synonym Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Long name for DDTESTCD. The value in DDTEST cannot be longer than 40 characters. Examples: \"Primary Cause of Death\", \"Secondary Cause of Death\"." ;
    dc:identifier "DDTEST" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DD/DDTESTCD> a sdtmig:Variable ;
    rdfs:label "Death Detail Assessment Short Name" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C116108> ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "5" ;
    sdtmig:role "Topic" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Short name of the measurement, test, or examination described in DDTEST. It can be used as a column name when converting a dataset from a vertical to a horizontal format. The value in DDTESTCD cannot be longer than 8 characters, nor can it start with a number (e.g., \"1TEST\" is not valid). DDTESTCD cannot contain characters other than letters, numbers, or underscores. Examples: \"PRCDTH\", \"SECDTH\"." ;
    dc:identifier "DDTESTCD" .

