    sdtmig:ordinal "20" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Standardized units used for OESTRESC and OESTRESN. Examples: \"mm\", \"um\"." ;
    dc:identifier "OESTRESU" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/OE/OETEST> a sdtmig:Variable ;
