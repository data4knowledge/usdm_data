        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PE/VISITDY>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PE/VISITNUM> ;
    sdtmig:ordinal "35" ;
    sdtmig:structure "One record per body system or abnormality per visit per subject" ;
    dc:description "Physical Examination" ;
    dc:identifier "PE" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PE/DOMAIN> a sdtmig:Variable ;
    rdfs:label "Domain Abbreviation" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "2" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Two-character abbreviation for the domain." ;
    dc:identifier "DOMAIN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PE/EPOCH> a sdtmig:Variable ;
    rdfs:label "Epoch" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C99079> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "28" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Epoch associated with the observation date/time of the physical exam finding." ;
    dc:identifier "EPOCH" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PE/PEBLFL> a sdtmig:Variable ;
    rdfs:label "Baseline Flag" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "22" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "A baseline defined by the sponsor (could be derived in the same manner as PELOBXFL or ABLFL, but is not required to be). The value should be \"Y\" or null. Note that PEBLFL is retained for backward compatibility. The authoritative baseline flag for statistical analysis is in an ADaM dataset." ;
    dc:identifier "PEBLFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PE/PEBODSYS> a sdtmig:Variable ;
    rdfs:label "Body System or Organ Class" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "12" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Body system or organ class (e.g., MedDRA SOC) that is involved for a finding from the standard hierarchy for dictionary-coded results." ;
    dc:identifier "PEBODSYS" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PE/PECAT> a sdtmig:Variable ;
    rdfs:label "Category for Examination" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "10" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to define a category of topic-variable values. Example: \"GENERAL\"." ;
    dc:identifier "PECAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PE/PEDTC> a sdtmig:Variable ;
    rdfs:label "Date/Time of Examination" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "29" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Date and time of the physical examination represented in ISO 8601 character format." ;
    dc:identifier "PEDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PE/PEDY> a sdtmig:Variable ;
    rdfs:label "Study Day of Examination" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "30" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Study day of physical exam, measured as integer days. Algorithm for calculations must be relative to the sponsor-defined RFSTDTC variable in Demographics." ;
    dc:identifier "PEDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PE/PEEVAL> a sdtmig:Variable ;
    rdfs:label "Evaluator" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C78735> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "23" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Role of the person who provided the evaluation. Used only for results that are subjective (e.g., assigned by a person or a group). Example: \"INVESTIGATOR\"." ;
    dc:identifier "PEEVAL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PE/PEGRPID> a sdtmig:Variable ;
    rdfs:label "Group ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "5" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to link together a block of related records in a single domain for a subject." ;
    dc:identifier "PEGRPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PE/PELAT> a sdtmig:Variable ;
    rdfs:label "Laterality" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C99073> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "19" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Qualifier for anatomical location or specimen further detailing laterallity. Examples: \"RIGHT\", \"LEFT\", \"BILATERAL\"." ;
    dc:identifier "PELAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PE/PELOBXFL> a sdtmig:Variable ;
    rdfs:label "Last Observation Before Exposure Flag" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "21" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Operationally derived indicator used to identify the last non-missing value prior to RFXSTDTC. Should be \"Y\" or null." ;
    dc:identifier "PELOBXFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PE/PELOC> a sdtmig:Variable ;
    rdfs:label "Location of Physical Exam Finding" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C74456> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "18" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Anatomical location of the subject relevant to the collection of the measurement. Example: \"ARM\" for skin rash." ;
    dc:identifier "PELOC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PE/PEMETHOD> a sdtmig:Variable ;
    rdfs:label "Method of Test or Examination" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C85492> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "20" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Method of the test or examination. Examples: \"PALPATION\", \"PERCUSSION\"." ;
    dc:identifier "PEMETHOD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PE/PEMODIFY> a sdtmig:Variable ;
    rdfs:label "Modified Reported Term" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "9" ;
    sdtmig:role "Synonym Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "If the value of PEORRES is modified for coding purposes, then the modified text is placed here." ;
    dc:identifier "PEMODIFY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PE/PEORRES> a sdtmig:Variable ;
    rdfs:label "Verbatim Examination Finding" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "13" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Text description of any abnormal findings. If the examination was completed and there were no abnormal findings, the value should be \"NORMAL\". If the examination was not performed on a particular body system, or at the subject level, then the value should be null, and \"NOT DONE\" should appear in PESTAT." ;
    dc:identifier "PEORRES" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PE/PEORRESU> a sdtmig:Variable ;
    rdfs:label "Original Units" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C71620> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "14" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Original units in which the data were collected. The unit for PEORRES." ;
    dc:identifier "PEORRESU" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PE/PEREASND> a sdtmig:Variable ;
    rdfs:label "Reason Not Examined" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "17" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Describes why an examination was not performed or why a body system was not examined. Example: \"SUBJECT REFUSED\". Used in conjunction with PESTAT when value is \"NOT DONE\"." ;
    dc:identifier "PEREASND" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PE/PESCAT> a sdtmig:Variable ;
    rdfs:label "Subcategory for Examination" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "11" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to define a further categorization of --CAT values." ;
    dc:identifier "PESCAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PE/PESEQ> a sdtmig:Variable ;
    rdfs:label "Sequence Number" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "4" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Sequence number to ensure uniqueness of records within a dataset for a subject. May be any valid number." ;
    dc:identifier "PESEQ" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PE/PESPID> a sdtmig:Variable ;
    rdfs:label "Sponsor-Defined Identifier" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "6" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Sponsor-defined reference number. Perhaps preprinted on the CRF as an explicit line identifier or defined in the sponsor\'s operational database. Example: Line number on a CRF." ;
    dc:identifier "PESPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PE/PESTAT> a sdtmig:Variable ;
    rdfs:label "Completion Status" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66789> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "16" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to indicate exam not done. Must be null if a result exists in PEORRES/PESTRESC." ;
    dc:identifier "PESTAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PE/PESTRESC> a sdtmig:Variable ;
    rdfs:label "Character Result/Finding in Std Format" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "15" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "If there are findings for a body system, then either the dictionary preferred term (if findings are coded using a dictionary) or PEORRES (if findings are not encoded) should appear here. If PEORRES is null, PESTRESC must be null." ;
    dc:identifier "PESTRESC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PE/PETEST> a sdtmig:Variable ;
    rdfs:label "Body System Examined" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "8" ;
    sdtmig:role "Synonym Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Long name of a part of the body examined in a physical examination. The value in PETEST cannot be longer than 40 characters. Examples: \"Head\", \"Ear/Nose/Throat\". If the results of the entire physical examination are represented in one record, value should be \"Physical Examination\"." ;
    dc:identifier "PETEST" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PE/PETESTCD> a sdtmig:Variable ;
    rdfs:label "Body System Examined Short Name" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "7" ;
    sdtmig:role "Topic" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Short name of a part of the body examined in a physical examination. It can be used as a column name when converting a dataset from a vertical to a horizontal format. The value in PETESTCD cannot be longer than 8 characters, nor can it start with a number (e.g., \"1TEST\" is not valid). PETESTCD cannot contain characters other than letters, numbers, or underscores. Examples: \"HEAD\", \"ENT\". If the results of the entire physical examination are represented in one record, value should be \"PHYSEXAM\"." ;
    dc:identifier "PETESTCD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PE/STUDYID> a sdtmig:Variable ;
    rdfs:label "Study Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "1" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Unique identifier for a study." ;
    dc:identifier "STUDYID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PE/TAETORD> a sdtmig:Variable ;
    rdfs:label "Planned Order of Element within Arm" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "27" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Number that gives the planned order of the element within the arm for the element in which the assessment was made." ;
    dc:identifier "TAETORD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PE/USUBJID> a sdtmig:Variable ;
    rdfs:label "Unique Subject Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "3" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifier used to uniquely identify a subject across all studies for all applications or submissions involving the product." ;
    dc:identifier "USUBJID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PE/VISIT> a sdtmig:Variable ;
    rdfs:label "Visit Name" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "25" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Protocol-defined description of a clinical encounter. May be used in addition to VISITNUM and/or VISITDY." ;
    dc:identifier "VISIT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PE/VISITDY> a sdtmig:Variable ;
    rdfs:label "Planned Study Day of Visit" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "26" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Planned study day of VISIT. Should be an integer." ;
    dc:identifier "VISITDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/PE/VISITNUM> a sdtmig:Variable ;
    rdfs:label "Visit Number" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "24" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Clinical encounter number. Numeric version of VISIT, used for sorting." ;
    dc:identifier "VISITNUM" .

