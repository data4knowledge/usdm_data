<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CM/CMADJ> a sdtmig:Variable ;
    rdfs:label "Reason for Dose Adjustment" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "27" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Describes reason or explanation of why a dose is adjusted. Examples: \"ADVERSE EVENT\", \"INSUFFICIENT RESPONSE\", \"NON-MEDICAL REASON\"." ;
    dc:identifier "CMADJ" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CM/CMCAT> a sdtmig:Variable ;
    rdfs:label "Category for Medication" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "10" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to define a category of medications/treatment. Examples: \"PRIOR\", \"CONCOMITANT\", \"ANTI-CANCER MEDICATION\", \"GENERAL CONMED\"." ;
    dc:identifier "CMCAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CM/CMCLAS> a sdtmig:Variable ;
    rdfs:label "Medication Class" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "17" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Drug class. May be obtained from coding. When coding to a single class, populate with class value. If using a dictionary and coding to multiple classes, then follow Section 4.2.8.3, Multiple Values for a Non-result Qualifier Variable, or omit CMCLAS." ;
    dc:identifier "CMCLAS" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CM/CMCLASCD> a sdtmig:Variable ;
    rdfs:label "Medication Class Code" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "18" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Class code corresponding to CMCLAS. Drug class. May be obtained from coding. When coding to a single class, populate with class code. If using a dictionary and coding to multiple classes, then follow Section 4.2.8.3, Multiple Values for a Non-result Qualifier Variable, or omit CMCLASCD." ;
    dc:identifier "CMCLASCD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CM/CMDECOD> a sdtmig:Variable ;
    rdfs:label "Standardized Medication Name" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "9" ;
    sdtmig:role "Synonym Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Standardized or dictionary-derived text description of CMTRT or CMMODIFY. Equivalent to the generic drug name in WHO Drug. The sponsor is expected to provide the dictionary name and version used to map the terms utilizing the external codelist element in the Define-XML document. If an intervention term does not have a decode value in the dictionary, then CMDECOD will be left blank." ;
    dc:identifier "CMDECOD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CM/CMDOSE> a sdtmig:Variable ;
    rdfs:label "Dose per Administration" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "19" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Amount of CMTRT given. Not populated when CMDOSTXT is populated." ;
    dc:identifier "CMDOSE" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CM/CMDOSFRM> a sdtmig:Variable ;
    rdfs:label "Dose Form" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66726> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "22" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Dose form for CMTRT. Examples: \"TABLET\", \"LOTION\"." ;
    dc:identifier "CMDOSFRM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CM/CMDOSFRQ> a sdtmig:Variable ;
    rdfs:label "Dosing Frequency per Interval" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C71113> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "23" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Usually expressed as the number of repeated administrations of CMDOSE within a specific time period. Examples: \"BID\" (twice daily), \"Q12H\" (every 12 hours)." ;
    dc:identifier "CMDOSFRQ" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CM/CMDOSRGM> a sdtmig:Variable ;
    rdfs:label "Intended Dose Regimen" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "25" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Text description of the (intended) schedule or regimen for the Intervention. Example: \"TWO WEEKS ON, TWO WEEKS OFF\"." ;
    dc:identifier "CMDOSRGM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CM/CMDOSTOT> a sdtmig:Variable ;
    rdfs:label "Total Daily Dose" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "24" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Total daily dose of CMTRT using the units in CMDOSU. Used when dosing is collected as total daily dose. Total dose over a period other than day could be recorded in a separate supplemental qualifier variable." ;
    dc:identifier "CMDOSTOT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CM/CMDOSTXT> a sdtmig:Variable ;
    rdfs:label "Dose Description" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "20" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Dosing amounts or a range of dosing information collected in text form. Units may be stored in CMDOSU. Examples: \"200-400\", \"15-20\". Not populated when CMDOSE is populated." ;
    dc:identifier "CMDOSTXT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CM/CMDOSU> a sdtmig:Variable ;
    rdfs:label "Dose Units" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C71620> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "21" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Units for CMDOSE, CMDOSTOT, or CMDOSTXT. Examples: \"ng\", \"mg\", \"mg/kg\"." ;
    dc:identifier "CMDOSU" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CM/CMDUR> a sdtmig:Variable ;
    rdfs:label "Duration" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "35" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 duration" ;
    dc:description "Collected duration for a treatment episode. Used only if collected on the CRF and not derived from start and end date/times." ;
    dc:identifier "CMDUR" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CM/CMENDTC> a sdtmig:Variable ;
    rdfs:label "End Date/Time of Medication" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "32" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "End date/time of the medication administration represented in ISO 8601 character format." ;
    dc:identifier "CMENDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CM/CMENDY> a sdtmig:Variable ;
    rdfs:label "Study Day of End of Medication" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "34" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Study day of end of medication relative to the sponsor-defined RFSTDTC." ;
    dc:identifier "CMENDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CM/CMENRF> a sdtmig:Variable ;
    rdfs:label "End Relative to Reference Period" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66728> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "37" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Describes the end of the medication relative to the sponsor-defined reference period. The sponsor-defined reference period is a continuous period of time defined by a discrete starting point and a discrete ending point (represented by RFSTDTC and RFENDTC in Demographics). If information such as \"PRIOR\", \"ONGOING, or \"CONTINUING\" was collected, this information may be translated into CMENRF. \\n Not all values of the codelist are allowable for this variable. See Section 4.4.7, Use of Relative Timing Variables." ;
    dc:identifier "CMENRF" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CM/CMENRTPT> a sdtmig:Variable ;
    rdfs:label "End Relative to Reference Time Point" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66728> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "40" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifies the end of the medication as being before or after the sponsor-defined reference time point defined by variable CMENTPT. \\n Not all values of the codelist are allowable for this variable. See Section 4.4.7, Use of Relative Timing Variables." ;
    dc:identifier "CMENRTPT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CM/CMENTPT> a sdtmig:Variable ;
    rdfs:label "End Reference Time Point" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "41" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Description or date/time in ISO 8601 character format of the sponsor-defined reference point referred to by CMENRTPT. Examples: \"2003-12-25\", \"VISIT 2\"." ;
    dc:identifier "CMENTPT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CM/CMGRPID> a sdtmig:Variable ;
    rdfs:label "Group ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "5" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to tie together a block of related records in a single domain for a subject." ;
    dc:identifier "CMGRPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CM/CMINDC> a sdtmig:Variable ;
    rdfs:label "Indication" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "16" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Denotes why a medication was taken or administered. Examples: \"NAUSEA\", \"HYPERTENSION\"." ;
    dc:identifier "CMINDC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CM/CMMODIFY> a sdtmig:Variable ;
    rdfs:label "Modified Reported Name" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "8" ;
    sdtmig:role "Synonym Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "If CMTRT is modified to facilitate coding, then CMMODIFY will contain the modified text." ;
    dc:identifier "CMMODIFY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CM/CMOCCUR> a sdtmig:Variable ;
    rdfs:label "CM Occurrence" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "13" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "When the use of a specific medication is solicited. CMOCCUR is used to indicate whether (\"Y\"/\"N\") use of the medication occurred. Values are null for medications not specifically solicited." ;
    dc:identifier "CMOCCUR" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CM/CMPRESP> a sdtmig:Variable ;
    rdfs:label "CM Pre-specified" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "12" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to indicate whether (\"Y\"/null) information about the use of a specific medication was solicited on the CRF." ;
    dc:identifier "CMPRESP" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CM/CMREASND> a sdtmig:Variable ;
    rdfs:label "Reason Medication Not Collected" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "15" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Reason not done. Used in conjunction with CMSTAT when value is \"NOT DONE\"." ;
    dc:identifier "CMREASND" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CM/CMROUTE> a sdtmig:Variable ;
    rdfs:label "Route of Administration" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66729> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "26" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Route of administration for the intervention. Examples: \"ORAL\", \"INTRAVENOUS\"." ;
    dc:identifier "CMROUTE" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CM/CMRSDISC> a sdtmig:Variable ;
    rdfs:label "Reason the Intervention Was Discontinued" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "28" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "When dosing of a treatment is recorded over multiple successive records, this variable is applicable only for the (chronologically) last record for the treatment." ;
    dc:identifier "CMRSDISC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CM/CMSCAT> a sdtmig:Variable ;
    rdfs:label "Subcategory for Medication" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "11" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "A further categorization of medications/treatment. Examples: \"CHEMOTHERAPY\", \"HORMONAL THERAPY\", \"ALTERNATIVE THERAPY\"." ;
    dc:identifier "CMSCAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CM/CMSEQ> a sdtmig:Variable ;
    rdfs:label "Sequence Number" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "4" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Sequence number to ensure uniqueness of subject records within a domain. May be any valid number." ;
    dc:identifier "CMSEQ" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CM/CMSPID> a sdtmig:Variable ;
    rdfs:label "Sponsor-Defined Identifier" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "6" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Sponsor-defined reference number. Example: a number preprinted on the CRF as an explicit line identifier or record identifier defined in the sponsor\'s operational database. Example: line number on a concomitant medication page." ;
    dc:identifier "CMSPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CM/CMSTAT> a sdtmig:Variable ;
    rdfs:label "Completion Status" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66789> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "14" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to indicate that a question about the occurrence of a prespecified intervention was not answered. Should be null or have a value of \"NOT DONE\"." ;
    dc:identifier "CMSTAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CM/CMSTDTC> a sdtmig:Variable ;
    rdfs:label "Start Date/Time of Medication" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "31" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Start date/time of the medication administration represented in ISO 8601 character format." ;
    dc:identifier "CMSTDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CM/CMSTDY> a sdtmig:Variable ;
    rdfs:label "Study Day of Start of Medication" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "33" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Study day of start of medication relative to the sponsor-defined RFSTDTC." ;
    dc:identifier "CMSTDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CM/CMSTRF> a sdtmig:Variable ;
    rdfs:label "Start Relative to Reference Period" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66728> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "36" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Describes the start of the medication relative to sponsor-defined reference period. The sponsor-defined reference period is a continuous period of time defined by a discrete starting point and a discrete ending point (represented by RFSTDTC and RFENDTC in Demographics). If information such as \"PRIOR\" was collected, this information may be translated into CMSTRF. \\n Not all values of the codelist are allowable for this variable. See Section 4.4.7, Use of Relative Timing Variables." ;
    dc:identifier "CMSTRF" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CM/CMSTRTPT> a sdtmig:Variable ;
    rdfs:label "Start Relative to Reference Time Point" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66728> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "38" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifies the start of the medication as being before or after the sponsor-defined reference time point defined by variable CMSTTPT. \\n Not all values of the codelist are allowable for this variable. See Section 4.4.7, Use of Relative Timing Variables." ;
    dc:identifier "CMSTRTPT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CM/CMSTTPT> a sdtmig:Variable ;
    rdfs:label "Start Reference Time Point" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "39" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Description or date/time in ISO 8601 character format of the sponsor-defined reference point referred to by CMSTRTPT. Examples: \"2003-12-15\", \"VISIT 1\"." ;
    dc:identifier "CMSTTPT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CM/CMTRT> a sdtmig:Variable ;
    rdfs:label "Reported Name of Drug, Med, or Therapy" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "7" ;
    sdtmig:role "Topic" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Verbatim medication name that is either preprinted or collected on a CRF." ;
    dc:identifier "CMTRT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CM/DOMAIN> a sdtmig:Variable ;
    rdfs:label "Domain Abbreviation" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "2" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Two-character abbreviation for the domain." ;
    dc:identifier "DOMAIN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CM/EPOCH> a sdtmig:Variable ;
    rdfs:label "Epoch" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C99079> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "30" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Epoch associated with the start date/time of the medication administration. Null for medications that started before study participation." ;
    dc:identifier "EPOCH" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CM/STUDYID> a sdtmig:Variable ;
    rdfs:label "Study Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "1" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Unique identifier for a study." ;
    dc:identifier "STUDYID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CM/TAETORD> a sdtmig:Variable ;
    rdfs:label "Planned Order of Element within Arm" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "29" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Number that gives the planned order of the element within the arm for the element in which the medication administration started. Null for medications that started before study participation." ;
    dc:identifier "TAETORD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CM/USUBJID> a sdtmig:Variable ;
    rdfs:label "Unique Subject Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "3" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifier used to uniquely identify a subject across all studies for all applications or submissions involving the product." ;
    dc:identifier "USUBJID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CO> a sdtmig:Domain ;
    rdfs:label "Comments" ;
