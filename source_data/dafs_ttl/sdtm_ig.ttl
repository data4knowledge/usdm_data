    sdtmig:hasVariable <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CE/CEBODSYS>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CE/CECAT>,
