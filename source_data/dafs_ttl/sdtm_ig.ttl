    sdtmig:ordinal "11" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to define a further categorization of FTCAT values." ;
    dc:identifier "FTSCAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/FT/FTSEQ> a sdtmig:Variable ;
