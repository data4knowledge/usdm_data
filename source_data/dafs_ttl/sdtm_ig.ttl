    sdtmig:simpleDatatype "Char" ;
    dc:description "Long name for the test or examination used to obtain the measurement or finding. The value in OETEST cannot be longer than 40 characters. Example: \"Number of Letters Correct\" for OETESTCD = \"NUMLCOR\"." ;
    dc:identifier "OETEST" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/OE/OETESTCD> a sdtmig:Variable ;
    rdfs:label "Short Name of Ophthalmic Test or Exam" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C117743> ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "9" ;
    sdtmig:role "Topic" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Short character value for OETEST used as a column name when converting a dataset from a vertical format to a horizontal format. It can be used as a column name when converting a dataset from a vertical to a horizontal format. The value in OETESTCD cannot be longer than 8 characters, nor can it start with a number (e.g., \"1TEST\" is not valid). OETESTCD cannot contain characters other than letters, numbers, or underscores. Example: \"NUMLCOR\"." ;
    dc:identifier "OETESTCD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/OE/OETPT> a sdtmig:Variable ;
