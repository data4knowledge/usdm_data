    dc:identifier "USUBJID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SR/VISIT> a sdtmig:Variable ;
    rdfs:label "Visit Name" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "29" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
