    sdtmig:core "Perm" ;
    sdtmig:ordinal "23" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Normal range or reference range for results stored in OESTRESC that are character in ordinal or categorical scale. Example: \"Negative to Trace\"." ;
    dc:identifier "OESTNRC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/OE/OESTNRHI> a sdtmig:Variable ;
    rdfs:label "Normal Range Upper Limit-Standard Units" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "22" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Upper end of normal range or reference range for standardized results (e.g., OESTRESC, OESTRESN) represented in standardized units (OESTRESU)." ;
    dc:identifier "OESTNRHI" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/OE/OESTNRLO> a sdtmig:Variable ;
