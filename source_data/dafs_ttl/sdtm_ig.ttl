        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AESCONG>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AESDISAB>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AESDTH>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AESEQ>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AESER>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AESEV>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AESHOSP>,
