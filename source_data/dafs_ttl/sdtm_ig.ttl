    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Two-character abbreviation for the domain." ;
    dc:identifier "DOMAIN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TA/ELEMENT> a sdtmig:Variable ;
    rdfs:label "Description of Element" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "7" ;
    sdtmig:role "Synonym Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "The name of the element. The same element may occur more than once within an arm." ;
    dc:identifier "ELEMENT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TA/EPOCH> a sdtmig:Variable ;
    rdfs:label "Epoch" ;
