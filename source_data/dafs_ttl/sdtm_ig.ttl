<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/OE/OEREPNUM> a sdtmig:Variable ;
    rdfs:label "Repetition Number" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "40" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "The incidence number of a test that is repeated within a given timeframe for the same test. The level of granularity can vary (e.g., within a time point, within a visit). Examples: multiple measurements of blood pressure, multiple analyses of a sample." ;
    dc:identifier "OEREPNUM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/OE/OERESCAT> a sdtmig:Variable ;
