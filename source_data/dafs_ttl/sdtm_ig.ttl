<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/UR/URSTRESC> a sdtmig:Variable ;
    rdfs:label "Character Result/Finding in Std Format" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "17" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Contains the result value for all findings copied or derived from URORRES, in a standard format or in standard units. URSTRESC should store all results or findings in character format; if results are numeric, they should also be stored in numeric format in URSTRESN." ;
    dc:identifier "URSTRESC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/UR/URSTRESN> a sdtmig:Variable ;
    rdfs:label "Numeric Result/Finding in Standard Units" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "18" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Used for continuous or numeric results or findings in standard format; copied in numeric format from URSTRESC. URSTRESN should store all numeric test results or findings." ;
    dc:identifier "URSTRESN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/UR/URSTRESU> a sdtmig:Variable ;
    rdfs:label "Standard Units" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C71620> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "19" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Standardized units used for URSTRESC and URSTRESN." ;
    dc:identifier "URSTRESU" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/UR/URTEST> a sdtmig:Variable ;
    rdfs:label "Name of Urinary Test" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C129941> ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "11" ;
    sdtmig:role "Synonym Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Long name For URTESTCD. Examples: \"Count\", \"Length\", \"Renal Blood Flow\"." ;
    dc:identifier "URTEST" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/UR/URTESTCD> a sdtmig:Variable ;
    rdfs:label "Short Name of Urinary Test" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C129942> ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "10" ;
    sdtmig:role "Topic" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Short character value for URTEST used as a column name when converting a dataset from a vertical format to a horizontal format. It can be used as a column name when converting a dataset from a vertical to a horizontal format. The value in URTESTCD cannot be longer than 8 characters, nor can it start with a number (e.g., \"1TEST\" is not valid). URTESTCD cannot contain characters other than letters, numbers, or underscores. Examples: \"COUNT\", \"LENGTH\", \"RBLDFLW\"." ;
    dc:identifier "URTESTCD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/UR/URTPT> a sdtmig:Variable ;
    rdfs:label "Planned Time Point Name" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "39" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Text description of time when a measurement or observation should be taken as defined in the protocol. This may be represented as an elapsed time relative to a fixed reference point (e.g., time of last dose). See URTPTNUM and URTPTREF." ;
    dc:identifier "URTPT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/UR/URTPTNUM> a sdtmig:Variable ;
    rdfs:label "Planned Time Point Number" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "40" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Numeric version of planned time point used in sorting." ;
    dc:identifier "URTPTNUM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/UR/URTPTREF> a sdtmig:Variable ;
    rdfs:label "Time Point Reference" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "42" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Description of the fixed reference point referred to by URELTM, URTPTNUM, and URTPT. Examples: \"PREVIOUS DOSE\", \"PREVIOUS MEAL\"." ;
    dc:identifier "URTPTREF" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/UR/URTSTDTL> a sdtmig:Variable ;
    rdfs:label "Urinary Test Detail" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "12" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Further description of URTESTCD and URTEST." ;
    dc:identifier "URTSTDTL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/UR/USUBJID> a sdtmig:Variable ;
    rdfs:label "Unique Subject Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "3" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifier used to uniquely identify a subject across all studies for all applications or submissions involving the product." ;
    dc:identifier "USUBJID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/UR/VISIT> a sdtmig:Variable ;
    rdfs:label "Visit Name" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "33" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Protocol-defined description of a clinical encounter." ;
    dc:identifier "VISIT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/UR/VISITDY> a sdtmig:Variable ;
    rdfs:label "Planned Study Day of Visit" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "34" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Planned study day of VISIT. Should be an integer." ;
    dc:identifier "VISITDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/UR/VISITNUM> a sdtmig:Variable ;
    rdfs:label "Visit Number" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "32" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Clinical encounter number. Numeric version of VISIT, used for sorting." ;
    dc:identifier "VISITNUM" .

