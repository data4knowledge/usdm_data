    dc:identifier "MKLOBXFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MK/MKLOC> a sdtmig:Variable ;
    rdfs:label "Location Used for the Measurement" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C74456> ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "22" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Anatomical location of the subject relevant to the collection of the measurement. Examples: \"INTERPHALANGEAL JOINT 1\", \"SHOULDER JOINT\"." ;
    dc:identifier "MKLOC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MK/MKMETHOD> a sdtmig:Variable ;
    rdfs:label "Method of Test or Examination" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C85492> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "25" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Method of the test or examination. Examples: \"X-RAY\", \"MRI\", \"CT SCAN\"." ;
    dc:identifier "MKMETHOD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MK/MKORRES> a sdtmig:Variable ;
    rdfs:label "Result or Finding in Original Units" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "15" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Result of the measurement or finding as originally received or collected." ;
    dc:identifier "MKORRES" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MK/MKORRESU> a sdtmig:Variable ;
    rdfs:label "Original Units" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C71620> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "16" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Unit for MKORRES." ;
    dc:identifier "MKORRESU" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MK/MKPOS> a sdtmig:Variable ;
    rdfs:label "Position of Subject" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C71148> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "14" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Position of the subject during a measurement or examination. Examples: \"SUPINE\", \"STANDING\", \"SITTING\"." ;
    dc:identifier "MKPOS" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MK/MKREASND> a sdtmig:Variable ;
    rdfs:label "Reason Not Done" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "21" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Reason not done. Used in conjunction with MKSTAT when value is \"NOT DONE\"." ;
    dc:identifier "MKREASND" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MK/MKREFID> a sdtmig:Variable ;
    rdfs:label "Reference ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "6" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Optional internal or external identifier such as lab specimen ID or a medical image." ;
    dc:identifier "MKREFID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MK/MKRFTDTC> a sdtmig:Variable ;
    rdfs:label "Date/Time of Reference Time Point" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "42" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Date/time for a fixed reference time point defined by MKTPTREF." ;
    dc:identifier "MKRFTDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MK/MKSCAT> a sdtmig:Variable ;
    rdfs:label "Subcategory for Musculoskeletal Test" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "13" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to define a further categorization of MKCAT values." ;
    dc:identifier "MKSCAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MK/MKSEQ> a sdtmig:Variable ;
    rdfs:label "Sequence Number" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "4" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Sequence number to ensure uniqueness of records within a dataset for a subject (or within a parameter, in the case of the Trial Summary domain). May be any valid number (including decimals) and does not have to start at 1." ;
    dc:identifier "MKSEQ" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MK/MKSPID> a sdtmig:Variable ;
    rdfs:label "Sponsor-Defined Identifier" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "7" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Sponsor-defined identifier. Example: Preprinted line identifier on a Concomitant Medications page." ;
    dc:identifier "MKSPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MK/MKSTAT> a sdtmig:Variable ;
    rdfs:label "Completion Status" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66789> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "20" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to indicate that a question was not asked or a test was not done, or that a test was attempted but did not generate a result. Should be null if a result exists in MKORRES." ;
    dc:identifier "MKSTAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MK/MKSTRESC> a sdtmig:Variable ;
    rdfs:label "Character Result/Finding in Std Format" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "17" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Contains the result value for all findings, copied or derived from MKORRES in a standard format or in standard units. MKSTRESC should store all results or findings in character format; if results are numeric, they should also be stored in numeric format in MKSTRESN. For example, if various tests have results \"NONE\", \"NEG\", and \"NEGATIVE\" in MKORRES and these results effectively have the same meaning, they could be represented in standard format in MKSTRESC as \"NEGATIVE\"." ;
    dc:identifier "MKSTRESC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MK/MKSTRESN> a sdtmig:Variable ;
    rdfs:label "Numeric Result/Finding in Standard Units" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "18" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Used for continuous or numeric results or findings in standard format; copied in numeric format from MKSTRESC. MKSTRESN should store all numeric test results or findings." ;
    dc:identifier "MKSTRESN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MK/MKSTRESU> a sdtmig:Variable ;
    rdfs:label "Standard Units" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C71620> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "19" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Standardized units used for MKSTRESC and MKSTRESN." ;
    dc:identifier "MKSTRESU" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MK/MKTEST> a sdtmig:Variable ;
    rdfs:label "Name of Musculoskeletal Test" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C127270> ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "11" ;
    sdtmig:role "Synonym Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Long name For MKTESTCD. Examples: \"Tenderness Indicator\", \"Swollen Indicator\", \"Sharp/Genant JSN Score\"." ;
    dc:identifier "MKTEST" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MK/MKTESTCD> a sdtmig:Variable ;
    rdfs:label "Short Name of Musculoskeletal Test" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C127269> ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "10" ;
    sdtmig:role "Topic" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Short character value for MKTEST used as a column name when converting a dataset from a vertical format to a horizontal format. The value in MKTESTCD cannot be longer than 8 characters, nor can it start with a number (e.g., \"1TEST\" is not valid). MKTESTCD cannot contain characters other than letters, numbers, or underscores. Examples: \"TNDRIND\", \"SWLLIND\", \"SGJSNSCR\"." ;
    dc:identifier "MKTESTCD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MK/MKTPT> a sdtmig:Variable ;
    rdfs:label "Planned Time Point Name" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "38" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Text description of time when a measurement or observation should be taken as defined in the protocol. This may be represented as an elapsed time relative to a fixed reference point, such as time of last dose. See MKTPTNUM and MKTPTREF." ;
    dc:identifier "MKTPT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MK/MKTPTNUM> a sdtmig:Variable ;
    rdfs:label "Planned Time Point Number" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "39" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Numeric version of planned time point used in sorting." ;
    dc:identifier "MKTPTNUM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MK/MKTPTREF> a sdtmig:Variable ;
    rdfs:label "Time Point Reference" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "41" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Description of the fixed reference point referred to by MKELTM, MKTPTNUM, and MKTPT. Examples: \"PREVIOUS DOSE\", \"PREVIOUS MEAL\"." ;
    dc:identifier "MKTPTREF" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MK/STUDYID> a sdtmig:Variable ;
    rdfs:label "Study Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "1" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Unique identifier for a study." ;
    dc:identifier "STUDYID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MK/TAETORD> a sdtmig:Variable ;
    rdfs:label "Planned Order of Element within Arm" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "34" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Number that gives the planned order of the element within the arm for the element in which the assessment was made." ;
    dc:identifier "TAETORD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MK/USUBJID> a sdtmig:Variable ;
