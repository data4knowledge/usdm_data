    sdtmig:ordinal "23" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Qualifier for anatomical location further detailing laterality of intervention administration. Examples: \"RIGHT\", \"LEFT\", \"BILATERAL\"." ;
    dc:identifier "SRLAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SR/SRLOBXFL> a sdtmig:Variable ;
    rdfs:label "Last Observation Before Exposure Flag" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "25" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Operationally derived indicator used to identify the last non-missing value prior to RFXSTDTC. The value should be \"Y\" or null." ;
    dc:identifier "SRLOBXFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SR/SRLOC> a sdtmig:Variable ;
    rdfs:label "Location Used for Measurement" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C74456> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "22" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Location relevant to the collection of the measurement." ;
    dc:identifier "SRLOC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SR/SRMETHOD> a sdtmig:Variable ;
    rdfs:label "Method of Test or Examination" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C85492> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "24" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Method of test or examination. Examples: \"ELISA\", \"EIA\", \"MICRONEUTRALIZATION ASSAY\", \"PLAQUE REDUCTION NEUTRALIZATION ASSAY\"." ;
    dc:identifier "SRMETHOD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SR/SRNAM> a sdtmig:Variable ;
    rdfs:label "Vendor Name" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "20" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Name or identifier of the laboratory or vendor who provided the test results." ;
    dc:identifier "SRNAM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SR/SROBJ> a sdtmig:Variable ;
    rdfs:label "Object of the Observation" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "10" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to describe the object or focal point of the findings observation that is represented by --TEST. Examples: the dose of the immunogenic material or the allergen associated with the response (e.g., \"Johnson Grass IgE 0.15 BAU mL\")." ;
    dc:identifier "SROBJ" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SR/SRORRES> a sdtmig:Variable ;
    rdfs:label "Results or Findings in Original Units" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "13" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Results of measurement or finding as originally received or collected." ;
    dc:identifier "SRORRES" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SR/SRORRESU> a sdtmig:Variable ;
    rdfs:label "Original Units" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C71620> ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "14" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Original units in which the data were collected. The unit for SRORRES. Example: \"mm\"." ;
    dc:identifier "SRORRESU" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SR/SRREASND> a sdtmig:Variable ;
    rdfs:label "Reason Not Done" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "19" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Describes why a measurement or test was not performed. Used in conjunction with SRSTAT when value is \"NOT DONE\"." ;
    dc:identifier "SRREASND" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SR/SRREFID> a sdtmig:Variable ;
