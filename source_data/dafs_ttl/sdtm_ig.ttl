    sdtmig:ordinal "16" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "The status indicates that the prespecified question was not asked/answered." ;
    dc:identifier "MHSTAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MH/MHSTDTC> a sdtmig:Variable ;
