    dc:identifier "GFCOPYID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/GF/GFDRVFL> a sdtmig:Variable ;
    rdfs:label "Derived Flag" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "45" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to indicate a derived record (e.g., a record that represents the average of other records such as a computed baseline). Should be \"Y\" or null." ;
    dc:identifier "GFDRVFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/GF/GFDTC> a sdtmig:Variable ;
    rdfs:label "Date/Time of Specimen Collection" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "51" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Date and time of specimen collection." ;
    dc:identifier "GFDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/GF/GFDY> a sdtmig:Variable ;
    rdfs:label "Study Day of Specimen Collection" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "52" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Actual study day of visit/collection/exam expressed in integer days relative to the sponsor-defined RFSTDTC in Demographics." ;
    dc:identifier "GFDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/GF/GFELTM> a sdtmig:Variable ;
    rdfs:label "Planned Elapsed Time from Time Point Ref" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "55" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 duration" ;
    dc:description "Elapsed time relative to a planned fixed reference (GFTPTREF). This variable is useful where there are repetitive measures. Not a clock time or a date time variable, but an interval, represented as ISO duration." ;
    dc:identifier "GFELTM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/GF/GFGENLOC> a sdtmig:Variable ;
    rdfs:label "Genetic Location" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "31" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Specifies the location within a sequence for the observed value in GFORRES." ;
    dc:identifier "GFGENLOC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/GF/GFGENREF> a sdtmig:Variable ;
    rdfs:label "Genome Reference" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "27" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "An identifier for the genome reference used to generate the reported result. For example, Genome Reference Consortium Human Build 38 patch release 13 may be represented as \"GRCh38.p13\"." ;
    dc:identifier "GFGENREF" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/GF/GFGENSR> a sdtmig:Variable ;
    rdfs:label "Genetic Sub-Region" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "32" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "The portion of the locus in which the variation was found. Examples: \"Exon 15\", \"Kinase domain\"." ;
    dc:identifier "GFGENSR" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/GF/GFGRPID> a sdtmig:Variable ;
    rdfs:label "Group ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "7" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to link together a block of related records within a subject in a domain." ;
    dc:identifier "GFGRPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/GF/GFINHERT> a sdtmig:Variable ;
    rdfs:label "Inheritability" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C181177> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "26" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifies whether the variation can be passed to the next generation." ;
    dc:identifier "GFINHERT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/GF/GFLLOQ> a sdtmig:Variable ;
