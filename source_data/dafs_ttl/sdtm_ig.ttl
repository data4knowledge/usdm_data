    sdtmig:core "Perm" ;
    sdtmig:ordinal "23" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Collection date and time of the subject characteristic represented in ISO 8601 character format." ;
    dc:identifier "SCDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SC/SCDY> a sdtmig:Variable ;
    rdfs:label "Study Day of Examination" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "24" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Study day of collection, measured as integer days. Algorithm for calculations must be relative to the sponsor-defined RFSTDTC variable in Demographics." ;
    dc:identifier "SCDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SC/SCGRPID> a sdtmig:Variable ;
    rdfs:label "Group ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "5" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to tie together a block of related records in a single domain for a subject." ;
    dc:identifier "SCGRPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SC/SCORRES> a sdtmig:Variable ;
    rdfs:label "Result or Finding in Original Units" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "11" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Result of the subject characteristic as originally received or collected." ;
    dc:identifier "SCORRES" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SC/SCORRESU> a sdtmig:Variable ;
    rdfs:label "Original Units" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C71620> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "12" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Original unit in which the data were collected. The unit for SCORRES." ;
    dc:identifier "SCORRESU" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SC/SCREASND> a sdtmig:Variable ;
    rdfs:label "Reason Not Performed" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "17" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Describes why the observation has no result. Example: \"Subject refused\". Used in conjunction with SCSTAT when value is \"NOT DONE\"." ;
    dc:identifier "SCREASND" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SC/SCSCAT> a sdtmig:Variable ;
