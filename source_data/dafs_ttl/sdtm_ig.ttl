    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Start date/time of the medical history event represented in ISO 8601 character format." ;
    dc:identifier "MHSTDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MH/MHTERM> a sdtmig:Variable ;
