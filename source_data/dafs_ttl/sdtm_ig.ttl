<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CE/CEBODSYS> a sdtmig:Variable ;
    rdfs:label "Body System or Organ Class" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "16" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Dictionary-derived. Body system or organ class that is involved in an event or measurement from a standard hierarchy (e.g., MedDRA). When using a multi-axial dictionary such as MedDRA, this should contain the SOC used for the sponsor\'s analyses and summary tables, which may not necessarily be the primary SOC." ;
    dc:identifier "CEBODSYS" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CE/CECAT> a sdtmig:Variable ;
    rdfs:label "Category for the Clinical Event" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "10" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to define a category of related records." ;
    dc:identifier "CECAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CE/CEDECOD> a sdtmig:Variable ;
    rdfs:label "Dictionary-Derived Term" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "9" ;
    sdtmig:role "Synonym Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Controlled terminology for the name of the clinical event. The sponsor is expected to provide the dictionary name and version used to map the terms utilizing the external codelist element in the Define-XML document." ;
    dc:identifier "CEDECOD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CE/CEDTC> a sdtmig:Variable ;
    rdfs:label "Date/Time of Event Collection" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "21" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Collection date and time for the clinical event observation represented in ISO 8601 character format." ;
    dc:identifier "CEDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CE/CEDY> a sdtmig:Variable ;
    rdfs:label "Study Day of Event Collection" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "24" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Study day of clinical event collection, measured as integer days. Algorithm for calculations must be relative to the sponsor-defined RFSTDTC variable in Demographics. This formula should be consistent across the submission." ;
    dc:identifier "CEDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CE/CEENDTC> a sdtmig:Variable ;
    rdfs:label "End Date/Time of Clinical Event" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "23" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "End date/time of the clinical event, represented in ISO 8601 character format." ;
    dc:identifier "CEENDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CE/CEENDY> a sdtmig:Variable ;
    rdfs:label "Study Day of End of Event" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "26" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Actual study day of end of the clinical event expressed in integer days relative to the sponsor-defined RFSTDTC in Demographics." ;
    dc:identifier "CEENDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CE/CEENRF> a sdtmig:Variable ;
    rdfs:label "End Relative to Reference Period" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66728> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "28" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Describes the end of the event relative to the sponsor-defined reference period. The sponsor-defined reference period is a continuous period of time defined by a discrete starting point and a discrete ending point (represented by RFSTDTC and RFENDTC in Demographics). \\n Not all values of the codelist are allowable for this variable. See Section 4.4.7, Use of Relative Timing Variables." ;
    dc:identifier "CEENRF" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CE/CEENRTPT> a sdtmig:Variable ;
    rdfs:label "End Relative to Reference Time Point" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66728> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "31" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifies the end of the observation as being before or after the sponsor-defined reference time point defined by variable CEENTPT. \\n Not all values of the codelist are allowable for this variable. See Section 4.4.7, Use of Relative Timing Variables." ;
    dc:identifier "CEENRTPT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CE/CEENTPT> a sdtmig:Variable ;
    rdfs:label "End Reference Time Point" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "32" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Description or date/time in ISO 8601 character format of the reference point referred to by CEENRTPT. Examples: \"2003-12-25\", \"VISIT 2\"." ;
    dc:identifier "CEENTPT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CE/CEGRPID> a sdtmig:Variable ;
    rdfs:label "Group ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "5" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to link together a block of related records for a subject within a domain." ;
    dc:identifier "CEGRPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CE/CEOCCUR> a sdtmig:Variable ;
    rdfs:label "Clinical Event Occurrence" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "13" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used when the occurrence of specific events is solicited, to indicate whether or not a clinical event occurred. Values are null for spontaneously reported events." ;
    dc:identifier "CEOCCUR" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CE/CEPRESP> a sdtmig:Variable ;
    rdfs:label "Clinical Event Pre-specified" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "12" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to indicate whether the event in CETERM was prespecified. Value is \"Y\" for prespecified events and null for spontaneously reported events." ;
    dc:identifier "CEPRESP" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CE/CEREASND> a sdtmig:Variable ;
    rdfs:label "Reason Clinical Event Not Collected" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "15" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Describes the reason clinical event data was not collected. Used in conjunction with CESTAT when value is \"NOT DONE\"." ;
    dc:identifier "CEREASND" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CE/CEREFID> a sdtmig:Variable ;
    rdfs:label "Reference ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "6" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Internal or external identifier (e.g., lab specimen ID, UUID for an ECG waveform or medical image)." ;
    dc:identifier "CEREFID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CE/CESCAT> a sdtmig:Variable ;
    rdfs:label "Subcategory for the Clinical Event" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "11" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "A further categorization of the condition or event." ;
    dc:identifier "CESCAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CE/CESEQ> a sdtmig:Variable ;
    rdfs:label "Sequence Number" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "4" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Sequence number given to ensure uniqueness of subject records within a domain. May be any valid number." ;
    dc:identifier "CESEQ" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CE/CESEV> a sdtmig:Variable ;
    rdfs:label "Severity/Intensity" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C165643> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "17" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "The severity or intensity of the event. Examples: \"MILD\", \"MODERATE\", \"SEVERE\"." ;
    dc:identifier "CESEV" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CE/CESPID> a sdtmig:Variable ;
    rdfs:label "Sponsor-Defined Identifier" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "7" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Sponsor-defined identifier." ;
    dc:identifier "CESPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CE/CESTAT> a sdtmig:Variable ;
    rdfs:label "Completion Status" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66789> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "14" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "The status indicates that a question from a prespecified list was not answered." ;
    dc:identifier "CESTAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CE/CESTDTC> a sdtmig:Variable ;
    rdfs:label "Start Date/Time of Clinical Event" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "22" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Start date/time of the clinical event represented in ISO 8601 character format." ;
    dc:identifier "CESTDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CE/CESTDY> a sdtmig:Variable ;
    rdfs:label "Study Day of Start of Event" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "25" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Actual study day of start of the clinical event expressed in integer days relative to the sponsor-defined RFSTDTC in Demographics." ;
    dc:identifier "CESTDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CE/CESTRF> a sdtmig:Variable ;
    rdfs:label "Start Relative to Reference Period" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66728> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "27" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Describes the start of the clinical event relative to the sponsor-defined reference period. The sponsor-defined reference period is a continuous period of time defined by a discrete starting point and a discrete ending point (represented by RFSTDTC and RFENDTC in Demographics). \\n Not all values of the codelist are allowable for this variable. See Section 4.4.7, Use of Relative Timing Variables." ;
    dc:identifier "CESTRF" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CE/CESTRTPT> a sdtmig:Variable ;
    rdfs:label "Start Relative to Reference Time Point" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66728> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "29" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifies the start of the observation as being before or after the reference time point defined by variable CESTTPT. \\n Not all values of the codelist are allowable for this variable. See Section 4.4.7, Use of Relative Timing Variables." ;
    dc:identifier "CESTRTPT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CE/CESTTPT> a sdtmig:Variable ;
    rdfs:label "Start Reference Time Point" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "30" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Description or date/time in ISO 8601 character format of the sponsor-defined reference point referred to by --STRTPT. Examples: \"2003-12-15\", \"VISIT 1\"." ;
    dc:identifier "CESTTPT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CE/CETERM> a sdtmig:Variable ;
    rdfs:label "Reported Term for the Clinical Event" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "8" ;
    sdtmig:role "Topic" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Term for the medical condition or event. Most likely preprinted on CRF." ;
    dc:identifier "CETERM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CE/CETOXGR> a sdtmig:Variable ;
    rdfs:label "Standard Toxicity Grade" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "18" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Toxicity grade according to a standard toxicity scale (e.g., Common Terminology Criteria for Adverse Events (CTCAE) v3.0). Sponsor should specify name of the scale and version used in the metadata. If value is from a numeric scale, represent only the number (e.g., \"2\", not \"Grade 2\")." ;
    dc:identifier "CETOXGR" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CE/DOMAIN> a sdtmig:Variable ;
    rdfs:label "Domain Abbreviation" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "2" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Two-character abbreviation for the domain." ;
    dc:identifier "DOMAIN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CE/EPOCH> a sdtmig:Variable ;
    rdfs:label "Epoch" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C99079> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "20" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Epoch associated with the start date/time of the clinical event." ;
    dc:identifier "EPOCH" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CE/STUDYID> a sdtmig:Variable ;
    rdfs:label "Study Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "1" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Unique identifier for a study." ;
    dc:identifier "STUDYID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CE/TAETORD> a sdtmig:Variable ;
    rdfs:label "Planned Order of Element within Arm" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "19" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Number that gives the planned order of the element within the arm for the element in which the clinical event started." ;
    dc:identifier "TAETORD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CE/USUBJID> a sdtmig:Variable ;
    rdfs:label "Unique Subject Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "3" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifier used to uniquely identify a subject across all studies for all applications or submissions involving the product." ;
    dc:identifier "USUBJID" .

