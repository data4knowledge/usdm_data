<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RS/DOMAIN> a sdtmig:Variable ;
    rdfs:label "Domain Abbreviation" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "2" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Two-character abbreviation for the domain." ;
    dc:identifier "DOMAIN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RS/EPOCH> a sdtmig:Variable ;
    rdfs:label "Epoch" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C99079> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "33" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Epoch associated with the date/time at which the assessment was made." ;
    dc:identifier "EPOCH" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RS/RSACPTFL> a sdtmig:Variable ;
    rdfs:label "Accepted Record Flag" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "28" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "In cases where more than 1 independent assessor (e.g., \"RADIOLOGIST 1\", \"RADIOLOGIST 2\", \"ADJUDICATOR\") provides an evaluation of response, this flag identifies the record that is considered to be the accepted evaluation." ;
    dc:identifier "RSACPTFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RS/RSBLFL> a sdtmig:Variable ;
    rdfs:label "Baseline Flag" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "24" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Indicator used to identify a baseline value. Should be \"Y\" or null. Note that --BLFL is retained for backward compatibility. The authoritative baseline for statistical analysis is in an ADaM dataset." ;
    dc:identifier "RSBLFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RS/RSCAT> a sdtmig:Variable ;
    rdfs:label "Category for Assessment" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C124298> ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "12" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to define a category of related records across subjects. Examples: \"RECIST 1.1\", \"CHILD-PUGH CLASSIFICATION\". There are separate codelists used for RSCAT where the choice depends on whether the related records are about an oncology response criterion or another clinical classification. \\n RSCAT is required for clinical classifications other than oncology response criteria." ;
    dc:identifier "RSCAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RS/RSDRVFL> a sdtmig:Variable ;
    rdfs:label "Derived Flag" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "25" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to indicate a derived record (e.g., a record that represents the average of other records such as a computed baseline). Should be \"Y\" or null." ;
    dc:identifier "RSDRVFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RS/RSDTC> a sdtmig:Variable ;
    rdfs:label "Date/Time of Assessment" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "34" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Collection date and time of the assessment represented in ISO 8601 character format." ;
    dc:identifier "RSDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RS/RSDY> a sdtmig:Variable ;
    rdfs:label "Study Day of Assessment" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "35" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Study day of the assessment, measured as integer days. Algorithm for calculations must be relative to the sponsor-defined RFSTDTC variable in Demographics." ;
    dc:identifier "RSDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RS/RSELTM> a sdtmig:Variable ;
    rdfs:label "Planned Elapsed Time from Time Point Ref" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "38" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 duration" ;
    dc:description "Planned elapsed time in ISO 8601 character format relative to a planned fixed reference (RSTPTREF; e.g., \"PREVIOUS DOSE\", \"PREVIOUS MEAL\"). This variable is useful where there are repetitive measures. Not a clock time or a date/time variable, but an interval, represented as ISO duration." ;
    dc:identifier "RSELTM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RS/RSENRTPT> a sdtmig:Variable ;
    rdfs:label "End Relative to Reference Time Point" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66728> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "45" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifies the end of the observation as being before or after the sponsor-defined reference time point defined by variable RSENTPT. \\n Not all values of the codelist are allowable for this variable. See Section 4.4.7, Use of Relative Timing Variables." ;
    dc:identifier "RSENRTPT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RS/RSENTPT> a sdtmig:Variable ;
    rdfs:label "End Reference Time Point" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "46" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Description or date/time in ISO 8601 character format of the sponsor-defined reference point referred to by RSENRTPT. Examples: \"2003-12-25\", \"VISIT 2\"." ;
    dc:identifier "RSENTPT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RS/RSEVAL> a sdtmig:Variable ;
    rdfs:label "Evaluator" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C78735> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "26" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Role of the person who provided the evaluation. Used only for results that are subjective (e.g., assigned by a person or a group). Examples: \"ADJUDICATION COMMITTEE\", \"INDEPENDENT ASSESSOR\", \"RADIOLOGIST\". \\n RSEVAL is expected for oncology response criteria. It can be left null when the investigator provides the complete set of data in the domain. However, the column should contain no null values when data from one or more independent assessors is included, meaning that the rows attributed to the investigator should contain a value of \"INVESTIGATOR\"." ;
    dc:identifier "RSEVAL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RS/RSEVALID> a sdtmig:Variable ;
    rdfs:label "Evaluator Identifier" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C96777> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "27" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to distinguish multiple evaluators with the same role recorded in RSEVAL. Examples: \"RADIOLOGIST1\", \"RADIOLOGIST2\". See assumptions in Section 6.3.9.3.1, Disease Response Use Case." ;
    dc:identifier "RSEVALID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RS/RSEVINTX> a sdtmig:Variable ;
    rdfs:label "Evaluation Interval Text" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "42" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Evaluation interval associated with an observation, where the interval is not able to be represented in ISO 8601 format. Examples: \"LIFETIME\", \"LAST NIGHT\", \"RECENTLY\", \"OVER THE LAST FEW WEEKS\"." ;
    dc:identifier "RSEVINTX" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RS/RSEVLINT> a sdtmig:Variable ;
    rdfs:label "Evaluation Interval" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "41" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 duration or interval" ;
    dc:description "Duration of interval associated with an observation such as a finding RSTESTCD, represented in ISO 8601 character format. Example: \"-P2M\" to represent a period of the past 2 months as the evaluation interval." ;
    dc:identifier "RSEVLINT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RS/RSGRPID> a sdtmig:Variable ;
    rdfs:label "Group ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "5" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to link together a block of related records within a subject in a domain." ;
    dc:identifier "RSGRPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RS/RSLNKGRP> a sdtmig:Variable ;
    rdfs:label "Link Group ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "9" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "A grouping identifier used to link the response assessment to a group of measurement/assessment records which were used in the assessment of the response. LNKGRP values group records within USUBJID." ;
    dc:identifier "RSLNKGRP" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RS/RSLNKID> a sdtmig:Variable ;
    rdfs:label "Link ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "8" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "An identifier used to link the response assessment to the related measurement record in another domain which was used to determine the response result. LNKID values group records within USUBJID." ;
    dc:identifier "RSLNKID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RS/RSLOBXFL> a sdtmig:Variable ;
    rdfs:label "Last Observation Before Exposure Flag" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "23" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Operationally derived indicator used to identify the last non-missing value prior to RFXSTDTC. The value should be \"Y\" or null. \\n When a clinical classification is assessed at multiple times, including baseline, RSLOBXFL should be included in the dataset." ;
    dc:identifier "RSLOBXFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RS/RSMETHOD> a sdtmig:Variable ;
    rdfs:label "Method of Test or Examination" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C158113> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "22" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Method of the test or examination." ;
    dc:identifier "RSMETHOD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RS/RSNAM> a sdtmig:Variable ;
    rdfs:label "Vendor Name" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "21" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "The name or identifier of the vendor that performed the response assessment. This column can be left null when the investigator provides the complete set of data in the domain." ;
    dc:identifier "RSNAM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RS/RSORRES> a sdtmig:Variable ;
    rdfs:label "Result or Finding in Original Units" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "14" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Result of the response assessment as originally received, collected, or calculated." ;
    dc:identifier "RSORRES" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RS/RSORRESU> a sdtmig:Variable ;
    rdfs:label "Original Units" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C71620> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "15" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Unit for RSORRES." ;
    dc:identifier "RSORRESU" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RS/RSREASND> a sdtmig:Variable ;
    rdfs:label "Reason Not Done" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "20" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Describes why a response assessment was not performed. Examples: \"All target tumors not evaluated\", \"Subject does not have non-target tumors\". Used in conjunction with RSSTAT when value is \"NOT DONE\"." ;
    dc:identifier "RSREASND" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RS/RSREFID> a sdtmig:Variable ;
    rdfs:label "Reference ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "6" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Internal or external identifier." ;
    dc:identifier "RSREFID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RS/RSRFTDTC> a sdtmig:Variable ;
    rdfs:label "Date/Time of Reference Time Point" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "40" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Date/time for a fixed reference time point defined by RSTPTREF in ISO 8601 character format." ;
    dc:identifier "RSRFTDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RS/RSSCAT> a sdtmig:Variable ;
    rdfs:label "Subcategory" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "13" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to define a further categorization of RSCAT values." ;
    dc:identifier "RSSCAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RS/RSSEQ> a sdtmig:Variable ;
    rdfs:label "Sequence Number" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "4" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Sequence number given to ensure uniqueness within a dataset for a subject. May be any valid number." ;
    dc:identifier "RSSEQ" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RS/RSSPID> a sdtmig:Variable ;
    rdfs:label "Sponsor-Defined Identifier" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "7" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Sponsor-defined identifier." ;
    dc:identifier "RSSPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RS/RSSTAT> a sdtmig:Variable ;
    rdfs:label "Completion Status" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66789> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "19" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to indicate the response assessment was not performed. Should be null if a result exists in RSORRES." ;
    dc:identifier "RSSTAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RS/RSSTRESC> a sdtmig:Variable ;
    rdfs:label "Character Result/Finding in Std Format" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C96785> ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "16" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Contains the result value for the response assessment, copied, or derived from RSORRES in a standard format or standard units. RSSTRESC should store all results or findings in character format. \\n For Clinical Classifications, this may be a score." ;
    dc:identifier "RSSTRESC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RS/RSSTRESN> a sdtmig:Variable ;
    rdfs:label "Numeric Result/Finding in Standard Units" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "17" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Used for continuous or numeric results or findings in standard format; copied in numeric format from --STRESC. --STRESN should store all numeric test results or findings. For Clinical Classifications, this may be a score." ;
    dc:identifier "RSSTRESN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RS/RSSTRESU> a sdtmig:Variable ;
    rdfs:label "Standard Units" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C71620> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "18" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Standardized units used for RSSTRESC and RSSTRESN." ;
    dc:identifier "RSSTRESU" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RS/RSSTRTPT> a sdtmig:Variable ;
    rdfs:label "Start Relative to Reference Time Point" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66728> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "43" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifies the start of the observation as being before or after the sponsor-defined reference time point defined by variable RSSTTPT. \\n Not all values of the codelist are allowable for this variable. See Section 4.4.7, Use of Relative Timing Variables." ;
    dc:identifier "RSSTRTPT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RS/RSSTTPT> a sdtmig:Variable ;
    rdfs:label "Start Reference Time Point" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "44" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Description or date/time in ISO 8601 character format of the sponsor-defined reference point referred to by RSSTRTPT. Examples: \"2003-12-15\", \"VISIT 1\"." ;
    dc:identifier "RSSTTPT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RS/RSTEST> a sdtmig:Variable ;
    rdfs:label "Assessment Name" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C96781> ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "11" ;
    sdtmig:role "Synonym Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Verbatim name of the response assessment. The value in RSTEST cannot be longer than 40 characters. \\n There are separate codelists used for RSTEST where the choice depends on the value of RSCAT. Codelist \"ONCRTS\" is used for oncology response criteria (when RSCAT is a term in codelist \"ONCRSCAT\"). Examples: \"Target Response\", \"Non-target Response\", \"Overall Response\", \"Symptomatic Deterioration\". For Clinical Classifications (when RSCAT is a term in codelist \"CCCAT\"), QRS Naming Rules apply. These instruments have individual dedicated terminology codelists." ;
    dc:identifier "RSTEST" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RS/RSTESTCD> a sdtmig:Variable ;
    rdfs:label "Assessment Short Name" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C96782> ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "10" ;
    sdtmig:role "Topic" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Short name of the TEST in RSTEST. The value in RSTESTCD cannot be longer than 8 characters, nor can it start with a number (e.g., \"1TEST\" is not valid). RSTESTCD cannot contain characters other than letters, numbers, or underscores. Examples: \"TRGRESP\", \"NTRGRESP\", \"OVRLRESP\", \"SYMPTDTR\", \"CPS0102\". \\n There are separate codelists used for RSTESTCD where the choice depends on the value of RSCAT. Codelist \"ONCRTSCD\" is used for oncology response criteria (when RSCAT is a term in codelist \"ONCRSCAT\"). Examples: TRGRESP, \"NTRGRESP, \"OVRLRESP\". For Clinical Classifications (when RSCAT is a term in codelist \"CCCAT\"), QRS Naming Rules apply. These instruments have individual dedicated terminology codelists." ;
    dc:identifier "RSTESTCD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RS/RSTPT> a sdtmig:Variable ;
    rdfs:label "Planned Time Point Name" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "36" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Text description of time when a measurement or observation should be taken as defined in the protocol. This may be represented as an elapsed time relative to a fixed reference point, such as time of last dose. See RSTPTNUM and RSTPTREF." ;
    dc:identifier "RSTPT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RS/RSTPTNUM> a sdtmig:Variable ;
    rdfs:label "Planned Time Point Number" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "37" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Numeric version of planned time point used in sorting." ;
    dc:identifier "RSTPTNUM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RS/RSTPTREF> a sdtmig:Variable ;
    rdfs:label "Time Point Reference" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "39" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Description of the fixed reference point referred to by RSELTM, RSTPTNUM, and RSTPT. Examples: \"PREVIOUS DOSE\", \"PREVIOUS MEAL\"." ;
    dc:identifier "RSTPTREF" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RS/STUDYID> a sdtmig:Variable ;
    rdfs:label "Study Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "1" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Unique identifier for a study." ;
    dc:identifier "STUDYID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RS/TAETORD> a sdtmig:Variable ;
    rdfs:label "Planned Order of Element within Arm" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "32" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Number that gives the planned order of the element within the arm for the element in which the assessment was made." ;
    dc:identifier "TAETORD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RS/USUBJID> a sdtmig:Variable ;
    rdfs:label "Unique Subject Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "3" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifier used to uniquely identify a subject across all studies for all applications or submissions involving the product." ;
    dc:identifier "USUBJID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RS/VISIT> a sdtmig:Variable ;
    rdfs:label "Visit Name" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "30" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Protocol-defined description of a clinical encounter." ;
    dc:identifier "VISIT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RS/VISITDY> a sdtmig:Variable ;
    rdfs:label "Planned Study Day of Visit" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "31" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Planned study day of the visit based upon RFSTDTC in Demographics." ;
    dc:identifier "VISITDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RS/VISITNUM> a sdtmig:Variable ;
    rdfs:label "Visit Number" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "29" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Clinical encounter number. Numeric version of VISIT, used for sorting." ;
    dc:identifier "VISITNUM" .

