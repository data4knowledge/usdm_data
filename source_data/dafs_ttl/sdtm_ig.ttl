    sdtmig:core "Perm" ;
    sdtmig:ordinal "16" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to define a further categorization of GFCAT values." ;
    dc:identifier "GFSCAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/GF/GFSEQ> a sdtmig:Variable ;
    rdfs:label "Sequence Number" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "6" ;
    sdtmig:role "Identifier" ;
