        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SUPPQUAL/QLABEL>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SUPPQUAL/QNAM>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SUPPQUAL/QORIG>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SUPPQUAL/QVAL>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SUPPQUAL/RDOMAIN>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SUPPQUAL/STUDYID>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SUPPQUAL/USUBJID> ;
    sdtmig:ordinal "51" ;
    sdtmig:structure "One record per supplemental qualifier per related parent domain record(s)" ;
    dc:description "Supplemental Qualifiers for [domain name]" ;
    dc:identifier "SUPPQUAL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SUPPQUAL/IDVAR> a sdtmig:Variable ;
    rdfs:label "Identifying Variable" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "4" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifying variable in the dataset that identifies the related record(s). Examples: --SEQ, --GRPID." ;
    dc:identifier "IDVAR" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SUPPQUAL/IDVARVAL> a sdtmig:Variable ;
