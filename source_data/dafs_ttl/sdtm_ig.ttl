    sdtmig:simpleDatatype "Num" ;
    dc:description "Numeric version of planned time point used in sorting." ;
    dc:identifier "FTTPTNUM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/FT/FTTPTREF> a sdtmig:Variable ;
    rdfs:label "Time Point Reference" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "37" ;
