    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to indicate a derived record. The value should be \"Y\" or null. Records that represent the average of other records, or that do not come from the CRF, or are not as originally collected or received are examples of records that would be derived for the submission datasets. If EGDRVFL=\"Y\", then EGORRES could be null, with EGSTRESC and EGSTRESN (if the result is numeric) having the derived value." ;
    dc:identifier "EGDRVFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EG/EGDTC> a sdtmig:Variable ;
    rdfs:label "Date/Time of ECG" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "38" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Date/Time of ECG." ;
    dc:identifier "EGDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EG/EGDY> a sdtmig:Variable ;
    rdfs:label "Study Day of ECG" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "39" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Study day of the ECG, measured as integer days. Algorithm for calculations must be relative to the sponsor-defined RFSTDTC variable in Demographics." ;
    dc:identifier "EGDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EG/EGELTM> a sdtmig:Variable ;
    rdfs:label "Planned Elapsed Time from Time Point Ref" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "42" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 duration" ;
    dc:description "Planned elapsed time (in ISO 8601) relative to a fixed time point reference (EGTPTREF). Not a clock time or a date time variable. Represented as an ISO 8601 duration. Examples: \"-PT15M\" to represent the period of 15 minutes prior to the reference point indicated by EGTPTREF, \"PT8H\" to represent the period of 8 hours after the reference point indicated by EGTPTREF." ;
    dc:identifier "EGELTM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EG/EGEVAL> a sdtmig:Variable ;
    rdfs:label "Evaluator" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C78735> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "29" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Role of the person who provided the evaluation. Used only for results that are subjective (e.g., assigned by a person or a group). Should be null for records that contain collected or derived data. Examples: \"INVESTIGATOR\", \"ADJUDICATION COMMITTEE\", \"VENDOR\"." ;
    dc:identifier "EGEVAL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EG/EGEVALID> a sdtmig:Variable ;
    rdfs:label "Evaluator Identifier" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C96777> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "30" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to distinguish multiple evaluators with the same role recorded in EGEVAL. Examples: \"RADIOLOGIST 1\" or \"RADIOLOGIST 2\"." ;
    dc:identifier "EGEVALID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EG/EGGRPID> a sdtmig:Variable ;
    rdfs:label "Group ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "6" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to tie together a block of related records in a single domain for a subject." ;
    dc:identifier "EGGRPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EG/EGLEAD> a sdtmig:Variable ;
    rdfs:label "Lead Location Used for Measurement" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C90013> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "25" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "The lead used for the measurement. Examples: \"LEAD 1\", \"LEAD 2\", \"LEAD rV2\", \"LEAD V1\"." ;
    dc:identifier "EGLEAD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EG/EGLOBXFL> a sdtmig:Variable ;
    rdfs:label "Last Observation Before Exposure Flag" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "26" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Operationally derived indicator used to identify the last non-missing value prior to RFXSTDTC. The value should be \"Y\" or null." ;
    dc:identifier "EGLOBXFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EG/EGMETHOD> a sdtmig:Variable ;
    rdfs:label "Method of Test or Examination" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C71151> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "24" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Method of the ECG test. Example: \"12-LEAD STANDARD\"." ;
    dc:identifier "EGMETHOD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EG/EGNAM> a sdtmig:Variable ;
    rdfs:label "Vendor Name" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "23" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Name or identifier of the laboratory or vendor providing the test results." ;
    dc:identifier "EGNAM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EG/EGORRES> a sdtmig:Variable ;
    rdfs:label "Result or Finding in Original Units" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "15" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Result of the ECG measurement or finding as originally received or collected. Examples of expected values are \"62\" or \"0.151\" when the result is an interval or measurement, or \"ATRIAL FIBRILLATION\" or \"QT PROLONGATION\" when the result is a finding." ;
    dc:identifier "EGORRES" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EG/EGORRESU> a sdtmig:Variable ;
    rdfs:label "Original Units" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C71620> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "16" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Original units in which the data were collected. The unit for EGORRES. Examples: \"sec\", \"msec\"." ;
    dc:identifier "EGORRESU" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EG/EGPOS> a sdtmig:Variable ;
    rdfs:label "ECG Position of Subject" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C71148> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "14" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Position of the subject during a measurement or examination. Examples: \"SUPINE\", \"STANDING\", \"SITTING\"." ;
    dc:identifier "EGPOS" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EG/EGREASND> a sdtmig:Variable ;
    rdfs:label "Reason ECG Not Done" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "21" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Describes why a measurement or test was not performed. Examples: \"BROKEN EQUIPMENT\", \"SUBJECT REFUSED\". Used in conjunction with EGSTAT when value is \"NOT DONE\"." ;
    dc:identifier "EGREASND" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EG/EGREFID> a sdtmig:Variable ;
    rdfs:label "ECG Reference ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "7" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Internal or external ECG identifier. Example: \"334PT89\"." ;
    dc:identifier "EGREFID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EG/EGREPNUM> a sdtmig:Variable ;
    rdfs:label "Repetition Number" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "32" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "The incidence number of a test that is repeated within a given timeframe for the same test. The level of granularity can vary (e.g., within a time point, within a visit). Examples: multiple measurements of blood pressure, multiple analyses of a sample." ;
    dc:identifier "EGREPNUM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EG/EGRFTDTC> a sdtmig:Variable ;
    rdfs:label "Date/Time of Reference Time Point" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "44" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Date/time for a fixed reference time point defined by EGTPTREF." ;
    dc:identifier "EGRFTDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EG/EGSCAT> a sdtmig:Variable ;
    rdfs:label "Subcategory for ECG" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "13" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "A further categorization of the ECG." ;
    dc:identifier "EGSCAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EG/EGSEQ> a sdtmig:Variable ;
    rdfs:label "Sequence Number" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "5" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Sequence number given to ensure uniqueness of subject records within a domain. May be any valid number." ;
    dc:identifier "EGSEQ" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EG/EGSPID> a sdtmig:Variable ;
    rdfs:label "Sponsor-Defined Identifier" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "8" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Sponsor-defined reference number. May be printed on the CRF as an explicit line identifier or defined in the sponsor\'s operational database. Example: Line number on the ECG page." ;
    dc:identifier "EGSPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EG/EGSTAT> a sdtmig:Variable ;
    rdfs:label "Completion Status" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66789> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "20" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to indicate an ECG was not done, or an ECG measurement was not taken. Should be null if a result exists in EGORRES." ;
    dc:identifier "EGSTAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EG/EGSTRESC> a sdtmig:Variable ;
    rdfs:label "Character Result/Finding in Std Format" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C71150> ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "17" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Contains the result value for all findings copied or derived from EGORRES, in a standard format or standard units. EGSTRESC should store all results or findings in character format; if results are numeric, they should also be stored in numeric format in EGSTRESN. For example, if a test has results of 62 beats/min, then EGORRES = \"62\", EGORRESU = \"beats/min\", EGSTRESC = \"62\", EGSTRESN = 62, and EGSTRESU = \"beats/min\" . For other examples, see Original and Standardized Results. Additional examples of result data: \"SINUS BRADYCARDIA\", \"ATRIAL FLUTTER\", \"ATRIAL FIBRILLATION\". \\n Test results are in 3 separate codelists: EGSTRESC for abnormal test results based on regular 10-second ECGs; HESTRESC for abnormal test results based on Holter monitoring, and NORMABNM for generic test results and/or responses to EGTEST = \"Interpretation\"." ;
    dc:identifier "EGSTRESC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EG/EGSTRESN> a sdtmig:Variable ;
    rdfs:label "Numeric Result/Finding in Standard Units" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "18" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Used for continuous or numeric results or findings in standard format; copied in numeric format from EGSTRESC. EGSTRESN should store all numeric test results or findings." ;
    dc:identifier "EGSTRESN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EG/EGSTRESU> a sdtmig:Variable ;
    rdfs:label "Standard Units" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C71620> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "19" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Standardized units used for EGSTRESC and EGSTRESN." ;
    dc:identifier "EGSTRESU" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EG/EGTEST> a sdtmig:Variable ;
    rdfs:label "ECG Test or Examination Name" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C71152> ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "11" ;
    sdtmig:role "Synonym Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Verbatim name of the test or examination used to obtain the measurement or finding. The value in EGTEST cannot be longer than 40 characters. Examples: \"PR Interval, Aggregate\", \"QRS Duration, Aggregate\". \\n Test names are in 2 separate codelists, 1 for tests based on regular 10-second ECGs (EGTEST) and 1 for tests based on Holter monitoring (HETEST)." ;
    dc:identifier "EGTEST" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EG/EGTESTCD> a sdtmig:Variable ;
    rdfs:label "ECG Test or Examination Short Name" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C71153> ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "10" ;
    sdtmig:role "Topic" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Short name of the measurement, test, or examination described in EGTEST. It can be used as a column name when converting a dataset from a vertical to a horizontal format. The value in EGTESTCD cannot be longer than 8 characters, nor can it start with a number (e.g., \"1TEST\" is not valid). EGTESTCD cannot contain characters other than letters, numbers, or underscores. Examples: \"PRAG\", \"QRSAG\". \\n Test codes are in 2 separate codelists, 1 for tests based on regular 10-second ECGs (EGTESTCD) and one 1 tests based on Holter monitoring (HETESTCD)." ;
    dc:identifier "EGTESTCD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EG/EGTPT> a sdtmig:Variable ;
    rdfs:label "Planned Time Point Name" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "40" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Text description of time when measurement should be taken. This may be represented as an elapsed time relative to a fixed reference point, such as time of last dose. See EGTPTNUM and EGTPTREF. Examples: \"Start\", \"5 min post\"." ;
    dc:identifier "EGTPT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EG/EGTPTNUM> a sdtmig:Variable ;
    rdfs:label "Planned Time Point Number" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "41" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Numerical version of EGTPT to aid in sorting." ;
    dc:identifier "EGTPTNUM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EG/EGTPTREF> a sdtmig:Variable ;
    rdfs:label "Time Point Reference" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "43" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Name of the fixed reference point referred to by EGELTM, EGTPTNUM, and EGTPT. Examples: \"PREVIOUS DOSE\", \"PREVIOUS MEAL\"." ;
    dc:identifier "EGTPTREF" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EG/EGXFN> a sdtmig:Variable ;
    rdfs:label "ECG External File Path" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "22" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "File name and path for the external ECG waveform file." ;
    dc:identifier "EGXFN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EG/EPOCH> a sdtmig:Variable ;
    rdfs:label "Epoch" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C99079> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "37" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Epoch associated with the date/time at which the assessment was made." ;
    dc:identifier "EPOCH" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EG/SPDEVID> a sdtmig:Variable ;
    rdfs:label "Sponsor Device Identifier" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "4" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Sponsor-defined identifier for a device." ;
    dc:identifier "SPDEVID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EG/STUDYID> a sdtmig:Variable ;
    rdfs:label "Study Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "1" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Unique identifier for a study." ;
    dc:identifier "STUDYID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EG/TAETORD> a sdtmig:Variable ;
    rdfs:label "Planned Order of Element within Arm" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "36" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Number that gives the planned order of the element within the arm for the element in which the assessment was made." ;
    dc:identifier "TAETORD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EG/USUBJID> a sdtmig:Variable ;
    rdfs:label "Unique Subject Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "3" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifier used to uniquely identify a subject across all studies for all applications or submissions involving the product." ;
    dc:identifier "USUBJID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EG/VISIT> a sdtmig:Variable ;
    rdfs:label "Visit Name" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "34" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Protocol-defined description of clinical encounter. May be used in addition to VISITNUM and/or VISITDY." ;
    dc:identifier "VISIT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EG/VISITDY> a sdtmig:Variable ;
    rdfs:label "Planned Study Day of Visit" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "35" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Planned study day of the visit based upon RFSTDTC in Demographics." ;
    dc:identifier "VISITDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EG/VISITNUM> a sdtmig:Variable ;
    rdfs:label "Visit Number" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "33" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Clinical encounter number. Numeric version of VISIT, used for sorting." ;
    dc:identifier "VISITNUM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EX> a sdtmig:Domain ;
    rdfs:label "Exposure" ;
    sdtmig:hasVariable <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EX/DOMAIN>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EX/EPOCH>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EX/EXADJ>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EX/EXCAT>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EX/EXDIR>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EX/EXDOSE>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EX/EXDOSFRM>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EX/EXDOSFRQ>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EX/EXDOSRGM>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EX/EXDOSTXT>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EX/EXDOSU>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EX/EXDUR>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EX/EXELTM>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EX/EXENDTC>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EX/EXENDY>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EX/EXFAST>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EX/EXGRPID>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EX/EXLAT>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EX/EXLNKGRP>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EX/EXLNKID>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EX/EXLOC>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EX/EXLOT>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EX/EXREFID>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EX/EXRFTDTC>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EX/EXROUTE>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/EX/EXSCAT>,
