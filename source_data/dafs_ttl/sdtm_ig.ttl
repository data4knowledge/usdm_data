        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AESOCCD>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AESOD>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AESPID>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AESTDTC>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AESTDY>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AETERM>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AETOXGR>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AEUNANT>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/DOMAIN>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/EPOCH>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/SPDEVID>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/STUDYID>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/TAETORD>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/USUBJID> ;
    sdtmig:ordinal "1" ;
    sdtmig:structure "One record per adverse event per subject" ;
    dc:description "Adverse Events" ;
    dc:identifier "AE" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AEACN> a sdtmig:Variable ;
    rdfs:label "Action Taken with Study Treatment" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66767> ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "29" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Describes changes to the study treatment as a result of the event. AEACN is specifically for the relationship to study treatment. AEACNOTH is for actions unrelated to dose adjustments of study treatment. Examples of AEACN values include ICH E2B values: \"DRUG WITHDRAWN\", \"DOSE REDUCED\", \"DOSE INCREASED\", \"DOSE NOT CHANGED\", \"UNKNOWN\" and \"NOT APPLICABLE\"." ;
    dc:identifier "AEACN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AEACNDEV> a sdtmig:Variable ;
    rdfs:label "Action Taken with Device" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C111110> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "31" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "An action taken with a device as the result of the event. The device may or may not be a device under study." ;
    dc:identifier "AEACNDEV" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AEACNOTH> a sdtmig:Variable ;
    rdfs:label "Other Action Taken" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "30" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Describes other actions taken as a result of the event that are unrelated to dose adjustments of study treatment. Usually reported as free text. Example: \"TREATMENT UNBLINDED. PRIMARY CARE PHYSICIAN NOTIFIED\"." ;
    dc:identifier "AEACNOTH" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AEBDSYCD> a sdtmig:Variable ;
    rdfs:label "Body System or Organ Class Code" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "23" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Num" ;
    sdtmig:valueDomain "MedDRA" ;
    dc:description "Dictionary derived. Code for the body system or organ class used by the sponsor. When using a multi-axial dictionary such as MedDRA, this should contain the SOC used for the sponsor\'s analyses and summary tables, which may not necessarily be the primary SOC." ;
    dc:identifier "AEBDSYCD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AEBODSYS> a sdtmig:Variable ;
    rdfs:label "Body System or Organ Class" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "22" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Dictionary derived. Body system or organ class used by the sponsor from the coding dictionary (e.g., MedDRA). When using a multi-axial dictionary such as MedDRA, this should contain the SOC used for the sponsor\'s analyses and summary tables, which may not necessarily be the primary SOC." ;
    dc:identifier "AEBODSYS" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AECAT> a sdtmig:Variable ;
    rdfs:label "Category for Adverse Event" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "19" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to define a category of related records. Examples: \"BLEEDING\", \"NEUROPSYCHIATRIC\"." ;
    dc:identifier "AECAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AECONTRT> a sdtmig:Variable ;
    rdfs:label "Concomitant or Additional Trtmnt Given" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "49" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Was another treatment given because of the occurrence of the event? Valid values are \"Y\" and \"N\"." ;
    dc:identifier "AECONTRT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AEDECOD> a sdtmig:Variable ;
    rdfs:label "Dictionary-Derived Term" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "13" ;
    sdtmig:role "Synonym Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "MedDRA" ;
    dc:description "Dictionary-derived text description of AETERM or AEMODIFY. Equivalent to the Preferred Term (PT in MedDRA). The sponsor is expected to provide the dictionary name and version used to map the terms utilizing the external codelist element in the Define-XML document." ;
    dc:identifier "AEDECOD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AEDUR> a sdtmig:Variable ;
    rdfs:label "Duration of Adverse Event" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "57" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 duration" ;
    dc:description "Collected duration and unit of an adverse event. Used only if collected on the CRF and not derived from start and end date/times. Example: \"P1DT2H\" (for 1 day, 2 hours)." ;
    dc:identifier "AEDUR" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AEENDTC> a sdtmig:Variable ;
    rdfs:label "End Date/Time of Adverse Event" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "54" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "End date/time of the adverse event represented in ISO 8601 character format." ;
    dc:identifier "AEENDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AEENDY> a sdtmig:Variable ;
    rdfs:label "Study Day of End of Adverse Event" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "56" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Study day of end of event relative to the sponsor-defined RFSTDTC." ;
    dc:identifier "AEENDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AEENRF> a sdtmig:Variable ;
    rdfs:label "End Relative to Reference Period" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66728> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "58" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Describes the end of the event relative to the sponsor-defined reference period. The sponsor-defined reference period is a continuous period of time defined by a discrete starting point (RFSTDTC) and a discrete ending point (RFENDTC) of the trial. \\n Not all values of the codelist are allowable for this variable. See Section 4.4.7, Use of Relative Timing Variables." ;
    dc:identifier "AEENRF" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AEENRTPT> a sdtmig:Variable ;
    rdfs:label "End Relative to Reference Time Point" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66728> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "59" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifies the end of the event as being before or after the reference time point defined by variable AEENTPT. \\n Not all values of the codelist are allowable for this variable. See Section 4.4.7, Use of Relative Timing Variables." ;
    dc:identifier "AEENRTPT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AEENTPT> a sdtmig:Variable ;
    rdfs:label "End Reference Time Point" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "60" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Description of date/time in ISO 8601 character format of the reference point referred to by AEENRTPT. Examples: \"2003-12-25\", \"VISIT 2\"." ;
    dc:identifier "AEENTPT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AEGRPID> a sdtmig:Variable ;
    rdfs:label "Group ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "6" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to tie together a block of related records in a single domain for a subject." ;
    dc:identifier "AEGRPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AEHLGT> a sdtmig:Variable ;
    rdfs:label "High Level Group Term" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "17" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "MedDRA" ;
    dc:description "Dictionary-derived text description of the high level group term for the primary SOC." ;
    dc:identifier "AEHLGT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AEHLGTCD> a sdtmig:Variable ;
    rdfs:label "High Level Group Term Code" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "18" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Num" ;
    sdtmig:valueDomain "MedDRA" ;
    dc:description "Dictionary-derived code for the high level group term for the primary SOC." ;
    dc:identifier "AEHLGTCD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AEHLT> a sdtmig:Variable ;
    rdfs:label "High Level Term" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "15" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "MedDRA" ;
    dc:description "Dictionary-derived text description of the high level term for the primary system organ class (SOC)." ;
    dc:identifier "AEHLT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AEHLTCD> a sdtmig:Variable ;
    rdfs:label "High Level Term Code" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "16" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Num" ;
    sdtmig:valueDomain "MedDRA" ;
    dc:description "Dictionary-derived code for the high level term for the primary SOC." ;
    dc:identifier "AEHLTCD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AELLT> a sdtmig:Variable ;
    rdfs:label "Lowest Level Term" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "11" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "MedDRA" ;
    dc:description "Dictionary-derived text description of the lowest level term." ;
    dc:identifier "AELLT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AELLTCD> a sdtmig:Variable ;
    rdfs:label "Lowest Level Term Code" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "12" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Num" ;
    sdtmig:valueDomain "MedDRA" ;
    dc:description "Dictionary-derived code for the lowest level term." ;
    dc:identifier "AELLTCD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AELOC> a sdtmig:Variable ;
    rdfs:label "Location of Event" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C74456> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "26" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Describes anatomical location relevant for the event (e.g., \"ARM\" for skin rash)." ;
    dc:identifier "AELOC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AEMODIFY> a sdtmig:Variable ;
    rdfs:label "Modified Reported Term" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "10" ;
    sdtmig:role "Synonym Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "If AETERM is modified to facilitate coding, then AEMODIFY will contain the modified text." ;
    dc:identifier "AEMODIFY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AEOUT> a sdtmig:Variable ;
    rdfs:label "Outcome of Adverse Event" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66768> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "36" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Description of the outcome of an event." ;
    dc:identifier "AEOUT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AEPATT> a sdtmig:Variable ;
    rdfs:label "Pattern of Adverse Event" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "35" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to indicate the pattern of the event over time. Examples: \"INTERMITTENT\", \"CONTINUOUS\", \"SINGLE EVENT\"." ;
    dc:identifier "AEPATT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AEPRESP> a sdtmig:Variable ;
    rdfs:label "Pre-Specified Adverse Event" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "21" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "A value of \"Y\" indicates that this adverse event was prespecified on the CRF. Values are null for spontaneously reported events (i.e., those collected as free-text verbatim terms)." ;
    dc:identifier "AEPRESP" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AEPTCD> a sdtmig:Variable ;
    rdfs:label "Preferred Term Code" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "14" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Num" ;
    sdtmig:valueDomain "MedDRA" ;
    dc:description "Dictionary-derived code for the preferred term." ;
    dc:identifier "AEPTCD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AEREFID> a sdtmig:Variable ;
    rdfs:label "Reference ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "7" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Internal or external identifier such as a serial number on an SAE reporting form." ;
    dc:identifier "AEREFID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AEREL> a sdtmig:Variable ;
    rdfs:label "Causality" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "32" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Records the investigator\'s opinion as to the causality of the event to the treatment. ICH does not establish any required or recommended terms for non-device relatedness. ICH E2A and E2B examples include (up-cased here for alignment to SDTM conventions) terms such as \"NOT RELATED\", \"UNLIKELY RELATED\", \"POSSIBLY RELATED\", \"RELATED\", but these example terms do not establish any conventions or expectations. Controlled terminology may be defined in the future. Check with regulatory authority for population of this variable." ;
    dc:identifier "AEREL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AERELNST> a sdtmig:Variable ;
    rdfs:label "Relationship to Non-Study Treatment" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "34" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Records the investigator\'s opinion as to whether the event may have been due to a treatment other than study drug. May be reported as free text. Example: \"MORE LIKELY RELATED TO ASPIRIN USE\"." ;
    dc:identifier "AERELNST" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AERLDEV> a sdtmig:Variable ;
    rdfs:label "Relationship of Event to Device" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "33" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "A judgment as to the likelihood that the device caused the adverse event. The relationship is to a device identified in the data (i.e., has an SPDEVID). The device may be ancillary or under study. \\n Terminology: \\n * In the EU, follow the European Commission Guidelines on Medical Devices, Clinical Investigations: SAE Reporting (MEDDEV 2.7/3) (e.g., Not Related, Unlikely, Possible, Probable, Causal Relationship), with device-specific definitions. \\n * No required Controlled Terminology in US." ;
    dc:identifier "AERLDEV" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AERLPRC> a sdtmig:Variable ;
    rdfs:label "Rel of AE to Device-Related Procedure" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "48" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "The investigator\'s opinion as to the likelihood that the device-related study procedure (e.g., implant/insertion, revision/adjustment, explant/removal) caused the AE. The relationship is to a device-related procedure where the device is identified in the data (i.e., has an SPDEVID). The device may be ancillary or under study. \\n Terminology: \\n * In the EU, follow the European Commission Guidelines on Medical Devices, Clinical Investigations: SAE Reporting (MEDDEV 2.7/3) (e.g., Not Related, Unlikely, Possible, Probable, Causal Relationship), with device-specific definitions. \\n * No required Controlled Terminology in US." ;
    dc:identifier "AERLPRC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AERLPRT> a sdtmig:Variable ;
    rdfs:label "Rel of AE to Non-Dev-Rel Study Activity" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "47" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "The investigator\'s opinion as to the causality of the event as related to other protocol-required activities, actions, or assessments (e.g., medication changes, tests/assessments, other procedures). The relationship is to a protocol-specified, non-device-related activity where the device is identified in the data (i.e., has an SPDEVID). The device may be ancillary or under study. \\n Terminology: \\n * In the EU, follow the European Commission Guidelines on Medical Devices, Clinical Investigations: SAE Reporting (MEDDEV 2.7/3) (e.g., Not Related, Unlikely, Possible, Probable, Causal Relationship), with device-specific definitions. \\n * No required Controlled Terminology in US." ;
    dc:identifier "AERLPRT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AESCAN> a sdtmig:Variable ;
    rdfs:label "Involves Cancer" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "37" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Was the serious event associated with the development of cancer? Valid values are \"Y\" and \"N\". This is a legacy seriousness criterion. It is not included in ICH E2A or E2B." ;
    dc:identifier "AESCAN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AESCAT> a sdtmig:Variable ;
    rdfs:label "Subcategory for Adverse Event" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "20" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "A further categorization of adverse event. Example: \"NEUROLOGIC\"." ;
    dc:identifier "AESCAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AESCONG> a sdtmig:Variable ;
    rdfs:label "Congenital Anomaly or Birth Defect" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "38" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Was the serious event associated with congenital anomaly or birth defect? Valid values are \"Y\" and \"N\"." ;
    dc:identifier "AESCONG" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AESDISAB> a sdtmig:Variable ;
    rdfs:label "Persist or Signif Disability/Incapacity" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "39" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Did the serious event result in persistent or significant disability/incapacity? Valid values are \"Y\" and \"N\"." ;
    dc:identifier "AESDISAB" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AESDTH> a sdtmig:Variable ;
    rdfs:label "Results in Death" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "40" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Did the serious event result in death? Valid values are \"Y\" and \"N\"." ;
    dc:identifier "AESDTH" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AESEQ> a sdtmig:Variable ;
    rdfs:label "Sequence Number" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "5" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Sequence number given to ensure uniqueness of subject records within a domain. May be any valid number." ;
    dc:identifier "AESEQ" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AESER> a sdtmig:Variable ;
    rdfs:label "Serious Event" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "28" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Is this a serious event? Valid values are \"Y\" and \"N\"." ;
    dc:identifier "AESER" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AESEV> a sdtmig:Variable ;
    rdfs:label "Severity/Intensity" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66769> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "27" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "The severity or intensity of the event. Examples: \"MILD\", \"MODERATE\", \"SEVERE\"." ;
    dc:identifier "AESEV" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AESHOSP> a sdtmig:Variable ;
    rdfs:label "Requires or Prolongs Hospitalization" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "41" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Did the serious event require or prolong hospitalization? Valid values are \"Y\" and \"N\"." ;
    dc:identifier "AESHOSP" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AESINTV> a sdtmig:Variable ;
    rdfs:label "Needs Intervention to Prevent Impairment" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "45" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Records whether medical or surgical intervention was necessary to preclude permanent impairment of a body function, or to prevent permanent damage to a body structure, with either situation suspected to be due to the use of a medical product. This variable is used in conjunction with the other \"seriousness\" variables (e.g., fatal, life-threatening). It is part of the US federal government definition of a serious adverse event; see 21 CFR Part 803.3(w)(3)." ;
    dc:identifier "AESINTV" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AESLIFE> a sdtmig:Variable ;
    rdfs:label "Is Life Threatening" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "42" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Was the serious event life-threatening? Valid values are \"Y\" and \"N\"." ;
    dc:identifier "AESLIFE" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AESMIE> a sdtmig:Variable ;
    rdfs:label "Other Medically Important Serious Event" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "44" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Do additional categories for seriousness apply? Valid values are \"Y\" and \"N\"." ;
    dc:identifier "AESMIE" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AESOC> a sdtmig:Variable ;
    rdfs:label "Primary System Organ Class" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "24" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "MedDRA" ;
    dc:description "Dictionary-derived text description of the primary SOC. Will be the same as AEBODSYS if the primary SOC was used for analysis." ;
    dc:identifier "AESOC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AESOCCD> a sdtmig:Variable ;
    rdfs:label "Primary System Organ Class Code" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "25" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Num" ;
    sdtmig:valueDomain "MedDRA" ;
    dc:description "Dictionary-derived code for the primary SOC. Will be the same as AEBDSYCD if the primary SOC was used for analysis." ;
    dc:identifier "AESOCCD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AESOD> a sdtmig:Variable ;
    rdfs:label "Occurred with Overdose" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "43" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Did the serious event occur with an overdose? Valid values are \"Y\" and \"N\". This is a legacy seriousness criterion. It is not included in ICH E2A or E2B." ;
    dc:identifier "AESOD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AESPID> a sdtmig:Variable ;
    rdfs:label "Sponsor-Defined Identifier" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "8" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Sponsor-defined identifier. It may be preprinted on the CRF as an explicit line identifier or defined in the sponsor\'s operational database. Example: Line number on an Adverse Events CRF page." ;
    dc:identifier "AESPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AESTDTC> a sdtmig:Variable ;
    rdfs:label "Start Date/Time of Adverse Event" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "53" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Start date/time of the adverse event represented in ISO 8601 character format." ;
    dc:identifier "AESTDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AESTDY> a sdtmig:Variable ;
    rdfs:label "Study Day of Start of Adverse Event" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "55" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Study day of start of adverse event relative to the sponsor-defined RFSTDTC." ;
    dc:identifier "AESTDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AETERM> a sdtmig:Variable ;
    rdfs:label "Reported Term for the Adverse Event" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "9" ;
    sdtmig:role "Topic" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Verbatim name of the event." ;
    dc:identifier "AETERM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AETOXGR> a sdtmig:Variable ;
    rdfs:label "Standard Toxicity Grade" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "50" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Toxicity grade according to a standard toxicity scale (e.g., Common Terminology Criteria for Adverse Events, CTCAE). Sponsors should specify the name of the scale and version used in the metadata (see assumption 7d). If value is from a numeric scale, represent only the number (e.g., \"2\", not \"Grade 2\")." ;
    dc:identifier "AETOXGR" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AEUNANT> a sdtmig:Variable ;
    rdfs:label "Unanticipated Adverse Device Effect" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "46" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Any serious adverse effect on health or safety or any life-threatening problem or death caused by or associated with a device, if that effect, problem, or death was not previously identified in nature, severity, or degree of incidence in the investigational plan or application (including a supplementary plan or application), \\n or \\n any other unanticipated serious problem associated with a device that relates to the rights, safety, or welfare of subjects. (21 CFR Part 812.3(s)). \\n This variable applies only to serious AEs and should hold collected data; if the value is derived, it should be held in ADaM." ;
    dc:identifier "AEUNANT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/DOMAIN> a sdtmig:Variable ;
    rdfs:label "Domain Abbreviation" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "2" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Two-character abbreviation for the domain." ;
    dc:identifier "DOMAIN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/EPOCH> a sdtmig:Variable ;
    rdfs:label "Epoch" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C99079> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "52" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Epoch associated with the start date/time of the adverse event. Examples: \"SCREENING\", \"TREATMENT\", \"FOLLOW-UP\"." ;
    dc:identifier "EPOCH" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/SPDEVID> a sdtmig:Variable ;
    rdfs:label "Sponsor Device Identifier" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "4" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "A sequence of characters used by the sponsor to uniquely identify a specific device. Used to represent a device associated in some way with the adverse event. SPDEVID values are defined in the Device Identifiers (DI) domain." ;
    dc:identifier "SPDEVID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/STUDYID> a sdtmig:Variable ;
    rdfs:label "Study Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "1" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Unique identifier for a study." ;
    dc:identifier "STUDYID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/TAETORD> a sdtmig:Variable ;
    rdfs:label "Planned Order of Element within Arm" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "51" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Number that gives the planned order of the element within the arm." ;
    dc:identifier "TAETORD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/USUBJID> a sdtmig:Variable ;
    rdfs:label "Unique Subject Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "3" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifier used to uniquely identify a subject across all studies for all applications or submissions involving the product." ;
    dc:identifier "USUBJID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AG> a sdtmig:Domain ;
    rdfs:label "Procedure Agents" ;
    sdtmig:hasVariable <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AG/AGCAT>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AG/AGCLAS>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AG/AGCLASCD>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AG/AGDECOD>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AG/AGDOSE>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AG/AGDOSFRM>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AG/AGDOSFRQ>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AG/AGDOSTXT>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AG/AGDOSU>,
