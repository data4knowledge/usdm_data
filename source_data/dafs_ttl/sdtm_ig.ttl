    dc:identifier "VSRFTDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/VS/VSSCAT> a sdtmig:Variable ;
    rdfs:label "Subcategory for Vital Signs" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "10" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "A further categorization of a measurement or examination." ;
    dc:identifier "VSSCAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/VS/VSSEQ> a sdtmig:Variable ;
    rdfs:label "Sequence Number" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "4" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Sequence number given to ensure uniqueness of subject records within a domain. May be any valid number." ;
    dc:identifier "VSSEQ" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/VS/VSSPID> a sdtmig:Variable ;
    rdfs:label "Sponsor-Defined Identifier" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "6" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Sponsor-defined reference number. May be preprinted on the CRF as an explicit line identifier or defined in the sponsor\'s operational database." ;
    dc:identifier "VSSPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/VS/VSSTAT> a sdtmig:Variable ;
    rdfs:label "Completion Status" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66789> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "17" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to indicate that a vital sign measurement was not done. Should be null if a result exists in VSORRES." ;
    dc:identifier "VSSTAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/VS/VSSTRESC> a sdtmig:Variable ;
    rdfs:label "Character Result/Finding in Std Format" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "14" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Contains the result value for all findings, copied or derived from VSORRES in a standard format or standard units. VSSTRESC should store all results or findings in character format; if results are numeric, they should also be stored in numeric format in VSSTRESN. For example, if a test has results \"NONE\", \"NEG\", and \"NEGATIVE\" in VSORRES, and these results effectively have the same meaning, they could be represented in standard format in VSSTRESC as \"NEGATIVE\"." ;
    dc:identifier "VSSTRESC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/VS/VSSTRESN> a sdtmig:Variable ;
    rdfs:label "Numeric Result/Finding in Standard Units" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "15" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Used for continuous or numeric results or findings in standard format; copied in numeric format from VSSTRESC. VSSTRESN should store all numeric test results or findings." ;
    dc:identifier "VSSTRESN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/VS/VSSTRESU> a sdtmig:Variable ;
    rdfs:label "Standard Units" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66770> ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "16" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Standardized unit used for VSSTRESC and VSSTRESN." ;
    dc:identifier "VSSTRESU" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/VS/VSTEST> a sdtmig:Variable ;
    rdfs:label "Vital Signs Test Name" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C67153> ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "8" ;
    sdtmig:role "Synonym Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Verbatim name of the test or examination used to obtain the measurement or finding. The value in VSTEST cannot be longer than 40 characters. Examples: \"Systolic Blood Pressure\", \"Diastolic Blood Pressure\", \"Body Mass Index\"." ;
    dc:identifier "VSTEST" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/VS/VSTESTCD> a sdtmig:Variable ;
    rdfs:label "Vital Signs Test Short Name" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66741> ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "7" ;
    sdtmig:role "Topic" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Short name of the measurement, test, or examination described in VSTEST. It can be used as a column name when converting a dataset from a vertical to a horizontal format. The value in VSTESTCD cannot be longer than 8 characters, nor can it start with a number (e.g., \"1TEST\" is not valid). VSTESTCD cannot contain characters other than letters, numbers, or underscores. Examples: \"SYSBP\", \"DIABP\", \"BMI\"." ;
    dc:identifier "VSTESTCD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/VS/VSTOX> a sdtmig:Variable ;
    rdfs:label "Toxicity" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "24" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Description of toxicity quantified by VSTOXGR. The sponsor is expected to provide the name of the scale and version used to map the terms, utilizing the external codelist element in the Define-XML document." ;
    dc:identifier "VSTOX" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/VS/VSTOXGR> a sdtmig:Variable ;
    rdfs:label "Standard Toxicity Grade" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "25" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Records toxicity grade value using a standard toxicity scale (e.g., NCI CTCAE). If value is from a numeric scale, represent only the number (e.g., \"2\", not \"Grade 2\"). The sponsor is expected to provide the name of the scale and version used to map the terms, utilizing the external codelist element in the Define-XML document." ;
    dc:identifier "VSTOXGR" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/VS/VSTPT> a sdtmig:Variable ;
    rdfs:label "Planned Time Point Name" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "34" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Text description of time when measurement should be taken. This may be represented as an elapsed time relative to a fixed reference point (e.g., time of last dose). See VSTPTNUM and VSTPTREF. Examples: \"START\", \"5 MIN POST\"." ;
    dc:identifier "VSTPT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/VS/VSTPTNUM> a sdtmig:Variable ;
    rdfs:label "Planned Time Point Number" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "35" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Numerical version of VSTPT to aid in sorting." ;
    dc:identifier "VSTPTNUM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/VS/VSTPTREF> a sdtmig:Variable ;
    rdfs:label "Time Point Reference" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "37" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Name of the fixed reference point referred to by VSELTM, VSTPTNUM, and VSTPT. Examples: \"PREVIOUS DOSE\", \"PREVIOUS MEAL\"." ;
    dc:identifier "VSTPTREF" .

