    sdtmig:core "Exp" ;
    sdtmig:ordinal "9" ;
    sdtmig:role "Rule" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "If the trial design allows a subject to transition to an element other than the next element in sequence, then the conditions for transitioning to those other elements, and the alternative element sequences, are specified in this rule (e.g., \"Responders go to washout\")." ;
    dc:identifier "TATRANS" .

