<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE> a sdtmig:Domain ;
    rdfs:label "Adverse Events" ;
    sdtmig:hasVariable <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AEACN>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AE/AEACNDEV>,
