    sdtmig:core "Perm" ;
    sdtmig:ordinal "42" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "A unique identifier for a particular run of a test performed by the wet lab on a particular batch of samples. This identifier can be used to distinguish between records for the same test performed at different times." ;
    dc:identifier "GFRUNID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/GF/GFSCAT> a sdtmig:Variable ;
