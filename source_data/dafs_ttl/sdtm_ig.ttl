<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IE/IESCAT> a sdtmig:Variable ;
    rdfs:label "Inclusion/Exclusion Subcategory" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "9" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "A further categorization of the exception criterion. Can be used to distinguish criteria for a sub-study or for to categorize as a major or minor exceptions. Examples: \"MAJOR\", \"MINOR\"." ;
    dc:identifier "IESCAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IE/IESEQ> a sdtmig:Variable ;
    rdfs:label "Sequence Number" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "4" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Sequence number given to ensure uniqueness of subject records within a domain. May be any valid number." ;
    dc:identifier "IESEQ" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IE/IESPID> a sdtmig:Variable ;
    rdfs:label "Sponsor-Defined Identifier" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "5" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Sponsor-defined reference number. May be preprinted on the CRF as an explicit line identifier or defined in the sponsor\'s operational database. Example: Inclusion or exclusion criteria number from CRF." ;
    dc:identifier "IESPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IE/IESTRESC> a sdtmig:Variable ;
    rdfs:label "I/E Criterion Result in Std Format" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "11" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Response to inclusion/exclusion criterion result, in standard format." ;
    dc:identifier "IESTRESC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IE/IETEST> a sdtmig:Variable ;
    rdfs:label "Inclusion/Exclusion Criterion" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "7" ;
    sdtmig:role "Synonym Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Verbatim description of the inclusion or exclusion criterion that was the exception for the subject within the study. IETEST cannot be longer than 200 characters." ;
    dc:identifier "IETEST" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IE/IETESTCD> a sdtmig:Variable ;
    rdfs:label "Inclusion/Exclusion Criterion Short Name" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "6" ;
    sdtmig:role "Topic" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Short name of the criterion described in IETEST. The value in IETESTCD cannot be longer than 8 characters, nor can it start with a number (e.g., \"1TEST\" is not valid). IETESTCD cannot contain characters other than letters, numbers, or underscores. Examples: \"IN01\", \"EX01\"." ;
    dc:identifier "IETESTCD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IE/STUDYID> a sdtmig:Variable ;
    rdfs:label "Study Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "1" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Unique identifier for a study." ;
    dc:identifier "STUDYID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IE/TAETORD> a sdtmig:Variable ;
    rdfs:label "Planned Order of Element within Arm" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "15" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Number that gives the planned order of the element within the arm for the element in which the assessment was made." ;
    dc:identifier "TAETORD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IE/USUBJID> a sdtmig:Variable ;
    rdfs:label "Unique Subject Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "3" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifier used to uniquely identify a subject across all studies for all applications or submissions involving the product." ;
    dc:identifier "USUBJID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IE/VISIT> a sdtmig:Variable ;
    rdfs:label "Visit Name" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "13" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Protocol-defined description of clinical encounter. May be used in addition to VISITNUM and/or VISITDY." ;
    dc:identifier "VISIT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IE/VISITDY> a sdtmig:Variable ;
    rdfs:label "Planned Study Day of Visit" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "14" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Planned study day of the visit based upon RFSTDTC in Demographics." ;
    dc:identifier "VISITDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/IE/VISITNUM> a sdtmig:Variable ;
    rdfs:label "Visit Number" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "12" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Clinical encounter number. Numeric version of VISIT, used for sorting." ;
    dc:identifier "VISITNUM" .

