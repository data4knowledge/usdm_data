    sdtmig:core "Perm" ;
    sdtmig:ordinal "13" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "A further categorization of the condition or event." ;
    dc:identifier "MHSCAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MH/MHSEQ> a sdtmig:Variable ;
