    dc:identifier "NVLAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/NV/NVLNKGRP> a sdtmig:Variable ;
    rdfs:label "Link Group" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "10" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifier used to link related records across domains. This will usually be a many-to-one relationship." ;
    dc:identifier "NVLNKGRP" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/NV/NVLNKID> a sdtmig:Variable ;
    rdfs:label "Link ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "9" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifier used to link a procedure to the assessment results over the course of the study." ;
    dc:identifier "NVLNKID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/NV/NVLOBXFL> a sdtmig:Variable ;
    rdfs:label "Last Observation Before Exposure Flag" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "26" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Operationally derived indicator used to identify the last non-missing value prior to RFXSTDTC. The value should be \"Y\" or null." ;
    dc:identifier "NVLOBXFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/NV/NVLOC> a sdtmig:Variable ;
    rdfs:label "Location Used for the Measurement" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C74456> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "22" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Anatomical location of the subject relevant to the collection of the measurement. Examples: \"BRAIN\", \"EYE\", \"PRECUNEUS\", \"CINGULATE CORTEX\"." ;
    dc:identifier "NVLOC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/NV/NVMETHOD> a sdtmig:Variable ;
    rdfs:label "Method of Test or Examination" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C85492> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "25" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Method of the test or examination. Examples: \"EEG\", \"PET/CT SCAN \", \"FDGPET\"." ;
    dc:identifier "NVMETHOD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/NV/NVORRES> a sdtmig:Variable ;
    rdfs:label "Result or Finding in Original Units" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "15" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Result of the procedure measurement or finding as originally received or collected." ;
    dc:identifier "NVORRES" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/NV/NVORRESU> a sdtmig:Variable ;
    rdfs:label "Original Units" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C71620> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "16" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Original units in which the data were collected. The unit for NVORRES." ;
    dc:identifier "NVORRESU" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/NV/NVREASND> a sdtmig:Variable ;
    rdfs:label "Reason Not Done" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "21" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Describes why a measurement or test was not performed. Examples: \"BROKEN EQUIPMENT\", \"SUBJECT REFUSED\". Used in conjunction with NVSTAT when value is \"NOT DONE\"." ;
    dc:identifier "NVREASND" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/NV/NVREFID> a sdtmig:Variable ;
    rdfs:label "Reference ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "7" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Internal or external procedure identifier." ;
    dc:identifier "NVREFID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/NV/NVRFTDTC> a sdtmig:Variable ;
    rdfs:label "Date/Time of Reference Time Point" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "42" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Date/time for a fixed reference time point defined by --TPTREF in ISO 8601 character format." ;
    dc:identifier "NVRFTDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/NV/NVSCAT> a sdtmig:Variable ;
    rdfs:label "Subcategory for Nervous System Test" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "14" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to define a further categorization of NVCAT values." ;
    dc:identifier "NVSCAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/NV/NVSEQ> a sdtmig:Variable ;
    rdfs:label "Sequence Number" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "5" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Sequence number given to ensure uniqueness of subject records within a domain. May be any valid number." ;
    dc:identifier "NVSEQ" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/NV/NVSPID> a sdtmig:Variable ;
    rdfs:label "Sponsor-Defined Identifier" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "8" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Sponsor-defined reference number. May be preprinted on the CRF as an explicit line identifier or defined in the sponsor\'s operational database. Example: Line number from the Procedure or Test page." ;
    dc:identifier "NVSPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/NV/NVSTAT> a sdtmig:Variable ;
    rdfs:label "Completion Status" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66789> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "20" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to indicate a test was not done, or a measurement was not taken. Should be null if a result exists in NVORRES." ;
    dc:identifier "NVSTAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/NV/NVSTRESC> a sdtmig:Variable ;
    rdfs:label "Character Result/Finding in Std Format" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "17" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Contains the result value for all findings copied or derived from NVORRES, in a standard format or standard units. NVSTRESC should store all results or findings in character format; if results are numeric, they should also be stored in numeric format in NVSTRESN." ;
    dc:identifier "NVSTRESC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/NV/NVSTRESN> a sdtmig:Variable ;
    rdfs:label "Numeric Result/Finding in Standard Units" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "18" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Used for continuous or numeric results or findings in standard format; copied in numeric format from NVSTRESC. NVSTRESN should store all numeric test results or findings." ;
    dc:identifier "NVSTRESN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/NV/NVSTRESU> a sdtmig:Variable ;
    rdfs:label "Standard Units" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C71620> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "19" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Standardized unit used for NVSTRESC or NVSTRESN." ;
    dc:identifier "NVSTRESU" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/NV/NVTEST> a sdtmig:Variable ;
    rdfs:label "Name of Nervous System Test" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C116103> ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "12" ;
    sdtmig:role "Synonym Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Verbatim name of the test or examination used to obtain the measurement or finding. The value in NVTEST cannot be longer than 40 characters. Examples: \"Standard Uptake Value Ratio\", \"N75 Latency\", \"P100 Latency\", \"N145 Latency\"." ;
    dc:identifier "NVTEST" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/NV/NVTESTCD> a sdtmig:Variable ;
    rdfs:label "Short Name of Nervous System Test" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C116104> ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "11" ;
    sdtmig:role "Topic" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Short name of the measurement, test, or examination described in NVTEST. It can be used as a column name when converting a dataset from a vertical to a horizontal format. The value in NVTESTCD cannot be longer than 8 characters, nor can it start with a number (e.g., \"1TEST\" is not valid). NVTESTCD cannot contain characters other than letters, numbers, or underscores. Examples: \"SUVR\", \"N75LAT\", \"P100LAT\",\"N145LAT\"." ;
    dc:identifier "NVTESTCD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/NV/NVTPT> a sdtmig:Variable ;
    rdfs:label "Planned Time Point Name" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "38" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Text description of time when measurement should be taken. This may be represented as an elapsed time relative to a fixed reference point (e.g., \"TIME OF LAST DOSE\"). See NVTPTNUM and NVTPTREF. Examples: \"START\", \"5 MIN POST\"." ;
    dc:identifier "NVTPT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/NV/NVTPTNUM> a sdtmig:Variable ;
    rdfs:label "Planned Time Point Number" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "39" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Numerical version of NVTPT to aid in sorting." ;
    dc:identifier "NVTPTNUM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/NV/NVTPTREF> a sdtmig:Variable ;
    rdfs:label "Time Point Reference" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "41" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Name of the fixed reference point referred to by NVELTM, NVTPTNUM, and NVTPT. Examples: \"PREVIOUS DOSE\", \"PREVIOUS MEAL\"." ;
    dc:identifier "NVTPTREF" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/NV/STUDYID> a sdtmig:Variable ;
    rdfs:label "Study Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "1" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Unique identifier for a study." ;
    dc:identifier "STUDYID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/NV/TAETORD> a sdtmig:Variable ;
    rdfs:label "Planned Order of Element within Arm" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "34" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Number that gives the planned order of the element within the arm for the element in which the assessment was made." ;
    dc:identifier "TAETORD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/NV/USUBJID> a sdtmig:Variable ;
    rdfs:label "Unique Subject Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "3" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifier used to uniquely identify a subject across all studies for all applications or submissions involving the product." ;
    dc:identifier "USUBJID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/NV/VISIT> a sdtmig:Variable ;
    rdfs:label "Visit Name" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "32" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Protocol-defined description of clinical encounter. May be used in addition to VISITNUM and/or VISITDY." ;
    dc:identifier "VISIT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/NV/VISITDY> a sdtmig:Variable ;
    rdfs:label "Planned Study Day of Visit" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "33" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Planned study day of the visit based upon RFSTDTC in Demographics." ;
    dc:identifier "VISITDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/NV/VISITNUM> a sdtmig:Variable ;
    rdfs:label "Visit Number" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "31" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Clinical encounter number. Numeric version of VISIT, used for sorting." ;
    dc:identifier "VISITNUM" .

