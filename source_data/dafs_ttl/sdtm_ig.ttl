    dc:description "Epoch associated with the date/time of the observation. Examples: \"SCREENING\", \"TREATMENT\", \"FOLLOW-UP\"." ;
    dc:identifier "EPOCH" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/FA/FABLFL> a sdtmig:Variable ;
    rdfs:label "Baseline Flag" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "22" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Indicator used to identify a baseline value. The value should be \"Y\" or null. Note that FABLFL is retained for backward compatibility. The authoritative baseline flag for statistical analysis is in an ADaM dataset." ;
    dc:identifier "FABLFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/FA/FACAT> a sdtmig:Variable ;
    rdfs:label "Category for Findings About" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "10" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to define a category of related records. Examples: \"GERD\", \"PRE-SPECIFIED AE\"." ;
    dc:identifier "FACAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/FA/FADTC> a sdtmig:Variable ;
    rdfs:label "Date/Time of Collection" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "29" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Collection date and time of findings assessment represented in ISO 8601 character format." ;
    dc:identifier "FADTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/FA/FADY> a sdtmig:Variable ;
    rdfs:label "Study Day of Collection" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "30" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "1. Study day of collection, measured as integer days. \\n 2. Algorithm for calculations must be relative to the sponsor-defined RFSTDTC variable in Demographics. This formula should be consistent across the submission." ;
    dc:identifier "FADY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/FA/FAEVAL> a sdtmig:Variable ;
    rdfs:label "Evaluator" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C78735> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "23" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Role of the person who provided the evaluation. Used only for results that are subjective (e.g., assigned by a person or a group). Should be null for records that contain collected or derived data. Examples: \"INVESTIGATOR\", \"ADJUDICATION COMMITTEE\", \"VENDOR\"." ;
    dc:identifier "FAEVAL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/FA/FAGRPID> a sdtmig:Variable ;
    rdfs:label "Group ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "5" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to tie together a block of related records in a single domain for a subject." ;
    dc:identifier "FAGRPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/FA/FALAT> a sdtmig:Variable ;
    rdfs:label "Laterality" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C99073> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "20" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Qualifier for anatomical location or specimen further detailing laterality. Examples: \"RIGHT\", \"LEFT\", \"BILATERAL\"." ;
    dc:identifier "FALAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/FA/FALOBXFL> a sdtmig:Variable ;
    rdfs:label "Last Observation Before Exposure Flag" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "21" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Operationally-derived indicator used to identify the last non-missing value prior to RFXSTDTC. The value should be \"Y\" or null." ;
    dc:identifier "FALOBXFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/FA/FALOC> a sdtmig:Variable ;
    rdfs:label "Location of the Finding About" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C74456> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "19" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to specify the location of the clinical evaluation. Example: \"ARM\"." ;
    dc:identifier "FALOC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/FA/FAOBJ> a sdtmig:Variable ;
    rdfs:label "Object of the Observation" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "9" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to describe the object or focal point of the findings observation that is represented by --TEST. Examples: the term (e.g., \"Acne\") describing a clinical sign or symptom that is being measured by a severity test; an event (e.g., \"VOMIT, where the volume of vomit is being measured by a VOLUME test)." ;
    dc:identifier "FAOBJ" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/FA/FAORRES> a sdtmig:Variable ;
    rdfs:label "Result or Finding in Original Units" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "12" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Result of the test as originally received or collected." ;
    dc:identifier "FAORRES" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/FA/FAORRESU> a sdtmig:Variable ;
    rdfs:label "Original Units" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C71620> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "13" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Original units in which the data were collected. The unit for FAORRES." ;
    dc:identifier "FAORRESU" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/FA/FAREASND> a sdtmig:Variable ;
    rdfs:label "Reason Not Performed" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "18" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Describes why a question was not answered. Example: \"Subject refused\". Used in conjunction with FASTAT when value is \"NOT DONE\"." ;
    dc:identifier "FAREASND" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/FA/FASCAT> a sdtmig:Variable ;
    rdfs:label "Subcategory for Findings About" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "11" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "A further categorization of FACAT." ;
    dc:identifier "FASCAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/FA/FASEQ> a sdtmig:Variable ;
    rdfs:label "Sequence Number" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "4" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Sequence number given to ensure uniqueness of subject records within a domain. May be any valid number." ;
    dc:identifier "FASEQ" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/FA/FASPID> a sdtmig:Variable ;
    rdfs:label "Sponsor-Defined Identifier" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "6" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Sponsor-defined reference number. May be preprinted on the CRF as an explicit line identifier or defined in the sponsor\'s operational database. Example: Line number on a CRF." ;
    dc:identifier "FASPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/FA/FASTAT> a sdtmig:Variable ;
    rdfs:label "Completion Status" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66789> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "17" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to indicate that the measurement was not done. Should be null if a result exists in FAORRES." ;
    dc:identifier "FASTAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/FA/FASTRESC> a sdtmig:Variable ;
    rdfs:label "Character Result/Finding in Std Format" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "14" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Contains the result value for all findings, copied or derived from FAORRES in a standard format or standard units. FASTRESC should store all results or findings in character format; if results are numeric, they should also be stored in numeric format in FASTRESN. For example, if a test has results \"NONE\", \"NEG\", and \"NEGATIVE\" in FAORRES, and these results effectively have the same meaning; they could be represented in standard format in FASTRESC as \"NEGATIVE\"." ;
    dc:identifier "FASTRESC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/FA/FASTRESN> a sdtmig:Variable ;
    rdfs:label "Numeric Result/Finding in Standard Units" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "15" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Used for continuous or numeric results or findings in standard format; copied in numeric format from FASTRESC. FASTRESN should store all numeric test results or findings." ;
    dc:identifier "FASTRESN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/FA/FASTRESU> a sdtmig:Variable ;
    rdfs:label "Standard Units" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C71620> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "16" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Standardized unit used for FASTRESC and FASTRESN." ;
    dc:identifier "FASTRESU" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/FA/FATEST> a sdtmig:Variable ;
    rdfs:label "Findings About Test Name" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C101833> ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "8" ;
    sdtmig:role "Synonym Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Verbatim name of the test or examination used to obtain the measurement or finding. The value in FATEST cannot be longer than 40 characters. Examples: \"Severity/Intensity\", \"Occurrence\". Note that controlled terminology is in a FATEST general codelist and in several therapeutic area-specific codelists." ;
    dc:identifier "FATEST" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/FA/FATESTCD> a sdtmig:Variable ;
    rdfs:label "Findings About Test Short Name" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C101832> ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "7" ;
    sdtmig:role "Topic" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Short name of the measurement, test, or examination described in FATEST. It can be used as a column name when converting a dataset from a vertical to a horizontal format. The value in FATESTCD cannot be longer than 8 characters, nor can it start with a number (e.g., \"1TEST\" is not valid). FATESTCD cannot contain characters other than letters, numbers, or underscores. Examples: \"SEV\", \"OCCUR\". Note that controlled terminology is in a FATESTCD general codelist and in several therapeutic area-specific codelists." ;
    dc:identifier "FATESTCD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/FA/STUDYID> a sdtmig:Variable ;
    rdfs:label "Study Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "1" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Unique identifier for a study." ;
    dc:identifier "STUDYID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/FA/TAETORD> a sdtmig:Variable ;
    rdfs:label "Planned Order of Element within Arm" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "27" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Number that gives the planned order of the element within the arm." ;
    dc:identifier "TAETORD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/FA/USUBJID> a sdtmig:Variable ;
    rdfs:label "Unique Subject Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "3" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifier used to uniquely identify a subject across all studies for all applications or submissions involving the product." ;
    dc:identifier "USUBJID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/FA/VISIT> a sdtmig:Variable ;
    rdfs:label "Visit Name" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "25" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "1. Protocol-defined description of clinical encounter. \\n 2. May be used in addition to VISITNUM and/or VISITDY." ;
    dc:identifier "VISIT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/FA/VISITDY> a sdtmig:Variable ;
    rdfs:label "Planned Study Day of Visit" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "26" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Planned study day of the visit based upon RFSTDTC in Demographics." ;
    dc:identifier "VISITDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/FA/VISITNUM> a sdtmig:Variable ;
    rdfs:label "Visit Number" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "24" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "1. Clinical encounter number. \\n 2. Numeric version of VISIT, used for sorting." ;
    dc:identifier "VISITNUM" .

