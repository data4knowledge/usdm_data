    sdtmig:ordinal "7" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Sponsor-defined identifier. May be preprinted on the CRF as an explicit line identifier or defined in the sponsor\'s operational database. Example: Line number on the Test page." ;
    dc:identifier "FTSPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/FT/FTSTAT> a sdtmig:Variable ;
