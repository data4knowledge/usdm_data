    dc:description "Clinical encounter number. Numeric version of VISIT, used for sorting." ;
    dc:identifier "VISITNUM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/VS/VSBLFL> a sdtmig:Variable ;
    rdfs:label "Baseline Flag" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "22" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Indicator used to identify a baseline value. Should be \"Y\" or null. Note that VSBLFL is retained for backward compatibility. The authoritative baseline for statistical analysis is in an ADaM dataset." ;
    dc:identifier "VSBLFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/VS/VSCAT> a sdtmig:Variable ;
    rdfs:label "Category for Vital Signs" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "9" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to define a category of related records." ;
    dc:identifier "VSCAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/VS/VSCLSIG> a sdtmig:Variable ;
    rdfs:label "Clinically Significant, Collected" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "26" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to indicate whether a collected observation is clinically significant based on judgment." ;
    dc:identifier "VSCLSIG" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/VS/VSDRVFL> a sdtmig:Variable ;
    rdfs:label "Derived Flag" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "23" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to indicate a derived record. The value should be \"Y\" or null. Records that represent the average of other records or that do not come from the CRF are examples of records that would be derived for the submission datasets. If VSDRVFL = \"Y,\" then VSORRES may be null, with VSSTRESC and (if numeric) VSSTRESN having the derived value." ;
    dc:identifier "VSDRVFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/VS/VSDTC> a sdtmig:Variable ;
    rdfs:label "Date/Time of Measurements" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "32" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Date and time of the vital signs assessment represented in ISO 8601 character format." ;
    dc:identifier "VSDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/VS/VSDY> a sdtmig:Variable ;
    rdfs:label "Study Day of Vital Signs" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "33" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Study day of vital signs measurements, measured as integer days. Algorithm for calculations must be relative to the sponsor-defined RFSTDTC variable in Demographics." ;
    dc:identifier "VSDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/VS/VSELTM> a sdtmig:Variable ;
    rdfs:label "Planned Elapsed Time from Time Point Ref" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "36" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 duration" ;
    dc:description "Planned elapsed time (in ISO 8601) relative to a planned fixed reference (VSTPTREF). This variable is useful where there are repetitive measures. Not a clock time or a date time variable. Represented as an ISO 8601 Duration. Examples: \"-PT15M\" to represent the period of 15 minutes prior to the reference point indicated by VSTPTREF, \"PT8H\" to represent the period of 8 hours after the reference point indicated by VSTPTREF." ;
    dc:identifier "VSELTM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/VS/VSGRPID> a sdtmig:Variable ;
    rdfs:label "Group ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "5" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to tie together a block of related records in a single domain for a subject." ;
    dc:identifier "VSGRPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/VS/VSLAT> a sdtmig:Variable ;
    rdfs:label "Laterality" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C99073> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "20" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Qualifier for anatomical location or specimen further detailing laterality. Examples: \"RIGHT\", \"LEFT\", \"BILATERAL\"." ;
    dc:identifier "VSLAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/VS/VSLOBXFL> a sdtmig:Variable ;
    rdfs:label "Last Observation Before Exposure Flag" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "21" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Operationally derived indicator used to identify the last non-missing value prior to RFXSTDTC. Should be \"Y\" or null." ;
    dc:identifier "VSLOBXFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/VS/VSLOC> a sdtmig:Variable ;
    rdfs:label "Location of Vital Signs Measurement" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C74456> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "19" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Location relevant to the collection of vital signs measurement. Example: \"ARM\" for blood pressure." ;
    dc:identifier "VSLOC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/VS/VSORRES> a sdtmig:Variable ;
    rdfs:label "Result or Finding in Original Units" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "12" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Result of the vital signs measurement as originally received or collected." ;
    dc:identifier "VSORRES" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/VS/VSORRESU> a sdtmig:Variable ;
    rdfs:label "Original Units" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66770> ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "13" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Original units in which the data were collected. The unit for VSORRES. Examples: \"in\", \"LB\", \"beats/min\"." ;
    dc:identifier "VSORRESU" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/VS/VSPOS> a sdtmig:Variable ;
    rdfs:label "Vital Signs Position of Subject" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C71148> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "11" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Position of the subject during a measurement or examination. Examples: \"SUPINE\", \"STANDING\", \"SITTING\"." ;
    dc:identifier "VSPOS" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/VS/VSREASND> a sdtmig:Variable ;
    rdfs:label "Reason Not Performed" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "18" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Describes why a measurement or test was not performed. Examples: \"BROKEN EQUIPMENT\", \"SUBJECT REFUSED\". Used in conjunction with VSSTAT when value is \"NOT DONE\"." ;
    dc:identifier "VSREASND" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/VS/VSRFTDTC> a sdtmig:Variable ;
