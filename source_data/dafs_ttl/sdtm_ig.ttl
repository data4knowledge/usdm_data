    sdtmig:core "Perm" ;
    sdtmig:ordinal "39" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Date/time of the reference time point, SRTPTREF." ;
    dc:identifier "SRRFTDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SR/SRSCAT> a sdtmig:Variable ;
    rdfs:label "Subcategory for Test" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "12" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "A further categorization of SRCAT values." ;
    dc:identifier "SRSCAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/SR/SRSEQ> a sdtmig:Variable ;
