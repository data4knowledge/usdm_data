<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TU/DOMAIN> a sdtmig:Variable ;
    rdfs:label "Domain Abbreviation" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "2" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Two-character abbreviation for the domain." ;
    dc:identifier "DOMAIN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TU/EPOCH> a sdtmig:Variable ;
    rdfs:label "Epoch" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C99079> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "29" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Epoch associated with the date/time at which the assessment was made." ;
    dc:identifier "EPOCH" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TU/STUDYID> a sdtmig:Variable ;
    rdfs:label "Study Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "1" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Unique identifier for a study." ;
    dc:identifier "STUDYID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TU/TAETORD> a sdtmig:Variable ;
    rdfs:label "Planned Order of Element within Arm" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "28" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Number that gives the planned order of the element within the arm for the element in which the assessment was made." ;
    dc:identifier "TAETORD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TU/TUACPTFL> a sdtmig:Variable ;
    rdfs:label "Accepted Record Flag" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "24" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "In cases where more than 1 independent assessor (e.g., \"RADIOLOGIST 1\", \"RADIOLOGIST 2\", \"ADJUDICATION COMMITTEE\") provide independent assessments at the same time point, this flag identifies the record that is considered to be the accepted assessment." ;
    dc:identifier "TUACPTFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TU/TUBLFL> a sdtmig:Variable ;
    rdfs:label "Baseline Flag" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "21" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Indicator used to identify a baseline value. Should be \"Y\" or null. Note that TUBLFL is retained for backward compatibility. The authoritative baseline flag for statistical analysis is in an ADaM dataset." ;
    dc:identifier "TUBLFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TU/TUDIR> a sdtmig:Variable ;
    rdfs:label "Directionality" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C99074> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "17" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Qualifier for anatomical location or specimen further detailing directionality (e.g., \"UPPER\", \"INTERIOR\")." ;
    dc:identifier "TUDIR" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TU/TUDTC> a sdtmig:Variable ;
    rdfs:label "Date/Time of Tumor/Lesion Identification" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "30" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "TUDTC variable represents the date of the scan/image/physical exam. TUDTC does not represent the date that the image was read to identify tumors. TUDTC also does not represent the VISIT date." ;
    dc:identifier "TUDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TU/TUDY> a sdtmig:Variable ;
    rdfs:label "Study Day of Tumor/Lesion Identification" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "31" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Study day of the scan/image/physical exam, measured as integer days. Algorithm for calculations must be relative to the sponsor-defined RFSTDTC variable in Demographics." ;
    dc:identifier "TUDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TU/TUEVAL> a sdtmig:Variable ;
    rdfs:label "Evaluator" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C78735> ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "22" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Role of the person who provided the evaluation. Examples: \"ADJUDICATION COMMITTEE\", \"INDEPENDENT ASSESSOR\". \\n This column can be left null when the investigator provides the complete set of data in the domain. However, the column should contain no null values when data from 1 or more independent assessors is included. For example, the rows attributed to the investigator should contain a value of \"INVESTIGATOR\"." ;
    dc:identifier "TUEVAL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TU/TUEVALID> a sdtmig:Variable ;
    rdfs:label "Evaluator Identifier" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C96777> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "23" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to distinguish multiple evaluators with the same role recorded in --EVAL. Examples: \"RADIOLOGIST1\", \"RADIOLOGIST2\". See assumption 9." ;
    dc:identifier "TUEVALID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TU/TUGRPID> a sdtmig:Variable ;
    rdfs:label "Group ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "5" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to link together a block of related records within a subject in a domain. Can be used to group split or merged tumors/lesions which have been identified." ;
    dc:identifier "TUGRPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TU/TULAT> a sdtmig:Variable ;
    rdfs:label "Laterality" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C99073> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "16" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Qualifier for anatomical location or specimen further detailing laterality (e.g., \"LEFT\", \"RIGHT\", \"BILATERAL\")." ;
    dc:identifier "TULAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TU/TULNKGRP> a sdtmig:Variable ;
    rdfs:label "Link Group ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "9" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifier used to link related records across domains. This will usually be a many-to-one relationship." ;
    dc:identifier "TULNKGRP" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TU/TULNKID> a sdtmig:Variable ;
    rdfs:label "Link ID" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "8" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifier used to link identified tumor/lesion/location of interest to the assessment results (in TR domain) over the course of the study." ;
    dc:identifier "TULNKID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TU/TULOBXFL> a sdtmig:Variable ;
    rdfs:label "Last Observation Before Exposure Flag" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "20" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Operationally derived indicator used to identify the last non-missing value prior to RFXSTDTC. Should be \"Y\" or null." ;
    dc:identifier "TULOBXFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TU/TULOC> a sdtmig:Variable ;
    rdfs:label "Location of the Tumor/Lesion" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C74456> ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "15" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to specify the anatomical location of the identified tumor/lesion (e.g., \"LIVER\"). \\n Note: When anatomical location is broken down and collected as distinct pieces of data that when combined provide the overall location information (e.g., laterality/directionality/distribution), then additional anatomical location qualifiers should be used. See assumption 3." ;
    dc:identifier "TULOC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TU/TUMETHOD> a sdtmig:Variable ;
    rdfs:label "Method of Identification" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C85492> ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "19" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Method used to identify the tumor/lesion. Examples: \"MRI\", \"CT SCAN\"." ;
    dc:identifier "TUMETHOD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TU/TUNAM> a sdtmig:Variable ;
    rdfs:label "Laboratory/Vendor Name" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "14" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "The name or identifier of the vendor that performed the tumor/lesion Identification. This column can be left null when the investigator provides the complete set of data in the domain." ;
    dc:identifier "TUNAM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TU/TUORRES> a sdtmig:Variable ;
    rdfs:label "Tumor/Lesion ID Result" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "12" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Result of the tumor/lesion identification. The result of tumor/lesion identification is a classification of the identified tumor/lesion. Example: When TUTESTCD = \"TUMIDENT\", values of TUORRES might be \"TARGET\", \"NON-TARGET\", \"NEW\", or \"BENIGN ABNORMALITY\"." ;
    dc:identifier "TUORRES" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TU/TUPORTOT> a sdtmig:Variable ;
    rdfs:label "Portion or Totality" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C99075> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "18" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Qualifier for anatomical location or specimen further detailing the distribution, which means arrangement of, or apportioning of. Examples: \"ENTIRE\", \"SINGLE\", \"SEGMENT\", \"MULTIPLE\"." ;
    dc:identifier "TUPORTOT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TU/TUREFID> a sdtmig:Variable ;
    rdfs:label "Reference ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "6" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Internal or external identifier (e.g., medical image ID number)." ;
    dc:identifier "TUREFID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TU/TUSEQ> a sdtmig:Variable ;
    rdfs:label "Sequence Number" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "4" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Sequence number given to ensure uniqueness within a dataset for a subject. May be any valid number." ;
    dc:identifier "TUSEQ" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TU/TUSPID> a sdtmig:Variable ;
    rdfs:label "Sponsor-Defined Identifier" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "7" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Sponsor-defined identifier." ;
    dc:identifier "TUSPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TU/TUSTRESC> a sdtmig:Variable ;
    rdfs:label "Tumor/Lesion ID Result Std. Format" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C123650> ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "13" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Contains the result value for all findings copied or derived from TUORRES in a standard format." ;
    dc:identifier "TUSTRESC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TU/TUTEST> a sdtmig:Variable ;
    rdfs:label "Tumor/Lesion ID Test Name" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C96783> ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "11" ;
    sdtmig:role "Synonym Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Verbatim name of the test for the tumor/lesion identification. The value in TUTEST cannot be longer than 40 characters. Example: \"Tumor identification\". See assumption 3." ;
    dc:identifier "TUTEST" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TU/TUTESTCD> a sdtmig:Variable ;
    rdfs:label "Tumor/Lesion ID Short Name" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C96784> ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "10" ;
    sdtmig:role "Topic" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Short name of the TEST in TUTEST. TUTESTCD cannot be longer than 8 characters nor can start with a number. TUTESTCD cannot contain characters other than letters, numbers, or underscores. Example: \"TUMIDENT\". See assumption 3." ;
    dc:identifier "TUTESTCD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TU/USUBJID> a sdtmig:Variable ;
    rdfs:label "Unique Subject Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "3" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifier used to uniquely identify a subject across all studies for all applications or submissions involving the product." ;
    dc:identifier "USUBJID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TU/VISIT> a sdtmig:Variable ;
    rdfs:label "Visit Name" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "26" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Protocol-defined description of a clinical encounter." ;
    dc:identifier "VISIT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TU/VISITDY> a sdtmig:Variable ;
    rdfs:label "Planned Study Day of Visit" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "27" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Planned study day of the visit based upon RFSTDTC in Demographics. Should be an integer." ;
    dc:identifier "VISITDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TU/VISITNUM> a sdtmig:Variable ;
    rdfs:label "Visit Number" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "25" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Clinical encounter number. Numeric version of VISIT, used for sorting." ;
    dc:identifier "VISITNUM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TV> a sdtmig:Domain ;
    rdfs:label "Trial Visits" ;
    sdtmig:hasVariable <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TV/ARM>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TV/ARMCD>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TV/DOMAIN>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TV/STUDYID>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TV/TVENRL>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TV/TVSTRL>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TV/VISIT>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TV/VISITDY>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TV/VISITNUM> ;
    sdtmig:ordinal "61" ;
    sdtmig:structure "One record per planned Visit per Arm" ;
    dc:description "Trial Visits" ;
    dc:identifier "TV" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TV/ARM> a sdtmig:Variable ;
    rdfs:label "Description of Planned Arm" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "7" ;
    sdtmig:role "Synonym Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "1. Name given to an arm or treatment group. \\n 2. If the timing of visits for a trial does not depend on which arm a subject is in, then Arm should be left blank." ;
    dc:identifier "ARM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TV/ARMCD> a sdtmig:Variable ;
    rdfs:label "Planned Arm Code" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "6" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "1. ARMCD is limited to 20 characters and does not have special character restrictions. The maximum length of ARMCD is longer than for other \"short\" variables to accommodate the kind of values that are likely to be needed for crossover trials. For example, if ARMCD values for a 7-period crossover were constructed using 2-character abbreviations for each treatment and separating hyphens, the length of ARMCD values would be 20. \\n 2. If the timing of visits for a trial does not depend on which arm a subject is in, then ARMCD should be null." ;
    dc:identifier "ARMCD" .

