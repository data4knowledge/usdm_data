    sdtmig:ordinal "29" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Epoch associated with the date/time at which the assessment was made." ;
    dc:identifier "TAETORD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TR/TRACPTFL> a sdtmig:Variable ;
    rdfs:label "Accepted Record Flag" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "25" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "In cases where more than 1 independent assessor (e.g., \"RADIOLOGIST 1\", \"RADIOLOGIST 2\", \"ADJUDICATION COMMITTEE\") provide independent assessments at the same time point, this flag identifies the record that is considered to be the accepted assessment." ;
    dc:identifier "TRACPTFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TR/TRBLFL> a sdtmig:Variable ;
    rdfs:label "Baseline Flag" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "22" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Indicator used to identify a baseline value. Should be \"Y\" or null. Note that TRBLFL is retained for backward compatibility. The authoritative baseline flag for statistical analysis is in an ADaM dataset." ;
    dc:identifier "TRBLFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TR/TRDTC> a sdtmig:Variable ;
    rdfs:label "Date/Time of Tumor/Lesion Measurement" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "31" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "The date of the scan/image/physical exam. TRDTC does not represent the date that the image was read to identify tumors/lesions. TRDTC also does not represent the VISIT date." ;
    dc:identifier "TRDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TR/TRDY> a sdtmig:Variable ;
    rdfs:label "Study Day of Tumor/Lesion Measurement" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "32" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Study day of the scan/image/physical exam, measured as integer days. Algorithm for calculations must be relative to the sponsor-defined RFSTDTC variable in Demographics." ;
    dc:identifier "TRDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TR/TREVAL> a sdtmig:Variable ;
    rdfs:label "Evaluator" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C78735> ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "23" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Role of the person who provided the evaluation. Used only for results that are subjective (e.g., assigned by a person or a group). Examples: \"ADJUDICATION COMMITTEE\", \"INDEPENDENT ASSESSOR\"." ;
    dc:identifier "TREVAL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TR/TREVALID> a sdtmig:Variable ;
    rdfs:label "Evaluator Identifier" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C96777> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "24" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to distinguish multiple evaluators with the same role recorded in TREVAL. Examples: \"RADIOLOGIST1\", \"RADIOLOGIST2\". See assumption 6." ;
    dc:identifier "TREVALID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TR/TRGRPID> a sdtmig:Variable ;
    rdfs:label "Group ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "5" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to link together a block of related records within a subject in a domain." ;
    dc:identifier "TRGRPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TR/TRLNKGRP> a sdtmig:Variable ;
    rdfs:label "Link Group" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "9" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to group and link all of the measurement/assessment records used in the assessment of the response record in the RS domain." ;
    dc:identifier "TRLNKGRP" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TR/TRLNKID> a sdtmig:Variable ;
    rdfs:label "Link ID" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "8" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifier used to link the assessment result records to the individual tumor/lesion identification record in TU domain." ;
    dc:identifier "TRLNKID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TR/TRLOBXFL> a sdtmig:Variable ;
    rdfs:label "Last Observation Before Exposure Flag" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "21" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Operationally-derived indicator used to identify the last non-missing value prior to RFXSTDTC. Should be \"Y\" or null." ;
    dc:identifier "TRLOBXFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TR/TRMETHOD> a sdtmig:Variable ;
    rdfs:label "Method Used to Identify the Tumor/Lesion" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C85492> ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "20" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Method used to measure the tumor/lesion/location of interest. Examples: \"MRI\", \"CT SCAN\", \"PET SCAN\", \"Coronary angiography\"." ;
    dc:identifier "TRMETHOD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TR/TRNAM> a sdtmig:Variable ;
    rdfs:label "Laboratory/Vendor Name" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "19" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "The name or identifier of the vendor that performed the tumor/lesion measurement or assessment. This column can be left null when the investigator provides the complete set of data in the domain." ;
    dc:identifier "TRNAM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TR/TRORRES> a sdtmig:Variable ;
    rdfs:label "Result or Finding in Original Units" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "12" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Result of the tumor/lesion measurement/assessment as originally received or collected." ;
    dc:identifier "TRORRES" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TR/TRORRESU> a sdtmig:Variable ;
    rdfs:label "Original Units" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C71620> ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "13" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Original units in which the data were collected. The unit for TRORRES. Example: \"mm\"." ;
