<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/QS/QSBLFL> a sdtmig:Variable ;
    rdfs:label "Baseline Flag" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "20" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Indicator used to identify a baseline value. Should be \"Y\" or null. Note that QSBLFL is retained for backward compatibility. The authoritative baseline for statistical analysis is in an ADaM dataset." ;
    dc:identifier "QSBLFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/QS/QSCAT> a sdtmig:Variable ;
    rdfs:label "Category of Question" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C100129> ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "9" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to specify the questionnaire in which the question identified by QSTEST and QSTESTCD was included. Examples: \"ADAS-COG\", \"MDS-UPDRS\"." ;
    dc:identifier "QSCAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/QS/QSDRVFL> a sdtmig:Variable ;
    rdfs:label "Derived Flag" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "21" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to indicate a derived record. The value should be \"Y\" or null. Records that represent the average of other records or questionnaire subscores that do not come from the CRF are examples of records that would be derived for the submission datasets. If QSDRVFL = \"Y\", then QSORRES may be null with QSSTRESC and (if numeric) QSSTRESN having the derived value." ;
    dc:identifier "QSDRVFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/QS/QSDTC> a sdtmig:Variable ;
    rdfs:label "Date/Time of Finding" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "27" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Date of questionnaire." ;
    dc:identifier "QSDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/QS/QSDY> a sdtmig:Variable ;
    rdfs:label "Study Day of Finding" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "28" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Study day of finding collection, measured as integer days. Algorithm for calculations must be relative to the sponsor-defined RFSTDTC variable in Demographics." ;
    dc:identifier "QSDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/QS/QSELTM> a sdtmig:Variable ;
    rdfs:label "Planned Elapsed Time from Time Point Ref" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "31" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 duration" ;
    dc:description "Planned elapsed time (in ISO 8601) relative to a planned fixed reference (QSTPTREF). This variable is useful where there are repetitive measures. Not a clock time or a date time variable. Represented as an ISO 8601 duration. Examples: \"-PT15M\" to represent the period of 15 minutes prior to the reference point indicated by QSTPTREF, \"PT8H\" to represent the period of 8 hours after the reference point indicated by QSTPTREF." ;
    dc:identifier "QSELTM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/QS/QSEVINTX> a sdtmig:Variable ;
    rdfs:label "Evaluation Interval Text" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "35" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Evaluation interval associated with an observation, where the interval is not able to be represented in ISO 8601 format. Examples: \"LIFETIME\", \"LAST NIGHT\", \"RECENTLY\", \"OVER THE LAST FEW WEEKS\"." ;
    dc:identifier "QSEVINTX" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/QS/QSEVLINT> a sdtmig:Variable ;
    rdfs:label "Evaluation Interval" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "34" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 duration or interval" ;
    dc:description "Evaluation interval associated with a QSTEST question represented in ISO 8601 character format. Example: \"-P2Y\" to represent an interval of 2 years in the question \"Have you experienced any episodes in the past 2 years?\"." ;
    dc:identifier "QSEVLINT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/QS/QSGRPID> a sdtmig:Variable ;
    rdfs:label "Group ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "5" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to tie together a block of related records in a single domain for a subject." ;
    dc:identifier "QSGRPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/QS/QSLOBXFL> a sdtmig:Variable ;
    rdfs:label "Last Observation Before Exposure Flag" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "19" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Operationally derived indicator used to identify the last non-missing value prior to RFXSTDTC. Should be \"Y\" or null." ;
    dc:identifier "QSLOBXFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/QS/QSMETHOD> a sdtmig:Variable ;
    rdfs:label "Method of Test or Examination" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C158113> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "18" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Method of the test or examination." ;
    dc:identifier "QSMETHOD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/QS/QSORRES> a sdtmig:Variable ;
    rdfs:label "Finding in Original Units" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "11" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Finding as originally received or collected (e.g., \"RARELY\", \"SOMETIMES\"). When sponsors apply codelist to indicate that code values are statistically meaningful standardized scores (which are defined by sponsors or by valid methodologies, e.g., SF36 questionnaires), QSORRES will contain the decode format; QSSTRESC and QSSTRESN may contain the standardized code values or scores." ;
    dc:identifier "QSORRES" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/QS/QSORRESU> a sdtmig:Variable ;
    rdfs:label "Original Units" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C71620> ;
