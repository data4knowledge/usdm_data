    sdtmig:ordinal "17" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Describes the reason a response to a question about the occurrence of a procedure agent was not collected. Used in conjunction with AGSTAT when value is \"NOT DONE\"." ;
    dc:identifier "AGREASND" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AG/AGROUTE> a sdtmig:Variable ;
    rdfs:label "Route of Administration" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66729> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "25" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Route of administration for AGTRT. Example: \"ORAL\"." ;
    dc:identifier "AGROUTE" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AG/AGSCAT> a sdtmig:Variable ;
    rdfs:label "Subcategory for Agent" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "13" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Further categorization of agent." ;
    dc:identifier "AGSCAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AG/AGSEQ> a sdtmig:Variable ;
    rdfs:label "Sequence Number" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "4" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Sequence number given to ensure uniqueness of subject records within a domain. May be any valid number." ;
    dc:identifier "AGSEQ" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AG/AGSPID> a sdtmig:Variable ;
    rdfs:label "Sponsor-Defined Identifier" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "6" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Sponsor-defined reference number. May be preprinted on the CRF as an explicit line identifier or defined in the sponsor\'s operational database. Example: Line number from the procedure or test page." ;
    dc:identifier "AGSPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AG/AGSTAT> a sdtmig:Variable ;
    rdfs:label "Completion Status" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66789> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "16" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to indicate that a question about a prespecified agent was not answered. Should be null or have a value of \"NOT DONE\"." ;
    dc:identifier "AGSTAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AG/AGSTDTC> a sdtmig:Variable ;
    rdfs:label "Start Date/Time of Agent" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "31" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "The date/time when administration of the treatment indicated by AGTRT and the dosing variables began." ;
    dc:identifier "AGSTDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AG/AGSTDY> a sdtmig:Variable ;
    rdfs:label "Study Day of Start of Agent" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "33" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Study day of start of agent relative to the sponsor-defined RFSTDTC." ;
    dc:identifier "AGSTDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AG/AGSTRF> a sdtmig:Variable ;
    rdfs:label "Start Relative to Reference Period" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66728> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "36" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Describes the start of the agent relative to sponsor-defined reference period. The sponsor-defined reference period is a continuous period of time defined by a discrete starting point and a discrete ending point (represented by RFSTDTC and RFENDTC in Demographics). If information such as \"PRIOR\", \"ONGOING\", or \"CONTINUING\" was collected, this information may be translated into AGSTRF. \\n Not all values of the codelist are allowable for this variable. See Section 4.4.7, Use of Relative Timing Variables." ;
    dc:identifier "AGSTRF" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AG/AGSTRTPT> a sdtmig:Variable ;
    rdfs:label "Start Relative to Reference Time Point" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66728> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "38" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifies the start of the agent as being before or after the sponsor-defined reference time point defined by variable AGSTTPT. \\n Not all values of the codelist are allowable for this variable. See Section 4.4.7, Use of Relative Timing Variables." ;
    dc:identifier "AGSTRTPT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AG/AGSTTPT> a sdtmig:Variable ;
    rdfs:label "Start Reference Time Point" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "39" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Description or date/time in ISO 8601 character format of the reference point referred to by AGSTRTPT. Examples: \"2003-12-15\", \"VISIT 1\"." ;
    dc:identifier "AGSTTPT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/AG/AGTRT> a sdtmig:Variable ;
