    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Position of the subject during the test. Examples: \"SUPINE\", \"STANDING\", \"SITTING\"." ;
    dc:identifier "FTPOS" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/FT/FTREASND> a sdtmig:Variable ;
