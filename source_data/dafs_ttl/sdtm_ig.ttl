<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MH/DOMAIN> a sdtmig:Variable ;
    rdfs:label "Domain Abbreviation" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "2" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Two-character abbreviation for the domain." ;
    dc:identifier "DOMAIN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MH/EPOCH> a sdtmig:Variable ;
    rdfs:label "Epoch" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C99079> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "20" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Epoch associated with the start date/time of the medical history event." ;
    dc:identifier "EPOCH" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MH/MHBODSYS> a sdtmig:Variable ;
    rdfs:label "Body System or Organ Class" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "18" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Dictionary-derived. Body system or organ class that is involved in an event or measurement from a standard hierarchy (e.g., MedDRA). When using a multi-axial dictionary such as MedDRA, this should contain the SOC used for the sponsor\'s analyses and summary tables which may not necessarily be the primary SOC." ;
    dc:identifier "MHBODSYS" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MH/MHCAT> a sdtmig:Variable ;
    rdfs:label "Category for Medical History" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "12" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to define a category of related records. Examples: \"CARDIAC\", \"GENERAL\"." ;
    dc:identifier "MHCAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MH/MHDECOD> a sdtmig:Variable ;
    rdfs:label "Dictionary-Derived Term" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "10" ;
    sdtmig:role "Synonym Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Dictionary-derived text description of MHTERM or MHMODIFY. Equivalent to the Preferred Term (PT in MedDRA). The sponsor is expected to provide the dictionary name and version used to map the terms utilizing the external codelist element in the Define-XML document." ;
    dc:identifier "MHDECOD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MH/MHDTC> a sdtmig:Variable ;
    rdfs:label "Date/Time of History Collection" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "21" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Collection date and time of the medical history observation represented in ISO 8601 character format." ;
    dc:identifier "MHDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MH/MHDY> a sdtmig:Variable ;
    rdfs:label "Study Day of History Collection" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "24" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Study day of medical history collection, measured as integer day. Algorithm for calculations must be relative to the sponsor-defined RFSTDTC variable in Demographics. This formula should be consistent across the submission." ;
    dc:identifier "MHDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MH/MHENDTC> a sdtmig:Variable ;
    rdfs:label "End Date/Time of Medical History Event" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "23" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "End date/time of the medical history event." ;
    dc:identifier "MHENDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MH/MHENRF> a sdtmig:Variable ;
    rdfs:label "End Relative to Reference Period" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66728> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "25" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Describes the end of the event relative to the sponsor-defined reference period. The sponsor-defined reference period is a continuous period of time defined by a discrete starting point and a discrete ending point (represented by RFSTDTC and RFENDTC in Demographics). \\n Not all values of the codelist are allowable for this variable. See Section 4.4.7, Use of Relative Timing Variables." ;
    dc:identifier "MHENRF" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MH/MHENRTPT> a sdtmig:Variable ;
    rdfs:label "End Relative to Reference Time Point" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66728> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "26" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifies the end of the event as being before or after the reference time point defined by variable MHENTPT. \\n Not all values of the codelist are allowable for this variable. See Section 4.4.7, Use of Relative Timing Variables." ;
    dc:identifier "MHENRTPT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MH/MHENTPT> a sdtmig:Variable ;
    rdfs:label "End Reference Time Point" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "27" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Description or date/time in ISO 8601 character format of the reference point referred to by MHENRTPT. Examples: \"2003-12-25\", \"VISIT 2\"." ;
    dc:identifier "MHENTPT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MH/MHEVDTYP> a sdtmig:Variable ;
    rdfs:label "Medical History Event Date Type" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C124301> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "11" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Specifies the aspect of the medical condition or event by which MHSTDTC and/or the MHENDTC is defined. Examples: \"DIAGNOSIS\", \"SYMPTOMS\", \"RELAPSE\", \"INFECTION\"." ;
    dc:identifier "MHEVDTYP" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MH/MHGRPID> a sdtmig:Variable ;
    rdfs:label "Group ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "5" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to tie together a block of related records in a single domain for a subject." ;
    dc:identifier "MHGRPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MH/MHMODIFY> a sdtmig:Variable ;
    rdfs:label "Modified Reported Term" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "9" ;
    sdtmig:role "Synonym Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "If MHTERM is modified to facilitate coding, then MHMODIFY will contain the modified text." ;
    dc:identifier "MHMODIFY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MH/MHOCCUR> a sdtmig:Variable ;
    rdfs:label "Medical History Occurrence" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "15" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used when the occurrence of specific medical history conditions is solicited, to indicate whether (\"Y\"/\"N\") a medical condition (MHTERM) had ever occurred. Values are null for spontaneously reported events." ;
    dc:identifier "MHOCCUR" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MH/MHPRESP> a sdtmig:Variable ;
    rdfs:label "Medical History Event Pre-Specified" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "14" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "A value of \"Y\" indicates that this medical history event was prespecified on the CRF. Values are null for spontaneously reported events (i.e., those collected as free-text verbatim terms)." ;
    dc:identifier "MHPRESP" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MH/MHREASND> a sdtmig:Variable ;
    rdfs:label "Reason Medical History Not Collected" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "17" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Describes the reason why data for a prespecified condition was not collected. Used in conjunction with MHSTAT when value is \"NOT DONE\"." ;
    dc:identifier "MHREASND" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MH/MHREFID> a sdtmig:Variable ;
    rdfs:label "Reference ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "6" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Internal or external medical history identifier." ;
    dc:identifier "MHREFID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/MH/MHSCAT> a sdtmig:Variable ;
