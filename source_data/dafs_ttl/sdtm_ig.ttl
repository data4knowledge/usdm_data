    sdtmig:core "Req" ;
    sdtmig:ordinal "2" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Two-character abbreviation for the domain." ;
    dc:identifier "DOMAIN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/FT/EPOCH> a sdtmig:Variable ;
    rdfs:label "Epoch" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C99079> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "31" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Epoch associated with the observation date/time of the functional tests finding." ;
    dc:identifier "EPOCH" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/FT/FTBLFL> a sdtmig:Variable ;
    rdfs:label "Baseline Flag" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "24" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "A baseline defined by the sponsor (could be derived in the same manner as FTLOBXFL or ABLFL, but is not required to be). The value should be \"Y\" or null. Note that FTBLFL is retained for backward compatibility. The authoritative baseline flag for statistical analysis is in an ADaM dataset." ;
    dc:identifier "FTBLFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/FT/FTCAT> a sdtmig:Variable ;
    rdfs:label "Category" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C115304> ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "10" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to specify the functional test in which the functional test question identified by FTTEST and FTTESTCD was included." ;
    dc:identifier "FTCAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/FT/FTDRVFL> a sdtmig:Variable ;
    rdfs:label "Derived Flag" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "25" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to indicate a derived record (e.g., a record that represents the average of other records such as a computed baseline). Should be \"Y\" or null." ;
    dc:identifier "FTDRVFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/FT/FTDTC> a sdtmig:Variable ;
    rdfs:label "Date/Time of Test" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "32" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Collection date and time of functional test." ;
    dc:identifier "FTDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/FT/FTDY> a sdtmig:Variable ;
    rdfs:label "Study Day of Test" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "33" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Actual study day of test expressed in integer days relative to the sponsor-defined RFSTDTC in Demographics." ;
    dc:identifier "FTDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/FT/FTELTM> a sdtmig:Variable ;
    rdfs:label "Planned Elapsed Time from Time Point Ref" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "36" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 duration" ;
    dc:description "Planned elapsed time relative to a planned fixed reference (FTTPTREF). Not a clock time or a date/time variable, but an interval, represented as ISO duration." ;
    dc:identifier "FTELTM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/FT/FTGRPID> a sdtmig:Variable ;
    rdfs:label "Group ID" ;
    sdtmig:core "Perm" ;
