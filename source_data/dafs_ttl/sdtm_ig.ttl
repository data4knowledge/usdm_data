    dc:identifier "FTSTAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/FT/FTSTRESC> a sdtmig:Variable ;
    rdfs:label "Result or Finding in Standard Format" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "15" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Contains the result value for all findings, copied or derived from FTORRES in a standard format or in standard units. FTSTRESC should store all results or findings in character format; if results are numeric, they should also be stored in numeric format in FTSTRESN." ;
    dc:identifier "FTSTRESC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/FT/FTSTRESN> a sdtmig:Variable ;
    rdfs:label "Numeric Result/Finding in Standard Units" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "16" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Used for continuous or numeric results or findings in standard format; copied in numeric format from FTSTRESC. FTSTRESN should store all numeric test results or findings." ;
    dc:identifier "FTSTRESN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/FT/FTSTRESU> a sdtmig:Variable ;
    rdfs:label "Standard Units" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C71620> ;
