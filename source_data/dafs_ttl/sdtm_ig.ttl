        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TD/TDORDER>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TD/TDSTOFF>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TD/TDTGTPAI> ;
    sdtmig:ordinal "54" ;
    sdtmig:structure "One record per planned constant assessment period" ;
    dc:description "Trial Disease Assessments" ;
    dc:identifier "TD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/TD/DOMAIN> a sdtmig:Variable ;
    rdfs:label "Domain Abbreviation" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "2" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Two-character abbreviation for the domain." ;
