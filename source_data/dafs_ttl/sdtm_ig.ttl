<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DA/DACAT> a sdtmig:Variable ;
    rdfs:label "Category" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "12" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to define a category of topic-variable values. Examples: \"STUDY MEDICATION\", \"RESCUE MEDICATION\"." ;
    dc:identifier "DACAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DA/DADTC> a sdtmig:Variable ;
    rdfs:label "Date/Time of Collection" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "26" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Date and time of the product accountability assessment represented in ISO 8601 character format." ;
    dc:identifier "DADTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DA/DADY> a sdtmig:Variable ;
    rdfs:label "Study Day of Visit/Collection/Exam" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "27" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Study day of product accountability assessment, measured in integer days. Algorithm for calculations must be relative to the sponsor-defined RFSTDTC in Demographics." ;
    dc:identifier "DADY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DA/DAGRPID> a sdtmig:Variable ;
    rdfs:label "Group ID" ;
