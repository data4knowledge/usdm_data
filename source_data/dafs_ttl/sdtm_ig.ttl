<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/GF/GFSEQID> a sdtmig:Variable ;
    rdfs:label "Sequence Identifier \\n" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "33" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "A unique identifier for the sequence used as the reference to identify the genetic variation in the result. Examples: \"NM_001234\", \"ENSG00000182533\", \"ENST00000343849.2\"." ;
    dc:identifier "GFSEQID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/GF/GFSPEC> a sdtmig:Variable ;
    rdfs:label "Specimen Material Type" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C111114> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "40" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifies the type of genetic material used for the measurement." ;
    dc:identifier "GFSPEC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/GF/GFSPID> a sdtmig:Variable ;
    rdfs:label "Sponsor-Defined Identifier" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "9" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Sponsor-defined identifier." ;
    dc:identifier "GFSPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/GF/GFSTAT> a sdtmig:Variable ;
    rdfs:label "Completion Status" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66789> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "36" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to indicate that a question was not asked or a test was not done, or a test was attempted but did not generate a result. Should be null or have a value of \"NOT DONE\"." ;
    dc:identifier "GFSTAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/GF/GFSTREFC> a sdtmig:Variable ;
    rdfs:label "Reference Result in Standard Format" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "23" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Reference value for the result or finding copied or derived from GFORREF in a standard format." ;
    dc:identifier "GFSTREFC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/GF/GFSTREFN> a sdtmig:Variable ;
    rdfs:label "Numeric Reference Result in Std Units" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "24" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Reference value for continuous or numeric results or findings in standard format or in standard units. GFSTREFN uses the same units as GFSTRESN, if applicable." ;
    dc:identifier "GFSTREFN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/GF/GFSTRESC> a sdtmig:Variable ;
    rdfs:label "Result or Finding in Standard Format" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "20" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Contains the result value for all findings, copied or derived from GFORRES, in a standard format or in standard units. GFSTRESC should store all results or findings in character format; if results are numeric, they should also be stored in numeric format in GFSTRESN." ;
    dc:identifier "GFSTRESC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/GF/GFSTRESN> a sdtmig:Variable ;
    rdfs:label "Numeric Result/Finding in Standard Units" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "21" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Used for continuous or numeric results or findings in standard format; copied in numeric format from GFSTRESC. GFSTRESN should store all numeric test results or findings." ;
    dc:identifier "GFSTRESN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/GF/GFSTRESU> a sdtmig:Variable ;
    rdfs:label "Standard Units" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C71620> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "22" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Standardized units used for GFSTRESC, GFSTRESN, GFSTREFC, and GFSTREFN." ;
    dc:identifier "GFSTRESU" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/GF/GFSYM> a sdtmig:Variable ;
    rdfs:label "Genomic Symbol" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "29" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "A published symbol for the portion of the genome serving as a locus for the experiment/test." ;
    dc:identifier "GFSYM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/GF/GFSYMTYP> a sdtmig:Variable ;
    rdfs:label "Genomic Symbol Type" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C181176> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "30" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "A description of the type of genomic entity that is represented by the published symbol in GFSYM." ;
    dc:identifier "GFSYMTYP" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/GF/GFTEST> a sdtmig:Variable ;
    rdfs:label "Name of Genomic Measurement" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C181179> ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "13" ;
    sdtmig:role "Synonym Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Long name for GFTESTCD. The value in GFTEST cannot be longer than 40 characters." ;
    dc:identifier "GFTEST" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/GF/GFTESTCD> a sdtmig:Variable ;
    rdfs:label "Short Name of Genomic Measurement" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C181178> ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "12" ;
    sdtmig:role "Topic" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Short name of the measurement, test, or examination described in GFTEST. It can be used as a column name when converting a dataset from a vertical to a horizontal format. The value in GFTESTCD cannot be longer than 8 characters, nor can it start with a number (e.g., \"1TEST\" is not valid). GFTESTCD cannot contain characters other than letters, numbers, or underscores." ;
    dc:identifier "GFTESTCD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/GF/GFTPT> a sdtmig:Variable ;
    rdfs:label "Planned Time Point Name" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "53" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Text description of time when a measurement or observation should be taken as defined in the protocol. This may be represented as an elapsed time relative to a fixed reference point, such as time of last dose. See GFTPTNUM and GFTPTREF." ;
    dc:identifier "GFTPT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/GF/GFTPTNUM> a sdtmig:Variable ;
    rdfs:label "Planned Time Point Number" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "54" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Numerical version of GFTPT used in sorting." ;
    dc:identifier "GFTPTNUM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/GF/GFTPTREF> a sdtmig:Variable ;
    rdfs:label "Time Point Reference" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "56" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Name of the fixed reference point referred to by GFELTM, GFTPTNUM, and GFTPT. Examples: \"PREVIOUS DOSE\", \"PREVIOUS MEAL\"." ;
    dc:identifier "GFTPTREF" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/GF/GFTSTDTL> a sdtmig:Variable ;
    rdfs:label "Measurement, Test, or Examination Detail" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C181180> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "14" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Description of a reportable qualifying the assessment in GFTESTCD and GFTEST." ;
    dc:identifier "GFTSTDTL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/GF/GFXFN> a sdtmig:Variable ;
    rdfs:label "External File Path" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "38" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "The filename and/or path to external data not stored in the same format and possibly not the same location as the other data for a study." ;
    dc:identifier "GFXFN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/GF/NHOID> a sdtmig:Variable ;
    rdfs:label "Non-Host Organism Identifier" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "5" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Sponsor-defined identifier for a non-host organism which should only be used when the organism is the subject of the TEST. This variable should be populated with an intuitive name based on the identity of the non-host organism as reported by a lab (e.g., \"A/California/7/2009 (H1N1)\"). It is not to be used as a qualifier of the result in the record on which it appears." ;
    dc:identifier "NHOID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/GF/SPDEVID> a sdtmig:Variable ;
    rdfs:label "Sponsor Device Identifier" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "4" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Sponsor-defined identifier for a device." ;
    dc:identifier "SPDEVID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/GF/STUDYID> a sdtmig:Variable ;
    rdfs:label "Study Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "1" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Unique identifier for a study." ;
    dc:identifier "STUDYID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/GF/USUBJID> a sdtmig:Variable ;
    rdfs:label "Unique Subject Identifier" ;
    sdtmig:core "Req" ;
