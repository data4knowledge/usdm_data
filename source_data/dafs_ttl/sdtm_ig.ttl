        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CE/CESCAT>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CE/CESEQ>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CE/CESEV>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CE/CESPID>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CE/CESTAT>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CE/CESTDTC>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CE/CESTDY>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CE/CESTRF>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CE/CESTRTPT>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CE/CESTTPT>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CE/CETERM>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CE/CETOXGR>,
