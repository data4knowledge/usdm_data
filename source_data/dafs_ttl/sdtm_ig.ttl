        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPORRES>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPORRESU>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPREASND>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPREFID>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPRESSCL>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPRESTYP>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPRFTDTC>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPSBMRKS>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPSCAT>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPSEQ>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPSPCCND>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPSPEC>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPSPID>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPSPTSTD>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPSTAT>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPSTNRHI>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPSTNRLO>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPSTRESC>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPSTRESN>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPSTRESU>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPTEST>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPTESTCD>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPTPT>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPTPTNUM>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPTPTREF>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPTSTCND>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPTSTPNL>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/DOMAIN>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/EPOCH>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/STUDYID>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/TAETORD>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/USUBJID>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/VISIT>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/VISITDY>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/VISITNUM> ;
    sdtmig:ordinal "8" ;
    sdtmig:structure "One record per test per specimen per timepoint per visit per subject" ;
    dc:description "Cell Phenotype Findings" ;
    dc:identifier "CP" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPABCLID> a sdtmig:Variable ;
    rdfs:label "Antibody Clone Identifier" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "18" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifies the antibody clone (e.g., supplier-provided catalog name) used to confer specificity for the binding agent specified in CPBDAGNT." ;
    dc:identifier "CPABCLID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPANMETH> a sdtmig:Variable ;
    rdfs:label "Analysis Method" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "46" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Analysis method applied to obtain a summarized result. Analysis method describes the method of secondary processing applied to a complex observation result." ;
    dc:identifier "CPANMETH" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPBDAGNT> a sdtmig:Variable ;
    rdfs:label "Binding Agent" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "17" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "The textual description of the agent that is binding to the entity in the CPTEST variable. The CPBDAGNT variable is used to indicate that there is a binding relationship between the entities in the CPTEST and CPBDAGNT variables, regardless of direction. \\n The binding agent may be, but is not limited to, a test article; a portion of a test article; a substance related to a test article; an endogenous molecule; an allergen; an infectious agent; or a reagent (e.g., primary antibody) that confers the binding specificity for the measurement defined in CPTEST when it is needed to uniquely identify the test." ;
    dc:identifier "CPBDAGNT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPBLFL> a sdtmig:Variable ;
    rdfs:label "Baseline Flag" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "48" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Indicator used to identify a baseline value. The value should be \"Y\" or null." ;
    dc:identifier "CPBLFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPCAT> a sdtmig:Variable ;
    rdfs:label "Category" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C181171> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "23" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to define a category of topic-variable values across subjects. Examples: \"IMMUNOPHENOTYPING\", \"CELL FUNCTION\", \"TARGET ENGAGEMENT\"." ;
    dc:identifier "CPCAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPCELSTA> a sdtmig:Variable ;
    rdfs:label "Cell State" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C181172> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "13" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "A textual description of a subset of the cell population identified in CPTEST based on a particular functional and/or biological state (e.g., \"ACTIVATED\", \"PROLIFERATING\", \"SENESCENT\"). When populated, the values in CPCELSTA and CPSMRKS, in combination with the values in CPTEST and CPSBMRKS, fully describe the cell population being measured." ;
    dc:identifier "CPCELSTA" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPCLSIG> a sdtmig:Variable ;
    rdfs:label "Clinically Significant, Collected" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "50" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to indicate whether a collected observation is clinically significant based on judgement." ;
    dc:identifier "CPCLSIG" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPCNDAGT> a sdtmig:Variable ;
    rdfs:label "Test Condition Agent" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "16" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "The textual description of the agent, if applicable, used to impose the condition identified in CPTSTCND. For example, records might be produced for the same assay run under stimulating (CPTSTCND value = \"STIMULATED\") conditions produced by different stimulating agents (e.g., phorbol myristate acetate, concanavalin A, PHA-P, TNF-alpha, Ionomycin, candida antigen)." ;
    dc:identifier "CPCNDAGT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPCOLSRT> a sdtmig:Variable ;
    rdfs:label "Collected Summary Result Type" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C177908> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "30" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to indicate the type of collected summary result. This includes source summary results collected on a CRF or provided by an external vendor (e.g., central lab). If the summary result is derived using individual source data records, this summary result should be represented in ADaM. If a sponsor has both a collected summary result and a derived summary result, the collected summary result should be represented in SDTM and the derived summary result should be represented in ADaM." ;
    dc:identifier "CPCOLSRT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPCSMRKS> a sdtmig:Variable ;
    rdfs:label "Cell State Marker String" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "14" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifies the marker(s) or indicator(s) used to define the cell state (i.e., the value in CPCELSTA). \\n For example, when Ki67 expression is used to determine that a cell population is in a proliferating state (i.e., CPCELSTA value=\"PROLIFERATING\"), the value \"Ki67+\" in CPCSMRKS indicates that positive expression of Ki67 was used to define the population as proliferating. Similarly, a value of \"Ki67-\" in CPCSMRKS would indicate that lack of expression of Ki67 defined the \"NON-PROLIFERATING\" cell state in CPCELSTA. The CPCSMRKS value is useful for quickly determining which marker(s) were used to classify (i.e., operationally define) a cell population based on a functional/biological state." ;
    dc:identifier "CPCSMRKS" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPDRVFL> a sdtmig:Variable ;
    rdfs:label "Derived Flag" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "49" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to indicate a derived record. The value should be \"Y\" or null. Records that represent the average of other records, or do not come from the CRF, or are not as originally received or collected are examples of records that might be derived for the submission datasets. If CPDRVFL = \"Y\", then CPORRES may be null, with CPSTRESC and (if numeric) CPSTRESN having the derived value." ;
    dc:identifier "CPDRVFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPDTC> a sdtmig:Variable ;
    rdfs:label "Date/Time of Collection" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "56" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Date/time of specimen collection represented in ISO 8601 character format." ;
    dc:identifier "CPDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPDY> a sdtmig:Variable ;
    rdfs:label "Study Day of Visit/Collection/Exam" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "57" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Study day of specimen collection, measured in integer days. Algorithm for calculations must be relative to the sponsor-defined RFSTDTC value in Demographics." ;
    dc:identifier "CPDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPELTM> a sdtmig:Variable ;
    rdfs:label "Planned Elapsed Time from Time Point Ref" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "60" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 duration" ;
    dc:description "Planned elapsed time relative to the planned fixed reference value in CPTPTREF, represented in ISO 8601 duration format. Examples: \"-PT15M\" to represent 15 minutes prior to the reference time point indicated by CPTPTREF, \"T8H\" to represent 8 hours after the reference time point represented by CPTPTREF." ;
    dc:identifier "CPELTM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPGATDEF> a sdtmig:Variable ;
    rdfs:label "Gate Definition" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "21" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "The text string identifying the set of parameters and the order in which they are applied to define the gating strategy. In practice, a series of 2-dimensional sub-gates based on different cell characteristics (i.e., markers/indicators/physical properties) are most often combined until the cell population of interest is sufficiently resolved (i.e., electronically isolated) from other cell populations contained within the specimen. \\n For complex analyses, differences in gating strategies can produce subtle differences in results obtained for a test. To ensure nuances important for accurately interpreting the data are accounted for and which arise from the use of different gating strategies, it is often necessary to qualify the test in terms of the gating strategy. For some purposes, however, and at the discretion of the sponsor, only the ultimate or penultimate gate is identified. When specifying the gating strategy in CPGATDEF, each sub-gate should be listed in the order it was applied and separated from the next sub-gate using the pipe/vertical line (\"|\") character." ;
    dc:identifier "CPGATDEF" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPGATE> a sdtmig:Variable ;
    rdfs:label "Gate" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "20" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "The sponsor-defined name assigned to a gate. Gates are electronic (i.e., a device setting or software-defined) boundaries set by a user to virtually parse a specimen into discrete populations based on a set of defined characteristics (e.g., presence, absence, or intensity of expression of various markers; physical size; internal complexity or granularity). Gates are used to constrain data collection or analysis to a specific cell population or region of interest within the specimen." ;
    dc:identifier "CPGATE" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPGRPID> a sdtmig:Variable ;
    rdfs:label "Group ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "5" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to tie together a block of related records in a single domain for a subject." ;
    dc:identifier "CPGRPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPLNKGRP> a sdtmig:Variable ;
    rdfs:label "Link Group ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "9" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifier used to link related records across domains. This will usually be a many-to-one relationship." ;
    dc:identifier "CPLNKGRP" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPLNKID> a sdtmig:Variable ;
    rdfs:label "Link ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "8" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifier used to link related records across domains. This may be a one-to-one or a one-to-many relationship." ;
    dc:identifier "CPLNKID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPLOBXFL> a sdtmig:Variable ;
    rdfs:label "Last Observation Before Exposure Flag" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "47" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Operationally-derived indicator used to identify the last non-missing value prior to RFXSTDTC. The value should be \"Y\" or null." ;
    dc:identifier "CPLOBXFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPLOINC> a sdtmig:Variable ;
    rdfs:label "LOINC Code" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "42" ;
    sdtmig:role "Synonym Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "LOINC" ;
    dc:description "Code for the test from the LOINC code system. The sponsor is expected to provide the dictionary name and version used to map the terms utilizing the Define-XML external codelist attributes." ;
    dc:identifier "CPLOINC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPMETHOD> a sdtmig:Variable ;
    rdfs:label "Method of Test or Examination" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C85492> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "45" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Method of the test or examination. Example: \"FLOW CYTOMETRY\"." ;
    dc:identifier "CPMETHOD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPMRKSTR> a sdtmig:Variable ;
    rdfs:label "Marker String" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "19" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "The text string identifying the full set of markers/indicators used by the laboratory to operationally define the complete test based on the combination of CPTEST, CPSBMRKS, and CPCELSTA. Because laboratories often use different markers/indicators to identify a cell population, the relationship between a named cell population in CPTEST (as combined with CPSBMRKS and CPCELSTA values) and the set of markers used to identify that population is many-to-one. To ensure nuances important for accurately interpreting the data are accounted for and which arise from the use of different sets of markers, it is necessary to operationally define the test in terms of the complete set of markers/indicators used to perform that test." ;
    dc:identifier "CPMRKSTR" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPNAM> a sdtmig:Variable ;
    rdfs:label "Vendor Name" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "41" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "The name or identifier of the laboratory that performed the test." ;
    dc:identifier "CPNAM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPNRIND> a sdtmig:Variable ;
    rdfs:label "Reference Range Indicator" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C78736> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "38" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Indicates where the value falls with respect to reference range defined by CPORNRLO and CPORNRHI, CPSTNRLO and CPSTNRHI, or by CPSTNRC. Examples: \"NORMAL\", \"ABNORMAL\", \"HIGH\", \"LOW\". Sponsors should specify in the study metadata (Comments column in the Define-XML document) whether CPNRIND refers to the original or standard reference ranges and results. CPNRIND should not be used to indicate clinical significance." ;
    dc:identifier "CPNRIND" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPORNRHI> a sdtmig:Variable ;
    rdfs:label "Reference Range Upper Limit in Orig Unit" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "32" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Upper end of reference range for continuous measurement in original units. Should be populated only for continuous results." ;
    dc:identifier "CPORNRHI" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPORNRLO> a sdtmig:Variable ;
    rdfs:label "Reference Range Lower Limit in Orig Unit" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "31" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Lower end of reference range for continuous measurement in original units. Should be populated only for continuous results." ;
    dc:identifier "CPORNRLO" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPORRES> a sdtmig:Variable ;
    rdfs:label "Result or Finding in Original Units" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "26" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Result of the measurement or finding as originally received or collected." ;
    dc:identifier "CPORRES" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPORRESU> a sdtmig:Variable ;
    rdfs:label "Original Units" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C71620> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "27" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Original units in which the data were collected. The unit for CPORRES. Examples: \"10^6/L\", \"%\", \"MESF\"." ;
    dc:identifier "CPORRESU" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPREASND> a sdtmig:Variable ;
    rdfs:label "Reason Not Done" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "40" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Describes why a test was not performed, e.g., \"BROKEN EQUIPMENT\", \"SUBJECT REFUSED\", \"SPECIMEN LOST\". Used in conjunction with CPSTAT when value is \"NOT DONE\"." ;
    dc:identifier "CPREASND" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPREFID> a sdtmig:Variable ;
    rdfs:label "Reference ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "6" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Internal or external specimen identifier." ;
    dc:identifier "CPREFID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPRESSCL> a sdtmig:Variable ;
    rdfs:label "Result Scale" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C177910> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "28" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Classifies the scale of the original result value with respect to whether the result is quantitative, ordinal, nominal, or narrative." ;
    dc:identifier "CPRESSCL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPRESTYP> a sdtmig:Variable ;
    rdfs:label "Result Type" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C179588> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "29" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Classifies the kind of result (i.e., property type) originally reported for the test. Examples: \"NUMBER CONCENTRATION\", \"NUMBER FRACTION\", \"RATIO\"." ;
    dc:identifier "CPRESTYP" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPRFTDTC> a sdtmig:Variable ;
    rdfs:label "Date/Time of Reference Time Point" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "62" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Date/time for a fixed reference time point defined by CPTPTREF." ;
    dc:identifier "CPRFTDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPSBMRKS> a sdtmig:Variable ;
    rdfs:label "Sublineage Marker String" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "12" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to further subset the cell population identified in CPTEST based on the use of additional marker(s) that define a sublineage. The value in CPSBMRKS is used in combination with values in CPTEST and CPCELSTA to fully describe the cell population being measured. As such, it is an essential component of the full test name. \\n For example, three unnamed sublineages of monocytes have been identified as: CCR2+CD16-, CCR2-CD16+, and CCR2+CD16+. Whereas the entire monocyte cell population can be defined as CD14+ cells, the additional CCR2 and CD16 markers are used to differentiate one sublineage from another. As none of these sublineages have been given names, they are only known by the CCR2 and CD16 marker combinations. By associating the CPTEST value of \"Monocytes Sub\" with, for example, a value of \"CCR2+CD16-\" in CPSBMRKS, the full test is defined to be the CCR2+CD16- monocyte subpopulation." ;
    dc:identifier "CPSBMRKS" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPSCAT> a sdtmig:Variable ;
    rdfs:label "Subcategory" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "24" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "A further categorization of CPCAT." ;
    dc:identifier "CPSCAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPSEQ> a sdtmig:Variable ;
    rdfs:label "Sequence Number" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "4" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Sequence number to ensure uniqueness of subject records within a domain. May be any valid number." ;
    dc:identifier "CPSEQ" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPSPCCND> a sdtmig:Variable ;
    rdfs:label "Specimen Condition" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C78733> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "44" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "The physical state or quality of a specimen for an assessment. Example: \"CLOTTED\"." ;
    dc:identifier "CPSPCCND" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPSPEC> a sdtmig:Variable ;
    rdfs:label "Specimen Type" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C78734> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "43" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Defines the type of specimen used for a measurement. Examples: \"BLOOD\", \"BONE MARROW\"." ;
    dc:identifier "CPSPEC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPSPID> a sdtmig:Variable ;
    rdfs:label "Sponsor-Defined Identifier" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "7" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Sponsor-defined reference number. May be preprinted on the CRF as an explicit line identifier or defined in the sponsor\'s operational database. Example: Line number on the lab page." ;
    dc:identifier "CPSPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPSPTSTD> a sdtmig:Variable ;
    rdfs:label "Sponsor Test Description" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "22" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Sponsor\'s description of a test. The variable is intended to contain highly structured test description metadata used by a sponsor to unambiguously define (label) a test. Such values generally reside in a sponsor/laboratory test metadata repository. CPSPTSTD is not intended for unstructured (spontaneous) free text. \\n An example of appropriate usage is when it is necessary to include identifying information for a target cell population on which a test is conducted when the target population is not part of the test name, e.g., tests for quantitative expression of a particular marker on a specific cell population." ;
    dc:identifier "CPSPTSTD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPSTAT> a sdtmig:Variable ;
    rdfs:label "Completion Status" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66789> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "39" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to indicate that the test was not performed or that it was attempted but did not generate a result. Should be null if a result exists in CPORRES." ;
    dc:identifier "CPSTAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPSTNRHI> a sdtmig:Variable ;
    rdfs:label "Reference Range Upper Limit-Std Units" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "37" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Upper end of reference range for continuous measurements in standardized units. Should be populated only for continuous results." ;
    dc:identifier "CPSTNRHI" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPSTNRLO> a sdtmig:Variable ;
    rdfs:label "Reference Range Lower Limit-Std Units" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "36" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Lower end of reference range for continuous measurements for CPSTRESC/CPSTRESN in standardized units. Should be populated only for continuous results." ;
    dc:identifier "CPSTNRLO" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPSTRESC> a sdtmig:Variable ;
    rdfs:label "Result or Finding in Standard Format" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "33" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Contains the result value for all findings, copied or derived from CPORRES in a standard format or in standard units. CPSTRESC should store all results or findings in character format; if results are numeric, they should also be stored in numeric format in CPSTRESN." ;
    dc:identifier "CPSTRESC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPSTRESN> a sdtmig:Variable ;
    rdfs:label "Numeric Result/Finding in Standard Units" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "34" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Used for continuous or numeric results or findings in standard format; copied in numeric format from CPSTRESC. CPSTRESN should store all numeric test results or findings." ;
    dc:identifier "CPSTRESN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPSTRESU> a sdtmig:Variable ;
    rdfs:label "Standard Units" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C71620> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "35" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Standardized unit used for CPSTRESC or CPSTRESN." ;
    dc:identifier "CPSTRESU" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPTEST> a sdtmig:Variable ;
    rdfs:label "Name of Measurement, Test or Examination" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C181174> ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "11" ;
    sdtmig:role "Synonym Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Long name for CPTESTCD. For cell phenotyping, the name (often abbreviated) of the cell population, as it is generally accepted by the scientific community, is populated (rather than a colloquial designation based on a primary marker, e.g., TLym Help rather than CD4). When the test is for a sublineage which can only be identified by specifying additional markers (i.e., has not been given a name) or which is further restricted to a subpopulation based on a particular cell state (e.g., activated, proliferating, apoptotic), the Sublineage Marker String (CPSBMRKS), Cell State (CPCELSTA), and Cell State Marker String (CPCSMRKS) variables are additionally populated and the value in CPTEST is suffixed with \"Sub\" to denote that it is a subset of the population identified in CPTEST (e.g., Monocytes Sub). \\n The value in CPTEST cannot be longer than 40 characters." ;
    dc:identifier "CPTEST" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPTESTCD> a sdtmig:Variable ;
    rdfs:label "Test or Examination Short Name" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C181173> ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "10" ;
    sdtmig:role "Topic" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Short name of the measurement, test, or examination described in CPTEST. It can be used as a column name when converting a dataset from a vertical to a horizontal format. The value in CPTESTCD cannot be longer than 8 characters, nor can it start with a number (e.g., \"1TEST\" is not valid). CPTESTCD cannot contain characters other than letters, numbers, or underscores. Examples: \"MONO\", \"MNS\"." ;
    dc:identifier "CPTESTCD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPTPT> a sdtmig:Variable ;
    rdfs:label "Planned Time Point Name" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "58" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Text description of time when a specimen is to be taken, as defined in the protocol. This may be represented as an elapsed time relative to a fixed reference point (i.e., to the value in CPTPTREF). Example: \"1 hour post\"." ;
    dc:identifier "CPTPT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPTPTNUM> a sdtmig:Variable ;
    rdfs:label "Planned Time Point Number" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "59" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Numerical version of CPTPT to aid in sorting. When CPTPT is represented as an elapsed time relative to a fixed reference point (i.e., to the value in CPTPTREF), the values in CPTPTNUM should be assigned in ascending order relative to the value in CPTPTREF. For example, records for time points where CPTPT = \"5 minutes post\", 1 hour post\", and \"4 hours post\" could be represented in CPTPTNUM as \"1\", \"2\", and \"3\", which maintains the order between CPTPT and CPTPTNUM with respect to the fixed time point reference in CPTPTREF." ;
    dc:identifier "CPTPTNUM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPTPTREF> a sdtmig:Variable ;
    rdfs:label "Time Point Reference" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "61" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Descriptive name of the fixed reference point referred to by CPTPT, CPTPTNUM, and CPELTM. Examples: \"PREVIOUS DOSE\", \"PREVIOUS MEAL\"." ;
    dc:identifier "CPTPTREF" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPTSTCND> a sdtmig:Variable ;
    rdfs:label "Test Condition" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C181175> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "15" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifies any planned condition imposed by the assay system on the specimen at the time the test is performed. --TSTCND is generally used to distinguish between two or more records where the same assay is performed under varying (as opposed to fixed) conditions, usually for the purpose of making a comparison. For example, when the same assay (identified in --TEST) is performed under stimulated and non-stimulated conditions, the --TSTCND variable is used distinguish between the records." ;
    dc:identifier "CPTSTCND" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/CPTSTPNL> a sdtmig:Variable ;
    rdfs:label "Test Panel" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "25" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Sponsor-defined textual description used to group tests run together as part of a test panel. Can be used with --GRPID to ensure that relationships between associated tests are accurately identified." ;
    dc:identifier "CPTSTPNL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/DOMAIN> a sdtmig:Variable ;
    rdfs:label "Domain Abbreviation" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "2" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Two-character abbreviation for the domain." ;
    dc:identifier "DOMAIN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/EPOCH> a sdtmig:Variable ;
    rdfs:label "Epoch" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C99079> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "55" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Epoch associated with the start date/time of the observation, or the date/time of collection if start date/time is not collected." ;
    dc:identifier "EPOCH" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/STUDYID> a sdtmig:Variable ;
    rdfs:label "Study Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "1" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Unique identifier for a study." ;
    dc:identifier "STUDYID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/TAETORD> a sdtmig:Variable ;
    rdfs:label "Planned Order of Element within Arm" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "54" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Number that gives the planned order of the element within the arm." ;
    dc:identifier "TAETORD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/USUBJID> a sdtmig:Variable ;
    rdfs:label "Unique Subject Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "3" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifier used to uniquely identify a subject across all studies for all applications or submissions involving the product." ;
    dc:identifier "USUBJID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/VISIT> a sdtmig:Variable ;
    rdfs:label "Visit Name" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "52" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Protocol-defined description of clinical encounter. May be used in addition to VISITNUM and/or VISITDY." ;
    dc:identifier "VISIT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/VISITDY> a sdtmig:Variable ;
    rdfs:label "Planned Study Day of Visit" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "53" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Planned study day of the visit based upon RFSTDTC in Demographics. Should be an integer." ;
    dc:identifier "VISITDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CP/VISITNUM> a sdtmig:Variable ;
    rdfs:label "Visit Number" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "51" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Clinical encounter number. Numeric version of VISIT, used for sorting." ;
    dc:identifier "VISITNUM" .

