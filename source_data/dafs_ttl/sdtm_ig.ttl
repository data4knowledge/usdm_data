        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RP/RPSPID>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RP/RPSTAT>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RP/RPSTRESC>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RP/RPSTRESN>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RP/RPSTRESU>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RP/RPTEST>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RP/RPTESTCD>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RP/RPTPT>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/RP/RPTPTNUM>,
