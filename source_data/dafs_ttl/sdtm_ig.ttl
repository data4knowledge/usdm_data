    sdtmig:ordinal "27" ;
    sdtmig:role "Synonym Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Description of actual arm. \\n With the exception of studies which use multistage arm assignments, must be a value of ARM in the Trial Arms dataset. \\n If the subject was not assigned to an arm or followed a course not described by any planned arm, ACTARM is null and ARMNRS is populated." ;
    dc:identifier "ACTARM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DM/ACTARMCD> a sdtmig:Variable ;
    rdfs:label "Actual Arm Code" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "26" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Code of actual arm. ACTARMCD is limited to 20 characters. It is not subject to the character restrictions that apply to TESTCD. The maximum length of ACTARMCD is longer than for other short variables to accommodate the kind of values that are likely to be needed for crossover trials. \\n With the exception of studies which use multistage arm assignments, must be a value of ARMCD in the Trial Arms dataset. \\n If the subject was not assigned to an arm or followed a course not described by any planned arm, ACTARMCD is null and ARMNRS is populated." ;
    dc:identifier "ACTARMCD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DM/ACTARMUD> a sdtmig:Variable ;
    rdfs:label "Description of Unplanned Actual Arm" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "29" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "A description of actual treatment for a subject who did not receive treatment described in a planned trial arm." ;
    dc:identifier "ACTARMUD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DM/AGE> a sdtmig:Variable ;
    rdfs:label "Age" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "19" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Age expressed in AGEU. May be derived from RFSTDTC and BRTHDTC, but BRTHDTC may not be available in all cases (due to subject privacy concerns)." ;
    dc:identifier "AGE" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DM/AGEU> a sdtmig:Variable ;
    rdfs:label "Age Units" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66781> ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "20" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Units associated with AGE." ;
    dc:identifier "AGEU" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DM/ARM> a sdtmig:Variable ;
    rdfs:label "Description of Planned Arm" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "25" ;
    sdtmig:role "Synonym Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Name of the arm to which the subject was assigned. If the subject was not assigned to an arm, ARM is null and ARMNRS is populated. \\n With the exception of studies which use multistage arm assignments, must be a value of ARM in the Trial Arms dataset." ;
    dc:identifier "ARM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DM/ARMCD> a sdtmig:Variable ;
    rdfs:label "Planned Arm Code" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "24" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "ARMCD is limited to 20 characters. It is not subject to the character restrictions that apply to TESTCD. The maximum length of ARMCD is longer than for other \"short\" variables to accommodate the kind of values that are likely to be needed for crossover trials. For example, if ARMCD values for a 7-period crossover were constructed using 2-character abbreviations for each treatment and separating hyphens, the length of ARMCD values would be 20. If the subject was not assigned to a trial arm, ARMCD is null and ARMNRS is populated. \\n With the exception of studies which use multistage arm assignments, must be a value of ARMCD in the Trial Arms dataset." ;
    dc:identifier "ARMCD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DM/ARMNRS> a sdtmig:Variable ;
    rdfs:label "Reason Arm and/or Actual Arm is Null" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C142179> ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "28" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "A coded reason that arm variables (ARM and ARMCD) and/or actual arm variables (ACTARM and ACTARMCD) are null. Examples: \"SCREEN FAILURE\", \"NOT ASSIGNED\", \"ASSIGNED, NOT TREATED\", \"UNPLANNED TREATMENT\". It is assumed that if the arm and actual arm variables are null, the same reason applies to both arm and actual arm." ;
    dc:identifier "ARMNRS" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DM/BRTHDTC> a sdtmig:Variable ;
    rdfs:label "Date/Time of Birth" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "18" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Date/time of birth of the subject." ;
    dc:identifier "BRTHDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DM/COUNTRY> a sdtmig:Variable ;
    rdfs:label "Country" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "30" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Country of the investigational site in which the subject participated in the trial. \\n \\n Generally represented using ISO 3166-1 Alpha-3. Note that regulatory agency specific requirements (e.g., US FDA) may require other terminologies; in such cases, follow regulatory requirements." ;
    dc:identifier "COUNTRY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DM/DMDTC> a sdtmig:Variable ;
    rdfs:label "Date/Time of Collection" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "31" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Date/time of demographic data collection." ;
    dc:identifier "DMDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DM/DMDY> a sdtmig:Variable ;
    rdfs:label "Study Day of Collection" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "32" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Study day of collection measured as integer days." ;
    dc:identifier "DMDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DM/DOMAIN> a sdtmig:Variable ;
    rdfs:label "Domain Abbreviation" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "2" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Two-character abbreviation for the domain." ;
    dc:identifier "DOMAIN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DM/DTHDTC> a sdtmig:Variable ;
    rdfs:label "Date/Time of Death" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "13" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Date/time of death for any subject who died, in ISO 8601 format. Should represent the date/time that is captured in the clinical-trial database." ;
    dc:identifier "DTHDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DM/DTHFL> a sdtmig:Variable ;
    rdfs:label "Subject Death Flag" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "14" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Indicates the subject died. Should be \"Y\" or null. Should be populated even when the death date is unknown." ;
    dc:identifier "DTHFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DM/ETHNIC> a sdtmig:Variable ;
    rdfs:label "Ethnicity" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66790> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "23" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "The ethnicity of the subject. Sponsors should refer to the FDA guidance1 regarding the collection of ethnicity." ;
    dc:identifier "ETHNIC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DM/INVID> a sdtmig:Variable ;
    rdfs:label "Investigator Identifier" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "16" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "An identifier to describe the Investigator for the study. May be used in addition to SITEID. Not needed if SITEID is equivalent to INVID." ;
    dc:identifier "INVID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DM/INVNAM> a sdtmig:Variable ;
    rdfs:label "Investigator Name" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "17" ;
    sdtmig:role "Synonym Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Name of the investigator for a site." ;
    dc:identifier "INVNAM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DM/RACE> a sdtmig:Variable ;
    rdfs:label "Race" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C74457> ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "22" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Race of the subject. Sponsors should refer to the FDA guidance2 regarding the collection of race. See assumption below regarding RACE." ;
    dc:identifier "RACE" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DM/RFCENDTC> a sdtmig:Variable ;
    rdfs:label "Date/Time of Last Challenge Agent Admin" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "10" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Used only when protocol specifies a challenge agent to induce a condition that the investigational treatment is intended to cure, mitigate, treat, or prevent. Equal to the latest value of AGENDTC for the challenge agent (or the latest value of AGSTDTC if AGENDTC was not collected or is missing)." ;
    dc:identifier "RFCENDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DM/RFCSTDTC> a sdtmig:Variable ;
    rdfs:label "Date/Time of First Challenge Agent Admin" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "9" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Used only when protocol specifies a challenge agent to induce a condition that the investigational treatment is intended to cure, mitigate, treat, or prevent. Equal to the earliest value of AGSTDTC for the challenge agent." ;
    dc:identifier "RFCSTDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DM/RFENDTC> a sdtmig:Variable ;
    rdfs:label "Subject Reference End Date/Time" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "6" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Reference end date/time for the subject in ISO 8601 character format. Usually equivalent to the date/time when subject was determined to have ended the trial, and often equivalent to date/time of last exposure to study treatment. Required for all randomized subjects; null for screen failures or unassigned subjects." ;
    dc:identifier "RFENDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DM/RFICDTC> a sdtmig:Variable ;
    rdfs:label "Date/Time of Informed Consent" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "11" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Date/time of informed consent in ISO 8601 character format. This will be the same as the date of informed consent in the Disposition domain, if that protocol milestone is documented. Would be null only in studies not collecting the date of informed consent." ;
    dc:identifier "RFICDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DM/RFPENDTC> a sdtmig:Variable ;
    rdfs:label "Date/Time of End of Participation" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "12" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Date/time when subject ended participation or follow-up in a trial, as defined in the protocol, in ISO 8601 character format. Should correspond to the last known date of contact. Examples include completion date, withdrawal date, last follow-up, date recorded for lost to follow up, and death date." ;
    dc:identifier "RFPENDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DM/RFSTDTC> a sdtmig:Variable ;
    rdfs:label "Subject Reference Start Date/Time" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "5" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Reference start date/time for the subject in ISO 8601 character format. Usually equivalent to date/time when subject was first exposed to study treatment. See assumption 9 for additional detail on when RFSTDTC may be null." ;
    dc:identifier "RFSTDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DM/RFXENDTC> a sdtmig:Variable ;
    rdfs:label "Date/Time of Last Study Treatment" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "8" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Last date/time of exposure to any protocol-specified treatment or therapy, equal to the latest value of EXENDTC (or the latest value of EXSTDTC if EXENDTC was not collected or is missing)." ;
    dc:identifier "RFXENDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DM/RFXSTDTC> a sdtmig:Variable ;
    rdfs:label "Date/Time of First Study Treatment" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "7" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "First date/time of exposure to any protocol-specified treatment or therapy, equal to the earliest value of EXSTDTC." ;
    dc:identifier "RFXSTDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DM/SEX> a sdtmig:Variable ;
    rdfs:label "Sex" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66731> ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "21" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Sex of the subject." ;
    dc:identifier "SEX" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DM/SITEID> a sdtmig:Variable ;
    rdfs:label "Study Site Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "15" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Unique identifier for a site within a study." ;
    dc:identifier "SITEID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DM/STUDYID> a sdtmig:Variable ;
    rdfs:label "Study Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "1" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Unique identifier for a study." ;
    dc:identifier "STUDYID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DM/SUBJID> a sdtmig:Variable ;
    rdfs:label "Subject Identifier for the Study" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "4" ;
    sdtmig:role "Topic" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Subject identifier, which must be unique within the study. Often the ID of the subject as recorded on a CRF." ;
    dc:identifier "SUBJID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DM/USUBJID> a sdtmig:Variable ;
    rdfs:label "Unique Subject Identifier" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "3" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifier used to uniquely identify a subject across all studies for all applications or submissions involving the product. This must be a unique value, and could be a compound identifier formed by concatenating STUDYID-SITEID-SUBJID." ;
    dc:identifier "USUBJID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DS> a sdtmig:Domain ;
    rdfs:label "Disposition" ;
    sdtmig:hasVariable <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DS/DOMAIN>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DS/DSCAT>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DS/DSDECOD>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DS/DSDTC>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DS/DSDY>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DS/DSGRPID>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DS/DSREFID>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DS/DSSCAT>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DS/DSSEQ>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DS/DSSPID>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DS/DSSTDTC>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DS/DSSTDY>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DS/DSTERM>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DS/EPOCH>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DS/STUDYID>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DS/USUBJID> ;
    sdtmig:ordinal "13" ;
    sdtmig:structure "One record per disposition status or protocol milestone per subject" ;
    dc:description "Disposition" ;
    dc:identifier "DS" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DS/DOMAIN> a sdtmig:Variable ;
    rdfs:label "Domain Abbreviation" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "2" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Two-character abbreviation for the domain." ;
    dc:identifier "DOMAIN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DS/DSCAT> a sdtmig:Variable ;
    rdfs:label "Category for Disposition Event" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C74558> ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "10" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to define a category of related records." ;
    dc:identifier "DSCAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DS/DSDECOD> a sdtmig:Variable ;
    rdfs:label "Standardized Disposition Term" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66727> ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "9" ;
    sdtmig:role "Synonym Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Controlled terminology for the name of disposition event or protocol milestone. Examples of protocol milestones: \"INFORMED CONSENT OBTAINED\", \"RANDOMIZED\". There are separate codelists used for DSDECOD where the choice depends on the value of DSCAT. Codelist \"NCOMPLT\" is used for disposition events, codelist \"PROTMLST\" is used for protocol milestones, and codelist \"OTHEVENT\" is used for other events." ;
    dc:identifier "DSDECOD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DS/DSDTC> a sdtmig:Variable ;
    rdfs:label "Date/Time of Collection" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "13" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Collection date and time of the disposition observation represented in ISO 8601 character format." ;
    dc:identifier "DSDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DS/DSDY> a sdtmig:Variable ;
    rdfs:label "Study Day of Collection" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "15" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Study day of collection of event relative to the sponsor-defined RFSTDTC." ;
    dc:identifier "DSDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DS/DSGRPID> a sdtmig:Variable ;
    rdfs:label "Group ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "5" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to tie together a block of related records in a single domain for a subject." ;
    dc:identifier "DSGRPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DS/DSREFID> a sdtmig:Variable ;
    rdfs:label "Reference ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "6" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Internal or external identifier." ;
    dc:identifier "DSREFID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DS/DSSCAT> a sdtmig:Variable ;
    rdfs:label "Subcategory for Disposition Event" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C170443> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "11" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "A further categorization of DSCAT (e.g., \"STUDY PARTICIPATION\", \"STUDY TREATMENT\" when DSCAT = \"DISPOSITION EVENT\"). The variable may be subject to controlled terminology for other categories of disposition event records." ;
    dc:identifier "DSSCAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DS/DSSEQ> a sdtmig:Variable ;
    rdfs:label "Sequence Number" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "4" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Sequence number given to ensure uniqueness of subject records within a domain. May be any valid number." ;
    dc:identifier "DSSEQ" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DS/DSSPID> a sdtmig:Variable ;
    rdfs:label "Sponsor-Defined Identifier" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "7" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Sponsor-defined reference number. May be preprinted on the CRF as an explicit line identifier or defined in the sponsor\'s operational database. Example: Line number on a Disposition page." ;
    dc:identifier "DSSPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/DS/DSSTDTC> a sdtmig:Variable ;
    rdfs:label "Start Date/Time of Disposition Event" ;
