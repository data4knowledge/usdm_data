        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CE/TAETORD>,
        <http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CE/USUBJID> ;
    sdtmig:ordinal "5" ;
    sdtmig:structure "One record per event per subject" ;
