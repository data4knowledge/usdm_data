    dc:description "Used for continuous or numeric results or findings in standard format; copied in numeric format from OESTRESC. OESTRESN should store all numeric test results or findings." ;
    dc:identifier "OESTRESN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/OE/OESTRESU> a sdtmig:Variable ;
