<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/OE/DOMAIN> a sdtmig:Variable ;
    rdfs:label "Domain Abbreviation" ;
    sdtmig:core "Req" ;
    sdtmig:ordinal "2" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Two-character abbreviation for the domain." ;
    dc:identifier "DOMAIN" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/OE/EPOCH> a sdtmig:Variable ;
    rdfs:label "Epoch" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C99079> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "45" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Epoch associated with the date/time at which the assessment was made." ;
    dc:identifier "EPOCH" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/OE/FOCID> a sdtmig:Variable ;
    rdfs:label "Focus of Study-Specific Interest" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C119013> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "4" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identification of a focus of study-specific interest on or within a subject or specimen as called out in the protocol for which a measurement, test, or examination was performed." ;
    dc:identifier "FOCID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/OE/OEACPTFL> a sdtmig:Variable ;
    rdfs:label "Accepted Record Flag" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "39" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "In cases where more than one assessor provides an evaluation of a result or response, this flag identifies the record that is considered, by an independent assessor, to be the accepted evaluation. Expected to be \"Y\" or null." ;
    dc:identifier "OEACPTFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/OE/OEBLFL> a sdtmig:Variable ;
    rdfs:label "Baseline Flag" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "35" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Indicator used to identify a baseline value. Should be \"Y\" or null. Note that OEBLFL is retained for backward compatibility. The authoritative baseline for statistical analysis is in an ADaM dataset." ;
    dc:identifier "OEBLFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/OE/OECAT> a sdtmig:Variable ;
    rdfs:label "Category for Ophthalmic Test or Exam" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "12" ;
    sdtmig:role "Grouping Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to define a category of topic-variable values. Examples: \"VISUAL ACUITY\", \"CONTRAST SENSITIVITY\", \"OCULAR COMFORT\"." ;
    dc:identifier "OECAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/OE/OEDIR> a sdtmig:Variable ;
    rdfs:label "Directionality" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C99074> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "31" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Qualifier for anatomical location or specimen further detailing directionality. Examples: \"ANTERIOR\", \"LOWER\", \"PROXIMAL\"." ;
    dc:identifier "OEDIR" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/OE/OEDRVFL> a sdtmig:Variable ;
    rdfs:label "Derived Flag" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "36" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to indicate a derived record (e.g., a record that represents the average of other records such as a computed baseline). Should be \"Y\" or null." ;
    dc:identifier "OEDRVFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/OE/OEDTC> a sdtmig:Variable ;
    rdfs:label "Date/Time of Collection" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "46" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 datetime or interval" ;
    dc:description "Collection date/time of the observation." ;
    dc:identifier "OEDTC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/OE/OEDY> a sdtmig:Variable ;
    rdfs:label "Study Day of Visit/Collection/Exam" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "47" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Num" ;
    dc:description "Actual study day of observation/exam expressed in integer days relative to the sponsor-defined RFSTDTC in Demographics." ;
    dc:identifier "OEDY" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/OE/OEELTM> a sdtmig:Variable ;
    rdfs:label "Planned Elapsed Time from Time Point Ref" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "50" ;
    sdtmig:role "Timing" ;
    sdtmig:simpleDatatype "Char" ;
    sdtmig:valueDomain "ISO 8601 duration" ;
    dc:description "Planned elapsed time relative to a planned fixed reference (OETPTREF; e.g., \"PREVIOUS DOSE\", \"PREVIOUS MEAL\"). This variable is useful where there are repetitive measures. Not a clock time or a date/time variable, but an interval, represented as ISO duration." ;
    dc:identifier "OEELTM" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/OE/OEEVAL> a sdtmig:Variable ;
    rdfs:label "Evaluator" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C78735> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "37" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Role of the person who provided the evaluation. Used only for results that are subjective (e.g., assigned by a person or a group). Examples: \"INDEPENDENT ASSESSOR\", \"INVESTIGATOR\"." ;
    dc:identifier "OEEVAL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/OE/OEEVALID> a sdtmig:Variable ;
    rdfs:label "Evaluator Identifier" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C96777> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "38" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to distinguish multiple evaluators with the same role recorded in OEEVAL. Examples: \"RADIOLOGIST1\", \"RADIOLOGIST2\"." ;
    dc:identifier "OEEVALID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/OE/OEGRPID> a sdtmig:Variable ;
    rdfs:label "Group ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "6" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Optional group identifier, used to link together a block of related records within a subject in a domain." ;
    dc:identifier "OEGRPID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/OE/OELAT> a sdtmig:Variable ;
    rdfs:label "Laterality" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C99073> ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "30" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Qualifier for anatomical location or specimen further detailing laterality. Examples: \"RIGHT\", \"LEFT\", \"BILATERAL\"." ;
    dc:identifier "OELAT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/OE/OELNKGRP> a sdtmig:Variable ;
    rdfs:label "Link Group" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "8" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifier used to link related records across domains. This will usually be a many-to-one relationship." ;
    dc:identifier "OELNKGRP" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/OE/OELNKID> a sdtmig:Variable ;
    rdfs:label "Link ID" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "7" ;
    sdtmig:role "Identifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Identifier used to link related records across domains. This may be a one-to-one or a one-to-many relationship." ;
    dc:identifier "OELNKID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/OE/OELOBXFL> a sdtmig:Variable ;
    rdfs:label "Last Observation Before Exposure Flag" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C66742> ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "34" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Operationally derived indicator used to identify the last non-missing value prior to RFXSTDTC. The value should be \"Y\" or null." ;
    dc:identifier "OELOBXFL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/OE/OELOC> a sdtmig:Variable ;
    rdfs:label "Location Used for the Measurement" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C74456> ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "29" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Anatomical location of the subject relevant to the collection of the measurement. Examples: \"EYE\" for a finding record relative to the complete eye, \"RETINA\" for a measurement or assessment of only the retina." ;
    dc:identifier "OELOC" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/OE/OEMETHOD> a sdtmig:Variable ;
    rdfs:label "Method of Test or Examination" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C85492> ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "33" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Method of the test or examination. Example: \"ETDRS EYE CHART\" for OETESTCD = \"NUMLCOR\". The different methods may offer different functionality or granularity, affecting the set of results and associated meaning." ;
    dc:identifier "OEMETHOD" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/OE/OENRIND> a sdtmig:Variable ;
    rdfs:label "Normal/Reference Range Indicator" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C78736> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "24" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to indicate the value is outside the normal range or reference range. May be defined by OEORNRLO and OEORNRHI or other objective criteria. Examples: \"Y\", \"N\"; \"HIGH\", \"LOW\"; \"NORMAL\", \"ABNORMAL\"." ;
    dc:identifier "OENRIND" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/OE/OEORNRHI> a sdtmig:Variable ;
    rdfs:label "Normal Range Upper Limit-Original Units" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "17" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Upper end of normal range or reference range for results stored in OEORRES." ;
    dc:identifier "OEORNRHI" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/OE/OEORNRLO> a sdtmig:Variable ;
    rdfs:label "Normal Range Lower Limit-Original Units" ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "16" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Lower end of normal range or reference range for results stored in OEORRES." ;
    dc:identifier "OEORNRLO" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/OE/OEORRES> a sdtmig:Variable ;
    rdfs:label "Result or Finding in Original Units" ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "14" ;
    sdtmig:role "Result Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Result of the measurement or finding as originally received or collected. Examples: \"120\", \"<1, NORMAL\", \"RED SPOT VISIBLE\"." ;
    dc:identifier "OEORRES" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/OE/OEORRESU> a sdtmig:Variable ;
    rdfs:label "Original Units" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C71620> ;
    sdtmig:core "Exp" ;
    sdtmig:ordinal "15" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Original unit for OEORRES. Examples: \"mm\", \"um\"." ;
    dc:identifier "OEORRESU" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/OE/OEPORTOT> a sdtmig:Variable ;
    rdfs:label "Portion or Totality" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C99075> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "32" ;
    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Qualifier for anatomical location or specimen further detailing the distribution (i.e., arrangement of, apportioning of). Examples: \"ENTIRE\", \"SINGLE\", \"SEGMENT\", \"MANY\"." ;
    dc:identifier "OEPORTOT" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/OE/OEREASND> a sdtmig:Variable ;
