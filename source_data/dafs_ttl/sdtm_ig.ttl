<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CO/COEVAL> a sdtmig:Variable ;
    rdfs:label "Evaluator" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C78735> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "10" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Role of the person who provided the evaluation. Used only for results that are subjective (e.g., assigned by a person or a group). Example: \"INVESTIGATOR\"." ;
    dc:identifier "COEVAL" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CO/COEVALID> a sdtmig:Variable ;
    rdfs:label "Evaluator Identifier" ;
    sdtmig:codeList <http://id.gsk.com/dataset/cdisc/ct/v48/sdtm/C96777> ;
    sdtmig:core "Perm" ;
    sdtmig:ordinal "11" ;
    sdtmig:role "Record Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to distinguish multiple evaluators with the same role recorded in --EVAL. Examples: \"RADIOLOGIST\", \"RADIOLOGIST 1\", \"RADIOLOGIST 2\"." ;
    dc:identifier "COEVALID" .

<http://id.gsk.com/dataset/cdisc/sdtm-ig/v3-4/CO/COREF> a sdtmig:Variable ;
