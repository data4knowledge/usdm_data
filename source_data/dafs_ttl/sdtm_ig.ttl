    sdtmig:role "Variable Qualifier" ;
    sdtmig:simpleDatatype "Char" ;
    dc:description "Used to indicate whether the visit was planned (i.e., visits specified in the TV domain). Value is \"Y\" for planned visits, null for unplanned visits." ;
