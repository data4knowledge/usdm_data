<http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C78417-C28253> a skos:Concept ;
    ns1:identifier "C28253" ;
    skos:altLabel "Milligram" ;
    skos:definition "A unit of mass equal to one thousandth (1E-3) of a gram." ;
    skos:notation "mg" ;
