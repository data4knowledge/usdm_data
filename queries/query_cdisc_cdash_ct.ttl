        <http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C78426-C42998> ;
    skos:notation "EXDOSFRM" ;
    skos:prefLabel "CDISC CDASH Exposure Dose Form Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C78426-C25158> a skos:Concept ;
    ns1:identifier "C25158" ;
    skos:altLabel "cap" ;
    skos:definition "A solid pharmaceutical dosage form that contains medicinal agent within either a hard or soft soluble container or shell, usually used for the oral administration of medicine. The shells are made of a suitable form of gelatin or other substance. (NCI)" ;
    skos:notation "CAPSULE" ;
    skos:prefLabel "Capsule Dosage Form" .

<http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C78426-C28944> a skos:Concept ;
    ns1:identifier "C28944" ;
    skos:definition "A semisolid emulsion of either the oil-in-water or the water-in-oil type, ordinarily intended for topical use. (NCI)" ;
    skos:notation "CREAM" ;
    skos:prefLabel "Cream Dosage Form" .

<http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C78426-C42887> a skos:Concept ;
    ns1:identifier "C42887" ;
    skos:altLabel "aer" ;
    skos:definition "A product that is packaged under pressure and contains therapeutically active ingredients that are released upon activation of an appropriate valve system; it is intended for topical application to the skin as well as local application into the nose (nasal aerosols), mouth (lingual aerosols), or lungs (inhalation aerosols)." ;
    skos:notation "AEROSOL" ;
    skos:prefLabel "Aerosol Dosage Form" .

<http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C78426-C42933> a skos:Concept ;
    ns1:identifier "C42933" ;
    skos:definition "Any elastic aeriform fluid in which the molecules are separated from one another and have free paths. (NCI)" ;
    skos:notation "GAS" ;
    skos:prefLabel "Gas Dosage Form" .

<http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C78426-C42934> a skos:Concept ;
    ns1:identifier "C42934" ;
    skos:definition "A semisolid (1) dosage form that contains a gelling agent to provide stiffness to a solution or a colloidal dispersion (2). A gel may contain suspended particles. Note 1: A semisolid is not pourable; it does not flow or conform to its container at room temperature. It does not flow at low shear stress and generally exhibits plastic flow behavior. Note 2: A colloidal dispersion is a system in which particles of colloidal dimension (i.e., typically between 1 nm and 1 micrometer) are distributed uniformly throughout a liquid." ;
    skos:notation "GEL" ;
    skos:prefLabel "Gel Dosage Form" .

<http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C78426-C42966> a skos:Concept ;
    ns1:identifier "C42966" ;
    skos:altLabel "oint" ;
    skos:definition "A suspension or emulsion, semisolid (1) dosage form, usually containing less than 20 percent water and volatiles (2) and greater than 50 percent hydrocarbons, waxes, or polyols as the vehicle. This dosage form is generally for external application to the skin or mucous membranes. Note 1: A semisolid is not pourable; it does not flow or conform to its container at room temperature. It does not flow at low shear stress and generally exhibits plastic flow behavior. Note 2: Percent water and volatiles are measured by a loss on drying test in which the sample is heated at 105 degrees C until constant weight is achieved." ;
    skos:notation "OINTMENT" ;
    skos:prefLabel "Ointment Dosage Form" .

<http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C78426-C42968> a skos:Concept ;
    ns1:identifier "C42968" ;
    skos:definition "A drug delivery system that often contains an adhesive backing that is usually applied to an external site on the body. Its ingredients either passively diffuse from, or are actively transported from, some portion of the patch. Depending upon the patch, the ingredients are either delivered to the outer surface of the body or into the body. A patch is sometimes synonymous with the terms Extended Release Film and System." ;
    skos:notation "PATCH" ;
    skos:prefLabel "Patch Dosage Form" .

<http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C78426-C42972> a skos:Concept ;
    ns1:identifier "C42972" ;
    skos:definition "An intimate mixture of dry, finely divided drugs and/or chemicals that may be intended for internal or external use. (NCI)" ;
    skos:notation "POWDER" ;
    skos:prefLabel "Powder Dosage Form" .

<http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C78426-C42989> a skos:Concept ;
    ns1:identifier "C42989" ;
    skos:definition "A liquid minutely divided as by a jet of air or steam. (NCI)" ;
    skos:notation "SPRAY" ;
    skos:prefLabel "Spray Dosage Form" .

<http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C78426-C42993> a skos:Concept ;
    ns1:identifier "C42993" ;
    skos:altLabel "supp" ;
    skos:definition "A solid body of various weights and shapes, adapted for introduction into the rectal, vaginal, or urethral orifice of the human body; they usually melt, soften, or dissolve at body temperature." ;
    skos:notation "SUPPOSITORY" ;
    skos:prefLabel "Suppository Dosage Form" .

<http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C78426-C42994> a skos:Concept ;
    ns1:identifier "C42994" ;
    skos:altLabel "Ready to Use Suspension",
        "susp" ;
    skos:definition "A liquid dosage form that contains solid particles dispersed in a liquid vehicle. Note: A liquid is pourable; it flows and conforms to its container at room temperature. It displays Newtonian or pseudoplastic flow behavior." ;
    skos:notation "SUSPENSION" ;
    skos:prefLabel "Suspension Dosage Form" .

<http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C78426-C42998> a skos:Concept ;
    ns1:identifier "C42998" ;
    skos:altLabel "tab" ;
    skos:definition "A solid dosage form containing medicinal substances with or without suitable diluents. (NCI)" ;
    skos:notation "TABLET" ;
    skos:prefLabel "Tablet Dosage Form" .

