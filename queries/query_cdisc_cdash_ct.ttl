<http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C78417-C28254> a skos:Concept ;
    ns1:identifier "C28254" ;
    skos:altLabel "Milliliter",
        "cm3" ;
    skos:definition "A unit of volume equal to one thousandth (1E-3) of a liter." ;
    skos:notation "mL" ;
