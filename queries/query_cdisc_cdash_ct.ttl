    ns1:identifier "C48152" ;
    skos:altLabel "Microgram",
        "mcg" ;
    skos:definition "A unit of mass equal to one millionth (1E-6) of a gram." ;
    skos:notation "ug" ;
    skos:prefLabel "Microgram" .

<http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C78417-C48155> a skos:Concept ;
    ns1:identifier "C48155" ;
    skos:altLabel "Gram" ;
    skos:definition "A unit of mass equal to one thousandth (1E-3) of a kilogram, the kilogram being the base unit of mass in the International System of Units (SI)." ;
    skos:notation "g" ;
    skos:prefLabel "Gram" .

<http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C78417-C48480> a skos:Concept ;
    ns1:identifier "C48480" ;
    skos:altLabel "Capsule Dosing Unit",
        "cap" ;
    skos:definition "A dosing measurement based on the capsule unit.(NCI)" ;
    skos:notation "CAPSULE" ;
    skos:prefLabel "Capsule Dosing Unit" .

<http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C78417-C48542> a skos:Concept ;
    ns1:identifier "C48542" ;
    skos:altLabel "Tablet Dosing Unit",
        "tab" ;
    skos:definition "A dosing measurement based on the tablet unit.(NCI)" ;
    skos:notation "TABLET" ;
    skos:prefLabel "Tablet Dosing Unit" .

<http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C78417-C48579> a skos:Concept ;
    ns1:identifier "C48579" ;
    skos:altLabel "IE",
        "International Unit" ;
    skos:definition "The unitage assigned by the WHO (World Health Organization) to International Biological Standards - substances, classed as biological according to the criteria provided by WHO Expert Committee on Biological Standardization, to enable the results of biological and immunological assay procedures to be expressed in the same way throughout the world. The definition of an international unit is generally arbitrary and technical, and has to be officially approved by the International Conference for Unification of Formulae.(NCI)" ;
    skos:notation "IU" ;
    skos:prefLabel "International Unit" .

<http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C78417-C65060> a skos:Concept ;
    ns1:identifier "C65060" ;
    skos:altLabel "Puff Dosing Unit" ;
    skos:definition "A means of delivering a defined dose of a therapeutic aerolized solution into either the upper or lower respiratory tract. Metered-dose inhalers or spray pumps are devices that provide a puff dose for delivery into either the oral or the nasal cavity.(NCI)" ;
    skos:notation "PUFF" ;
    skos:prefLabel "Puff Dosing Unit" .

<http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C78418> a skos:Concept ;
    rdfs:label "Concomitant Medication Dose Form" ;
    gsk:extensible "true" ;
    ns1:identifier "C78418" ;
    skos:altLabel "Concomitant Medication Dose Form" ;
    skos:definition "A terminology subset of the CDISC SDTM Pharmaceutical Dosage Form codelist created for CDASH Concomitant Medication Dose Form codelist. (NCI)" ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C78418-C25158>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C78418-C28944>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C78418-C42887>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C78418-C42933>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C78418-C42934>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C78418-C42966>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C78418-C42968>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C78418-C42972>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C78418-C42989>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C78418-C42993>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C78418-C42994>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C78418-C42998> ;
    skos:notation "CMDOSFRM" ;
    skos:prefLabel "CDISC CDASH Concomitant Medication Dose Form Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C78418-C25158> a skos:Concept ;
    ns1:identifier "C25158" ;
    skos:altLabel "cap" ;
    skos:definition "A solid pharmaceutical dosage form that contains medicinal agent within either a hard or soft soluble container or shell, usually used for the oral administration of medicine. The shells are made of a suitable form of gelatin or other substance. (NCI)" ;
    skos:notation "CAPSULE" ;
    skos:prefLabel "Capsule Dosage Form" .

<http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C78418-C28944> a skos:Concept ;
    ns1:identifier "C28944" ;
    skos:definition "A semisolid emulsion of either the oil-in-water or the water-in-oil type, ordinarily intended for topical use. (NCI)" ;
    skos:notation "CREAM" ;
    skos:prefLabel "Cream Dosage Form" .

<http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C78418-C42887> a skos:Concept ;
    ns1:identifier "C42887" ;
    skos:altLabel "aer" ;
    skos:definition "A product that is packaged under pressure and contains therapeutically active ingredients that are released upon activation of an appropriate valve system; it is intended for topical application to the skin as well as local application into the nose (nasal aerosols), mouth (lingual aerosols), or lungs (inhalation aerosols)." ;
    skos:notation "AEROSOL" ;
    skos:prefLabel "Aerosol Dosage Form" .

<http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C78418-C42933> a skos:Concept ;
    ns1:identifier "C42933" ;
    skos:definition "Any elastic aeriform fluid in which the molecules are separated from one another and have free paths. (NCI)" ;
    skos:notation "GAS" ;
    skos:prefLabel "Gas Dosage Form" .

<http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C78418-C42934> a skos:Concept ;
    ns1:identifier "C42934" ;
    skos:definition "A semisolid (1) dosage form that contains a gelling agent to provide stiffness to a solution or a colloidal dispersion (2). A gel may contain suspended particles. Note 1: A semisolid is not pourable; it does not flow or conform to its container at room temperature. It does not flow at low shear stress and generally exhibits plastic flow behavior. Note 2: A colloidal dispersion is a system in which particles of colloidal dimension (i.e., typically between 1 nm and 1 micrometer) are distributed uniformly throughout a liquid." ;
    skos:notation "GEL" ;
    skos:prefLabel "Gel Dosage Form" .

<http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C78418-C42966> a skos:Concept ;
    ns1:identifier "C42966" ;
    skos:altLabel "oint" ;
    skos:definition "A suspension or emulsion, semisolid (1) dosage form, usually containing less than 20 percent water and volatiles (2) and greater than 50 percent hydrocarbons, waxes, or polyols as the vehicle. This dosage form is generally for external application to the skin or mucous membranes. Note 1: A semisolid is not pourable; it does not flow or conform to its container at room temperature. It does not flow at low shear stress and generally exhibits plastic flow behavior. Note 2: Percent water and volatiles are measured by a loss on drying test in which the sample is heated at 105 degrees C until constant weight is achieved." ;
    skos:notation "OINTMENT" ;
    skos:prefLabel "Ointment Dosage Form" .

<http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C78418-C42968> a skos:Concept ;
    ns1:identifier "C42968" ;
    skos:definition "A drug delivery system that often contains an adhesive backing that is usually applied to an external site on the body. Its ingredients either passively diffuse from, or are actively transported from, some portion of the patch. Depending upon the patch, the ingredients are either delivered to the outer surface of the body or into the body. A patch is sometimes synonymous with the terms Extended Release Film and System." ;
    skos:notation "PATCH" ;
    skos:prefLabel "Patch Dosage Form" .

<http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C78418-C42972> a skos:Concept ;
    ns1:identifier "C42972" ;
    skos:definition "An intimate mixture of dry, finely divided drugs and/or chemicals that may be intended for internal or external use. (NCI)" ;
    skos:notation "POWDER" ;
    skos:prefLabel "Powder Dosage Form" .

<http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C78418-C42989> a skos:Concept ;
    ns1:identifier "C42989" ;
    skos:definition "A liquid minutely divided as by a jet of air or steam. (NCI)" ;
    skos:notation "SPRAY" ;
    skos:prefLabel "Spray Dosage Form" .

<http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C78418-C42993> a skos:Concept ;
    ns1:identifier "C42993" ;
    skos:altLabel "supp" ;
    skos:definition "A solid body of various weights and shapes, adapted for introduction into the rectal, vaginal, or urethral orifice of the human body; they usually melt, soften, or dissolve at body temperature." ;
    skos:notation "SUPPOSITORY" ;
    skos:prefLabel "Suppository Dosage Form" .

<http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C78418-C42994> a skos:Concept ;
    ns1:identifier "C42994" ;
    skos:altLabel "Ready to Use Suspension",
