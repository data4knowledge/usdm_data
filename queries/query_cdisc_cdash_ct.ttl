<http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C181163> a skos:Concept ;
    rdfs:label "Study Agent Rechallenge Reaction Response" ;
    gsk:extensible "true" ;
    ns1:identifier "C181163" ;
    skos:altLabel "Study Agent Rechallenge Reaction Response" ;
    skos:definition "A terminology codelist relevant to the resultant reaction due to restarting or otherwise returning administration of study treatment to previous level, after a dechallenge event." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C181163-C181226>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C181163-C181227>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C181163-C181228>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C181163-C181229> ;
    skos:notation "SARCRR" ;
    skos:prefLabel "CDISC CDASH Study Agent Rechallenge Reaction Response Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C181163-C181226> a skos:Concept ;
    ns1:identifier "C181226" ;
    skos:definition "Failure of the product/drug, when reintroduced, to produce signs or symptoms similar to those observed when the product/drug was previously used." ;
    skos:notation "NEGATIVE RECHALLENGE" ;
    skos:prefLabel "Negative Rechallenge Response" .

<http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C181163-C181227> a skos:Concept ;
    ns1:identifier "C181227" ;
    skos:definition "Recurrence of similar or new signs and symptoms upon reintroduction of the product/drug." ;
    skos:notation "POSITIVE RECHALLENGE" ;
    skos:prefLabel "Positive Rechallenge Response" .

<http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C181163-C181228> a skos:Concept ;
    ns1:identifier "C181228" ;
    skos:definition "The outcome of reintroduction of product/drug is not relevant in the current context." ;
    skos:notation "NOT APPLICABLE RECHALLENGE" ;
    skos:prefLabel "Not Applicable Rechallenge Response" .

<http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C181163-C181229> a skos:Concept ;
    ns1:identifier "C181229" ;
    skos:definition "No information regarding the outcome of reintroduction of product/drug." ;
    skos:notation "UKNOWN RECHALLENGE" ;
    skos:prefLabel "Unknown Rechallenge Response" .

<http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C181164> a skos:Concept ;
    rdfs:label "Study Agent Dechallenge Reaction Response" ;
    gsk:extensible "true" ;
    ns1:identifier "C181164" ;
    skos:altLabel "Study Agent Dechallenge Reaction Response" ;
    skos:definition "A terminology codelist relevant to the resultant reaction due to withdrawing, interrupting, or otherwise altering administration of study treatment." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C181164-C181222>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C181164-C181223>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C181164-C181224>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C181164-C181225> ;
    skos:notation "SADCRR" ;
    skos:prefLabel "CDISC CDASH Study Agent Dechallenge Reaction Response Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C181164-C181222> a skos:Concept ;
    ns1:identifier "C181222" ;
    skos:definition "Continued presence of an adverse event after decrease or change in dose, or withdrawal of the product/drug." ;
    skos:notation "NEGATIVE DECHALLENGE" ;
    skos:prefLabel "Negative Dechallenge Response" .

<http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C181164-C181223> a skos:Concept ;
    ns1:identifier "C181223" ;
    skos:definition "Partial or complete abatement of an adverse event after decrease or change in dose, or withdrawal of the product/drug." ;
    skos:notation "POSITIVE DECHALLENGE" ;
    skos:prefLabel "Positive Dechallenge Response" .

<http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C181164-C181224> a skos:Concept ;
    ns1:identifier "C181224" ;
    skos:definition "The outcome of decreasing the dose or discontinuation of the product/drug is not relevant in the current context." ;
    skos:notation "NOT APPLICABLE DECHALLENGE" ;
    skos:prefLabel "Not Applicable Dechallenge Response" .

<http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C181164-C181225> a skos:Concept ;
    ns1:identifier "C181225" ;
    skos:definition "No information regarding the outcome of decreasing the dose or discontinuation of the product/drug." ;
    skos:notation "UNKNOWN DECHALLENGE" ;
    skos:prefLabel "Unknown Dechallenge Response" .

