<http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C78426> a skos:Concept ;
    rdfs:label "Exposure Dose Form" ;
    gsk:extensible "true" ;
    ns1:identifier "C78426" ;
    skos:altLabel "Exposure Dose Form" ;
    skos:definition "A terminology subset of the CDISC SDTM Pharmaceutical Dosage Form codelist created for CDASH Exposure Dose Form codelist. (NCI)" ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C78426-C25158>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C78426-C28944>,
