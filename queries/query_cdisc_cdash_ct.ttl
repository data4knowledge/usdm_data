    skos:notation "VAGINAL BIRTH AFTER CESAREAN DELIVERY" ;
    skos:prefLabel "Vaginal Birth after Cesarean Delivery" .

<http://id.gsk.com/dataset/cdisc/ct/v48/cdash/C181165-C81303> a skos:Concept ;
    ns1:identifier "C81303" ;
    skos:definition "Birth of the fetus through the vagina." ;
