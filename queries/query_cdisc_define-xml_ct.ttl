    ns1:identifier "C43820" ;
    skos:altLabel "Medical Dictionary for Regulatory Activities" ;
    skos:definition "MedDRA is an international medical terminology designed to support the classification, retrieval, presentation, and communication of medical information throughout the medical product regulatory cycle. MedDRA was developed under the auspices of the International Conference on Harmonisation of Technical Requirements for Registration of Pharmaceuticals for Human Use (ICH). The MedDRA Maintenance and Support Services Organization (MSSO) holds a contract with the International Federation of Pharmaceutical Manufacturers Associations (IFPMA) to maintain and support the implementation of the terminology. (NCI)" ;
    skos:notation "MedDRA" ;
    skos:prefLabel "MedDRA" .

<http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C66788-C49468> a skos:Concept ;
    ns1:identifier "C49468" ;
    skos:altLabel "World Health Organization Adverse Reaction Terms" ;
    skos:definition "A terminology implemented by the World Health Organization to describe adverse reactions to a prescribed medication or treatment regimen. (NCI)" ;
    skos:notation "WHOART" ;
    skos:prefLabel "World Health Organization Adverse Reaction Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C66788-C49471> a skos:Concept ;
    ns1:identifier "C49471" ;
    skos:altLabel "Coding Symbols for a Thesaurus of Adverse Reaction Terms" ;
    skos:definition "A terminology developed and used by the Food and Drug Administration (FDA) for the coding, filing and retrieving of post marketing adverse reaction reports. (NCI)" ;
    skos:notation "COSTART" ;
    skos:prefLabel "Thesaurus of Adverse Reaction Term Coding Symbols" .

<http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C66788-C49474> a skos:Concept ;
    ns1:identifier "C49474" ;
    skos:altLabel "International Classification of Diseases" ;
    skos:definition "A system of categories to which morbid entries are assigned according to established criteria. Included is the entire range of conditions in a manageable number of categories, grouped to facilitate mortality reporting. It is produced by the World Health Organization (from ICD-10, p1). The Clinical Modifications, produced by the United States Dept. of Health and Human Services, are larger extensions used for morbidity and general epidemiological purposes, primarily in the U.S. (MSH2005_2004_10_12)" ;
    skos:notation "ICD" ;
    skos:prefLabel "International Classification of Diseases" .

<http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C66788-C49475> a skos:Concept ;
    ns1:identifier "C49475" ;
    skos:altLabel "WHODrug Global",
        "World Health Organization Drug Dictionary" ;
    skos:definition "A reference source of drugs and drug associated information maintained by the World Health Organization. (NCI)" ;
    skos:notation "WHODD" ;
    skos:prefLabel "World Health Organization Drug Dictionary" .

<http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C66788-C49476> a skos:Concept ;
    ns1:identifier "C49476" ;
    skos:altLabel "Logical Observation Identifiers Names and Codes" ;
    skos:definition "Published by The Regenstrief Institute, the Logical Observation Identifiers Names and Codes covers clinical and clinical laboratory terminology. (NCI)" ;
    skos:notation "LOINC" ;
    skos:prefLabel "Logical Observation Identifiers Names and Codes" .

<http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C66788-C49704> a skos:Concept ;
    ns1:identifier "C49704" ;
    skos:altLabel "Common Terminology Criteria for Adverse Events" ;
    skos:definition "A standard terminology developed and maintained by the National Cancer Institute to report adverse events occurring in cancer clinical trials. The CTCAE contains a grading scale for each adverse event term representing the severity of the event." ;
    skos:notation "CTCAE" ;
    skos:prefLabel "Common Terminology Criteria for Adverse Events" .

<http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C66788-C53489> a skos:Concept ;
    ns1:identifier "C53489" ;
    skos:altLabel "Systematized Nomenclature of Medicine" ;
    skos:definition "A multiaxial, hierarchical classification system for diseases in man developed by the College of American Pathologists. (NCI)" ;
    skos:notation "SNOMED" ;
    skos:prefLabel "Systematized Nomenclature of Medicine" .

