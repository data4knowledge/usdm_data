CALL n10s.onto.import.inline('@prefix gsk: <http://ontologies.gsk.com/cdisc/ct#> .
@prefix ns1: <http://purl.org/dc/elements/1.1/> .
@prefix ns2: <http://purl.org/dc/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<http://id.gsk.com/dataset/cdisc/ct/v48/define-xml> a skos:ConceptScheme ;
    rdfs:label "Define-XML Controlled Terminology Package 52 Effective 2022-12-16" ;
    ns1:description "CDISC Controlled Terminology for Define-XML is the set of CDISC-developed or CDISC-adopted standard expressions (values) used with data items within CDISC-defined DEFINE-XML datasets." ;
    ns1:source "Define-XML Controlled Terminology developed by the CDISC Terminology Team in collaboration with the National Cancer Institute\'s Enterprise Vocabulary Services (EVS)" ;
    ns2:valid "2022-12-16" ;
    skos:hasTopConcept <http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C103329>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C117744>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C117745>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C160924>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C165635>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C170448>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C170449>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C170450>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C170451>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C170452>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C172331>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C172332>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C176227>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C177903>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C66788> .

<http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C103329> a skos:Concept ;
    rdfs:label "General Observation Class" ;
    gsk:extensible "false" ;
    ns1:identifier "C103329" ;
    skos:altLabel "General Observation Class" ;
    skos:definition "Terminology related to the classification of a CDISC domain." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C103329-C103371>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C103329-C103372>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C103329-C103373>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C103329-C103374>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C103329-C103375>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C103329-C103376>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C103329-C103377>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C103329-C103378>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C103329-C103379>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C103329-C123454>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C103329-C135396>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C103329-C147271>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C103329-C177921>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C103329-C177922>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C103329-C177923> ;
    skos:notation "GNRLOBSC" ;
    skos:prefLabel "CDISC Define-XML General Observation Class Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C103329-C103371> a skos:Concept ;
    ns1:identifier "C103371" ;
    skos:altLabel "BDS",
        "Basic Data Structure" ;
    skos:definition "An ADaM BDS dataset contains one or more records per subject, per analysis parameter, per analysis time point. Variables include the value being analyzed (e.g., AVAL) and the description of the value being analyzed (e.g., PARAM). Other variables in the dataset provide more information about the value being analyzed (e.g., the subject identification) or describe and trace the derivation of it (e.g., DTYPE) or support the analysis of it (e.g., treatment variables, covariates)." ;
    skos:notation "BASIC DATA STRUCTURE" ;
    skos:prefLabel "CDISC Basic Data Structure Dataset" .

<http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C103329-C103372> a skos:Concept ;
    ns1:identifier "C103372" ;
    skos:altLabel "Events" ;
    skos:definition "This SDTM class captures planned protocol milestones such as randomization and study completion, and occurrences, conditions, or incidents independent of planned study evaluations occurring during the trial (e.g., adverse events) or prior to the trial (e.g., medical history)." ;
    skos:notation "EVENTS" ;
    skos:prefLabel "CDISC Events Class" .

<http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C103329-C103373> a skos:Concept ;
    ns1:identifier "C103373" ;
    skos:altLabel "Findings" ;
    skos:definition "This SDTM class captures the observations resulting from planned evaluations to address specific tests or questions such as laboratory tests, ECG testing, and questions listed on questionnaires." ;
    skos:notation "FINDINGS" ;
    skos:prefLabel "CDISC Findings Class" .

<http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C103329-C103374> a skos:Concept ;
    ns1:identifier "C103374" ;
    skos:altLabel "Interventions" ;
    skos:definition "This SDTM class captures investigational, therapeutic and other treatments that are administered to the subject (with some actual or expected physiological effect) either as specified by the study protocol (e.g., exposure to study drug), coincident with the study assessment period (e.g., concomitant medications), or self-administered by the subject (such as use of alcohol, tobacco, or caffeine)." ;
    skos:notation "INTERVENTIONS" ;
    skos:prefLabel "CDISC Interventions Class" .

<http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C103329-C103375> a skos:Concept ;
    ns1:identifier "C103375" ;
    skos:altLabel "ADaM Other" ;
    skos:definition "An analysis dataset that doesn\'t conform to a pre-defined ADaM dataset structure (e.g. ADSL, BDS or OCCDS)." ;
    skos:notation "ADAM OTHER" ;
    skos:prefLabel "CDISC Other ADaM Dataset" .

<http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C103329-C103376> a skos:Concept ;
    ns1:identifier "C103376" ;
    skos:altLabel "Relationships" ;
    skos:definition "This SDTM class provides a means to link related records between datasets. It includes the RELREC and SUPPQUAL datasets." ;
    skos:notation "RELATIONSHIP" ;
    skos:prefLabel "CDISC Relationship Class" .

<http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C103329-C103377> a skos:Concept ;
    ns1:identifier "C103377" ;
    skos:altLabel "SPECIAL-PURPOSE",
        "Special Purpose" ;
    skos:definition "This SDTM class contains a set of domains which do not conform to the Findings, Events or Interventions observation classes. The domains included are DM, CO, SE and SV." ;
    skos:notation "SPECIAL PURPOSE" ;
    skos:prefLabel "CDISC Special Purpose Class" .

<http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C103329-C103378> a skos:Concept ;
    ns1:identifier "C103378" ;
    skos:altLabel "ADSL",
        "Subject Level Analysis Dataset" ;
    skos:definition "The Subject-Level Analysis Dataset (ADSL) is a one-record-per-subject dataset which contains variables that describe subject demographic characteristics and group the subjects for analysis. ADSL is the primary source for subject-level variables included in other analysis datasets such as population flags and treatment variables." ;
    skos:notation "SUBJECT LEVEL ANALYSIS DATASET" ;
    skos:prefLabel "CDISC Subject Level Analysis Dataset" .

<http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C103329-C103379> a skos:Concept ;
    ns1:identifier "C103379" ;
    skos:altLabel "Trial Design" ;
    skos:definition "This SDTM class describes the plan for the procedures to be followed in a clinical trial, including planned and actual timing of events, control group, method of allocating treatments, blinding methods, assignment of epochs that subjects pass through in the course of a trial." ;
    skos:notation "TRIAL DESIGN" ;
    skos:prefLabel "CDISC Trial Design Class" .

<http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C103329-C123454> a skos:Concept ;
    ns1:identifier "C123454" ;
    skos:altLabel "OCCDS",
        "Occurrence Data Structure" ;
    skos:definition "The Occurrence Data Structure (OCCDS) is the ADaM data structure for occurrence analysis. Occurrence analysis is the counting of subjects with a record or term, and often includes a structured hierarchy of dictionary coding categories." ;
    skos:notation "OCCURRENCE DATA STRUCTURE" ;
    skos:prefLabel "CDISC Occurrence Data Structure" .

<http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C103329-C135396> a skos:Concept ;
    ns1:identifier "C135396" ;
    skos:altLabel "Findings About" ;
    skos:definition "This SDTM class is a specialization of the findings general observation class. It is intended, as its name implies, to be used when collected data represent findings about an event or intervention that cannot be represented within an event or intervention record or as a supplemental qualifier to such a record." ;
    skos:notation "FINDINGS ABOUT" ;
    skos:prefLabel "CDISC Findings About Class" .

<http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C103329-C147271> a skos:Concept ;
    ns1:identifier "C147271" ;
    skos:altLabel "Study Reference" ;
    skos:definition "This special purpose SDTM class contains further descriptions of study-specific identifiers that will be used in subject based domains." ;
    skos:notation "STUDY REFERENCE" ;
    skos:prefLabel "CDISC Study Reference Class" .

<http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C103329-C177921> a skos:Concept ;
    ns1:identifier "C177921" ;
    skos:altLabel "ADDL",
        "Device Level Analysis Dataset" ;
    skos:definition "The Device-Level Analysis Dataset (ADDL) is a one-record-per-device or one-record-per-subject-per-device dataset which contains variables that describe device characteristics and timing, and group the devices for analysis. ADDL is the primary source for device-level variables included in other analysis datasets." ;
    skos:notation "DEVICE LEVEL ANALYSIS DATASET" ;
    skos:prefLabel "CDISC Device Level Analysis Dataset" .

<http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C103329-C177922> a skos:Concept ;
    ns1:identifier "C177922" ;
    skos:altLabel "MDBDS",
        "Medical Device Basic Data Structure" ;
    skos:definition "The Medical Device Basic Data Structure (MDBDS) supports the analysis needs by adding SPDEVID as a required key variable and USUBJID a conditionally required variable. See the BDS class for further details." ;
    skos:notation "MEDICAL DEVICE BASIC DATA STRUCTURE" ;
    skos:prefLabel "CDISC Medical Device Basic Data Structure" .

<http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C103329-C177923> a skos:Concept ;
    ns1:identifier "C177923" ;
    skos:altLabel "MDOCCDS",
        "Medical Device Occurrence Data Structure" ;
    skos:definition "The Medical Device Occurrence Data Structure (MDOCCDS) supports the analysis needs by adding SPDEVID as a required identifier and allowing USUBJID be a conditionally required variable. See the OCCDS class for further details." ;
    skos:notation "MEDICAL DEVICE OCCURRENCE DATA STRUCTURE" ;
    skos:prefLabel "CDISC Medical Device Occurrence Data Structure" .

<http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C117744> a skos:Concept ;
    rdfs:label "Analysis Reason" ;
    gsk:extensible "true" ;
    ns1:identifier "C117744" ;
    skos:altLabel "Analysis Reason" ;
    skos:definition "Reason for reporting a specific analysis result described in Define-XML analysis results metadata." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C117744-C117750>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C117744-C117751>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C117744-C117752>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C117744-C117753> ;
    skos:notation "ANLREAS" ;
    skos:prefLabel "CDISC Define-XML Analysis Reason Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C117744-C117750> a skos:Concept ;
    ns1:identifier "C117750" ;
    skos:definition "The analysis was triggered by findings in the data." ;
    skos:notation "DATA DRIVEN" ;
    skos:prefLabel "Data Driven Analysis" .

<http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C117744-C117751> a skos:Concept ;
    ns1:identifier "C117751" ;
    skos:definition "The analysis has been requested by a regulatory agency." ;
    skos:notation "REQUESTED BY REGULATORY AGENCY" ;
    skos:prefLabel "Analysis Requested by Regulatory Agency" .

<http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C117744-C117752> a skos:Concept ;
    ns1:identifier "C117752" ;
    skos:definition "The analysis is specified in a protocol." ;
    skos:notation "SPECIFIED IN PROTOCOL" ;
    skos:prefLabel "Analysis Specified in Protocol" .

<http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C117744-C117753> a skos:Concept ;
    ns1:identifier "C117753" ;
    skos:definition "The analysis is specified in a statistical analysis plan." ;
    skos:notation "SPECIFIED IN SAP" ;
    skos:prefLabel "Analysis Specified in Statistical Analysis Plan" .

<http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C117745> a skos:Concept ;
    rdfs:label "Analysis Purpose" ;
    gsk:extensible "true" ;
    ns1:identifier "C117745" ;
    skos:altLabel "Analysis Purpose" ;
    skos:definition "Purpose of a specific analysis result described in Define-XML analysis results metadata." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C117745-C98724>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C117745-C98772>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C117745-C98781> ;
    skos:notation "ANLPURP" ;
    skos:prefLabel "CDISC Define-XML Analysis Purpose Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C117745-C98724> a skos:Concept ;
    ns1:identifier "C98724" ;
    skos:altLabel "Exploratory Outcome Measure" ;
    skos:definition "The outcome measure(s) that is part of a pre-specified analysis plan used to evaluate the exploratory endpoint(s) associated with exploratory study objective(s) and/or any other measures, excluding post-hoc measures, that are a focus of the study. (After clinicaltrials.gov)" ;
    skos:notation "EXPLORATORY OUTCOME MEASURE" ;
    skos:prefLabel "Exploratory Outcome Measure" .

<http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C117745-C98772> a skos:Concept ;
    ns1:identifier "C98772" ;
    skos:altLabel "Primary Outcome Measure" ;
    skos:definition "The outcome measure(s) of greatest importance specified in the protocol, usually the one(s) used in the power calculation, to evaluate the primary endpoint(s) associated with the primary study objective(s). (After Clinicaltrials.gov)" ;
    skos:notation "PRIMARY OUTCOME MEASURE" ;
    skos:prefLabel "Primary Outcome Measure" .

<http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C117745-C98781> a skos:Concept ;
    ns1:identifier "C98781" ;
    skos:altLabel "Secondary Outcome Measure" ;
    skos:definition "The outcome measure(s) that is part of a pre-specified analysis plan used to evaluate the secondary endpoint(s) associated with secondary study objective(s) and/or used to evaluate any measure(s) ancillary to the primary or secondary endpoint(s). (After Clinicaltrials.gov)." ;
    skos:notation "SECONDARY OUTCOME MEASURE" ;
    skos:prefLabel "Secondary Outcome Measure" .

<http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C160924> a skos:Concept ;
    rdfs:label "SDTMIG Version Response" ;
    gsk:extensible "true" ;
    ns1:identifier "C160924" ;
    skos:altLabel "SDTMIG Version Response" ;
    skos:definition "Terminology relevant to the version of the study data tabulation model implementation guide used in the study." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C160924-C161432>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C160924-C161433>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C160924-C161434>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C160924-C161435>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C160924-C161436>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C160924-C161437>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C160924-C189638> ;
    skos:notation "SDTMIGRS" ;
    skos:prefLabel "CDISC SDTM Implementation Guide Version Response Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C160924-C161432> a skos:Concept ;
    ns1:identifier "C161432" ;
    skos:altLabel "SDTMIG Version 3.1.1" ;
    skos:definition "Version 3.1.1 of the CDISC Study Data Tabulation Model (SDTM) Implementation Guide." ;
    skos:notation "3.1.1" ;
    skos:prefLabel "CDISC SDTM Implementation Guide Version 3.1.1" .

<http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C160924-C161433> a skos:Concept ;
    ns1:identifier "C161433" ;
    skos:altLabel "SDTMIG Version 3.1.2" ;
    skos:definition "Version 3.1.2 of the CDISC Study Data Tabulation Model (SDTM) Implementation Guide." ;
    skos:notation "3.1.2" ;
    skos:prefLabel "CDISC SDTM Implementation Guide Version 3.1.2" .

<http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C160924-C161434> a skos:Concept ;
    ns1:identifier "C161434" ;
    skos:altLabel "SDTMIG Version 3.1.2 Amendment 1" ;
    skos:definition "Amendment 1 of the 3.1.2 version of the CDISC Study Data Tabulation Model (SDTM) Implementation Guide." ;
    skos:notation "Version 3.1.2 Amendment 1" ;
    skos:prefLabel "CDISC SDTM Implementation Guide Version 3.1.2 Amendment 1" .

<http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C160924-C161435> a skos:Concept ;
    ns1:identifier "C161435" ;
    skos:altLabel "SDTMIG Version 3.1.3" ;
    skos:definition "Version 3.1.3 of the CDISC Study Data Tabulation Model (SDTM) Implementation Guide." ;
    skos:notation "3.1.3" ;
    skos:prefLabel "CDISC SDTM Implementation Guide Version 3.1.3" .

<http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C160924-C161436> a skos:Concept ;
    ns1:identifier "C161436" ;
    skos:altLabel "SDTMIG Version 3.2" ;
    skos:definition "Version 3.2 of the CDISC Study Data Tabulation Model (SDTM) Implementation Guide." ;
    skos:notation "3.2" ;
    skos:prefLabel "CDISC SDTM Implementation Guide Version 3.2" .

<http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C160924-C161437> a skos:Concept ;
    ns1:identifier "C161437" ;
    skos:altLabel "SDTMIG Version 3.3" ;
    skos:definition "Version 3.3 of the CDISC Study Data Tabulation Model (SDTM) Implementation Guide." ;
    skos:notation "3.3" ;
    skos:prefLabel "CDISC SDTM Implementation Guide Version 3.3" .

<http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C160924-C189638> a skos:Concept ;
    ns1:identifier "C189638" ;
    skos:altLabel "SDTMIG Version 3.4" ;
    skos:definition "Version 3.4 of the CDISC Study Data Tabulation Model (SDTM) Implementation Guide." ;
    skos:notation "3.4" ;
    skos:prefLabel "CDISC SDTM Implementation Guide Version 3.4" .

<http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C165635> a skos:Concept ;
    rdfs:label "ADaM Basic Data Structure Subclass" ;
    gsk:extensible "false" ;
    ns1:identifier "C165635" ;
    skos:altLabel "ADaM Basic Data Structure Subclass" ;
    skos:definition "Terminology relevant to the subclasses of the ADaM basic data structure." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C165635-C165637>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C165635-C172452>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C165635-C189348> ;
    skos:notation "BDSSC" ;
    skos:prefLabel "CDISC Define-XML ADaM Basic Data Structure Subclass Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C165635-C165637> a skos:Concept ;
    ns1:identifier "C165637" ;
    skos:altLabel "TTE" ;
    skos:definition "A dataset containing data that is used for Time-to-Event analyses." ;
    skos:notation "TIME-TO-EVENT" ;
    skos:prefLabel "Time-to-Event Dataset" .

<http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C165635-C172452> a skos:Concept ;
    ns1:identifier "C172452" ;
    skos:altLabel "NCA" ;
    skos:definition "A dataset containing data that is used for non-compartmental analyses." ;
    skos:notation "NON-COMPARTMENTAL ANALYSIS" ;
    skos:prefLabel "Non-Compartmental Analysis Dataset" .

<http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C165635-C189348> a skos:Concept ;
    ns1:identifier "C189348" ;
    skos:altLabel "PPK" ;
    skos:definition "A dataset containing data that is used for population pharmacokinetic analyses." ;
    skos:notation "POPULATION PHARMACOKINETIC ANALYSIS" ;
    skos:prefLabel "Population Pharmacokinetic Analysis Dataset" .

<http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C170448> a skos:Concept ;
    rdfs:label "ODM Context" ;
    gsk:extensible "false" ;
    ns1:identifier "C170448" ;
    skos:altLabel "ODM Context" ;
    skos:definition "Terminology relevant to the context in which the Define-XML document is used." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C170448-C17649>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C170448-C70885> ;
    skos:notation "ODMCNTX" ;
    skos:prefLabel "CDISC Define-XML ODM Context Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C170448-C17649> a skos:Concept ;
    ns1:identifier "C17649" ;
    skos:altLabel "Other" ;
    skos:definition "Different than the one(s) previously specified or mentioned. (NCI)" ;
    skos:notation "Other" ;
    skos:prefLabel "Other" .

<http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C170448-C70885> a skos:Concept ;
    ns1:identifier "C70885" ;
    skos:definition "An assembly of one or more regulatory submission units supporting a specific regulatory purpose or decision. In most cases, the compilation of the submission units is utilized in the assessment of a regulated medical product quality, safety and/or effectiveness." ;
    skos:notation "Submission" ;
    skos:prefLabel "Regulatory Submission" .

<http://id.gsk.com/dataset/cdisc/ct/v48/define-xml/C170449> a skos:Concept ;
    rdfs:label "Origin Type" ;
    gsk:extensible "false" ;
