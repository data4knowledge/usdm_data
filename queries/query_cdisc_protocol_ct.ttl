        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132309-C94105>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132309-C94108> ;
    skos:notation "Study Protocol Attribute Terminology" ;
    skos:prefLabel "CDISC Protocol Entities Study Protocol Attribute Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132309-C115628> a skos:Concept ;
    ns1:identifier "C115628" ;
    skos:altLabel "Protocol Scientific Summary" ;
    skos:definition "A scientific summary of the key points of the protocol." ;
    skos:notation "Protocol Synopsis" ;
    skos:prefLabel "Clinical Trial Protocol Synopsis" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132309-C132344> a skos:Concept ;
    ns1:identifier "C132344" ;
    skos:definition "A unique code assigned by an affiliated governing body or other organization that identifies a specific protocol (e.g., grant number, national number)." ;
    skos:notation "Alternate Protocol Identifier" ;
    skos:prefLabel "Alternate Protocol Identifier" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132309-C132345> a skos:Concept ;
    ns1:identifier "C132345" ;
    skos:altLabel "Abbreviated Protocol Title" ;
    skos:definition "The short descriptive name for the protocol." ;
    skos:notation "Brief Protocol Title" ;
    skos:prefLabel "Brief Protocol Title" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132309-C132346> a skos:Concept ;
    ns1:identifier "C132346" ;
    skos:definition "The formal descriptive name for the protocol." ;
    skos:notation "Official Protocol Title" ;
    skos:prefLabel "Official Protocol Title" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132309-C132347> a skos:Concept ;
    ns1:identifier "C132347" ;
    skos:definition "A written description of a change(s) to, or formal clarification of, a protocol. (ICH E6)" ;
    skos:notation "Protocol Amendment" ;
    skos:prefLabel "Protocol Amendment" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132309-C132348> a skos:Concept ;
    ns1:identifier "C132348" ;
    skos:definition "A unique code assigned by a clinical trial registry that identifies a specific protocol." ;
    skos:notation "Registry Protocol Identifier" ;
    skos:prefLabel "Registry Protocol Identifier" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132309-C132349> a skos:Concept ;
    ns1:identifier "C132349" ;
    skos:altLabel "Schedule of Events",
        "SoA" ;
    skos:definition "A standardized representation of planned clinical trial activities including interventions (e.g., administering drug, surgery) and study administrative activities (e.g., obtaining informed consent, distributing clinical trial material and diaries, randomization) as well as assessments. (CDISC Glossary)" ;
    skos:notation "Schedule of Activities" ;
    skos:prefLabel "Schedule of Activities" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132309-C132350> a skos:Concept ;
    ns1:identifier "C132350" ;
    skos:definition "A more extensive descriptive name of the protocol that is intended for medical professionals, written using medical and scientific language." ;
    skos:notation "Scientific Protocol Title" ;
    skos:prefLabel "Scientific Protocol Title" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132309-C132351> a skos:Concept ;
    ns1:identifier "C132351" ;
    skos:altLabel "Sponsor Protocol Code",
        "Sponsor Protocol Number" ;
    skos:definition "A unique code assigned by the sponsor that identifies a specific protocol." ;
    skos:notation "Sponsor Protocol Identifier" ;
    skos:prefLabel "Sponsor Protocol Identifier" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132309-C132352> a skos:Concept ;
    ns1:identifier "C132352" ;
    skos:altLabel "Protocol Amendment Approval by Sponsor Date",
        "Study Protocol Version Approval Date" ;
    skos:definition "The date on which a version of the protocol was finalized or approved by the sponsor." ;
    skos:notation "Study Protocol Version Approval by Sponsor Date" ;
    skos:prefLabel "Protocol Approval by Sponsor Date" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132309-C181245> a skos:Concept ;
    ns1:identifier "C181245" ;
    skos:definition "The date on which a version of the protocol was finalized or approved by the study oversight committee." ;
    skos:notation "Study Protocol Version Approval by Oversight Committee Date" ;
    skos:prefLabel "Study Protocol Version Approval by Oversight Committee Date" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132309-C51853> a skos:Concept ;
    ns1:identifier "C51853" ;
    skos:definition "A person who is the writer of a structured research study protocol." ;
    skos:notation "Protocol Author" ;
    skos:prefLabel "Protocol Author" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132309-C93490> a skos:Concept ;
    ns1:identifier "C93490" ;
    skos:definition "A plan at a particular point in time for a formal investigation to assess the utility, impact, pharmacological, physiological, and/or psychological effects of a particular treatment, procedure, drug, device, biologic, food product, cosmetic, care plan, or subject characteristic. (BRIDG)" ;
    skos:notation "Study Protocol Version" ;
    skos:prefLabel "Study Protocol Version" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132309-C94105> a skos:Concept ;
    ns1:identifier "C94105" ;
    skos:definition "The descriptive name of the protocol that is intended for the lay public, written in easily understood language." ;
    skos:notation "Public Protocol Title" ;
    skos:prefLabel "Study Protocol Document Version Public Title" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132309-C94108> a skos:Concept ;
    ns1:identifier "C94108" ;
    skos:altLabel "Trial Acronym" ;
    skos:definition "A word or words formed from the beginning letters or a combination of syllables and letters of a compound term, which identifies a clinical study." ;
    skos:notation "Study Acronym" ;
    skos:prefLabel "Study Protocol Version Acronym" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132310> a skos:Concept ;
    rdfs:label "Protocol Entity Terminology" ;
    ns1:identifier "C132310" ;
    skos:altLabel "Protocol Entity Terminology" ;
    skos:definition "A terminology value set relevant to the entities within a protocol." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132310-C132347>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132310-C142444>,
