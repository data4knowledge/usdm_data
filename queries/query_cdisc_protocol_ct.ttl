    ns1:identifier "C41196" ;
    skos:definition "A reference to an authoritative source." ;
    skos:notation "Citation" ;
    skos:prefLabel "Citation" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C184334> a skos:Concept ;
    rdfs:label "Informed Consent Attribute Terminology" ;
    ns1:identifier "C184334" ;
    skos:altLabel "Informed Consent Attribute Terminology" ;
    skos:definition "A terminology value set relevant to the attributes of the informed consent." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C184334-C161418>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C184334-C16468>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C184334-C184390> ;
    skos:notation "Informed Consent Attribute Terminology" ;
    skos:prefLabel "CDISC Protocol Informed Consent Attribute Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C184334-C161418> a skos:Concept ;
    ns1:identifier "C161418" ;
    skos:altLabel "Informed Assent" ;
    skos:definition "Assent given by a minor or adult who is unable to give informed consent on their own behalf, to participate in a clinical trial. Assent must be accompanied by consent from a parent or legal guardian for full participation in the study." ;
    skos:notation "Assent" ;
    skos:prefLabel "Informed Assent" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C184334-C16468> a skos:Concept ;
    ns1:identifier "C16468" ;
    skos:altLabel "Informed Consent Document" ;
    skos:definition "A formal document used during the informed consent process explaining the potential risks and benefits of participation in a study and the rights and responsibilities of the parties involved, in a manner that is understandable to the subject or their legally authorized representative." ;
    skos:notation "Informed Consent Form" ;
    skos:prefLabel "Consent Form" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C184334-C184390> a skos:Concept ;
    ns1:identifier "C184390" ;
    skos:altLabel "Informed Consent Procedure" ;
    skos:definition "The procedure by which informed consent is obtained and documented by means of a written, signed, and dated informed consent form. This process may include obtaining assent from subjects with legally authorized representatives. (ICH GCP)" ;
    skos:notation "Informed Consent Process" ;
    skos:prefLabel "Informed Consent Process" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C185850> a skos:Concept ;
    rdfs:label "Subject Replacement Attribute Terminology" ;
    ns1:identifier "C185850" ;
    skos:altLabel "Subject Replacement Attribute Terminology" ;
    skos:definition "A terminology value set relevant to the attributes of the subject replacement." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C185850-C185962>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C185850-C185963> ;
    skos:notation "Subject Replacement Attribute Terminology" ;
    skos:prefLabel "CDISC Protocol Subject Replacement Attribute Terminology" .

