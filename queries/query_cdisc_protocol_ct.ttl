    skos:notation "Study Subject Discontinuation Attribute Terminology" ;
    skos:prefLabel "CDISC Protocol Study Subject Discontinuation Attribute Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C185851-C176342> a skos:Concept ;
    ns1:identifier "C176342" ;
    skos:altLabel "Informed Consent Withdrawn" ;
    skos:definition "An indication that the consent to participate in the study, or one or more components of the study, has been revoked." ;
    skos:notation "Subject Withdrawal of Consent" ;
    skos:prefLabel "Study Consent Withdrawn" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C185851-C185956> a skos:Concept ;
    ns1:identifier "C185956" ;
    skos:definition "A description of the provisions or stipulations under which the subject may withdraw themselves from the study, following local and national regulations." ;
    skos:notation "Conditions of Subject Withdrawal" ;
    skos:prefLabel "Conditions of Subject Withdrawal" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C185851-C185957> a skos:Concept ;
    ns1:identifier "C185957" ;
    skos:definition "A description of the process by which information about the health status of a subject is obtained after that subject has withdrawn from the study." ;
    skos:notation "Follow-up for Withdrawn Subject" ;
    skos:prefLabel "Withdrawn Subject Follow-Up Process Description" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C185851-C185958> a skos:Concept ;
    ns1:identifier "C185958" ;
    skos:definition "The set of protocol-defined criteria that qualifies a study subject as being lost to follow-up." ;
    skos:notation "Lost to Follow-up Criteria" ;
    skos:prefLabel "Lost to Follow-up Criteria" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C185851-C185959> a skos:Concept ;
    ns1:identifier "C185959" ;
    skos:definition "The explanation or rationale as to why the subject withdrew from the study." ;
    skos:notation "Reason for Subject Withdrawal from Study" ;
    skos:prefLabel "Reason for Subject Withdrawal from Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C185851-C185960> a skos:Concept ;
    ns1:identifier "C185960" ;
    skos:definition "The set of protocol-defined criteria that serves to determine whether and how an enrolled subject may conclude participation in a study, prior to completion of all protocol-required elements." ;
    skos:notation "Study Subject Discontinuation Criteria" ;
    skos:prefLabel "Study Subject Discontinuation Criteria" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C185851-C185961> a skos:Concept ;
    ns1:identifier "C185961" ;
    skos:altLabel "Subject Discontinuation Procedure" ;
    skos:definition "A description of the stepwise set of actions taken when a subject discontinues participation in a study." ;
    skos:notation "Subject Discontinuation Process" ;
    skos:prefLabel "Subject Discontinuation Process Description" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C185851-C48227> a skos:Concept ;
    ns1:identifier "C48227" ;
    skos:definition "The loss or lack of continuation of a subject to follow-up." ;
    skos:notation "Lost to Follow-up" ;
    skos:prefLabel "Lost To Follow-Up" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C185851-C49627> a skos:Concept ;
    ns1:identifier "C49627" ;
    skos:definition "The explanation for why the enrolled subject concluded participation, prior to completion of all protocol-required elements, in a study." ;
    skos:notation "Reason for Study Discontinuation" ;
    skos:prefLabel "Reason for Study Discontinuation" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C185851-C49634> a skos:Concept ;
    ns1:identifier "C49634" ;
    skos:altLabel "Dropout" ;
    skos:definition "The subject-initiated act of discontinuing participation in the study as a whole or one or more aspects of the study (e.g., a study period or use of biospecimens)." ;
    skos:notation "Subject Withdrawal" ;
    skos:prefLabel "Withdrawal by Subject" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C187682> a skos:Concept ;
    rdfs:label "Expanded Access Attribute Terminology" ;
    ns1:identifier "C187682" ;
    skos:altLabel "Expanded Access Attribute Terminology" ;
    skos:definition "A terminology value set relevant to the attributes of the expanded access entity." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C187682-C187705> ;
    skos:notation "Expanded Access Attribute Terminology" ;
    skos:prefLabel "CDISC Protocol Expanded Access Attribute Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C187682-C187705> a skos:Concept ;
    ns1:identifier "C187705" ;
    skos:definition "A characterization or classification of the studies that provide a means for obtaining an experimental drug or device for patients who are not adequately treated by existing therapy, who do not meet the eligibility criteria for enrollment, or who are otherwise unable to participate in another clinical study." ;
    skos:notation "Expanded Access Study Type" ;
    skos:prefLabel "Expanded Access Study Type" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C187683> a skos:Concept ;
    rdfs:label "Expanded Access Study Type Value Set Terminology" ;
    ns1:identifier "C187683" ;
    skos:altLabel "Expanded Access Study Type Value Set Terminology" ;
    skos:definition "The terminology relevant to the type of expanded access study." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C187683-C182399>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C187683-C187706>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C187683-C187707> ;
    skos:notation "Expanded Access Study Type Value Set Terminology" ;
    skos:prefLabel "CDISC Protocol Expanded Access Study Type Value Set Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C187683-C182399> a skos:Concept ;
    ns1:identifier "C182399" ;
    skos:altLabel "Individual Basis Treatment",
        "Single Patient IND" ;
    skos:definition "Expanded access to an investigational medical product (drug, biologic, or medical device) for treatment use by a single patient submitted under a new Investigational New Drug (IND) application. (FDA: Expanded Access to Investigational Drugs for Treatment Use - Questions and Answers Guidance for Industry, June 2016)" ;
    skos:notation "Individual Patient IND" ;
    skos:prefLabel "Compassionate Single Patient Indicator" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C187683-C187706> a skos:Concept ;
    ns1:identifier "C187706" ;
    skos:definition "Expanded access to an investigational medical product (drug, biologic, or medical device) for treatment use in subjects after the controlled clinical trial has been completed and while the marketing application is being prepared by the sponsor or reviewed by the regulator." ;
    skos:notation "Continued Access" ;
    skos:prefLabel "Continued Access Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C187683-C187707> a skos:Concept ;
    ns1:identifier "C187707" ;
    skos:altLabel "Expanded Access Treatment IND",
        "Large Population Treatment IND" ;
    skos:definition "Expanded access to an investigational medical product (drug, biologic, or medical device) for treatment use by a large (widespread) population, submitted under a new Investigational New Drug (IND) application. (FDA: Expanded Access to Investigational Drugs for Treatment Use - Questions and Answers Guidance for Industry, June 2016)" ;
    skos:notation "Treatment IND" ;
    skos:prefLabel "Treatment Investigational New Drug Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C189268> a skos:Concept ;
    rdfs:label "Study Blinding and Unblinding Attribute Terminology" ;
    ns1:identifier "C189268" ;
    skos:altLabel "Study Blinding and Unblinding Attribute Terminology" ;
    skos:definition "A terminology value set relevant to the attributes of the study blinding and unblinding entity." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C189268-C142408>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C189268-C142742>,
