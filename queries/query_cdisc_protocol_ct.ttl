<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C127259> a skos:Concept ;
    rdfs:label "Observational Study Model" ;
    gsk:extensible "true" ;
    ns1:identifier "C127259" ;
    skos:altLabel "Observational Study Model" ;
    skos:definition "The terminology relevant to the trial design for observational studies." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C127259-C127779>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C127259-C127780>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C127259-C15197>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C127259-C15208>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C127259-C15362>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C127259-C15407> ;
    skos:notation "OBSSMO" ;
    skos:prefLabel "CDISC SDTM Observational Study Model Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C127259-C127779> a skos:Concept ;
    ns1:identifier "C127779" ;
    skos:definition "A study in which the subject characteristics of the case, immediately prior to disease onset (sometimes called the hazard period), are compared to characteristics of same case at a prior time (i.e., control period). (ClinicalTrials.gov)" ;
    skos:notation "CASE CROSSOVER" ;
    skos:prefLabel "Observational Case-Crossover Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C127259-C127780> a skos:Concept ;
    ns1:identifier "C127780" ;
    skos:definition "A study in which geographically distinct study populations are compared with respect to a particular outcome." ;
    skos:notation "ECOLOGIC OR COMMUNITY" ;
    skos:prefLabel "Ecologic or Community Based Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C127259-C15197> a skos:Concept ;
    ns1:identifier "C15197" ;
    skos:definition "A study that compares groups of people with generally similar characteristics, those with the condition under study (case) and those without the condition under study (control)." ;
    skos:notation "CASE CONTROL" ;
    skos:prefLabel "Case-Control Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C127259-C15208> a skos:Concept ;
    ns1:identifier "C15208" ;
    skos:definition "A study in which subjects are grouped based on a predefined personal or administrative characteristic." ;
    skos:notation "COHORT" ;
    skos:prefLabel "Cohort Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C127259-C15362> a skos:Concept ;
    ns1:identifier "C15362" ;
    skos:definition "A study in which the subject with the condition under study (the case) is compared against a theoretical/historical model of distribution that serves as a control." ;
    skos:notation "CASE ONLY" ;
    skos:prefLabel "Case Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C127259-C15407> a skos:Concept ;
    ns1:identifier "C15407" ;
    skos:definition "A study in which related or non-related family members are compared with respect to a particular outcome." ;
    skos:notation "FAMILY BASED" ;
    skos:prefLabel "Family Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132308> a skos:Concept ;
    rdfs:label "Physical Address Attribute Terminology" ;
    ns1:identifier "C132308" ;
    skos:altLabel "Physical Address Attribute Terminology" ;
    skos:definition "A terminology value set relevant to the attributes of the physical address entity." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132308-C16632>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132308-C25160>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132308-C25464>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132308-C25621>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132308-C25632>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132308-C25690>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132308-C87189>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132308-C87194> ;
    skos:notation "Physical Address Attribute Terminology" ;
    skos:prefLabel "CDISC Protocol Entities Physical Address Attribute Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132308-C16632> a skos:Concept ;
    ns1:identifier "C16632" ;
    skos:definition "Any demarcated area of the Earth; may be determined by both natural and human boundaries, such as a state or province." ;
    skos:notation "Geographic Region" ;
    skos:prefLabel "Geographic Area" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132308-C25160> a skos:Concept ;
    ns1:identifier "C25160" ;
    skos:definition "A relatively large and/or densely populated area of human habitation with administrative or legal status that may be specified as a component of a postal address." ;
    skos:notation "City" ;
    skos:prefLabel "City" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132308-C25464> a skos:Concept ;
    ns1:identifier "C25464" ;
    skos:definition "A sovereign nation occupying a distinct territory and ruled by an autonomous government." ;
    skos:notation "Country" ;
    skos:prefLabel "Country" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132308-C25621> a skos:Concept ;
    ns1:identifier "C25621" ;
    skos:definition "An alphanumeric code assigned to a mail delivery area." ;
    skos:notation "Postal Code" ;
    skos:prefLabel "Postal Code" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132308-C25632> a skos:Concept ;
    ns1:identifier "C25632" ;
    skos:definition "A sub-division of a country created by the central government for administrative purposes. Provinces are usually, but not always, less autonomous than states, and must obey the laws of the central government." ;
    skos:notation "Province" ;
    skos:prefLabel "Province" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132308-C25690> a skos:Concept ;
    ns1:identifier "C25690" ;
    skos:definition "The street name and building number where an entity is located." ;
    skos:notation "Street Address" ;
    skos:prefLabel "Street Address" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132308-C87189> a skos:Concept ;
    ns1:identifier "C87189" ;
    skos:definition "A distinct geographic area in the immediate vicinity of a particular place, such as a city, neighborhood or district." ;
    skos:notation "Geographic Locality" ;
    skos:prefLabel "Locality" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132308-C87194> a skos:Concept ;
    ns1:identifier "C87194" ;
    skos:definition "A sub-division of a country that forms part of a federal union. States are usually, but not always, more autonomous than provinces and may have different laws from the central government." ;
    skos:notation "State" ;
    skos:prefLabel "State" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132309> a skos:Concept ;
    rdfs:label "Study Protocol Attribute Terminology" ;
    ns1:identifier "C132309" ;
    skos:altLabel "Study Protocol Attribute Terminology" ;
    skos:definition "A terminology value set relevant to the attributes of the study protocol entity." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132309-C115628>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132309-C132344>,
