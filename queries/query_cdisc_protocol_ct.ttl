    ns1:identifier "C185962" ;
    skos:altLabel "Study Subject Replacement Criteria" ;
    skos:definition "A description of the scenario(s) that would justify subject replacement." ;
    skos:notation "Subject Replacement Criteria" ;
    skos:prefLabel "Study Subject Replacement Criteria" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C185850-C185963> a skos:Concept ;
    ns1:identifier "C185963" ;
    skos:altLabel "Study Subject Replacement Statement" ;
    skos:definition "A statement asserting whether subject replacement is permitted within a study." ;
    skos:notation "Subject Replacement Statement" ;
    skos:prefLabel "Study Subject Replacement Statement" .

