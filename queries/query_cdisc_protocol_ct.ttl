        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66736-C49653>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66736-C49654>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66736-C49655>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66736-C49656>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66736-C49657>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66736-C71485>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66736-C71486> ;
    skos:notation "TINDTP" ;
    skos:prefLabel "CDISC SDTM Trial Indication Type Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66736-C139174> a skos:Concept ;
    ns1:identifier "C139174" ;
    skos:definition "An intervention of a device product is being evaluated to determine the feasibility of the product or to test a prototype device and not health outcomes. Such studies are conducted to confirm the design and operating specifications of a device before beginning a full clinical trial. (ClinicalTrials.gov)" ;
    skos:notation "DEVICE FEASIBILITY" ;
    skos:prefLabel "Device Feasibility Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66736-C15245> a skos:Concept ;
    ns1:identifier "C15245" ;
    skos:definition "A type of study designed to evaluate the delivery, processes, management, organization or financing of health care. (ClinicalTrials.gov)" ;
    skos:notation "HEALTH SERVICES RESEARCH" ;
    skos:prefLabel "Health Services Research" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66736-C15714> a skos:Concept ;
    ns1:identifier "C15714" ;
    skos:altLabel "Basic Research" ;
    skos:definition "A type of study designed to examine the basic mechanism of action (e.g., physiology, biomechanics) of an intervention. (ClinicalTrials.gov)" ;
    skos:notation "BASIC SCIENCE" ;
    skos:prefLabel "Basic Research" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66736-C170629> a skos:Concept ;
    ns1:identifier "C170629" ;
    skos:definition "A type of study designed to evaluate the effects of treatment(s) intended to cause a change in disease, syndrome, or condition beyond the point of treatment administration." ;
    skos:notation "DISEASE MODIFYING" ;
    skos:prefLabel "Disease Modifying Treatment Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66736-C49653> a skos:Concept ;
    ns1:identifier "C49653" ;
    skos:definition "A type of study designed to evaluate intervention(s) aimed at identifying a disease or condition." ;
    skos:notation "DIAGNOSIS" ;
    skos:prefLabel "Diagnosis Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66736-C49654> a skos:Concept ;
    ns1:identifier "C49654" ;
    skos:definition "A type of study designed to evaluate intervention(s) aimed to cure a disease or condition." ;
    skos:notation "CURE" ;
    skos:prefLabel "Cure Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66736-C49655> a skos:Concept ;
    ns1:identifier "C49655" ;
    skos:definition "A type of study designed to identify actions necessary to eliminate or reduce the risk to human life or well-being as a result of a particular medication or treatment regimen. (NCI)" ;
    skos:notation "MITIGATION" ;
    skos:prefLabel "Adverse Effect Mitigation Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66736-C49656> a skos:Concept ;
    ns1:identifier "C49656" ;
    skos:altLabel "Therapy Trial" ;
    skos:definition "A type of study designed to evaluate intervention(s) for treatment of disease, syndrome or condition." ;
    skos:notation "TREATMENT" ;
    skos:prefLabel "Treatment Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66736-C49657> a skos:Concept ;
    ns1:identifier "C49657" ;
    skos:altLabel "Prophylaxis Study" ;
    skos:definition "A type of study designed to identify actions necessary to permanently eliminate or reduce the long-term risk to human life as a result of a particular medication or treatment regimen." ;
    skos:notation "PREVENTION" ;
    skos:prefLabel "Prevention Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66736-C71485> a skos:Concept ;
    ns1:identifier "C71485" ;
    skos:definition "A type of study designed to assess or examine methods of identifying a condition (or risk factors for a condition) in people who are not yet known to have the condition (or risk factor). (Clinicaltrials.gov)" ;
    skos:notation "SCREENING" ;
    skos:prefLabel "Screening Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66736-C71486> a skos:Concept ;
    ns1:identifier "C71486" ;
    skos:definition "A type of study designed to evaluate one or more interventions where the primary intent is to maximize comfort, minimize side effects or mitigate against a decline in the subject\'s health or function. In general, supportive care interventions are not intended to cure a disease. (ClinicalTrials.gov)" ;
    skos:notation "SUPPORTIVE CARE" ;
    skos:prefLabel "Supportive Care Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66737> a skos:Concept ;
    rdfs:label "Trial Phase Response" ;
    gsk:extensible "true" ;
    ns1:identifier "C66737" ;
    skos:altLabel "Trial Phase Response" ;
    skos:definition "A terminology codelist relevant to the phase, or stage, of the clinical trial." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66737-C15600>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66737-C15601>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66737-C15602>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66737-C15603>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66737-C15693>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66737-C15694>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66737-C47865>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66737-C48660>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66737-C49686>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66737-C49687>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66737-C49688>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66737-C49689>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66737-C54721> ;
    skos:notation "TPHASE" ;
    skos:prefLabel "CDISC SDTM Trial Phase Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66737-C15600> a skos:Concept ;
    ns1:identifier "C15600" ;
    skos:altLabel "1",
        "Trial Phase 1" ;
    skos:definition "The initial introduction of an investigational new drug into humans. Phase 1 studies are typically closely monitored and may be conducted in patients or normal volunteer subjects. NOTE: These studies are designed to determine the metabolism and pharmacologic actions of the drug in humans, the side effects associated with increasing doses, and, if possible, to gain early evidence on effectiveness. During Phase 1, sufficient information about the drug\'s pharmacokinetics and pharmacological effects should be obtained to permit the design of well-controlled, scientifically valid, Phase 2 studies. The total number of subjects and patients included in Phase I studies varies with the drug, but is generally in the range of 20 to 80. Phase 1 studies also include studies of drug metabolism, structure-activity relationships, and mechanism of action in humans, as well as studies in which investigational drugs are used as research tools to explore biological phenomena or disease processes. [After FDA CDER Handbook, ICH E8] (CDISC glossary)" ;
    skos:notation "PHASE I TRIAL" ;
    skos:prefLabel "Phase I Trial" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66737-C15601> a skos:Concept ;
    ns1:identifier "C15601" ;
    skos:altLabel "2",
        "Trial Phase 2" ;
    skos:definition "Phase 2. Controlled clinical studies conducted to evaluate the effectiveness of the drug for a particular indication or indications in patients with the disease or condition under study and to determine the common short-term side effects and risks associated with the drug. NOTE: Phase 2 studies are typically well controlled, closely monitored, and conducted in a relatively small number of patients, usually involving no more than several hundred subjects. [After FDA CDER Handbook, ICH E8] (CDISC glossary)" ;
    skos:notation "PHASE II TRIAL" ;
    skos:prefLabel "Phase II Trial" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66737-C15602> a skos:Concept ;
    ns1:identifier "C15602" ;
    skos:altLabel "3",
        "Trial Phase 3" ;
    skos:definition "Phase 3. Studies are expanded controlled and uncontrolled trials. They are performed after preliminary evidence suggesting effectiveness of the drug has been obtained, and are intended to gather the additional information about effectiveness and safety that is needed to confirm efficacy and evaluate the overall benefit-risk relationship of the drug and to provide an adequate basis for physician labeling. NOTE: Phase 3 studies usually include from several hundred to several thousand subjects. [After FDA CDER Handbook, ICH E8] (CDISC glossary)" ;
    skos:notation "PHASE III TRIAL" ;
    skos:prefLabel "Phase III Trial" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66737-C15603> a skos:Concept ;
    ns1:identifier "C15603" ;
    skos:altLabel "4",
        "Trial Phase 4" ;
    skos:definition "Phase 4. Postmarketing (Phase 4) studies to delineate additional information about the drug\'s risks, benefits, and optimal use that may be requested by regulatory authorities in conjunction with marketing approval. NOTE: These studies could include, but would not be limited to, studying different doses or schedules of administration than were used in Phase 2 studies, use of the drug in other patient populations or other stages of the disease, or use of the drug over a longer period of time. [After FDA CDER Handbook, ICH E8] (CDISC glossary)" ;
    skos:notation "PHASE IV TRIAL" ;
    skos:prefLabel "Phase IV Trial" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66737-C15693> a skos:Concept ;
    ns1:identifier "C15693" ;
    skos:altLabel "1-2",
        "Trial Phase 1-2" ;
    skos:definition "A class of clinical study that combines elements characteristic of traditional Phase I and Phase II trials. See also Phase I, Phase II." ;
    skos:notation "PHASE I/II TRIAL" ;
    skos:prefLabel "Phase I/II Trial" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66737-C15694> a skos:Concept ;
    ns1:identifier "C15694" ;
    skos:altLabel "2-3",
        "Trial Phase 2-3" ;
    skos:definition "A class of clinical study that combines elements characteristic of traditional Phase II and Phase III trials." ;
    skos:notation "PHASE II/III TRIAL" ;
    skos:prefLabel "Phase II/III Trial" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66737-C47865> a skos:Concept ;
    ns1:identifier "C47865" ;
    skos:altLabel "5",
        "Trial Phase 5" ;
    skos:definition "Postmarketing surveillance is sometimes referred to as Phase V." ;
    skos:notation "PHASE V TRIAL" ;
    skos:prefLabel "Phase V Trial" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66737-C48660> a skos:Concept ;
    ns1:identifier "C48660" ;
    skos:altLabel "NA",
        "Not Applicable" ;
    skos:definition "Determination of a value is not relevant in the current context. (NCI)" ;
    skos:notation "NOT APPLICABLE" ;
    skos:prefLabel "Not Applicable" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66737-C49686> a skos:Concept ;
    ns1:identifier "C49686" ;
    skos:altLabel "2A",
        "Trial Phase 2A" ;
    skos:definition "A clinical research protocol generally referred to as a pilot or feasibility trial that aims to prove the concept of the new intervention in question. (NCI)" ;
    skos:notation "PHASE IIA TRIAL" ;
    skos:prefLabel "Phase IIa Trial" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66737-C49687> a skos:Concept ;
    ns1:identifier "C49687" ;
    skos:altLabel "3A",
        "Trial Phase 3A" ;
    skos:definition "A classification typically assigned retrospectively to a Phase III trial upon determination by regulatory authorities of a need for a Phase III B trial. (NCI)" ;
    skos:notation "PHASE IIIA TRIAL" ;
    skos:prefLabel "Phase IIIa Trial" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66737-C49688> a skos:Concept ;
    ns1:identifier "C49688" ;
    skos:altLabel "2B",
        "Trial Phase 2B" ;
    skos:definition "A clinical research protocol generally referred to as a well-controlled and pivotal trial that aims to prove the mechanism of action of the new intervention in question. A pivotal study will generally be well-controlled, randomized, of adequate size, and whenever possible, double-blind. (NCI)" ;
    skos:notation "PHASE IIB TRIAL" ;
    skos:prefLabel "Phase IIb Trial" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66737-C49689> a skos:Concept ;
    ns1:identifier "C49689" ;
    skos:altLabel "3B",
        "Trial Phase 3B" ;
    skos:definition "A subcategory of Phase III trials done near the time of approval to elicit additional findings. NOTE: Dossier review may continue while associated Phase IIIB trials are conducted. These trials may be required as a condition of regulatory authority approval." ;
    skos:notation "PHASE IIIB TRIAL" ;
    skos:prefLabel "Phase IIIb Trial" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66737-C54721> a skos:Concept ;
    ns1:identifier "C54721" ;
    skos:altLabel "0",
        "Pre-clinical Trial",
        "Trial Phase 0" ;
    skos:definition "First-in-human trials, in a small number of subjects, that are conducted before Phase 1 trials and are intended to assess new candidate therapeutic and imaging agents. The study agent is administered at a low dose for a limited time, and there is no therapeutic or diagnostic intent. NOTE: FDA Guidance for Industry, Investigators, and Reviewers: Exploratory IND Studies, January 2006 classifies such studies as Phase 1. NOTE: A Phase 0 study might not include any drug delivery but may be an exploration of human material from a study (e.g., tissue samples or biomarker determinations). [Improving the Quality of Cancer Clinical Trials: Workshop summary-Proceedings of the National Cancer Policy Forum Workshop, improving the Quality of Cancer Clinical Trials (Washington, DC, Oct 2007)] (CDISC glossary)" ;
    skos:notation "PHASE 0 TRIAL" ;
    skos:prefLabel "Phase 0 Trial" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739> a skos:Concept ;
    rdfs:label "Trial Type Response" ;
    gsk:extensible "true" ;
    ns1:identifier "C66739" ;
    skos:altLabel "Trial Type Response" ;
    skos:definition "A terminology codelist relevant to the type of primary outcome or endpoint that the protocol is designed to evaluate." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C120842>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C127803>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C129001>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C158283>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C158284>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C158285>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C158286>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C158287>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C158288>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C158289>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C158290>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C161477>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C161478>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C161479>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C161480>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C174366>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C178057>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C39493>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C49653>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C49656>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C49657>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C49661>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C49662>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C49663>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C49664>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C49665>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C49666>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C49667>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C98729>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C98791> ;
    skos:notation "TTYPE" ;
    skos:prefLabel "CDISC SDTM Trial Type Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C120842> a skos:Concept ;
    ns1:identifier "C120842" ;
    skos:definition "A study that assesses an agent\'s ability to provoke an immune response." ;
    skos:notation "IMMUNOGENICITY" ;
    skos:prefLabel "Immunogenicity Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C127803> a skos:Concept ;
    ns1:identifier "C127803" ;
    skos:definition "A study of the effect of dose changes on the efficacy of a drug in order to determine the dose-response relationship and optimal dose of a therapy." ;
    skos:notation "DOSE RESPONSE" ;
    skos:prefLabel "Dose Response Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C129001> a skos:Concept ;
    ns1:identifier "C129001" ;
    skos:definition "A study that assesses variation in DNA sequence, usually within a single gene, and its effect on drug response." ;
    skos:notation "PHARMACOGENETIC" ;
    skos:prefLabel "Pharmacogenetic Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C158283> a skos:Concept ;
    ns1:identifier "C158283" ;
    skos:definition "A type of study designed to evaluate the strength of the bond between an adhesive and the application surface." ;
    skos:notation "ADHESION PERFORMANCE" ;
    skos:prefLabel "Adhesion Performance Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C158284> a skos:Concept ;
    ns1:identifier "C158284" ;
    skos:definition "A type of study designed to evaluate the effects of alcohol on investigational product safety and/or efficacy." ;
    skos:notation "ALCOHOL EFFECT" ;
    skos:prefLabel "Alcohol Effect Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C158285> a skos:Concept ;
    ns1:identifier "C158285" ;
    skos:definition "A type of study designed to evaluate the interaction between a device and a drug, where the use of one may affect the disposition, function, efficacy, or safety of the other." ;
    skos:notation "DEVICE-DRUG INTERACTION" ;
    skos:prefLabel "Device-Drug Interaction Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C158286> a skos:Concept ;
    ns1:identifier "C158286" ;
    skos:definition "A type of study designed to evaluate the interaction between drugs, where the use of one may affect the disposition, efficacy, or safety of the other." ;
    skos:notation "DRUG-DRUG INTERACTION" ;
    skos:prefLabel "Drug-Drug Interaction Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C158287> a skos:Concept ;
    ns1:identifier "C158287" ;
    skos:altLabel "TQT Study" ;
    skos:definition "A type of study designed to evaluate the ability of an investigational product and/or approved drug to delay cardiac ventricular repolarization as detected by QT prolongation and other ECG parameters." ;
    skos:notation "THOROUGH QT" ;
    skos:prefLabel "Thorough QT Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C158288> a skos:Concept ;
    ns1:identifier "C158288" ;
    skos:definition "A type of study designed to evaluate whether a biologic test article is highly similar in function and effect to an existing biologic that has already been clinically tested and approved for use." ;
    skos:notation "BIOSIMILARITY" ;
    skos:prefLabel "Biosimilarity Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C158289> a skos:Concept ;
    ns1:identifier "C158289" ;
    skos:definition "An early phase clinical study with the objective of determining the optimal dose of an investigational product." ;
    skos:notation "DOSE FINDING" ;
    skos:prefLabel "Dose Finding Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C158290> a skos:Concept ;
    ns1:identifier "C158290" ;
    skos:definition "A type of study designed to evaluate the relationship between dose and resulting exposure." ;
    skos:notation "DOSE PROPORTIONALITY" ;
    skos:prefLabel "Dose Proportionality Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C161477> a skos:Concept ;
    ns1:identifier "C161477" ;
    skos:definition "A type of study designed to evaluate the effect of body position during and/or after administration of the investigational product." ;
    skos:notation "POSITION EFFECT" ;
    skos:prefLabel "Position Effect Trial" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C161478> a skos:Concept ;
    ns1:identifier "C161478" ;
    skos:definition "A type of study designed to evaluate the effect of the investigational product on the physiologic act of swallowing." ;
    skos:notation "SWALLOWING FUNCTION" ;
    skos:prefLabel "Swallowing Function Trial" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C161479> a skos:Concept ;
    ns1:identifier "C161479" ;
    skos:definition "A type of study designed to evaluate the user experience with a product." ;
    skos:notation "USABILITY TESTING" ;
    skos:prefLabel "Usability Testing Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C161480> a skos:Concept ;
    ns1:identifier "C161480" ;
    skos:definition "A type of study designed to evaluate the effects of water on investigational product safety and/or efficacy." ;
    skos:notation "WATER EFFECT" ;
    skos:prefLabel "Water Effect Trial" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C174366> a skos:Concept ;
    ns1:identifier "C174366" ;
    skos:definition "A type of study designed to evaluate the expected, acute types of immunological responses, sometimes considered excessive, following agent administration." ;
    skos:notation "REACTOGENICITY" ;
    skos:prefLabel "Reactogenicity Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C178057> a skos:Concept ;
    ns1:identifier "C178057" ;
    skos:altLabel "Electrocardiographic Study" ;
    skos:definition "A study that evaluates the effect of a treatment on cardiac electrical activity, as assessed by electrocardiography." ;
    skos:notation "ECG" ;
    skos:prefLabel "Electrocardiographic Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C39493> a skos:Concept ;
    ns1:identifier "C39493" ;
    skos:definition "A study that assesses the value associated with a given drug in therapeutic and economic terms. This type of study is multidisciplinary in nature and takes into consideration the social and economic costs (resource utilization costs including direct, indirect, and intangible costs) of drug therapy in addition to its direct therapeutic benefits. Analyses relate the difference in therapeutic benefits to the difference in costs between treatment alternatives. (NCI)" ;
    skos:notation "PHARMACOECONOMIC" ;
    skos:prefLabel "Pharmacoeconomic Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C49653> a skos:Concept ;
    ns1:identifier "C49653" ;
    skos:definition "A type of study designed to evaluate intervention(s) aimed at identifying a disease or condition." ;
    skos:notation "DIAGNOSIS" ;
    skos:prefLabel "Diagnosis Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C49656> a skos:Concept ;
    ns1:identifier "C49656" ;
    skos:altLabel "Therapy Trial" ;
    skos:definition "A type of study designed to evaluate intervention(s) for treatment of disease, syndrome or condition." ;
    skos:notation "TREATMENT" ;
    skos:prefLabel "Treatment Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C49657> a skos:Concept ;
    ns1:identifier "C49657" ;
    skos:altLabel "Prophylaxis Study" ;
    skos:definition "A type of study designed to identify actions necessary to permanently eliminate or reduce the long-term risk to human life as a result of a particular medication or treatment regimen." ;
    skos:notation "PREVENTION" ;
    skos:prefLabel "Prevention Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C49661> a skos:Concept ;
    ns1:identifier "C49661" ;
    skos:definition "A study that identifies or assesses variations within the entire genome, including DNA, RNA, or transcriptional elements, and its effects on drug response." ;
    skos:notation "PHARMACOGENOMIC" ;
    skos:prefLabel "Pharmacogenomic Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C49662> a skos:Concept ;
    ns1:identifier "C49662" ;
    skos:definition "A study of the biochemical and physiological effect of a drug and the mechanism of drug action and the relationship between drug concentration and effect. (NCI)" ;
    skos:notation "PHARMACODYNAMIC" ;
    skos:prefLabel "Pharmacodynamic Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C49663> a skos:Concept ;
    ns1:identifier "C49663" ;
    skos:definition "A study of the process by which a drug is absorbed, distributed, metabolized, and eliminated by the body. (NCI)" ;
    skos:notation "PHARMACOKINETIC" ;
    skos:prefLabel "Pharmacokinetic Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C49664> a skos:Concept ;
    ns1:identifier "C49664" ;
    skos:definition "A study of the degree to which or rate at which a drug or other substance is absorbed or becomes available at the site of physiological activity after administration. (NCI)" ;
    skos:notation "BIO-AVAILABILITY" ;
    skos:prefLabel "Bioavailability Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C49665> a skos:Concept ;
    ns1:identifier "C49665" ;
    skos:definition "A study most often used to compare the efficacy of different formulations to treat a given disease. It is the testing of an old versus a new formulation in healthy volunteers or subjects with the disease under study and usually in one dose. (NCI)" ;
    skos:notation "BIO-EQUIVALENCE" ;
    skos:prefLabel "Therapeutic Equivalency Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C49666> a skos:Concept ;
    ns1:identifier "C49666" ;
    skos:definition "A study of the relative therapeutic efficacy of treatment of a disease. Usually this is a Phase II or III study. (NCI)" ;
    skos:notation "EFFICACY" ;
    skos:prefLabel "Efficacy Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C49667> a skos:Concept ;
    ns1:identifier "C49667" ;
    skos:definition "A study that assesses the medical risks to a subject. Safety is usually assessed by examining a wide range of clinical parameters, including adverse events, vital signs, physical exam, laboratory tests." ;
    skos:notation "SAFETY" ;
    skos:prefLabel "Safety Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C98729> a skos:Concept ;
    ns1:identifier "C98729" ;
    skos:definition "Studies that are conducted to assess the effect of food on the rate and extent of absorption of a drug, either compared to a fasted state or to a reference drug." ;
    skos:notation "FOOD EFFECT" ;
    skos:prefLabel "Food Effect Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66739-C98791> a skos:Concept ;
    ns1:identifier "C98791" ;
    skos:definition "A type of safety study that assesses the degree to which overt adverse effects can be tolerated by the subject." ;
    skos:notation "TOLERABILITY" ;
    skos:prefLabel "Tolerability Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66742> a skos:Concept ;
    rdfs:label "No Yes Response" ;
    gsk:extensible "false" ;
    ns1:identifier "C66742" ;
    skos:altLabel "No Yes Response" ;
    skos:definition "A term that is used to indicate a question with permissible values of yes/no/unknown/not applicable." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66742-C17998>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66742-C48660>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66742-C49487>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66742-C49488> ;
    skos:notation "NY" ;
    skos:prefLabel "CDISC SDTM Yes No Unknown or Not Applicable Response Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66742-C17998> a skos:Concept ;
    ns1:identifier "C17998" ;
    skos:altLabel "U",
        "UNK",
        "Unknown" ;
    skos:definition "Not known, not observed, not recorded, or refused. (NCI)" ;
    skos:notation "U" ;
    skos:prefLabel "Unknown" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66742-C48660> a skos:Concept ;
    ns1:identifier "C48660" ;
    skos:altLabel "NA",
        "Not Applicable" ;
    skos:definition "Determination of a value is not relevant in the current context. (NCI)" ;
    skos:notation "NA" ;
    skos:prefLabel "Not Applicable" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66742-C49487> a skos:Concept ;
    ns1:identifier "C49487" ;
    skos:altLabel "No" ;
    skos:definition "The non-affirmative response to a question. (NCI)" ;
    skos:notation "N" ;
    skos:prefLabel "No" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66742-C49488> a skos:Concept ;
    ns1:identifier "C49488" ;
    skos:altLabel "Yes" ;
    skos:definition "The affirmative response to a question. (NCI)" ;
    skos:notation "Y" ;
    skos:prefLabel "Yes" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C99076> a skos:Concept ;
    rdfs:label "Intervention Model Response" ;
    gsk:extensible "true" ;
    ns1:identifier "C99076" ;
    skos:altLabel "Intervention Model Response" ;
    skos:definition "A terminology codelist relevant to the trial design developed to compare treatment groups." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C99076-C142568>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C99076-C82637>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C99076-C82638>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C99076-C82639>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C99076-C82640> ;
    skos:notation "INTMODEL" ;
    skos:prefLabel "CDISC SDTM Intervention Model Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C99076-C142568> a skos:Concept ;
    ns1:identifier "C142568" ;
    skos:definition "Groups of participants are assigned to receive interventions based on prior milestones being reached in the study. (clinicaltrials.gov)" ;
    skos:notation "SEQUENTIAL" ;
    skos:prefLabel "Group Sequential Design" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C99076-C82637> a skos:Concept ;
    ns1:identifier "C82637" ;
    skos:definition "Participants receive one of two or more alternative intervention(s) during the initial epoch of the study and receive other intervention(s) during the subsequent epoch(s) of the study." ;
    skos:notation "CROSS-OVER" ;
    skos:prefLabel "Crossover Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C99076-C82638> a skos:Concept ;
    ns1:identifier "C82638" ;
    skos:definition "Two or more interventions, each alone or in combination, are evaluated in parallel against a control group. This study design allows for the comparison of active drug to placebo, presence of drug-drug interactions, and comparison of active drugs against each other." ;
    skos:notation "FACTORIAL" ;
    skos:prefLabel "Factorial Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C99076-C82639> a skos:Concept ;
    ns1:identifier "C82639" ;
    skos:definition "Participants are assigned to one of two or more treatment groups in parallel for the duration of the study." ;
    skos:notation "PARALLEL" ;
    skos:prefLabel "Parallel Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C99076-C82640> a skos:Concept ;
    ns1:identifier "C82640" ;
    skos:definition "All trial participants are assigned to a single treatment group for the duration of the study." ;
    skos:notation "SINGLE GROUP" ;
    skos:prefLabel "Single Group Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C99077> a skos:Concept ;
    rdfs:label "Study Type Response" ;
    gsk:extensible "false" ;
    ns1:identifier "C99077" ;
    skos:altLabel "Study Type Response" ;
    skos:definition "A terminology codelist relevant to the role the study plays in determining the interventions a subject receives." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C99077-C129000>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C99077-C16084>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C99077-C98388>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C99077-C98722> ;
    skos:notation "STYPE" ;
    skos:prefLabel "CDISC SDTM Study Type Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C99077-C129000> a skos:Concept ;
    ns1:identifier "C129000" ;
    skos:definition "Observational studies which include an organized system that uses observational methods to collect uniform data (clinical and other) prospectively for a population defined by a particular disorder/disease, condition (including susceptibility to a disorder), or exposure (including products, health care services, and/or procedures) and that serves a predetermined scientific, clinical, or policy purpose. Patient registries may be single purpose or on-going data collection programs that address one or more questions. (AHRQ)" ;
    skos:notation "PATIENT REGISTRY" ;
    skos:prefLabel "Patient Registry Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C99077-C16084> a skos:Concept ;
    ns1:identifier "C16084" ;
    skos:definition "Studies in which biomedical and/or health outcomes are assessed in pre-defined groups of individuals. Subjects in the study may receive diagnostic, therapeutic, or other interventions, but the investigator does not assign specific interventions to the subjects of the study." ;
    skos:notation "OBSERVATIONAL" ;
    skos:prefLabel "Observational Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C99077-C98388> a skos:Concept ;
    ns1:identifier "C98388" ;
    skos:definition "Studies in which individuals are assigned by an investigator based on a protocol to receive specific interventions. Subjects may receive diagnostic, therapeutic or other types of interventions. The assignment of the intervention may or may not be random. The individuals are then followed and biomedical and/or health outcomes are assessed." ;
    skos:notation "INTERVENTIONAL" ;
    skos:prefLabel "Interventional Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C99077-C98722> a skos:Concept ;
    ns1:identifier "C98722" ;
    skos:altLabel "Compassionate Use" ;
    skos:definition "Studies that provide a means for obtaining an experimental drug or device for patients who are not adequately treated by existing therapy, who do not meet the eligibility criteria for enrollment, or who are otherwise unable to participate in another clinical study." ;
    skos:notation "EXPANDED ACCESS" ;
    skos:prefLabel "Expanded Access Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C99078> a skos:Concept ;
    rdfs:label "Intervention Type Response" ;
    gsk:extensible "false" ;
    ns1:identifier "C99078" ;
    skos:altLabel "Intervention Type Response" ;
    skos:definition "A terminology codelist relevant to the kind of product or procedure studied in a trial." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C99078-C1505>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C99078-C15184>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C99078-C15238>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C99078-C15313>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C99078-C16830>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C99078-C17649>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C99078-C1909>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C99078-C307>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C99078-C98769> ;
    skos:notation "INTTYPE" ;
    skos:prefLabel "CDISC SDTM Intervention Type Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C99078-C1505> a skos:Concept ;
    ns1:identifier "C1505" ;
    skos:definition "Preparations containing ingredient(s) intended to supplement the diet." ;
    skos:notation "DIETARY SUPPLEMENT" ;
    skos:prefLabel "Dietary Supplement" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C99078-C15184> a skos:Concept ;
    ns1:identifier "C15184" ;
    skos:definition "A technique used to change the behavior of a subject (e.g., psychotherapy, lifestyle counseling, or hypnosis)." ;
    skos:notation "BEHAVIORAL THERAPY" ;
    skos:prefLabel "Behavioral Intervention" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C99078-C15238> a skos:Concept ;
    ns1:identifier "C15238" ;
    skos:altLabel "Gene Therapy" ;
    skos:definition "Introduction of genetic material into cells in order to correct or treat an inherited or acquired disease." ;
    skos:notation "GENETIC" ;
    skos:prefLabel "Gene Therapy" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C99078-C15313> a skos:Concept ;
    ns1:identifier "C15313" ;
    skos:altLabel "Radiation Therapy",
        "Radiotherapy" ;
    skos:definition "Use of targeted or whole body radiation to treat a disease." ;
    skos:notation "RADIATION" ;
    skos:prefLabel "Radiation Therapy" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C99078-C16830> a skos:Concept ;
    ns1:identifier "C16830" ;
    skos:altLabel "Medical Device" ;
    skos:definition "Any instrument, apparatus, implement, machine, appliance, implant, reagent for in vitro use, software, material or other similar or related article, intended by the manufacturer to be used, alone or in combination for, one or more specific medical purpose(s). [After REGULATION (EU) 2017/745 OF THE EUROPEAN PARLIAMENT AND OF THE COUNCIL of 5 April 2017 on medical devices]" ;
    skos:notation "DEVICE" ;
    skos:prefLabel "Medical Device" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C99078-C17649> a skos:Concept ;
    ns1:identifier "C17649" ;
    skos:altLabel "Other" ;
    skos:definition "Different than the one(s) previously specified or mentioned. (NCI)" ;
    skos:notation "OTHER" ;
    skos:prefLabel "Other" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C99078-C1909> a skos:Concept ;
    ns1:identifier "C1909" ;
    skos:definition "An active natural, synthetic or semi-synthetic ingredient including endogenous body substance that is intended to furnish pharmacological activity or other direct effect in the diagnosis, cure, mitigation, treatment, or prevention of disease or to affect the structure or any function of the human body, but does not include intermediates used in the synthesis of such ingredient (21 CFR 314.3(b))." ;
    skos:notation "DRUG" ;
    skos:prefLabel "Pharmacologic Substance" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C99078-C307> a skos:Concept ;
    ns1:identifier "C307" ;
    skos:definition "A product of biological origin applicable to the prevention, treatment, or cure of a disease or condition, for example: virus, therapeutic serum, toxin, antitoxin, vaccine, blood, blood component or derivative, allergenic product, or analogous product. (FDA 21 CFR 600.3)" ;
    skos:notation "BIOLOGIC" ;
    skos:prefLabel "Biological Agent" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C99078-C98769> a skos:Concept ;
    ns1:identifier "C98769" ;
    skos:altLabel "Medical Procedure" ;
    skos:definition "Any activity performed by manual and/or instrumental means for the purpose of diagnosis, assessment, therapy, prevention, or palliative care." ;
    skos:notation "PROCEDURE" ;
    skos:prefLabel "Physical Medical Procedure" .

','Turtle')