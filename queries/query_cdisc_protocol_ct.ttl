        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C189268-C49658> ;
    skos:notation "Study Blinding and Unblinding Attribute Terminology" ;
    skos:prefLabel "CDISC Protocol Study Blinding and Unblinding Attribute Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C189268-C142408> a skos:Concept ;
    ns1:identifier "C142408" ;
    skos:altLabel "Blinded Medication" ;
    skos:definition "A study product whose appearance and characteristics are the same between each investigational agent and control." ;
    skos:notation "Masked Medication" ;
    skos:prefLabel "Blinded Medication" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C189268-C142742> a skos:Concept ;
    ns1:identifier "C142742" ;
    skos:definition "A study event during which the treatment assignment is made known to the subject, investigator, and/or other trial personnel." ;
    skos:notation "Study Unblinding" ;
    skos:prefLabel "Unblinding" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C189268-C189349> a skos:Concept ;
    ns1:identifier "C189349" ;
    skos:definition "The methodology used for enacting study blinding." ;
    skos:notation "Study Blinding Procedure" ;
    skos:prefLabel "Study Blinding Procedure" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C189268-C189350> a skos:Concept ;
    ns1:identifier "C189350" ;
    skos:definition "A description of the methodology used for planned or unplanned unblinding of the study." ;
    skos:notation "Study Unblinding Procedure" ;
    skos:prefLabel "Study Unblinding Procedure" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C189268-C49068> a skos:Concept ;
    ns1:identifier "C49068" ;
    skos:altLabel "Trial Blinding" ;
    skos:definition "A procedure to limit bias by preventing subjects and/ or study personnel from identifying which treatments or procedures are administered, or from learning the results of tests and measures undertaken as part of a clinical investigation. (CDISC Glossary)" ;
    skos:notation "Study Blinding" ;
    skos:prefLabel "Blinded" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C189268-C49658> a skos:Concept ;
    ns1:identifier "C49658" ;
    skos:altLabel "Study Blinding Design",
        "Study Blinding Schema",
        "Study Masking Design",
        "Trial Blinding Design",
        "Trial Blinding Schema",
        "Trial Masking Design" ;
    skos:definition "The type of experimental design used to describe the level of awareness of the study subjects and/ or study personnel as it relates to the respective intervention(s) or assessments being observed, received or administered." ;
    skos:notation "Study Blinding Schema" ;
    skos:prefLabel "Trial Blinding Schema" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C190866> a skos:Concept ;
    rdfs:label "Study Activity Attribute Terminology" ;
    ns1:identifier "C190866" ;
    skos:altLabel "Study Activity Attribute Terminology" ;
    skos:definition "A terminology value set relevant to the attributes of the study activity entity." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C190866-C191214>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C190866-C191215>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C190866-C25217>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C190866-C82437> ;
    skos:notation "Study Activity Attribute Terminology" ;
    skos:prefLabel "CDISC Protocol Study Activity Attribute Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C190866-C191214> a skos:Concept ;
    ns1:identifier "C191214" ;
    skos:altLabel "Visit" ;
    skos:definition "A protocol-defined clinical encounter that encompasses planned and contingent study interventions, procedures, and assessments that may be performed on a subject. [SDTM]" ;
    skos:notation "Study Visit" ;
    skos:prefLabel "Study Visit" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C190866-C191215> a skos:Concept ;
    ns1:identifier "C191215" ;
    skos:altLabel "Visit Window" ;
    skos:definition "The allowable period of time before and/or after a planned or scheduled study visit, during which the actual study visit shall occur." ;
    skos:notation "Study Visit Window" ;
    skos:prefLabel "Study Visit Window" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C190866-C25217> a skos:Concept ;
    ns1:identifier "C25217" ;
    skos:altLabel "Study Observation" ;
    skos:definition "A measurement, evaluation, observation, or judgment of a study variable pertaining to the status of a subject. [After BEST Resource] (CDISC Glossary)" ;
    skos:notation "Study Assessment" ;
    skos:prefLabel "Assessment" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C190866-C82437> a skos:Concept ;
    ns1:identifier "C82437" ;
    skos:definition "A relative day, in reference to the protocol-defined study start point, on which an intervention, procedure, assessment, and/or collection of other study data occurs." ;
    skos:notation "Study Day" ;
    skos:prefLabel "Study Day" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66735> a skos:Concept ;
    rdfs:label "Trial Blinding Schema Response" ;
    gsk:extensible "true" ;
    ns1:identifier "C66735" ;
    skos:altLabel "Trial Blinding Schema Response" ;
    skos:definition "A terminology codelist relevant to the type of blinding for the trial." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66735-C15228>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66735-C156592>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66735-C187674>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66735-C28233>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66735-C49659> ;
    skos:notation "TBLIND" ;
    skos:prefLabel "CDISC SDTM Trial Blinding Schema Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66735-C15228> a skos:Concept ;
    ns1:identifier "C15228" ;
    skos:altLabel "Double Masked",
        "Double-Masked" ;
    skos:definition "A study in which neither the subject nor the study personnel interacting with the subject or data during the study knows what intervention a subject is receiving." ;
    skos:notation "DOUBLE BLIND" ;
    skos:prefLabel "Double Blind Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66735-C156592> a skos:Concept ;
    ns1:identifier "C156592" ;
    skos:definition "A study in which the therapeutic treatment is open label but the dosing information of the investigational medicinal product (IMP) is double-blinded." ;
    skos:notation "OPEN LABEL TO TREATMENT AND DOUBLE BLIND TO IMP DOSE" ;
    skos:prefLabel "Open Label for Treatment And Double Blind to Dose" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66735-C187674> a skos:Concept ;
    ns1:identifier "C187674" ;
    skos:definition "A study in which the study personnel who measure, record, or assess the subject do not know which intervention the subject is receiving or, in the context of observational studies, do not know the external factors to which a subject has been exposed." ;
    skos:notation "OBSERVER BLIND" ;
    skos:prefLabel "Observer Blind Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66735-C28233> a skos:Concept ;
    ns1:identifier "C28233" ;
    skos:altLabel "Single Masked",
        "Single-Masked" ;
    skos:definition "A study in which one party, either the subject or study personnel, does not know which intervention is administered to the subject." ;
    skos:notation "SINGLE BLIND" ;
    skos:prefLabel "Single Blind Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66735-C49659> a skos:Concept ;
    ns1:identifier "C49659" ;
    skos:definition "A study in which subjects and study personnel know which intervention each subject is receiving." ;
    skos:notation "OPEN LABEL" ;
    skos:prefLabel "Open Label Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66736> a skos:Concept ;
    rdfs:label "Trial Intent Type Response" ;
    gsk:extensible "true" ;
    ns1:identifier "C66736" ;
    skos:altLabel "Trial Intent Type Response" ;
    skos:definition "A terminology codelist relevant to the responses for the planned purpose of the therapy, device, or agent under study in the clinical trial." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66736-C139174>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C66736-C15245>,
