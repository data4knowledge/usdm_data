        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132310-C98722> ;
    skos:notation "Protocol Entity Terminology" ;
    skos:prefLabel "CDISC Protocol Entities Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132310-C132347> a skos:Concept ;
    ns1:identifier "C132347" ;
    skos:definition "A written description of a change(s) to, or formal clarification of, a protocol. (ICH E6)" ;
    skos:notation "Protocol Amendment" ;
    skos:prefLabel "Protocol Amendment" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132310-C142444> a skos:Concept ;
    ns1:identifier "C142444" ;
    skos:definition "The act of concluding participation by an enrolled subject prior to completion of all protocol-required elements in a study. NOTE: Four categories of discontinuation are distinguished: a) dropout: Active discontinuation by a subject (also a noun referring to such a discontinued subject); b) investigator initiated discontinuation (e.g., for cause); c) loss to follow-up: cessation of participation without notice or action by the subject; d) sponsor initiated discontinuation. Note that subject discontinuation does not necessarily imply exclusion of subject data from analysis. \"Termination of subject\" has a history of synonymous use, but is now considered nonstandard. [After ICH E3, section 10.1 and FDA Guidance for Industry: Submission of Abbreviated Reports & Synopses in Support of Marketing Applications, IV A] (CDISC Glossary)" ;
    skos:notation "Study Subject Discontinuation" ;
    skos:prefLabel "Study Subject Discontinuation" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132310-C142707> a skos:Concept ;
    ns1:identifier "C142707" ;
    skos:definition "The act of overseeing the progress of a clinical study and of ensuring that it is conducted, recorded, and reported in accordance with the protocol, standard operating procedures (SOPs), good clinical practice (GCP), and regulatory requirement(s) where applicable. [after ICH E6 Glossary]" ;
    skos:notation "Study Monitoring" ;
    skos:prefLabel "Study Monitoring" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132310-C142738> a skos:Concept ;
    ns1:identifier "C142738" ;
    skos:altLabel "Study Subject Replacement" ;
    skos:definition "The act of enrolling a new study subject to compensate for a subject who is no longer participating." ;
    skos:notation "Subject Replacement" ;
    skos:prefLabel "Trial Subject Replacement" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132310-C15206> a skos:Concept ;
    ns1:identifier "C15206" ;
    skos:definition "A clinical study involves research using human volunteers (also called participants) that is intended to add to medical knowledge. There are two main types of clinical studies: clinical trials (also called interventional studies) and observational studies. [ClinicalTrials.gov] See also clinical trial. (CDISC Glossary)" ;
    skos:notation "Clinical Study" ;
    skos:prefLabel "Clinical Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132310-C15311> a skos:Concept ;
    ns1:identifier "C15311" ;
    skos:altLabel "QC" ;
    skos:definition "The operational techniques and activities undertaken within the quality assurance system to verify that the requirements for quality of the study related activities have been fulfilled. (ICH)" ;
    skos:notation "Quality Control" ;
    skos:prefLabel "Quality Control" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132310-C15320> a skos:Concept ;
    ns1:identifier "C15320" ;
    skos:definition "A plan detailing how a study will be performed in order to represent the phenomenon under examination, to answer the research questions that have been asked, and informing the statistical approach." ;
    skos:notation "Study Design" ;
    skos:prefLabel "Study Design" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132310-C15381> a skos:Concept ;
    ns1:identifier "C15381" ;
    skos:altLabel "QA" ;
    skos:definition "All those planned and systematic actions that are established to ensure that the study is performed and the data are generated, documented (recorded), and reported in compliance with good clinical practice (GCP) and the applicable regulatory requirement(s). (ICH)" ;
    skos:notation "Quality Assurance" ;
    skos:prefLabel "Quality Assurance" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132310-C154705> a skos:Concept ;
    ns1:identifier "C154705" ;
    skos:definition "Information regarding the means of contacting a person or group that performs a function within a clinical study." ;
    skos:notation "Study Contact Information" ;
    skos:prefLabel "Study Contact Information" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132310-C16735> a skos:Concept ;
    ns1:identifier "C16735" ;
    skos:definition "Consent given by a subject, or in the case of an individual that can only give assent, by a parent or legal guardian, for the participation in a clinical study only after having achieved an understanding of both the relevant medical facts and the relevant risks involved." ;
    skos:notation "Informed Consent" ;
    skos:prefLabel "Informed Consent" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132310-C174271> a skos:Concept ;
    ns1:identifier "C174271" ;
    skos:definition "The material artifact(s), such as the trial product, interventional product, study drug, device, or procedure and their comparator(s), that is the focus of the study." ;
    skos:notation "Study Product" ;
    skos:prefLabel "Study Product" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132310-C174447> a skos:Concept ;
    ns1:identifier "C174447" ;
    skos:altLabel "Arm" ;
    skos:definition "A planned pathway assigned to the subject as they progress through the study, usually referred to by a name that reflects one or more treatments, exposures, and/or controls included in the path." ;
    skos:notation "Study Arm" ;
    skos:prefLabel "Study Arm" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132310-C177924> a skos:Concept ;
    ns1:identifier "C177924" ;
    skos:definition "The act of the dispensing, applying, or tendering a study product to the participant. (NCI)" ;
    skos:notation "Study Product Administration" ;
    skos:prefLabel "Study Product Administration" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132310-C181183> a skos:Concept ;
    ns1:identifier "C181183" ;
    skos:definition "A written message providing an official assurance, account, or assertion within the study protocol." ;
    skos:notation "Protocol Statement" ;
    skos:prefLabel "Protocol Statement" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132310-C184397> a skos:Concept ;
    ns1:identifier "C184397" ;
    skos:altLabel "Reference List" ;
    skos:definition "The curated list of sources that are cited within the reference section of the document." ;
    skos:notation "Reference" ;
    skos:prefLabel "Reference List" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132310-C189351> a skos:Concept ;
    ns1:identifier "C189351" ;
    skos:definition "A methodology to limit bias by preventing subject(s) and/or study personnel from identifying which treatments or procedures are administered and the circumstances in which the blind would be broken for subject(s) and/or study personnel." ;
    skos:notation "Study Blinding and Unblinding" ;
    skos:prefLabel "Study Blinding and Unblinding" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132310-C20200> a skos:Concept ;
    ns1:identifier "C20200" ;
    skos:definition "Events or experiences that clinicians or investigators examining the impact of an intervention or exposure measure because they believe such events or experiences may be influenced by the research intervention or exposure. Outcome is a general term in that it does not necessarily relate to a planned objective of the study. (FDA)" ;
    skos:notation "Outcome" ;
    skos:prefLabel "Outcome" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132310-C25212> a skos:Concept ;
    ns1:identifier "C25212" ;
    skos:definition "A defined variable intended to reflect an outcome of interest that is statistically analyzed to address a particular research question. NOTE: A precise definition of an endpoint typically specifies the type of assessments made, the timing of those assessments, the assessment tools used, and possibly other details, as applicable, such as how multiple assessments within an individual are to be combined. [After BEST Resource] (CDISC Glossary)" ;
    skos:notation "Endpoint" ;
    skos:prefLabel "End Point" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132310-C25218> a skos:Concept ;
    ns1:identifier "C25218" ;
    skos:definition "The drug, device, therapy, or process under investigation in a clinical study that is believed to have an effect on outcomes of interest in a study (e.g., health-related quality of life, efficacy, safety, pharmacoeconomics). [After https://grants.nih.gov/grants/policy/faq_clinical_trial_definition.htm#5224]" ;
    skos:notation "Intervention" ;
    skos:prefLabel "Intervention or Procedure" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132310-C25407> a skos:Concept ;
    ns1:identifier "C25407" ;
    skos:definition "A standardized representation of the location of a person, business, building, or organization. (NCI)" ;
    skos:notation "Physical Address" ;
    skos:prefLabel "Address" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132310-C51981> a skos:Concept ;
    ns1:identifier "C51981" ;
    skos:definition "Any component that constitutes a part of a compound or mixture." ;
    skos:notation "Ingredient" ;
    skos:prefLabel "Ingredient" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132310-C70699> a skos:Concept ;
    ns1:identifier "C70699" ;
    skos:altLabel "Biological Sample",
        "Biological Specimen",
        "Biospecimen",
        "Sample" ;
    skos:definition "Any material collected from a biological entity for testing, diagnostic, propagation, treatment, or research purposes." ;
    skos:notation "Biological Sample" ;
    skos:prefLabel "Biospecimen" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132310-C70817> a skos:Concept ;
    ns1:identifier "C70817" ;
    skos:definition "The formal plan of an experiment or research activity, including the objective, rationale, design, materials and methods for the conduct of the study, intervention description, and method of data analysis." ;
    skos:notation "Study Protocol" ;
    skos:prefLabel "Study Protocol" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132310-C70833> a skos:Concept ;
    ns1:identifier "C70833" ;
    skos:definition "A group of individuals taken from the general population who share a set of common characteristics, such as age, sex, or health condition, precisely defined in the study protocol. This is a population to which the study results could be reasonably generalized." ;
    skos:notation "Study Population" ;
    skos:prefLabel "Study Population" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132310-C71104> a skos:Concept ;
    ns1:identifier "C71104" ;
    skos:definition "1) A research investigation involving human subjects that is designed to answer specific questions about the safety and efficacy of a biomedical intervention (drug, treatment, device) or new ways of using a known drug, treatment, or device). 2) A research study in which one or more human subjects are prospectively assigned to one or more interventions (which may include placebo or other control) to evaluate the effects of those interventions on health-related biomedical or behavioral outcomes.(1. modified from ICH E6 Glossary, Directive 2001/20/EC. 2. NIH revised definition 2015) (CDISC Glossary)" ;
    skos:notation "Clinical Trial" ;
    skos:prefLabel "Clinical Trial" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132310-C71473> a skos:Concept ;
    ns1:identifier "C71473" ;
    skos:definition "An action, undertaking, or event, which is anticipated to be performed or observed, or was performed or observed, according to the study protocol during the execution of the study." ;
    skos:notation "Study Activity" ;
    skos:prefLabel "Study Activity" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132310-C93407> a skos:Concept ;
    ns1:identifier "C93407" ;
    skos:definition "Specific key measurement(s) or observation(s) used to measure the effect of experimental variables on the participants in a study, or for observational studies, to describe patterns of diseases or traits or associations with exposures, risk factors or treatment. (BRIDG)" ;
    skos:notation "Outcome Measure" ;
    skos:prefLabel "Study Outcome Measurement" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132310-C93450> a skos:Concept ;
    ns1:identifier "C93450" ;
    skos:definition "A group of individuals that approves, monitors and reviews biomedical research to protect the rights, safety and welfare of the study participants, by providing critical scientific, ethical, and/or regulatory oversight functions." ;
    skos:notation "Study Oversight Entity" ;
    skos:prefLabel "Study Oversight Authority" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C132310-C98722> a skos:Concept ;
    ns1:identifier "C98722" ;
    skos:altLabel "Compassionate Use" ;
    skos:definition "Studies that provide a means for obtaining an experimental drug or device for patients who are not adequately treated by existing therapy, who do not meet the eligibility criteria for enrollment, or who are otherwise unable to participate in another clinical study." ;
    skos:notation "Expanded Access" ;
    skos:prefLabel "Expanded Access Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C139020> a skos:Concept ;
    rdfs:label "Clinical Trial Attribute Terminology" ;
    ns1:identifier "C139020" ;
    skos:altLabel "Clinical Trial Attribute Terminology" ;
    skos:definition "A terminology value set relevant to the attributes of the clinical trial entity." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C139020-C101302>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C139020-C112038>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C139020-C127796>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C139020-C139166>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C139020-C139167>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C139020-C139168>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C139020-C139169>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C139020-C139170>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C139020-C139171>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C139020-C139172>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C139020-C15787>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C139020-C25370>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C139020-C25532>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C139020-C48281>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C139020-C49652>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C139020-C49660>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C139020-C85826>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C139020-C85827>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C139020-C85838> ;
    skos:notation "Clinical Trial Attribute Terminology" ;
    skos:prefLabel "CDISC Protocol Entities Clinical Trial Attribute Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C139020-C101302> a skos:Concept ;
    ns1:identifier "C101302" ;
    skos:altLabel "Therapeutic Area" ;
    skos:definition "A knowledge field that focuses on research and development of specific treatments for diseases and pathologic findings, as well as prevention of conditions that negatively impact the health of an individual. (NCI)" ;
    skos:notation "Therapeutic Area" ;
    skos:prefLabel "Therapeutic Area" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C139020-C112038> a skos:Concept ;
    ns1:identifier "C112038" ;
    skos:altLabel "Trial Disease/Condition Indication",
        "Trial Disease/Condition Indication Description" ;
    skos:definition "The textual representation of the condition, disease or disorder that the clinical trial is intended to investigate or address." ;
    skos:notation "Trial Disease/Condition Indication" ;
    skos:prefLabel "Trial Indication" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C139020-C127796> a skos:Concept ;
    ns1:identifier "C127796" ;
    skos:altLabel "Planned Trial Duration" ;
    skos:definition "The approximate period of time over which the clinical trial is expected to occur." ;
    skos:notation "Planned Trial Duration" ;
    skos:prefLabel "Planned Trial Duration" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C139020-C139166> a skos:Concept ;
    ns1:identifier "C139166" ;
    skos:definition "An indication as to whether the clinical trial has been registered with a trial registry system." ;
    skos:notation "Trial Registration Indicator" ;
    skos:prefLabel "Trial Registration Indicator" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C139020-C139167> a skos:Concept ;
    ns1:identifier "C139167" ;
    skos:definition "The major organizations providing monetary or material support for the conduct of the trial, including, but not limited to, funding, design, implementation, data analysis and reporting. (EudraCT)" ;
    skos:notation "Source of Monetary or Material Support for Study" ;
    skos:prefLabel "Source of Monetary or Material Support for Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C139020-C139168> a skos:Concept ;
    ns1:identifier "C139168" ;
    skos:definition "The name of the entity that is considered the primary sponsor for the trial or study. (NCI)" ;
    skos:notation "Primary Sponsor Name" ;
    skos:prefLabel "Primary Study Sponsor Name" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C139020-C139169> a skos:Concept ;
    ns1:identifier "C139169" ;
    skos:definition "The name of the entity that is considered the secondary sponsor for the trial or study. (NCI)" ;
    skos:notation "Secondary Sponsor Name" ;
    skos:prefLabel "Secondary Study Sponsor Name" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C139020-C139170> a skos:Concept ;
    ns1:identifier "C139170" ;
    skos:definition "The country in which participants are located when enrolling in a trial or study." ;
    skos:notation "Country of Recruitment" ;
    skos:prefLabel "Country of Recruitment" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C139020-C139171> a skos:Concept ;
    ns1:identifier "C139171" ;
    skos:definition "Date or date and time of first subject enrollment into a study, as verifiable by a convention that is consistent with authoritative regulatory criteria. [Modified from ICH E3] (CDISC Glossary)" ;
    skos:notation "Date of First Enrollment" ;
    skos:prefLabel "Date of First Enrollment into Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C139020-C139172> a skos:Concept ;
    ns1:identifier "C139172" ;
    skos:definition "The total number of planned participants in a study or trial." ;
    skos:notation "Target Sample Size" ;
    skos:prefLabel "Target Sample Size" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C139020-C15787> a skos:Concept ;
    ns1:identifier "C15787" ;
    skos:definition "The detailed planning of a study of the safety, efficacy, or optimum dosage schedule (if appropriate) of one or more diagnostic, therapeutic, or prophylactic drugs, devices, or techniques selected according to predetermined criteria of eligibility and observed for predefined evidence of favorable and unfavorable effects. (NCI)" ;
    skos:notation "Trial Design" ;
    skos:prefLabel "Clinical Trials Design" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C139020-C25370> a skos:Concept ;
    ns1:identifier "C25370" ;
    skos:definition "List of characteristics in a protocol, any one of which may exclude a potential subject from participation in a study. (CDISC glossary)" ;
    skos:notation "Exclusion Criteria" ;
    skos:prefLabel "Exclusion Criteria" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C139020-C25532> a skos:Concept ;
    ns1:identifier "C25532" ;
    skos:definition "The criteria in a protocol that prospective subjects must meet to be eligible for participation in a study. NOTE: Exclusion and inclusion criteria define the study population. See also exclusion criteria. (CDISC glossary)" ;
    skos:notation "Inclusion Criteria" ;
    skos:prefLabel "Inclusion Criteria" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C139020-C48281> a skos:Concept ;
    ns1:identifier "C48281" ;
    skos:altLabel "Trial Phase",
        "Trial Phase Classification" ;
    skos:definition "A step in the clinical research and development of a therapy from initial clinical trials to post-approval studies. NOTE: Clinical trials are generally categorized into four (sometimes five) phases. A therapeutic intervention may be evaluated in two or more phases simultaneously in different trials, and some trials may overlap two different phases. [21 CFR section 312.21; After ICH Topic E8 NOTE FOR GUIDANCE ON GENERAL CONSIDERATIONS FOR CLINICAL TRIALS, CPMP/ICH/291/95 March 1998]" ;
    skos:notation "Trial Phase" ;
    skos:prefLabel "Trial Phase" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C139020-C49652> a skos:Concept ;
    ns1:identifier "C49652" ;
    skos:altLabel "Trial Intent Type" ;
    skos:definition "The planned purpose of the therapy, device, or agent under study in the clinical trial." ;
    skos:notation "Trial Intent" ;
    skos:prefLabel "Clinical Study by Intent" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C139020-C49660> a skos:Concept ;
    ns1:identifier "C49660" ;
    skos:altLabel "Trial Scope",
        "Trial Type" ;
    skos:definition "The nature of the interventional study for which information is being collected." ;
    skos:notation "Trial Type" ;
    skos:prefLabel "Trial Type" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C139020-C85826> a skos:Concept ;
    ns1:identifier "C85826" ;
    skos:altLabel "Study Primary Objective",
        "Trial Primary Objective" ;
    skos:definition "A principle objective of the study." ;
    skos:notation "Trial Primary Objective" ;
    skos:prefLabel "Trial Primary Objective" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C139020-C85827> a skos:Concept ;
    ns1:identifier "C85827" ;
    skos:altLabel "Study Secondary Objective",
        "Trial Secondary Objective" ;
    skos:definition "An auxiliary objective of the study." ;
    skos:notation "Trial Secondary Objective" ;
    skos:prefLabel "Trial Secondary Objective" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C139020-C85838> a skos:Concept ;
    ns1:identifier "C85838" ;
    skos:altLabel "Investigative Site",
        "Investigator Site" ;
    skos:definition "Any healthcare organization, institution, facility or provider directly involved in conducting or facilitating a particular clinical trial. (NCI)" ;
    skos:notation "Trial Site" ;
    skos:prefLabel "Clinical Trial Site" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C142191> a skos:Concept ;
    rdfs:label "Clinical Study Attribute Terminology" ;
    ns1:identifier "C142191" ;
    skos:altLabel "Clinical Study Attribute Terminology" ;
    skos:definition "A terminology value set relevant to the attributes of the clinical study entity." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C142191-C142175>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C142191-C70794>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C142191-C70795>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C142191-C71473>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C142191-C93682>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C142191-C94122> ;
    skos:notation "Clinical Study Attribute Terminology" ;
    skos:prefLabel "CDISC Protocol Entities Clinical Study Attribute Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C142191-C142175> a skos:Concept ;
    ns1:identifier "C142175" ;
    skos:altLabel "Study Type",
        "Study Type Classification" ;
    skos:definition "The nature of the investigation for which study information is being collected. (After clinicaltrials.gov)" ;
    skos:notation "Study Type" ;
    skos:prefLabel "Study Type" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C142191-C70794> a skos:Concept ;
    ns1:identifier "C70794" ;
    skos:definition "The individual, organization, group or other legal person taking responsibility for securing the arrangements to initiate and/or manage a study (including arrangements to ensure that the study design meets appropriate standards and to ensure appropriate conduct and reporting). In commercial trials, the primary sponsor is normally the main applicant for regulatory authorization to begin the study. It may or may not be the main funder. (NCI)" ;
    skos:notation "Primary Clinical Study Sponsor" ;
    skos:prefLabel "Primary Clinical Study Sponsor" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C142191-C70795> a skos:Concept ;
    ns1:identifier "C70795" ;
    skos:definition "Additional individuals, organizations or other legal persons, if any, that have agreed with the primary sponsor to take on responsibilities of sponsorship. A secondary sponsor may have agreed to take on all the responsibilities of sponsorship jointly with the primary sponsor; or to form a group with the primary sponsor in which the responsibilities of sponsorship are allocated among the members of the group; or to act as the sponsor\'s legal representative in relation to some or all of the study sites; or to take responsibility for the accuracy of study registration information submitted." ;
    skos:notation "Secondary Clinical Study Sponsor" ;
    skos:prefLabel "Secondary Clinical Study Sponsor" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C142191-C71473> a skos:Concept ;
    ns1:identifier "C71473" ;
    skos:definition "An action, undertaking, or event, which is anticipated to be performed or observed, or was performed or observed, according to the study protocol during the execution of the study." ;
    skos:notation "Study Activity" ;
    skos:prefLabel "Study Activity" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C142191-C93682> a skos:Concept ;
    ns1:identifier "C93682" ;
    skos:altLabel "Study Schema" ;
    skos:definition "A diagram that outlines the decision points (e.g. randomization, response evaluation) that define the different paths a participant could take through the study. This is typically a block diagram and may include epochs, timing of randomization, treatment arms, and duration of treatments." ;
    skos:notation "Study Schematic Diagram" ;
    skos:prefLabel "Study Schematic" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C142191-C94122> a skos:Concept ;
    ns1:identifier "C94122" ;
    skos:altLabel "Study Purpose" ;
    skos:definition "A statement describing the overall rationale of the study. This field describes the contribution of this study to product development, i.e., what knowledge is being contributed from the conduct of this study." ;
    skos:notation "Study Rationale" ;
    skos:prefLabel "Study Protocol Version Purpose Statement" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147066> a skos:Concept ;
    rdfs:label "Study Design Attribute Terminology" ;
    ns1:identifier "C147066" ;
    skos:altLabel "Study Design Attribute Terminology" ;
    skos:definition "A terminology value set relevant to the attributes of the study design entity." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147066-C142668>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147066-C142705>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147066-C147137>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147066-C147138>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147066-C147139>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147066-C147140>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147066-C147141>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147066-C147142>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147066-C16153>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147066-C25689>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147066-C49692>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147066-C52580>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147066-C98746>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147066-C98771> ;
    skos:notation "Study Design Attribute Terminology" ;
    skos:prefLabel "CDISC Protocol Entities Study Design Attribute Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147066-C142668> a skos:Concept ;
    ns1:identifier "C142668" ;
    skos:definition "A supposition or proposal made to explain certain observations or facts, which requires further investigation or exploration within a clinical study. (NCI)" ;
    skos:notation "Study Hypothesis" ;
    skos:prefLabel "Research Hypothesis" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147066-C142705> a skos:Concept ;
    ns1:identifier "C142705" ;
    skos:definition "Reason(s) for choosing the study design. This may include reasons for the choice of control or comparator, as well as the scientific rationale for the study design." ;
    skos:notation "Study Design Rationale" ;
    skos:prefLabel "Study Design Rationale" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147066-C147137> a skos:Concept ;
    ns1:identifier "C147137" ;
    skos:definition "The planned number of study groups." ;
    skos:notation "Planned Number of Cohorts" ;
    skos:prefLabel "Planned Number of Cohorts" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147066-C147138> a skos:Concept ;
    ns1:identifier "C147138" ;
    skos:altLabel "Observation Model" ;
    skos:definition "The general design of the strategy for identifying and following up with participants during observational studies. (clinicaltrials.gov)" ;
    skos:notation "Observational Study Design" ;
    skos:prefLabel "Observational Study Model" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147066-C147139> a skos:Concept ;
    ns1:identifier "C147139" ;
    skos:altLabel "Overall Design",
        "Study Design Description",
        "Study Design Overview",
        "Summary of Study Design" ;
    skos:definition "Summary description of the overall study plan and design, should include treatments studied, population studied, level and method of blinding/unmasking, kind of controls, method of assignment to treatment, sequence and duration of study periods, any safety, data monitoring or special steering or evaluation committees, and interim analyses. (ICH E3)" ;
    skos:notation "Overall Study Design" ;
    skos:prefLabel "Study Design Description" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147066-C147140> a skos:Concept ;
    ns1:identifier "C147140" ;
    skos:definition "A characterization or classification of the process of assigning trial subjects to treatment or control groups using an element of chance to determine the assignments in order to reduce bias." ;
    skos:notation "Randomization Type" ;
    skos:prefLabel "Randomization Method" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147066-C147141> a skos:Concept ;
    ns1:identifier "C147141" ;
    skos:definition "The principal reason or intention for the execution of an interventional or non-interventional clinical study. (NCI)" ;
    skos:notation "Study Primary Purpose" ;
    skos:prefLabel "Study Primary Purpose" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147066-C147142> a skos:Concept ;
    ns1:identifier "C147142" ;
    skos:definition "The ancillary reason or intention for the execution of an interventional or non-interventional clinical study. (NCI)" ;
    skos:notation "Study Secondary Purpose" ;
    skos:prefLabel "Study Secondary Purpose" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147066-C16153> a skos:Concept ;
    ns1:identifier "C16153" ;
    skos:altLabel "Stratification Factor" ;
    skos:definition "Selected factors that are used during randomization to ensure there is balance of these factors across all subjects within each arm of a study. The subject level values of these factors may be used as fixed effects in statistical models and for sensitivity analyses." ;
    skos:notation "Stratification Factor" ;
    skos:prefLabel "Stratification Factors" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147066-C25689> a skos:Concept ;
    ns1:identifier "C25689" ;
    skos:definition "Grouping defined by important prognostic factors measured at baseline. (ICH E9)" ;
    skos:notation "Stratification" ;
    skos:prefLabel "Stratification" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147066-C49692> a skos:Concept ;
    ns1:identifier "C49692" ;
    skos:altLabel "Anticipated Enrollment",
        "Planned Enrollment",
        "Planned Number of Subjects",
        "Target Enrollment" ;
    skos:definition "The planned number of subjects to be entered in a clinical trial. (NCI)" ;
    skos:notation "Planned Number of Participants" ;
    skos:prefLabel "Planned Subject Number" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147066-C52580> a skos:Concept ;
    ns1:identifier "C52580" ;
    skos:altLabel "Subject Allocation" ;
    skos:definition "The process of assigning participants to particular treatment groups or cohorts in a clinical study." ;
    skos:notation "Participant Allocation" ;
    skos:prefLabel "Allocation" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147066-C98746> a skos:Concept ;
    ns1:identifier "C98746" ;
    skos:altLabel "Intervention Model" ;
    skos:definition "The general design of the strategy for assigning interventions to participants in a clinical study. (clinicaltrials.gov)" ;
    skos:notation "Interventional Study Design" ;
    skos:prefLabel "Intervention Model" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147066-C98771> a skos:Concept ;
    ns1:identifier "C98771" ;
    skos:altLabel "Planned Number of Arms" ;
    skos:definition "The planned number of intervention groups." ;
    skos:notation "Planned Number of Arms" ;
    skos:prefLabel "Planned Number of Arms" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147067> a skos:Concept ;
    rdfs:label "Study Purpose Value Set" ;
    ns1:identifier "C147067" ;
    skos:altLabel "Study Purpose Value Set" ;
    skos:definition "A terminology codelist relevant to the reason(s) or intention(s) for the execution of an interventional or non-interventional clinical study." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147067-C139174>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147067-C147146>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147067-C147147>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147067-C15220>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147067-C15245>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147067-C15419>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147067-C15714>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147067-C15747>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147067-C15843>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147067-C70742> ;
    skos:notation "Study Purpose Value Set" ;
    skos:prefLabel "CDISC Protocol Study Purpose Response Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147067-C139174> a skos:Concept ;
    ns1:identifier "C139174" ;
    skos:definition "An intervention of a device product is being evaluated to determine the feasibility of the product or to test a prototype device and not health outcomes. Such studies are conducted to confirm the design and operating specifications of a device before beginning a full clinical trial. (ClinicalTrials.gov)" ;
    skos:notation "Device Feasibility" ;
    skos:prefLabel "Device Feasibility Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147067-C147146> a skos:Concept ;
    ns1:identifier "C147146" ;
    skos:definition "Any action or process to perform research on a hypothetical or theoretical idea in order to determine whether the phenomena is new (which may lead to additional studies) or can be explained by an existing and well-substantiated theory. (NCI)" ;
    skos:notation "Exploratory Research" ;
    skos:prefLabel "Exploratory Research" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147067-C147147> a skos:Concept ;
    ns1:identifier "C147147" ;
    skos:definition "Any action or process to create a tentative proposal to explain certain observations or facts, and which requires further investigation to be verified. (NCI)" ;
    skos:notation "Hypothesis Generation" ;
    skos:prefLabel "Hypothesis Generation" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147067-C15220> a skos:Concept ;
    ns1:identifier "C15220" ;
    skos:altLabel "Diagnostic" ;
    skos:definition "The investigation, analysis and recognition of the presence and nature of disease, condition, or injury from expressed signs and symptoms; also, the scientific determination of any kind; the concise results or summary of such an investigation. (NCI)" ;
    skos:notation "Diagnosis" ;
    skos:prefLabel "Diagnosis" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147067-C15245> a skos:Concept ;
    ns1:identifier "C15245" ;
    skos:definition "A type of study designed to evaluate the delivery, processes, management, organization or financing of health care. (ClinicalTrials.gov)" ;
    skos:notation "Health Services Research" ;
    skos:prefLabel "Health Services Research" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147067-C15419> a skos:Concept ;
    ns1:identifier "C15419" ;
    skos:definition "Any action or process to identify a condition, or risk factors for a condition, in humans who are not yet known to have the condition or risk factor. (clinicaltrials.gov)" ;
    skos:notation "Screening" ;
    skos:prefLabel "Disease Screening" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147067-C15714> a skos:Concept ;
    ns1:identifier "C15714" ;
    skos:altLabel "Basic Research" ;
    skos:definition "A type of study designed to examine the basic mechanism of action (e.g., physiology, biomechanics) of an intervention. (ClinicalTrials.gov)" ;
    skos:notation "Basic Science" ;
    skos:prefLabel "Basic Research" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147067-C15747> a skos:Concept ;
    ns1:identifier "C15747" ;
    skos:definition "Any action or process to maximize comfort, minimize side effects, or mitigate against a decline in the participant\'s health or function. (clinicaltrials.gov)" ;
    skos:notation "Supportive Care" ;
    skos:prefLabel "Supportive Care" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147067-C15843> a skos:Concept ;
    ns1:identifier "C15843" ;
    skos:altLabel "Prophylaxis" ;
    skos:definition "Any action or response to modify or stop the development of a disease." ;
    skos:notation "Prevention" ;
    skos:prefLabel "Preventive Intervention" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147067-C70742> a skos:Concept ;
    ns1:identifier "C70742" ;
    skos:definition "Any action or process to improve or remedy a syndrome, disease, or condition." ;
    skos:notation "Treatment" ;
    skos:prefLabel "Treat" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147068> a skos:Concept ;
    rdfs:label "Participant Allocation Value Set" ;
    ns1:identifier "C147068" ;
    skos:altLabel "Participant Allocation Value Set" ;
    skos:definition "A terminology codelist for the method of assigning participants, or subjects, to groups or categories within a clinical study." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147068-C25196>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147068-C48660>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147068-C93043> ;
    skos:notation "Participant Allocation Value Set" ;
    skos:prefLabel "CDISC Protocol Subject Allocation Response Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147068-C25196> a skos:Concept ;
    ns1:identifier "C25196" ;
    skos:altLabel "Trial is Randomized" ;
    skos:definition "The process of assigning trial subjects to treatment or control groups using an element of chance to determine the assignments in order to reduce bias. NOTE: Unequal randomization is used to allocate subjects into groups at a differential rate; for example, three subjects may be assigned to a treatment group for every one assigned to the control group. [ICH E6 1.48] See also balanced study. (CDISC glossary)" ;
    skos:notation "Randomized" ;
    skos:prefLabel "Randomization" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147068-C48660> a skos:Concept ;
    ns1:identifier "C48660" ;
    skos:altLabel "NA",
        "Not Applicable" ;
    skos:definition "Determination of a value is not relevant in the current context. (NCI)" ;
    skos:notation "Not Applicable" ;
    skos:prefLabel "Not Applicable" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147068-C93043> a skos:Concept ;
    ns1:identifier "C93043" ;
    skos:definition "Participants are expressly assigned to intervention groups through a non-random method. (clinicaltrials.gov)" ;
    skos:notation "Nonrandomized" ;
    skos:prefLabel "Nonrandomized Clinical Trial" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147069> a skos:Concept ;
    rdfs:label "Randomization Type Value Set" ;
    ns1:identifier "C147069" ;
    skos:altLabel "Randomization Type Value Set" ;
    skos:definition "A terminology codelist relevant to the types of randomization schemas associated with a randomized controlled trial." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147069-C142743>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147069-C147126>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147069-C147127>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147069-C147143>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147069-C147144>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147069-C147145> ;
    skos:notation "Randomization Type Value Set" ;
    skos:prefLabel "CDISC Protocol Randomization Type Response Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147069-C142743> a skos:Concept ;
    ns1:identifier "C142743" ;
    skos:definition "A type of randomization schema in which unequal numbers of participants are purposely assigned to multiple treatment groups." ;
    skos:notation "Unequal Randomization" ;
    skos:prefLabel "Unequal Randomization" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147069-C147126> a skos:Concept ;
    ns1:identifier "C147126" ;
    skos:definition "A type of randomization schema in which the group assignment probability of a participant is adjusted based on the group assignments of those participants already randomized in the trial." ;
    skos:notation "Adaptive Randomization" ;
    skos:prefLabel "Adaptive Randomization" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147069-C147127> a skos:Concept ;
    ns1:identifier "C147127" ;
    skos:altLabel "Constrained Randomization" ;
    skos:definition "A type of adaptive randomization in which a pre-specified number of participants is assigned to a block containing the same pre-specified number of balanced group assignments in random order." ;
    skos:notation "Block Randomization" ;
    skos:prefLabel "Block Randomization" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147069-C147143> a skos:Concept ;
    ns1:identifier "C147143" ;
    skos:altLabel "Covariate Adaptive Randomization" ;
    skos:definition "A type of adaptive randomization in which the participant is assigned to the treatment group in an attempt to minimize imbalances in the number of participants for each stratification covariate across treatment groups." ;
    skos:notation "Minimization Randomization" ;
    skos:prefLabel "Minimization Randomization" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147069-C147144> a skos:Concept ;
    ns1:identifier "C147144" ;
    skos:altLabel "Unrestricted Randomization" ;
    skos:definition "A type of randomization schema in which each participant has the same chance of being randomized into any one group as all other participants." ;
    skos:notation "Simple Randomization" ;
    skos:prefLabel "Simple Randomization" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C147069-C147145> a skos:Concept ;
    ns1:identifier "C147145" ;
    skos:definition "A type of block randomization in which participants are stratified into groups based on prognostic variables and then randomized into balanced treatment groups." ;
    skos:notation "Stratified Randomization" ;
    skos:prefLabel "Stratified Randomization" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C154681> a skos:Concept ;
    rdfs:label "Protocol Contact Role Value Set" ;
    ns1:identifier "C154681" ;
    skos:altLabel "Protocol Contact Role Value Set" ;
    skos:definition "The terminology relevant to the role that the individual or entity plays with respect to being a contact within a study protocol." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C154681-C127526>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C154681-C127532>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C154681-C154706>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C154681-C154707>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C154681-C154708>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C154681-C154709>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C154681-C19924>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C154681-C25936>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C154681-C51811>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C154681-C51818>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C154681-C51820>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C154681-C51836>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C154681-C51878>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C154681-C54622>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C154681-C70793>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C154681-C70794>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C154681-C70795> ;
    skos:notation "Protocol Contact Role Value Set" ;
    skos:prefLabel "CDISC Protocol Entities Protocol Contact Role Response Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C154681-C127526> a skos:Concept ;
    ns1:identifier "C127526" ;
    skos:definition "The study contact person who is responsible for questions from the public." ;
    skos:notation "Contact for Public Queries" ;
    skos:prefLabel "Public Queries Study Contact" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C154681-C127532> a skos:Concept ;
    ns1:identifier "C127532" ;
    skos:definition "An individual with expertise in the law who provides legal counsel and representation for a study." ;
    skos:notation "Legal Representative for the Study" ;
    skos:prefLabel "Legal Representative for the Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C154681-C154706> a skos:Concept ;
    ns1:identifier "C154706" ;
    skos:definition "In the case of a multinational study, a person who has the responsibilities of the sponsor of the study in his/her country and will be responsible for the coordination of the principal investigators at different sites within that member state. (EMA)" ;
    skos:notation "National Coordinating Investigator" ;
    skos:prefLabel "National Coordinating Investigator" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C154681-C154707> a skos:Concept ;
    ns1:identifier "C154707" ;
    skos:definition "An individual who is responsible for the delivery of technical aspects of a project. (NCI)" ;
    skos:notation "Technical Lead" ;
    skos:prefLabel "Technical Lead" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C154681-C154708> a skos:Concept ;
    ns1:identifier "C154708" ;
    skos:altLabel "Clinical Informatician" ;
    skos:definition "An individual that designs, implements, evaluates and/or analyzes information technology in a healthcare or research setting. (NCI)" ;
    skos:notation "Clinical Informaticist" ;
    skos:prefLabel "Clinical Informaticist" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C154681-C154709> a skos:Concept ;
    ns1:identifier "C154709" ;
    skos:definition "A person who is responsible for the statistical aspects of the clinical or pre-clinical study. (NCI)" ;
    skos:notation "Biostatistician" ;
    skos:prefLabel "Biostatistician" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C154681-C19924> a skos:Concept ;
    ns1:identifier "C19924" ;
    skos:definition "A person who has the primary responsibility for the conduct of a clinical study and study-related personnel at a study site. While a single-center study would not include a coordinating investigator, the investigator at the site would fulfill the same responsibilities as a principal investigator." ;
    skos:notation "Principal Investigator" ;
    skos:prefLabel "Principal Investigator" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C154681-C25936> a skos:Concept ;
    ns1:identifier "C25936" ;
    skos:definition "A person responsible for the conduct of the clinical trial at a trial site. If a trial is conducted by a team of individuals at the trial site, the investigator is the responsible leader of the team and may be called the principal investigator." ;
    skos:notation "Investigator" ;
    skos:prefLabel "Investigator" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C154681-C51811> a skos:Concept ;
    ns1:identifier "C51811" ;
    skos:altLabel "CRC" ;
    skos:definition "A person to whom a clinical investigator delegates routine administrative requirements of a protocol. The duties and responsibilities of a clinical research coordinator may vary across different infrastructures. Generally, the coordinator manages the subject\'s clinical trial participation and provides a vital linkage between the subject, the investigator, and the sponsor. (NCI)" ;
    skos:notation "Clinical Research Coordinator" ;
    skos:prefLabel "Clinical Coordinator" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C154681-C51818> a skos:Concept ;
    ns1:identifier "C51818" ;
    skos:definition "An investigator assigned the responsibility for the coordination of investigators at different centers participating in a multi-center trial. While a single-center study would not include a coordinating investigator, the investigator at the site would fulfill the same responsibilities as a principal investigator. (after ICH E6)" ;
    skos:notation "Coordinating Investigator" ;
    skos:prefLabel "Coordinating Investigator" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C154681-C51820> a skos:Concept ;
    ns1:identifier "C51820" ;
    skos:definition "An individual who is responsible for the development and implementation of architectures, policies and procedures for the effective management of data across its business lifecycle." ;
    skos:notation "Data Manager" ;
    skos:prefLabel "Data Manager" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C154681-C51836> a skos:Concept ;
    ns1:identifier "C51836" ;
    skos:definition "A sponsor representative who has medical authority for the evaluation of the safety aspects of a clinical trial. (CDISC Glossary)" ;
    skos:notation "Medical Monitor" ;
    skos:prefLabel "Medical Monitor" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C154681-C51878> a skos:Concept ;
    ns1:identifier "C51878" ;
    skos:altLabel "Study Director" ;
    skos:definition "A person who has overall responsibility for the technical conduct of a study, as well as for the interpretation, analysis, documentation and reporting of results, and represents the single point of study control. (FDA)" ;
    skos:notation "Study Chair" ;
    skos:prefLabel "Study Chair" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C154681-C54622> a skos:Concept ;
    ns1:identifier "C54622" ;
    skos:definition "Any member of the clinical trial team designated and supervised by the investigator at a trial site to perform critical trial-related procedures and/or to make important trial-related decisions (e.g., associates, residents, research fellows). (ICH)" ;
    skos:notation "Subinvestigator" ;
    skos:prefLabel "Subinvestigator" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C154681-C70793> a skos:Concept ;
    ns1:identifier "C70793" ;
    skos:altLabel "Clinical Study Sponsor",
        "Sponsor",
        "Study Sponsor" ;
    skos:definition "An individual, company, institution, or organization that takes responsibility for the initiation, management, and/or financing of a clinical study. [After ICH E6, WHO, 21 CFR 50.3 (e), and after IDMP]" ;
    skos:notation "Sponsor" ;
    skos:prefLabel "Clinical Study Sponsor" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C154681-C70794> a skos:Concept ;
    ns1:identifier "C70794" ;
    skos:definition "The individual, organization, group or other legal person taking responsibility for securing the arrangements to initiate and/or manage a study (including arrangements to ensure that the study design meets appropriate standards and to ensure appropriate conduct and reporting). In commercial trials, the primary sponsor is normally the main applicant for regulatory authorization to begin the study. It may or may not be the main funder. (NCI)" ;
    skos:notation "Primary Sponsor" ;
    skos:prefLabel "Primary Clinical Study Sponsor" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C154681-C70795> a skos:Concept ;
    ns1:identifier "C70795" ;
    skos:definition "Additional individuals, organizations or other legal persons, if any, that have agreed with the primary sponsor to take on responsibilities of sponsorship. A secondary sponsor may have agreed to take on all the responsibilities of sponsorship jointly with the primary sponsor; or to form a group with the primary sponsor in which the responsibilities of sponsorship are allocated among the members of the group; or to act as the sponsor\'s legal representative in relation to some or all of the study sites; or to take responsibility for the accuracy of study registration information submitted." ;
    skos:notation "Secondary Sponsor" ;
    skos:prefLabel "Secondary Clinical Study Sponsor" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C154682> a skos:Concept ;
    rdfs:label "Study Contact Information Attribute Terminology" ;
    ns1:identifier "C154682" ;
    skos:altLabel "Study Contact Information Attribute Terminology" ;
    skos:definition "A terminology value set relevant to the attributes of the study contact information entity." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C154682-C154704>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C154682-C25191>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C154682-C25354>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C154682-C25407>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C154682-C40978>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C154682-C42775>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C154682-C42879>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C154682-C48835> ;
    skos:notation "Study Contact Information Attribute Terminology" ;
    skos:prefLabel "CDISC Protocol Entities Study Contact Information Attribute Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C154682-C154704> a skos:Concept ;
    ns1:identifier "C154704" ;
    skos:definition "The name of the organization or entity that the person or group has an established relationship with." ;
    skos:notation "Organizational Affiliation" ;
    skos:prefLabel "Organizational Affiliation Name" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C154682-C25191> a skos:Concept ;
    ns1:identifier "C25191" ;
    skos:altLabel "Individual\'s Name",
        "Name" ;
    skos:definition "A word or group of words indicating the identity of a person usually consisting of a first (personal) name and a last (family) name with an optional middle name. In some cultural traditions the family name comes first." ;
    skos:notation "Person Name" ;
    skos:prefLabel "Person Name" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C154682-C25354> a skos:Concept ;
    ns1:identifier "C25354" ;
    skos:definition "An academic rank conferred by a college, university, or other postsecondary education institution as official recognition for the successful completion of a program of studies." ;
    skos:notation "Academic Degree" ;
    skos:prefLabel "Academic Degree" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C154682-C25407> a skos:Concept ;
    ns1:identifier "C25407" ;
    skos:definition "A standardized representation of the location of a person, business, building, or organization. (NCI)" ;
    skos:notation "Physical Address" ;
    skos:prefLabel "Address" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C154682-C40978> a skos:Concept ;
    ns1:identifier "C40978" ;
    skos:altLabel "Phone Number" ;
    skos:definition "A sequence of decimal digits (0-9) that is used for identifying a specific telephone line or other device in a telephone network." ;
    skos:notation "Telephone Number" ;
    skos:prefLabel "Telephone Number" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C154682-C42775> a skos:Concept ;
    ns1:identifier "C42775" ;
    skos:altLabel "Email Address" ;
    skos:definition "A text string identifier for a location to which electronic mail can be delivered. (NCI)" ;
    skos:notation "E-mail Address" ;
    skos:prefLabel "E-mail Address" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C154682-C42879> a skos:Concept ;
    ns1:identifier "C42879" ;
    skos:altLabel "Facsimile Number" ;
    skos:definition "A telephone number that is used for identifying a specific fax machine in a telephone network." ;
    skos:notation "Fax Number" ;
    skos:prefLabel "Fax Number" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C154682-C48835> a skos:Concept ;
    ns1:identifier "C48835" ;
    skos:definition "The usual or expected function of something; the part something plays in an action or event. (NCI)" ;
    skos:notation "Role" ;
    skos:prefLabel "Role" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C160921> a skos:Concept ;
    rdfs:label "Study Population Attribute Terminology" ;
    ns1:identifier "C160921" ;
    skos:altLabel "Study Population Attribute Terminology" ;
    skos:definition "A terminology value set relevant to the attributes of the study population entity." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C160921-C142728>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C160921-C142747>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C160921-C161316>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C160921-C161317>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C160921-C161318>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C160921-C161319>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C160921-C161320>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C160921-C161321>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C160921-C161322>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C160921-C161323>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C160921-C161324>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C160921-C16669>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C160921-C28143>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C160921-C49651> ;
    skos:notation "Study Population Attribute Terminology" ;
    skos:prefLabel "CDISC Protocol Study Population Attribute Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C160921-C142728> a skos:Concept ;
    ns1:identifier "C142728" ;
    skos:altLabel "Target Population" ;
    skos:definition "The population within the general population for which the study results can be generalized." ;
    skos:notation "Target Study Population" ;
    skos:prefLabel "Target Study Population" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C160921-C142747> a skos:Concept ;
    ns1:identifier "C142747" ;
    skos:definition "Individuals whose willingness to volunteer in a clinical trial may be unduly influenced by the expectation, whether justified or not, of benefits associated with participation, or of a retaliatory response from senior members of a hierarchy in case of refusal to participate. Examples include subordinate members of a group with a hierarchical structure, patients with incurable diseases, persons in nursing homes, unemployed or impoverished persons, patients in emergency situations, ethnic minority groups, homeless persons, nomads, refugees, minors, and those incapable of giving consent. (ICH)" ;
    skos:notation "Vulnerable Population" ;
    skos:prefLabel "Vulnerable Subjects" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C160921-C161316> a skos:Concept ;
    ns1:identifier "C161316" ;
    skos:altLabel "FOCBP",
        "WOCBP",
        "Women of Childbearing Potential" ;
    skos:definition "Female study subjects or patients who have the potential to become pregnant, i.e., those who have experienced menarche and who have not undergone surgical sterilization and are not postmenopausal." ;
    skos:notation "Females of Childbearing Potential" ;
    skos:prefLabel "Female of Childbearing Potential" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C160921-C161317> a skos:Concept ;
    ns1:identifier "C161317" ;
    skos:definition "An explanation as to the logical reasons for why a specific population of subjects is being considered for inclusion in a clinical study." ;
    skos:notation "Population Rationale" ;
    skos:prefLabel "Population Rationale" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C160921-C161318> a skos:Concept ;
    ns1:identifier "C161318" ;
    skos:definition "An explanation with defensible proof as to the reason why a special population of subjects is included in the clinical study." ;
    skos:notation "Justification of Special Population" ;
    skos:prefLabel "Justification of Special Population" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C160921-C161319> a skos:Concept ;
    ns1:identifier "C161319" ;
    skos:definition "Primary disease(s) or condition(s) being studied in the trial, or the focus of the study. (clinicaltrials.gov)" ;
    skos:notation "Condition or Disease under Study" ;
    skos:prefLabel "Condition or Disease under Study" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C160921-C161320> a skos:Concept ;
    ns1:identifier "C161320" ;
    skos:definition "Medical or health condition that is concomitant or concurrent with the primary condition or disease under study." ;
    skos:notation "Comorbid Condition" ;
    skos:prefLabel "Comorbid Condition" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C160921-C161321> a skos:Concept ;
    ns1:identifier "C161321" ;
    skos:altLabel "Reference Group for Study Sample Population" ;
    skos:definition "The study population that is defined for the purpose of comparison to the population under investigation." ;
    skos:notation "Reference Group" ;
    skos:prefLabel "Reference Group" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C160921-C161322> a skos:Concept ;
    ns1:identifier "C161322" ;
    skos:definition "A study population that receives an intervention(s) within a trial. This could include the investigational product(s) or a comparator (e.g., placebo or an approved intervention)." ;
    skos:notation "Treatment Group" ;
    skos:prefLabel "Treatment Group" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C160921-C161323> a skos:Concept ;
    ns1:identifier "C161323" ;
    skos:definition "A study population that receives the intervention that is the focus of the study." ;
    skos:notation "Experimental Group" ;
    skos:prefLabel "Experimental Group" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C160921-C161324> a skos:Concept ;
    ns1:identifier "C161324" ;
    skos:definition "A descriptive characterization of the study population (e.g., age, sex, race, education, etc.)." ;
    skos:notation "Demographic Group" ;
    skos:prefLabel "Demographic Group" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C160921-C16669> a skos:Concept ;
    ns1:identifier "C16669" ;
    skos:definition "The state of a subject\'s mental or physical condition." ;
    skos:notation "General Health Status" ;
    skos:prefLabel "Health Status" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C160921-C28143> a skos:Concept ;
    ns1:identifier "C28143" ;
    skos:definition "A study population that is defined for the purpose of comparison to the treatment group in a controlled trial. In an epidemiological study, a study population that does not have the outcome of interest." ;
    skos:notation "Control Group" ;
    skos:prefLabel "Control Group" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C160921-C49651> a skos:Concept ;
    ns1:identifier "C49651" ;
    skos:altLabel "Healthy Subject" ;
    skos:definition "An individual who is or becomes a participant in a research study and has no significant health-related issues. (NCI)" ;
    skos:notation "Healthy Volunteer" ;
    skos:prefLabel "Healthy Subject" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C163026> a skos:Concept ;
    rdfs:label "Study Monitoring Attribute Terminology" ;
    ns1:identifier "C163026" ;
    skos:altLabel "Study Monitoring Attribute Terminology" ;
    skos:definition "A terminology value set relevant to the attributes of the study monitoring entity." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C163026-C115753>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C163026-C142488>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C163026-C142674>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C163026-C15789>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C163026-C163406>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C163026-C163407>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C163026-C163408>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C163026-C163409>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C163026-C163410>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C163026-C163411>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C163026-C184395>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C163026-C184396> ;
    skos:notation "Study Monitoring Attribute Terminology" ;
    skos:prefLabel "CDISC Protocol Study Monitoring Attribute Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C163026-C115753> a skos:Concept ;
    ns1:identifier "C115753" ;
    skos:definition "A document that describes the strategy, methods, responsibilities, and requirements for monitoring the trial. (ICH E6(R2) Glossary Addendum)" ;
    skos:notation "Clinical Monitoring Plan" ;
    skos:prefLabel "Clinical Trial Monitoring Plan" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C163026-C142488> a skos:Concept ;
    ns1:identifier "C142488" ;
    skos:definition "Process by which clinical data are examined for completeness, consistency, and accuracy for the duration of the study lifecycle." ;
    skos:notation "Data Monitoring" ;
    skos:prefLabel "Data Monitoring" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C163026-C142674> a skos:Concept ;
    ns1:identifier "C142674" ;
    skos:definition "A systematic, prioritized approach that involves identifying, assessing, monitoring and mitigating the risks that could affect the quality of the study or safety of the study participants." ;
    skos:notation "Risk Monitoring" ;
    skos:prefLabel "Risk Based Monitoring" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C163026-C15789> a skos:Concept ;
    ns1:identifier "C15789" ;
    skos:definition "The act of overseeing the progress of a clinical trial and of ensuring that it is conducted, recorded, and reported in accordance with the protocol, standard operating procedures (SOPs), good clinical practice (GCP), and the applicable regulatory requirement(s). [ICH E6 Glossary]" ;
    skos:notation "Trial Monitoring" ;
    skos:prefLabel "Clinical Trials, Monitoring" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C163026-C163406> a skos:Concept ;
    ns1:identifier "C163406" ;
    skos:altLabel "DSMP",
        "Data Safety Monitoring Plan",
        "Safety Data Monitoring Plan" ;
    skos:definition "A written plan that prospectively identifies and documents monitoring activities intended to protect the safety of the participants, the validity of the data and the integrity of the research study. The DSMP may also identify when to terminate a participant\'s participation (i.e. individual stopping rules) and/or the appropriate termination of a study (i.e. study stopping rules). (Mayo Clinic)" ;
    skos:notation "Data and Safety Monitoring Plan" ;
    skos:prefLabel "Data and Safety Monitoring Plan" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C163026-C163407> a skos:Concept ;
    ns1:identifier "C163407" ;
    skos:altLabel "Good Clinical Practice Adherence Statement" ;
    skos:definition "A written message that asserts, affirms, or declares that the study is conducted in accordance with Good Clinical Practice (GCP)." ;
    skos:notation "GCP Adherence Statement" ;
    skos:prefLabel "GCP Adherence Statement" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C163026-C163408> a skos:Concept ;
    ns1:identifier "C163408" ;
    skos:definition "Review of cumulative safety data to identify possible safety concerns." ;
    skos:notation "Safety Data Monitoring" ;
    skos:prefLabel "Safety Data Monitoring" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C163026-C163409> a skos:Concept ;
    ns1:identifier "C163409" ;
    skos:definition "Review of safety data to ensure safety of the individuals who are participating in the study, or to identify potential safety concerns for the duration of the study lifecycle." ;
    skos:notation "Safety Monitoring" ;
    skos:prefLabel "Safety Monitoring" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C163026-C163410> a skos:Concept ;
    ns1:identifier "C163410" ;
    skos:definition "A written message that asserts, affirms, or declares that the study will be monitored in adherence to a clinical monitoring plan and in accordance with Good Clinical Practice (GCP)." ;
    skos:notation "Study Monitoring Statement" ;
    skos:prefLabel "Study Monitoring Statement" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C163026-C163411> a skos:Concept ;
    ns1:identifier "C163411" ;
    skos:definition "A systematic approach to identify and assess the risks of participant suicidal ideation and/or suicide." ;
    skos:notation "Suicidal Risk Monitoring" ;
    skos:prefLabel "Suicidal Risk Monitoring" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C163026-C184395> a skos:Concept ;
    ns1:identifier "C184395" ;
    skos:definition "A written message within the study protocol that describes the auditing activities that are to occur within a study and the intent to address findings from an audit report." ;
    skos:notation "Study Audit Statement" ;
    skos:prefLabel "Study Audit Statement" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C163026-C184396> a skos:Concept ;
    ns1:identifier "C184396" ;
    skos:definition "A systematic and independent examination of study-related activities and documents to determine whether the evaluated trial-related activities were conducted and the data were recorded, analyzed, and accurately reported according to the protocol, sponsor\'s standard operating procedures (SOPs), good clinical practice (GCP), and the applicable regulatory requirement(s). (ICH E6 Glossary)" ;
    skos:notation "Study Audit" ;
    skos:prefLabel "Study Audit" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C165640> a skos:Concept ;
    rdfs:label "Study Oversight Entity Attribute Terminology" ;
    ns1:identifier "C165640" ;
    skos:altLabel "Study Oversight Entity Attribute Terminology" ;
    skos:definition "A terminology value set relevant to the attributes of the study oversight entity." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C165640-C165862>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C165640-C165863>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C165640-C165864> ;
    skos:notation "Study Oversight Entity Attribute Terminology" ;
    skos:prefLabel "CDISC Protocol Study Oversight Entity Attribute Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C165640-C165862> a skos:Concept ;
    ns1:identifier "C165862" ;
    skos:definition "The date on which the study oversight entity grants approval." ;
    skos:notation "Study Oversight Entity Approval Date" ;
    skos:prefLabel "Study Oversight Entity Approval Date" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C165640-C165863> a skos:Concept ;
    ns1:identifier "C165863" ;
    skos:definition "The state of the study oversight entity approval process." ;
    skos:notation "Study Oversight Entity Approval Status" ;
    skos:prefLabel "Study Oversight Entity Approval Status" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C165640-C165864> a skos:Concept ;
    ns1:identifier "C165864" ;
    skos:definition "A characterization or classification of the group of individuals that approves, monitors and reviews biomedical research to protect the rights, safety and welfare of the study participants, by providing critical scientific, ethical, and/or regulatory oversight functions." ;
    skos:notation "Study Oversight Entity Type" ;
    skos:prefLabel "Study Oversight Entity Type" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C165641> a skos:Concept ;
    rdfs:label "Outcome Measure Attribute Terminology" ;
    ns1:identifier "C165641" ;
    skos:altLabel "Outcome Measure Attribute Terminology" ;
    skos:definition "A terminology value set relevant to the attributes of the outcome measure entity." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C165641-C165138>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C165641-C165859>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C165641-C165860>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C165641-C165861> ;
    skos:notation "Outcome Measure Attribute Terminology" ;
    skos:prefLabel "CDISC Protocol Outcome Measure Attribute Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C165641-C165138> a skos:Concept ;
    ns1:identifier "C165138" ;
    skos:definition "A full description of the outcome measure." ;
    skos:notation "Outcome Measure Description" ;
    skos:prefLabel "Study Outcome Measure Description" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C165641-C165859> a skos:Concept ;
    ns1:identifier "C165859" ;
    skos:definition "The period of time over which the study outcome measure is assessed." ;
    skos:notation "Outcome Measure Time Frame" ;
    skos:prefLabel "Outcome Measure Time Frame" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C165641-C165860> a skos:Concept ;
    ns1:identifier "C165860" ;
    skos:definition "The descriptive name of the outcome measure." ;
    skos:notation "Outcome Measure Title" ;
    skos:prefLabel "Outcome Measure Title" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C165641-C165861> a skos:Concept ;
    ns1:identifier "C165861" ;
    skos:definition "A characterization or classification of the specific key measurement(s) or observation(s) used to measure the effect of experimental variables on the participants in a study, or for observational studies, to describe patterns of diseases or traits or associations with exposures, risk factors or treatment." ;
    skos:notation "Outcome Measure Type" ;
    skos:prefLabel "Outcome Measure Type" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C165642> a skos:Concept ;
    rdfs:label "Oversight Entity Value Set" ;
    ns1:identifier "C165642" ;
    skos:altLabel "Oversight Entity Value Set" ;
    skos:definition "The terminology relevant to the type of oversight entity for the study." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C165642-C142489>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C165642-C142579>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C165642-C165865>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C165642-C165866>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C165642-C165867>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C165642-C16741> ;
    skos:notation "Oversight Entity Value Set" ;
    skos:prefLabel "CDISC Protocol Oversight Entity Value Set Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C165642-C142489> a skos:Concept ;
    ns1:identifier "C142489" ;
    skos:altLabel "DMC",
        "DMOC",
        "DSMC",
        "Data Monitoring and Oversight Committee",
        "Data and Safety Monitoring Board",
        "Data and Safety Monitoring Committee DSMB",
        "IDMC",
        "Independent Data Monitoring Committee" ;
    skos:definition "A group of independent experts who are appointed to monitor the safety and scientific integrity of a research intervention, protect the confidentiality of participant data, and to make recommendations to the sponsor regarding the stopping of the trial for safety, efficacy, or for futility. (clinicaltrials.gov)" ;
    skos:notation "Data Monitoring Committee" ;
    skos:prefLabel "Data Monitoring Committee" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C165642-C142579> a skos:Concept ;
    ns1:identifier "C142579" ;
    skos:altLabel "IEC" ;
    skos:definition "An independent body (a review board or a committee, institutional, regional, national, or supranational), constituted of medical professionals and non-medical members, whose responsibility it is to ensure the protection of the rights, safety and well-being of human subjects involved in a study and to provide public assurance of that protection, by, among other things, reviewing and approving/providing favorable opinion on, the study protocol, the suitability of the investigator(s), facilities, and the methods and material to be used in obtaining and documenting informed consent of the study subjects. The legal status, composition, function, operations and regulatory requirements pertaining to Independent Ethics Committees may differ among countries, but should allow the Independent Ethics Committee to act in agreement with GCP as described in the ICH E6 guideline. (ICH E6 R2)" ;
    skos:notation "Independent Ethics Committee" ;
    skos:prefLabel "Independent Ethics Committee" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C165642-C165865> a skos:Concept ;
    ns1:identifier "C165865" ;
    skos:altLabel "ISM" ;
    skos:definition "An independent physician or health-care professional who evaluates individual and cumulative participant data to make recommendations regarding the safe continuation of the study. (NIH)" ;
    skos:notation "Independent Safety Monitor" ;
    skos:prefLabel "Independent Safety Monitor" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C165642-C165866> a skos:Concept ;
    ns1:identifier "C165866" ;
    skos:altLabel "OSMB",
        "OSMC",
        "Observational Study Monitoring Board" ;
    skos:definition "A group of independent experts who are appointed to monitor the safety and scientific integrity of an observational study, including protecting the confidentiality of participant data and to make recommendations regarding the stopping of the study for safety or for futility. (clinicaltrials.gov)" ;
    skos:notation "Observational Study Monitoring Committee" ;
    skos:prefLabel "Observational Study Monitoring Committee" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C165642-C165867> a skos:Concept ;
    ns1:identifier "C165867" ;
    skos:altLabel "SMC",
        "Safety Assessment Committee",
        "Safety Monitoring Board" ;
    skos:definition "Group of individuals with pertinent expertise that reviews, on a regular basis, accumulating safety data from an ongoing clinical study. This independent committee monitors the safety of participants during the study." ;
    skos:notation "Safety Monitoring Committee" ;
    skos:prefLabel "Safety Monitoring Committee" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C165642-C16741> a skos:Concept ;
    ns1:identifier "C16741" ;
    skos:altLabel "IRB" ;
    skos:definition "An independent body constituted of medical, scientific, and non-scientific members, whose responsibility is to ensure the protection of the rights, safety and well-being of human subjects involved in a study by, among other things, reviewing, approving, and providing continuing review of study protocol and amendments and of the methods and material to be used in obtaining and documenting informed consent of the study subjects. (ICH E6 R2)" ;
    skos:notation "Institutional Review Board" ;
    skos:prefLabel "Institutional Review Board" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C170440> a skos:Concept ;
    rdfs:label "Endpoint Attribute Terminology" ;
    ns1:identifier "C170440" ;
    skos:altLabel "Endpoint Attribute Terminology" ;
    skos:definition "A terminology value set relevant to the attributes of the endpoint entity." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C170440-C170557>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C170440-C170558> ;
    skos:notation "Endpoint Attribute Terminology" ;
    skos:prefLabel "CDISC Protocol Endpoint Attribute Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C170440-C170557> a skos:Concept ;
    ns1:identifier "C170557" ;
    skos:definition "A characterization or classification of the defined variable intended to reflect an outcome measure of interest that is statistically analyzed to address a particular research question." ;
    skos:notation "Endpoint Type" ;
    skos:prefLabel "Study Endpoint Type" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C170440-C170558> a skos:Concept ;
    ns1:identifier "C170558" ;
    skos:definition "The rationale or explanation for why each study endpoint was chosen." ;
    skos:notation "Justification for Endpoint" ;
    skos:prefLabel "Justification for Study Endpoint" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C170441> a skos:Concept ;
    rdfs:label "Endpoint Type Value Set Terminology" ;
    ns1:identifier "C170441" ;
    skos:altLabel "Endpoint Type Value Set Terminology" ;
    skos:definition "The terminology relevant to the type of endpoint for the study." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C170441-C139173>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C170441-C170559>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C170441-C170560>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C170441-C170561>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C170441-C68772>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C170441-C94496> ;
    skos:notation "Endpoint Type Value Set Terminology" ;
    skos:prefLabel "CDISC Protocol Endpoint Type Value Set Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C170441-C139173> a skos:Concept ;
    ns1:identifier "C139173" ;
    skos:definition "Endpoint(s) that may provide supportive information about the effect of the study intervention(s) on the primary endpoint or demonstrate additional effects on the disease or condition. (After FDA-NIH Protocol Template)" ;
    skos:notation "Secondary Endpoint" ;
    skos:prefLabel "Secondary Endpoint" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C170441-C170559> a skos:Concept ;
    ns1:identifier "C170559" ;
    skos:definition "Endpoint(s) that may include clinically important events that are expected to occur too infrequently to show a treatment effect or endpoints that for other reasons are thought to be less likely to show an effect but are included to explore new hypotheses. (After FDA-NIH Protocol Template)" ;
    skos:notation "Exploratory Endpoint" ;
    skos:prefLabel "Exploratory Endpoint" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C170441-C170560> a skos:Concept ;
    ns1:identifier "C170560" ;
    skos:definition "Endpoint(s) used in clinical studies to directly measure how a patient feels, functions, or survives. These endpoint(s) in themselves represent or characterize the clinical outcome of interest. (FDA: https://www.fda.gov/media/84987/download)" ;
    skos:notation "Direct Endpoint" ;
    skos:prefLabel "Direct Endpoint" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C170441-C170561> a skos:Concept ;
    ns1:identifier "C170561" ;
    skos:altLabel "Combined Endpoint" ;
    skos:definition "Endpoint(s) constructed from two or more endpoints that represents an overall clinically relevant measure of clinical benefit." ;
    skos:notation "Composite Endpoint" ;
    skos:prefLabel "Composite Endpoint" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C170441-C68772> a skos:Concept ;
    ns1:identifier "C68772" ;
    skos:definition "An endpoint that is used in clinical trials as a substitute for a direct measure of how a patient feels, functions, or survives. A surrogate endpoint does not measure the clinical benefit of primary interest in and of itself, but rather is expected to predict that clinical benefit or harm based on epidemiologic, therapeutic, pathophysiologic, or other scientific evidence. (NIH-FDA BEST (Biomarkers, Endpoints, and other Tools) Resource)" ;
    skos:notation "Surrogate Endpoint" ;
    skos:prefLabel "Surrogate Endpoint" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C170441-C94496> a skos:Concept ;
    ns1:identifier "C94496" ;
    skos:definition "Endpoint(s) of greatest importance that is the basis for concluding whether the study met its objective(s) and provides a clinically relevant, valid, and reliable measure of the primary objective(s). (After FDA-NIH Protocol Template)" ;
    skos:notation "Primary Endpoint" ;
    skos:prefLabel "Primary Endpoint" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C170442> a skos:Concept ;
    rdfs:label "Outcome Measure Type Value Set Terminology" ;
    ns1:identifier "C170442" ;
    skos:altLabel "Outcome Measure Type Value Set Terminology" ;
    skos:definition "The terminology relevant to the type of outcome measure for the study." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C170442-C98724>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C170442-C98772>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C170442-C98781> ;
    skos:notation "Outcome Measure Type Value Set Terminology" ;
    skos:prefLabel "CDISC Protocol Outcome Measure Type Value Set Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C170442-C98724> a skos:Concept ;
    ns1:identifier "C98724" ;
    skos:altLabel "Exploratory Outcome Measure" ;
    skos:definition "The outcome measure(s) that is part of a pre-specified analysis plan used to evaluate the exploratory endpoint(s) associated with exploratory study objective(s) and/or any other measures, excluding post-hoc measures, that are a focus of the study. (After clinicaltrials.gov)" ;
    skos:notation "Exploratory Outcome Measure" ;
    skos:prefLabel "Exploratory Outcome Measure" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C170442-C98772> a skos:Concept ;
    ns1:identifier "C98772" ;
    skos:altLabel "Primary Outcome Measure" ;
    skos:definition "The outcome measure(s) of greatest importance specified in the protocol, usually the one(s) used in the power calculation, to evaluate the primary endpoint(s) associated with the primary study objective(s). (After Clinicaltrials.gov)" ;
    skos:notation "Primary Outcome Measure" ;
    skos:prefLabel "Primary Outcome Measure" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C170442-C98781> a skos:Concept ;
    ns1:identifier "C98781" ;
    skos:altLabel "Secondary Outcome Measure" ;
    skos:definition "The outcome measure(s) that is part of a pre-specified analysis plan used to evaluate the secondary endpoint(s) associated with secondary study objective(s) and/or used to evaluate any measure(s) ancillary to the primary or secondary endpoint(s). (After Clinicaltrials.gov)." ;
    skos:notation "Secondary Outcome Measure" ;
    skos:prefLabel "Secondary Outcome Measure" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C172329> a skos:Concept ;
    rdfs:label "Study Arm Attribute Terminology" ;
    ns1:identifier "C172329" ;
    skos:altLabel "Study Arm Attribute Terminology" ;
    skos:definition "A terminology value set relevant to the attributes of the study arm entity." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C172329-C172456>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C172329-C172457>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C172329-C172458>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C172329-C93728> ;
    skos:notation "Study Arm Attribute Terminology" ;
    skos:prefLabel "CDISC Protocol Study Arm Attribute Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C172329-C172456> a skos:Concept ;
    ns1:identifier "C172456" ;
    skos:altLabel "Arm Label" ;
    skos:definition "The given name of the arm for the study. (NCI)" ;
    skos:notation "Study Arm Label" ;
    skos:prefLabel "Study Arm Label" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C172329-C172457> a skos:Concept ;
    ns1:identifier "C172457" ;
    skos:altLabel "Arm Type" ;
    skos:definition "The identification of the kind of arm(s) for the study. (NCI)" ;
    skos:notation "Study Arm Type" ;
    skos:prefLabel "Study Arm Type" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C172329-C172458> a skos:Concept ;
    ns1:identifier "C172458" ;
    skos:definition "The total number of subjects intended to be included within each arm for the study. (NCI)" ;
    skos:notation "Planned Number of Subjects Per Study Arm" ;
    skos:prefLabel "Planned Number of Subjects Per Study Arm" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C172329-C93728> a skos:Concept ;
    ns1:identifier "C93728" ;
    skos:altLabel "Arm Description" ;
    skos:definition "The textual representation of the arm for the study." ;
    skos:notation "Study Arm Description" ;
    skos:prefLabel "Arm Description" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C174220> a skos:Concept ;
    rdfs:label "Study Product Attribute Terminology" ;
    ns1:identifier "C174220" ;
    skos:altLabel "Study Product Attribute Terminology" ;
    skos:definition "A terminology value set relevant to the attributes of the study product." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C174220-C174265>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C174220-C176266>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C174220-C176267>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C174220-C176268>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C174220-C176269>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C174220-C176270>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C174220-C176271>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C174220-C176272>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C174220-C176273>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C174220-C176274>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C174220-C176275>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C174220-C177927>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C174220-C98768> ;
    skos:notation "Study Product Attribute Terminology" ;
    skos:prefLabel "CDISC Protocol Study Product Attribute Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C174220-C174265> a skos:Concept ;
    ns1:identifier "C174265" ;
    skos:definition "The characterization or classification of the material artifact(s) that is the focus of the study." ;
    skos:notation "Study Product Type" ;
    skos:prefLabel "Study Product Type" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C174220-C176266> a skos:Concept ;
    ns1:identifier "C176266" ;
    skos:definition "The act or process by which the study product is obtained by the study site or investigator." ;
    skos:notation "Study Product Acquisition" ;
    skos:prefLabel "Study Product Acquisition" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C174220-C176267> a skos:Concept ;
    ns1:identifier "C176267" ;
    skos:definition "The act or process for documenting the storage, inventory tracking, and disposition of the study product." ;
    skos:notation "Study Product Accountability" ;
    skos:prefLabel "Study Product Accountability" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C174220-C176268> a skos:Concept ;
    ns1:identifier "C176268" ;
    skos:definition "The composition of the study product, which may include active and inactive ingredients, dose, and dosage form." ;
    skos:notation "Study Product Formulation" ;
    skos:prefLabel "Study Product Formulation" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C174220-C176269> a skos:Concept ;
    ns1:identifier "C176269" ;
    skos:definition "The outward or visible aspect of the study product." ;
    skos:notation "Study Product Appearance" ;
    skos:prefLabel "Study Product Appearance" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C174220-C176270> a skos:Concept ;
    ns1:identifier "C176270" ;
    skos:definition "The material type and configuration used to contain the study product." ;
    skos:notation "Study Product Packaging" ;
    skos:prefLabel "Study Product Packaging" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C174220-C176271> a skos:Concept ;
    ns1:identifier "C176271" ;
    skos:definition "The written, printed, or graphic matter on, or accompanying, the study product or its packaging." ;
    skos:notation "Study Product Labeling" ;
    skos:prefLabel "Study Product Labeling" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C174220-C176272> a skos:Concept ;
    ns1:identifier "C176272" ;
    skos:definition "The physical or environmental conditions under which the study product is maintained." ;
    skos:notation "Study Product Storage" ;
    skos:prefLabel "Study Product Storage" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C174220-C176273> a skos:Concept ;
    ns1:identifier "C176273" ;
    skos:definition "The parameters under which the study product retains the same properties and characteristics that it possessed at the time of its manufacture for its intended use or administration. (After Anissa W. Wong, Aruna Datla.13-Assay and Stability Testing, Editor(s): Satinder Ahuja, Michael W. Dong, Separation Science and Technology, Academic Press, Volume 6, 2005, Pages 335-358)" ;
    skos:notation "Study Product Stability" ;
    skos:prefLabel "Study Product Stability" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C174220-C176274> a skos:Concept ;
    ns1:identifier "C176274" ;
    skos:definition "Instructions for the act of making ready the study product for use or administration." ;
    skos:notation "Study Product Preparation" ;
    skos:prefLabel "Study Product Preparation" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C174220-C176275> a skos:Concept ;
    ns1:identifier "C176275" ;
    skos:definition "The enterprise or entity that produces the study product." ;
    skos:notation "Study Product Manufacturer" ;
    skos:prefLabel "Study Product Manufacturer" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C174220-C177927> a skos:Concept ;
    ns1:identifier "C177927" ;
    skos:altLabel "Study Product Therapeutic Category" ;
    skos:definition "The classification of a study product based on the disease, disorder, or condition it is intended to treat." ;
    skos:notation "Study Product Therapeutic Class" ;
    skos:prefLabel "Study Product Therapeutic Class" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C174220-C98768> a skos:Concept ;
    ns1:identifier "C98768" ;
    skos:altLabel "Pharmacologic Class" ;
    skos:definition "The pharmacological class of the investigational product." ;
    skos:notation "Study Product Pharmacologic Class" ;
    skos:prefLabel "Pharmacological Class of Investigational Therapy" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C174221> a skos:Concept ;
    rdfs:label "Study Product Type Value Set Terminology" ;
    ns1:identifier "C174221" ;
    skos:altLabel "Study Product Type Value Set Terminology" ;
    skos:definition "The terminology relevant to the identification of the kind of study product." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C174221-C116527>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C174221-C142587>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C174221-C142703>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C174221-C49648>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C174221-C68609> ;
    skos:notation "Study Product Type Value Set Terminology" ;
    skos:prefLabel "CDISC Protocol Study Product Type Value Set Terminology" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C174221-C116527> a skos:Concept ;
    ns1:identifier "C116527" ;
    skos:altLabel "Sham Intervention" ;
    skos:definition "A procedure or device that appears to be the same as the actual procedure or device being studied but does not contain active processes or components." ;
    skos:notation "Sham Comparator" ;
    skos:prefLabel "Sham Intervention" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C174221-C142587> a skos:Concept ;
    ns1:identifier "C142587" ;
    skos:altLabel "Experimental Product" ;
    skos:definition "A material (such as a drug, biologic, or device) produced by or resulting from a process, which is being tested in a study. This may also include a product with a marketing authorization when used or assembled (formulated or packaged) in a way different from the approved form, or when used for an unapproved indication, or when used to gain further information about an approved use. [After ICH]" ;
    skos:notation "Investigational Product" ;
    skos:prefLabel "Investigational Product" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C174221-C142703> a skos:Concept ;
    ns1:identifier "C142703" ;
    skos:definition "A comparator product against which the study treatment is evaluated [e.g., concurrent (placebo, no treatment, dose-response, active), and external (historical, published literature)]. [After ICH E10]" ;
    skos:notation "Control Product" ;
    skos:prefLabel "Study Control" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C174221-C49648> a skos:Concept ;
    ns1:identifier "C49648" ;
    skos:altLabel "Placebo",
        "Placebo Control" ;
    skos:definition "An inactive, identical-appearing drug or treatment that does not contain the test product." ;
    skos:notation "Placebo Comparator" ;
    skos:prefLabel "Placebo Control" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C174221-C68609> a skos:Concept ;
    ns1:identifier "C68609" ;
    skos:altLabel "Active Control" ;
    skos:definition "A type of control, which has a demonstrated effect, administered as a comparator to subjects in a clinical trial. [From ICH E10]" ;
    skos:notation "Active Comparator" ;
    skos:prefLabel "Active Comparator" .

<http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C174222> a skos:Concept ;
    rdfs:label "Study Arm Type Value Set Terminology" ;
    ns1:identifier "C174222" ;
    skos:altLabel "Study Arm Type Value Set Terminology" ;
    skos:definition "The terminology relevant to the identification of the kind of arm." ;
    skos:narrower <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C174222-C15538>,
        <http://id.gsk.com/dataset/cdisc/ct/v48/protocol/C174222-C174226>,
